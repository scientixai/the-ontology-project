      "Study": {
        "@id": "top:Study",
        "@type": "@id",
        "owl:equivalentClass": [
          {
            "@id": "fhir:ResearchStudy"
          },
          {
            "@id": "usdm:Study (with the StudyVersion + StudyDesign nesting collapsed; TOP carries the design content directly as sub-objects)"
          },
          {
            "@id": "cdash:DM"
          },
          {
            "@id": "ClinicalTrials.gov ProtocolSection"
          },
          {
            "@id": "no direct OMOP equivalent (trial-side; OMOP CDM is observational/research-warehouse-shaped). Per-Participant data flowing through this Study projects to OMOP via StudySite \u2192 Participant traversal."
          }
        ]
