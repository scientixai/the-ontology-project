      "type": "Property",
      "value": "INC1"
    },
    "status": {
      "type": "Property",
      "value": "active"
    },
    "observedAt": {
      "type": "Property",
      "value": "2026-06-29T23:26:30.434168+00:00"
    },
    "criterionCategory": {
      "type": "Property",
      "value": "inclusion"
    },
    "criterionNumber": {
      "type": "Property",
      "value": "1"
    },
    "criterionText": {
      "type": "Property",
      "value": "have had a diagnosis of either: \n \n   \n     [1a] T1DM based on the World Health Organization (WHO) diagnostic criteria, and have been on the following daily insulin therapy for at least 1 year \n     \n        [A] multiple daily injection of long-acting insulin analog (either insulin glargine [U-100 or U-300] or insulin degludec [U-100]) and rapid-acting insulin analog (insulin lispro, insulin aspart, or insulin glulisine), or \n         [B] continuous subcutaneous insulin infusion (CSII)     \n      \n   \n    Or  \n   \n     [1b] T2DM based on the WHO diagnostic criteria, and have received the \n     following daily insulin therapy with or without oral anti-hyperglycemic medications (OAMs) for at least 1 year \n     \n        [A] insulin: long-acting insulin analog (either insulin glargine [U-100 or U-300] or insulin degludec [U-100]) alone, or in combination with rapid-acting insulin analog (insulin lispro, insulin aspart, or insulin glulisine) or CSII \n         [B] OAM: up to 3 of the following OAMs in accordance with local regulations: metformin, dipeptidyl peptidase-4 inhibitor, sodium glucose cotransporter 2 inhibitor, sulfonylurea (should not be more than half of maximum approved doses), glinides, alpha-glucosidase inhibitor, or thiazolidine"
    }
  },
  {
    "id": "urn:ngsi-ld:top-cr:EligibilityCriterion:EligibilityCriterion_2",
    "type": "cr:EligibilityCriterion",
    "@context": [
      "https://uri.etsi.org/ngsi-ld/v1/ngsi-ld-core-context-v1.8.jsonld",
