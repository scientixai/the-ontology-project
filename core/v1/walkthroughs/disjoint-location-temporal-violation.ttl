@prefix ex:  <https://top.scientix.ai/examples/> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Violation: entity typed as both top:Location and top:Temporal — disjoint L2 categories.
# Expected: SHACL Violation from top:LocationNotTemporalShape.

ex:bad-location-temporal a top:Location, top:Temporal ;
    top:identifier "urn:bad-location-temporal"^^xsd:anyURI ;
    top:observedAt "2026-01-01T00:00:00Z"^^xsd:dateTime ;
    top:status "active" .
