@prefix ex:  <https://top.scientix.ai/examples/> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Conformant: each entity is typed to exactly one L2 category — no disjointness violation.

ex:agent-1 a top:Agent ;
    top:identifier "urn:agent-1"^^xsd:anyURI ;
    top:observedAt "2026-01-01T00:00:00Z"^^xsd:dateTime ;
    top:status "active" .

ex:evidence-1 a top:Evidence ;
    top:identifier "urn:evidence-1"^^xsd:anyURI ;
    top:observedAt "2026-01-01T00:00:00Z"^^xsd:dateTime ;
    top:status "active" .

ex:location-1 a top:Location ;
    top:identifier "urn:location-1"^^xsd:anyURI ;
    top:observedAt "2026-01-01T00:00:00Z"^^xsd:dateTime ;
    top:status "active" .
