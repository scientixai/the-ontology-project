@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix top:   <https://top.scientix.ai/v1#> .

# SHACL enforcement of L2 category disjointness.
# OWL disjointWith axioms are in top-root.ttl; these SHACL shapes provide
# instance-level violation messages for closed-world validation with pyshacl.

top:AgentNotEvidenceShape a sh:NodeShape ;
    rdfs:label "Agent ⊓ Evidence disjointness"@en ;
    sh:targetClass top:Agent ;
    sh:not [ sh:class top:Evidence ] ;
    sh:message "An entity typed top:Agent must not also be typed top:Evidence (L2 categories are mutually disjoint)." .

top:AgentNotLocationShape a sh:NodeShape ;
    rdfs:label "Agent ⊓ Location disjointness"@en ;
    sh:targetClass top:Agent ;
    sh:not [ sh:class top:Location ] ;
    sh:message "An entity typed top:Agent must not also be typed top:Location." .

top:AgentNotOutcomeShape a sh:NodeShape ;
