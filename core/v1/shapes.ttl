# TOP Core — aggregator (owl:imports all per-category modules)
#
# This file is the single entry point for tools that need the complete
# TOP Core OWL/SHACL graph. It imports each per-category module so that
# loading this file is equivalent to loading all ten modules.
#
# Per-category modules live in modules/. Each is independently parseable.
# Edit ontology content in the modules; edit this file only to add/remove modules.

@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .

<https://top.scientix.ai/core/v1> a owl:Ontology ;
    dct:title "TOP Core — OWL classes and SHACL contract"@en ;
    dct:description "OWL/SHACL view of the SKOS taxonomy at taxonomy/taxonomy.ttl. Defines the root top:CommonEntity, the eight L2 categories, the 29 L3 leaves, the Universal DNA properties, the category relational extensions, and the SHACL UniversalDNAShape that enforces the three required practitioner-grounded properties on every TOP entity."@en ;
    dct:created "2026-05-10"^^xsd:date ;
    dct:license "Apache-2.0" ;
    rdfs:seeAlso <https://top.scientix.ai/v1#TaxonomyV1>,
                 <https://top.scientix.ai/core/v1/index.html>,
                 <https://top.scientix.ai/governance/decision-log.md> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-root> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-agent> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-location> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-resource> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-scope> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-temporal> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-evidence> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-outcome> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-constraint> ;
    owl:imports <https://top.scientix.ai/core/v1/modules/top-bitemporal> .
