    topc:firstName          "Sarah" ; topc:lastName "Walsh" ; topc:title "MD" ;
    topc:jobTitle           "Principal Investigator" ;
    topc:gcpTrainingStatus  "CURRENT" ; topc:status "ACTIVE" ;
    topc:employedBy         <urn:ngsi-ld:Organization:elevate-research> .

