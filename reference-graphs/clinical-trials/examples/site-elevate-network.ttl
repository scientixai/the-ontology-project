<urn:ngsi-ld:Person:rodriguez-pi> a topc:Person ;
    topc:personId           "urn:ngsi-ld:Person:rodriguez-pi"^^xsd:anyURI ;
    topc:firstName          "Carlos" ; topc:lastName "Rodriguez" ; topc:title "MD" ;
