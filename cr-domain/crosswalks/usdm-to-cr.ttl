    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .

ex:ux-scheduledactivity a cx:Mapping ;
    cx:subjectId cr:PlannedActivity ; cx:predicateId skos:closeMatch ; cx:objectId usdm:ScheduledActivityInstance ;
    cx:justification semapv:ManualMappingCuration ; cx:confidence "0.85"^^xsd:decimal ;
    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .

ex:ux-timing a cx:Mapping ;
    cx:subjectId cr:Timing ; cx:predicateId skos:closeMatch ; cx:objectId usdm:Timing ;
    cx:justification semapv:ManualMappingCuration ; cx:confidence "0.85"^^xsd:decimal ;
    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .

####################################################################
# 3) Cross-kind / abstraction — relatedMatch, by logical reasoning
####################################################################
ex:ux-activity a cx:Mapping ;
    cx:subjectId cr:Capability ; cx:predicateId skos:relatedMatch ; cx:objectId usdm:Activity ;
    cx:justification semapv:LogicalReasoning ; cx:confidence "0.60"^^xsd:decimal ;
    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    rdfs:comment "USDM Activity is a reusable planned-activity definition; cr:Capability is the delegable action-type a performer must be authorized for. Related, not equivalent." ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .

####################################################################
# 4) Plan <-> execution boundary — relatedMatch (deliberately NOT exact).
#    These correct the over-strong exactMatch claims in the early analysis.
####################################################################
ex:ux-administration a cx:Mapping ;
    cx:subjectId cr:Administration ; cx:predicateId skos:relatedMatch ; cx:objectId usdm:Administration ;
    cx:justification semapv:LogicalReasoning ; cx:confidence "0.50"^^xsd:decimal ;
    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    rdfs:comment "USDM Administration is a PLANNED regimen (dose/route/frequency, design-time); cr:Administration is the EXECUTED, bitemporal dosing event. Same clinical act across the plan/execution boundary — relatedMatch, NOT the exactMatch(0.95) of the early analysis." ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .

ex:ux-enrollment a cx:Mapping ;
    cx:subjectId cr:Enrollment ; cx:predicateId skos:relatedMatch ; cx:objectId usdm:SubjectEnrollment ;
    cx:justification semapv:LogicalReasoning ; cx:confidence "0.40"^^xsd:decimal ;
    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    rdfs:comment "USDM SubjectEnrollment is a PLANNED enrollment QUANTITY by cohort/site (carries 'quantity', design-time); cr:Enrollment is the EXECUTED bitemporal Person<->Subject act. relatedMatch, NOT the exactMatch(1.0) of the early analysis." ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .
