@prefix ex:     <https://top.scientix.ai/examples/> .
@prefix cx:     <https://top.scientix.ai/crosswalk/v1#> .
@prefix cr:     <https://top.scientix.ai/cr/v1#> .
@prefix hcls:   <https://top.scientix.ai/hcls/v1#> .
@prefix usdm:   <https://w3id.org/cdisc/usdm/v4/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix semapv: <https://w3id.org/semapv/vocab/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix top:    <https://top.scientix.ai/core/v1#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# OWNED crosswalk: TOP cr-core  <->  CDISC USDM v4.0 (the generated, vendored layer).
# Target IRIs VERIFIED against the pinned primary source
# (github.com/cdisc-org/DDF-RA USDM_API.json @ tag v4.0.0, sha dc4303bc). Each mapping
# carries full SSSOM metadata and passes the hardened curation gate (cx:MappingShape).
#
# The curation respects the plan<->execution boundary: USDM is a design-time study
# DEFINITION model; cr-core is operator/execution + provenance + bitemporal. Where a
# USDM design construct names the same clinical act that cr-core records as an executed,
# bitemporal event, the mapping is relatedMatch (a boundary crossing), NOT exactMatch.
# This deliberately corrects the over-strong exactMatch assertions in the early analysis
# (see crosswalks/registry.md).

ex:curator-wg a prov:Agent ; rdfs:label "TOP CR curation WG" .

# Source pin reused by every mapping below.
#   retrievedFrom: github.com/cdisc-org/DDF-RA USDM_API.json @ tag v4.0.0 (sha dc4303bc)

####################################################################
# 1) Aligned design constructs — cr-core has a faithful counterpart
####################################################################
ex:ux-study a cx:Mapping ;
    cx:subjectId cr:Study ; cx:predicateId skos:closeMatch ; cx:objectId usdm:Study ;
    cx:justification semapv:ManualMappingCuration ; cx:confidence "0.90"^^xsd:decimal ;
    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .

