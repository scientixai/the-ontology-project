####################################################################
# 2) Schedule-of-Activities bridge — USDM's static timeline maps INTO
#    cr-core's bitemporal SoA (template/projection/execution). cr adds
#    the as-of + planned-vs-actual layer USDM does not express.
####################################################################
ex:ux-scheduletimeline a cx:Mapping ;
    cx:subjectId cr:ScheduleTimeline ; cx:predicateId skos:closeMatch ; cx:objectId usdm:ScheduleTimeline ;
    cx:justification semapv:ManualMappingCuration ; cx:confidence "0.85"^^xsd:decimal ;
    cx:author ex:curator-wg ; cx:mappingDate "2026-06-23"^^xsd:date ;
    cx:verificationStatus "verified" ;
    cx:retrievedFrom "DDF-RA USDM_API.json @ v4.0.0 (sha dc4303bc)" ;
    rdfs:comment "USDM ScheduleTimeline is static design; cr:ScheduleTimeline is bitemporal (amendment as-of) and reconciled against execution. The design content corresponds; the temporal capability is a TOP extension." ;
    top:recordedAt "2026-06-23T00:00:00Z"^^xsd:dateTime ; prov:wasAttributedTo ex:curator-wg .

ex:ux-encounter a cx:Mapping ;
