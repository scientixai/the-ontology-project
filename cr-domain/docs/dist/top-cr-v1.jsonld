      {
        "@value": "ScientixAI (2026). TOP \u2014 Clinical Research Reference Graph (v1). The Ontology Project."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "TOP Clinical Research working group"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "ScientixAI"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "An inheritable, provenance-native, bitemporal reference knowledge graph for the clinical-research lifecycle (Pre-IND through End-of-Phase-2, plus site operations). The founding domain of TOP (The Ontology Project)."
      }
    ],
    "http://purl.org/dc/terms/issued": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://www.apache.org/licenses/LICENSE-2.0"
      }
    ],
    "http://purl.org/dc/terms/publisher": [
      {
        "@value": "ScientixAI"
      }
    ],
    "http://purl.org/dc/terms/rights": [
      {
        "@value": "Includes an independent derivative adaptation of the ICH E6(R3) Good Clinical Practice Guideline (Step 4, 2025; Principles, Glossary, Annex 1) \u2014 paraphrased, not endorsed or sponsored by ICH, original copyright \u00a9 ICH. TMF artifact types align by name to the DIA TMF Reference Model (licensed; no text reproduced). See the repository NOTICE file."
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@value": "TOP \u2014 Clinical Research Reference Graph"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
