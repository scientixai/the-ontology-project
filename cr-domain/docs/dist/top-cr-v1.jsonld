    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A relative-timing rule: an offset (days or hours) from an anchor \u2014 another node, or an anchor event such as enrollment \u2014 with an allowed window. The footnote logic, made explicit."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Timing"
