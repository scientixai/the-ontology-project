  {
    "@id": "https://top.scientix.ai/cr/v1#Visit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A protocol visit \u2014 a kind of study event."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Trial Visit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#StudyEvent"
      },
      {
        "@id": "https://top.scientix.ai/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#VisitDefinition",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The protocol-defined visit template: what is SUPPOSED to happen (type, window, mode, ordering). USDM-ingest-derivable from StudyDesign.encounters[]. UNSCHEDULED visits (urgent care, AE workup) have no VisitDefinition; their VisitOccurrence.definedBy is absent. USDM: Encounter. SDTM projection: SE (Study Elements) domain."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Visit Definition"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.w3.org/ns/prov#Entity"
      },
      {
        "@id": "https://top.scientix.ai/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#VisitExecutionSubPhase",
    "@type": [
      "https://top.scientix.ai/hcls/v1#Phase"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Scheduled and unscheduled visit conduct: actuals vs. SOA, activity completion, IP administration, sample collection, CRF completion at visit level."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Visit Execution"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#VisitOccurrence",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An actual protocol visit: what DID happen. Anchored at Participant (1..1) and StudySite (1..1). Optionally definedBy a VisitDefinition (absent for unscheduled visits). FHIR R5: Encounter. SDTM: SV domain (SVSTDTC / SVENDTC / VISITNUM / VISIT). OMOP: VISIT_OCCURRENCE."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Visit Occurrence"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.w3.org/ns/prov#Activity"
      },
      {
        "@id": "https://top.scientix.ai/v1#Temporal"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Window",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An allowed tolerance around a planned time: a lower and an upper offset in days (e.g. [-2 days, +2 days])."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Window"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Constraint"
      }
    ]
  },
