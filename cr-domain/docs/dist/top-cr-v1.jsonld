  {
    "@id": "https://top.scientix.ai/cr/v1#ScreeningRecord",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "One eligibility-screening attempt (ICH E6(R3) \u00a72.5). Re-screening = additional ScreeningRecord. SDTM DS: DSDECOD=SCREEN FAILURE / ENROLLED. SDTM IE: failed criteria."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Screening Record"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Temporal"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SelectSiteForStudy",
    "@type": [
      "https://top.scientix.ai/hcls/v1#Action"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Select Site for Study"
      }
    ],
    "https://top.scientix.ai/hcls/v1#authorizedAgentType": [
      {
        "@id": "https://top.scientix.ai/cr/v1#SponsorProjectManager"
      }
    ],
    "https://top.scientix.ai/hcls/v1#occursIn": [
      {
        "@id": "https://top.scientix.ai/cr/v1#SiteSelectionSubPhase"
      }
    ],
    "https://top.scientix.ai/hcls/v1#operatesOn": [
      {
        "@id": "https://top.scientix.ai/cr/v1#StudySite"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SeriousAdverseEvent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An adverse event meeting seriousness criteria (expedited reporting)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Serious Adverse Event"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#AdverseEvent"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ServiceProvider",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Service Provider"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Organization"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A party to whom a sponsor or investigator transfers specified trial-related duties and functions (paraphrased, ICH E6(R3)). The CRO is a specialized service provider."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ShipSample",
    "@type": [
      "https://top.scientix.ai/hcls/v1#Action"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Ship Sample"
      }
    ],
    "https://top.scientix.ai/hcls/v1#authorizedAgentType": [
      {
        "@id": "https://top.scientix.ai/cr/v1#SiteCoordinator"
      }
    ],
    "https://top.scientix.ai/hcls/v1#occursIn": [
      {
        "@id": "https://top.scientix.ai/cr/v1#VisitExecutionSubPhase"
      }
    ],
    "https://top.scientix.ai/hcls/v1#operatesOn": [
      {
        "@id": "https://top.scientix.ai/cr/v1#ActivityOccurrence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SignCRF",
    "@type": [
      "https://top.scientix.ai/hcls/v1#Action"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Sign CRF"
      }
    ],
    "https://top.scientix.ai/hcls/v1#authorizedAgentType": [
