        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#seeAlso": [
      {
        "@id": "https://top.scientix.ai/cr/v1#AuditTrail"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Data-integrity expectations: attributable, legible, contemporaneous, original, accurate, plus complete, consistent, enduring, available (paraphrased, ICH E6(R3) data governance). Realized in TOP by the bitemporal + PROV envelope."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://top.scientix.ai/cr/v1#E6R3Glossary"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "ALCOA++"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#term_Auditor",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
