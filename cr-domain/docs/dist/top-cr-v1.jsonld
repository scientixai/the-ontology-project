        "@value": "v1"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Clinical-research domain core: entities recurring across >=2 CR workflows. Specializes TOP Core / HCLS-core. Scope: oncology Pre-IND -> EOP2. Standards projection target: CDISC (SDTM/CDASH/Define-XML), USDM, MedDRA."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "CR-core"
      }
    ]
  },
