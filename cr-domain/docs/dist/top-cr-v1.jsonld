      {
        "@id": "https://top.scientix.ai/cr/v1#DataCollectionSubPhase"
      }
    ],
    "https://top.scientix.ai/hcls/v1#operatesOn": [
      {
        "@id": "https://top.scientix.ai/cr/v1#eCRF"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SignMonitoringReport",
    "@type": [
      "https://top.scientix.ai/hcls/v1#Action"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Sign Monitoring Report"
      }
    ],
    "https://top.scientix.ai/hcls/v1#authorizedAgentType": [
      {
        "@id": "https://top.scientix.ai/cr/v1#Investigator"
      }
    ],
    "https://top.scientix.ai/hcls/v1#occursIn": [
      {
        "@id": "https://top.scientix.ai/cr/v1#OversightSubPhase"
      }
    ],
    "https://top.scientix.ai/hcls/v1#operatesOn": [
      {
        "@id": "https://top.scientix.ai/cr/v1#VisitOccurrence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteActivation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The green-light record (observedAt = activated date); must cite IRB approval, executed CTA, and SIV."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Activation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Temporal"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteBoundary",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteCoordinator",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The day-to-day clinical operations professional at a Site. Screens and enrolls participants, executes visits, completes CRFs, manages AE reporting, and maintains site logs. Also known as Clinical Research Coordinator (CRC). OOUX persona aliases: Coordinator, Study Coordinator, CRC."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Coordinator"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Practitioner"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteInitiationVisit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The visit that prepares and activates a site for enrollment."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Initiation Visit (SIV)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Temporal"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteMetrics",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A periodic KPI snapshot for a study site; bitemporal (top:observedAt = snapshot date, top:validFrom = reporting period start)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Metrics"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteSelectionDecision",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A recorded, provenance-tagged decision about a study site at a specific lifecycle transition. Captures both positive (Selected, Reserve) and negative (Dropped) outcomes with mandatory rationale. The negative path \u2014 why a site was not selected \u2014 is institutional intelligence that is almost never captured in practice today but is essential for: (a) sponsor learning across studies, (b) avoiding repeat qualification of unsuitable sites, (c) CRO accountability. Bitemporal (top:Versioned) because decisions can be revised (a Dropped site can become Reserve under rescue conditions)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Selection Decision"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteSelectionSubPhase",
    "@type": [
      "https://top.scientix.ai/hcls/v1#Phase"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Feasibility assessment, site evaluation, qualification visit (SQV), site selection committee review. Output: selected site list with signed contracts."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Selection"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteStatusActive",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Site is actively enrolling or conducting the trial (post-SIV, first subject possible or enrolled)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Active"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteStatusClosed",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Site close-out visit completed; no further subject activity; eTMF finalization in progress."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Closed"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteStatusDropped",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Site was not selected or was withdrawn after selection. The reason MUST be captured in a cr:SiteSelectionDecision \u2014 this is institutional intelligence almost never recorded today."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Dropped"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteStatusFeasibility",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Site is under feasibility assessment: SQV scheduled or completed, selection committee review pending."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Feasibility"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteStatusReserve",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Site has passed feasibility but is held in reserve as a rescue site. Sponsor may activate it if enrollment falls short at active sites. Distinct from Selected: no startup work has begun."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Reserve"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteStatusSelected",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Site has been selected: contracts signed, Study Startup Package in preparation."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Selected"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteStatusStartup",
    "@type": [
