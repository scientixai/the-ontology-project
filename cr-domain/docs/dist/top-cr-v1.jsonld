  {
    "@id": "https://top.scientix.ai/cr/v1/gcp",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/rights": [
      {
        "@value": "Independent derivative adaptation of the ICH E6(R3) Guideline. The classes, properties, and SKOS concepts here are an adaptation (structure + paraphrased definitions), not a reproduction. NOT endorsed or sponsored by ICH. The original ICH E6(R3) document is copyright \u00a9 ICH."
      }
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@value": "ICH E6(R3) Good Clinical Practice (Step 4, adopted January 2025): Principles, Glossary, and Annex 1 (interventional trials). Annex 2 (additional/non-traditional data sources) is NOT modeled in this version."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Changes made: ICH E6(R3) terms are reorganized into an OWL/SKOS structure, definitions are paraphrased, and obligations are expressed as SHACL shapes rather than encoded text. Each derived term carries rdfs:isDefinedBy the ICH efficacy-guidelines source."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "TOP CR \u2014 ICH E6(R3) GCP definitional layer"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "OWNED, provenance-tagged crosswalks from TOP/CR-core to external ontologies. Aligns to SSSOM slots (subject_id/predicate_id/object_id/mapping_justification/confidence/author_id/mapping_date); an SSSOM TSV is an edge projection of these. Crosswalks are assertions WE own and curate, never imports of the external ontology."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "TOP crosswalk vocabulary (SSSOM-aligned)"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#Mapping",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A curated, provenanced correspondence from a TOP term to an external ontology term."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Crosswalk Mapping"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#author",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The curator/agent IRI (SSSOM author_id)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "author id"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#confidence",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "confidence"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#justification",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A semapv justification IRI (e.g. ManualMappingCuration)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "mapping justification"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#mappingDate",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "mapping date"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#date"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#objectId",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The external ontology term (right side)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "object id"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#predicateId",
