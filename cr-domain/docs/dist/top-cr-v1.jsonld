  {
    "@id": "https://top.scientix.ai/cr/v1#ActivationSubPhase",
    "@type": [
      "https://top.scientix.ai/hcls/v1#Phase"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Study Startup Package readiness, Site Initiation Visit (SIV), training, delegation of authority, equipment qualification. Output: site activated and ready to enroll."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Activation"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ActivityOccurrence",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "One performed activity within a VisitOccurrence. Uses the universal substrate pattern: any assessment (vitals, MRI, ePRO, biopsy, IP administration) uses the same entity shape; content specialisation is via biomedicalConceptCode and taskValueType. FHIR R5: Procedure / Observation / MedicationAdministration (per activity type). SDTM: domain depends on type (VS, LB, EG, EX, PE, etc.)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Activity Occurrence"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://www.w3.org/ns/prov#Activity"
      },
      {
        "@id": "https://top.scientix.ai/v1#Temporal"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ActivityTemplate",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The protocol-defined activity template: the procedure to perform at a visit. USDM-ingest-derivable from StudyDesign.activities[]. Carries the biomedical-concept code that determines what kind of data the activity collects. USDM: Activity."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Activity Template"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Scope"
      }
    ]
  },
