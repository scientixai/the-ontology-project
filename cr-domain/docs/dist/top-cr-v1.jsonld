  {
    "@id": "https://top.scientix.ai/cr/v1#ScheduleTimeline",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The planned Schedule of Activities for a protocol version, as a timeline of planned encounters and activities. Bitemporal: a protocol amendment supersedes it, so the schedule is reconstructable as-of any date."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Schedule Timeline"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ScheduleVisit",
