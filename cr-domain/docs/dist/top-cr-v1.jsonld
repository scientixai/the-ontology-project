      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#yieldsResult",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An assay result that traces to this collection act (forward of cr:derivedFromCollection)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://top.scientix.ai/cr/v1#StudyEvent"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "yields result"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://top.scientix.ai/cr/v1#AssayResult"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#derivedFromCollection"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1/gcp",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/rights": [
      {
        "@value": "Independent derivative adaptation of the ICH E6(R3) Guideline. The classes, properties, and SKOS concepts here are an adaptation (structure + paraphrased definitions), not a reproduction. NOT endorsed or sponsored by ICH. The original ICH E6(R3) document is copyright \u00a9 ICH."
      }
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@value": "ICH E6(R3) Good Clinical Practice (Step 4, adopted January 2025): Principles, Glossary, and Annex 1 (interventional trials). Annex 2 (additional/non-traditional data sources) is NOT modeled in this version."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Changes made: ICH E6(R3) terms are reorganized into an OWL/SKOS structure, definitions are paraphrased, and obligations are expressed as SHACL shapes rather than encoded text. Each derived term carries rdfs:isDefinedBy the ICH efficacy-guidelines source."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "TOP CR \u2014 ICH E6(R3) GCP definitional layer"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "OWNED, provenance-tagged crosswalks from TOP/CR-core to external ontologies. Aligns to SSSOM slots (subject_id/predicate_id/object_id/mapping_justification/confidence/author_id/mapping_date); an SSSOM TSV is an edge projection of these. Crosswalks are assertions WE own and curate, never imports of the external ontology."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "TOP crosswalk vocabulary (SSSOM-aligned)"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#Mapping",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A curated, provenanced correspondence from a TOP term to an external ontology term."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Crosswalk Mapping"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#author",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The curator/agent IRI (SSSOM author_id)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "author id"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#confidence",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "confidence"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#confirmedAt",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Timestamp when a mapping was confirmed by a human reviewer. Together with cx:confirmedBy, closes the audit trail for human-in-the-loop validation."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "confirmed at"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#confirmedBy",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The human agent (or committee) that reviewed and confirmed a proposed mapping. Required for promotion from 'under_review' to 'confirmed'."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "confirmed by"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#inferredBy",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The top:AutonomousAgent instance that proposed this mapping via LLM inference. Enables provenance tracing back to the agent model and prompt version."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "inferred by"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#justification",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A semapv justification IRI (e.g. ManualMappingCuration)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "mapping justification"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#mappingDate",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "mapping date"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#date"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#mappingMethod",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "How the mapping was produced: ManualCuration | LLMInference | RuleBasedExtraction | HybridReview. Drives downstream trust and routing."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "mapping method"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#mappingRationale",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Human-readable explanation of why this mapping was proposed, especially for LLM-inferred mappings. Mirrors top:rationale on a Conclusion."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "mapping rationale"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#objectId",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The external ontology term (right side)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "object id"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#predicateId",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "SKOS mapping predicate."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "predicate id"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#retrievedFrom",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The primary source the target IRI was verified against (URL + retrieval date)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "retrieved from"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#reviewStatus",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Lifecycle state of the mapping: proposed | under_review | confirmed | rejected | deprecated. Confirmed mappings graduate from ephemeral inference to Layer-2 crosswalk."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "review status"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#subjectId",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The TOP/CR-core term (left side)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "subject id"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#verificationStatus",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "verified | unverified | deprecated \u2014 whether the target IRI was confirmed against a primary source."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "verification status"
      }
    ],
    "https://top.scientix.ai/v1#flavor": [
      {
        "@value": "Additive"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Mid-layer specializing TOP Core for entities that recur across >=2 HCLS domains (clinical research, hospital, manufacturing, pharmacovigilance, RWE, commercialization). Seeded minimally; grows by promotion (rule of three). Standards projection target: FHIR, OMOP."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "HCLS-core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Action",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A named, authorized operation (Call To Action in OOUX terms) that an agent of a given type may perform in a given Phase. Actions are reference-graph archetypes (top:Constraint: they specify what is authorized). Realized occurrences in instance graphs are prov:Activity individuals linked back via hcls:realizationOf."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Action"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Clinician",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A licensed clinician who provides or oversees clinical care or research. Specializes in sub-domains: Investigator (clinical research), Physician (clinical care), Pharmacist, etc."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Clinician"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Practitioner"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Condition",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A diagnosed state of a Person."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Condition"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Outcome"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Consent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An act of agreement by a Person authorizing an action or use of their data/person. HCLS-universal: permutates to cr:InformedConsentAct (clinical trial enrollment), HIPAA Authorization (data use), Treatment Consent (clinical care). Carries valid-time (when consent was given, when it expires) and transaction-time (when it was recorded)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Consent"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Temporal"
      },
      {
        "@id": "https://top.scientix.ai/v1#Versioned"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#HealthcareFacility",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A physical place where care or research is conducted."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Healthcare Facility"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Location"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#JobToBeDone",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A bounded unit of operator intent: the goal an agent type is trying to achieve, with a trigger condition and measurable success signals. Scoped to an agent type (OWL class) and a Phase. References the object graph and authorized Actions involved. Derived from OOUX JTBD blocks."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Job to Be Done"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Lot",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A manufactured batch/lot; the primary join to the manufacturing domain."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Lot"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Resource"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#MedicinalProduct",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A medicinal product (drug or biologic)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Medicinal Product"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Resource"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Observation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An information artifact recording a measured value; refersTo the Person/Specimen it is about."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Observation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Organization",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An organization \u2014 sponsor, CRO, site, central lab, or regulator."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Organization"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Agent"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Person",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A human. BOUNDARY-ONLY / PII layer: an identifiable Person lives inside the source/site sovereign boundary. Downstream and shareable artifacts must attach to a pseudonymous cr:StudySubject, never to a Person. The only legal Person<->Subject link is the attested Enrollment bridge (cr:enrolledPerson). Clinical data is PSEUDONYMIZED, not anonymized: re-identification is preserved but controlled (safety / emergency unblinding)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Person"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/v1#Agent"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Phase",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A bounded, sequenced stage of a process lifecycle within an HCLS domain. Phases form a containment tree (hcls:contains) and a precedence chain (hcls:precedes). Permutates to: cr:StartupPhase/ConductPhase/CloseoutPhase (clinical research); Admission/Inpatient/Discharge (clinical care); Formulation/Fill-Finish/Release (manufacturing)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Phase"
      }
    ],
