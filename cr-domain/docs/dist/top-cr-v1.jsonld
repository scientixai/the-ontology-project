[
  {
    "@id": "https://top.scientix.ai/core/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Local working stub of TOP Core: one root (top:Core) + eight Category-Level Objects (CLOs), aligned to the canonical Apache-2.0 TOP Core at github.com/scientixai/the-ontology-project. NOT authoritative; serves as the specialization anchor and carries TOP's Universal DNA (identifier + observedAt + status) plus the bitemporal + PROV convention vocabulary for the CR-domain build."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "TOP Core (local working stub)"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Agent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Something that acts or bears responsibility (person, organization, system)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Agent"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Constraint",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A rule, criterion, bound, or commitment that admissibility is judged against."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Constraint"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Core",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The single root of TOP. Everything modeled is, ultimately, a kind of top:Core, and so carries the Universal DNA (identifier + observedAt + status)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Evidence",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An information artifact that asserts or records something."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Evidence"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Location",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A place or spatial/jurisdictional region."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Location"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Outcome",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A result, finding, or state produced by a process."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Outcome"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Marker for any assertion/entity carrying the bitemporal + PROV envelope."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Provenanced Entity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Resource",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A persistent material or informational thing that is used or produced."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Resource"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Scope",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A bounded context of work (study, arm, population, indication)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Scope"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#Temporal",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Processes, events, acts, and intervals that unfold in time."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Temporal"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#identifier",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A stable, dereferenceable identifier for the entity (the 'who/what is this' of the Universal DNA)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "identifier"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#observedAt",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Valid-time instant \u2014 when the fact became true in the world (NGSI-LD observedAt)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "observed at"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#recordedAt",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Transaction-time instant \u2014 when the system first recorded the assertion (append-only)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "recorded at"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#status",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The lifecycle state of the entity (e.g. active, retired, superseded) \u2014 the 'where in its life' of the Universal DNA."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "status"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#supersededAt",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Transaction-time close \u2014 when a later assertion superseded this one."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "superseded at"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/core/v1#validTo",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Valid-time close \u2014 when the fact stopped being true in the world."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "valid to"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://purl.org/dc/terms/bibliographicCitation": [
      {
        "@value": "ScientixAI (2026). TOP \u2014 Clinical Research Reference Graph (v1). The Ontology Project."
      }
    ],
    "http://purl.org/dc/terms/contributor": [
      {
        "@value": "TOP Clinical Research working group"
      }
    ],
    "http://purl.org/dc/terms/creator": [
      {
        "@value": "ScientixAI"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "An inheritable, provenance-native, bitemporal reference knowledge graph for the clinical-research lifecycle (Pre-IND through End-of-Phase-2, plus site operations). The founding domain of TOP (The Ontology Project)."
      }
    ],
    "http://purl.org/dc/terms/issued": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2026-06-22"
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://www.apache.org/licenses/LICENSE-2.0"
      }
    ],
    "http://purl.org/dc/terms/publisher": [
      {
        "@value": "ScientixAI"
      }
    ],
    "http://purl.org/dc/terms/rights": [
      {
        "@value": "Includes an independent derivative adaptation of the ICH E6(R3) Good Clinical Practice Guideline (Step 4, 2025; Principles, Glossary, Annex 1) \u2014 paraphrased, not endorsed or sponsored by ICH, original copyright \u00a9 ICH. TMF artifact types align by name to the DIA TMF Reference Model (licensed; no text reproduced). See the repository NOTICE file."
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@value": "TOP \u2014 Clinical Research Reference Graph"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "TOP \u2014 Clinical Research Reference Graph"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionIRI": [
      {
        "@id": "https://top.scientix.ai/cr/v1"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "v1"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Clinical-research domain core: entities recurring across >=2 CR workflows. Specializes TOP Core / HCLS-core. Scope: oncology Pre-IND -> EOP2. Standards projection target: CDISC (SDTM/CDASH/Define-XML), USDM, MedDRA."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "CR-core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Administration",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A dosing event."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Administration"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#AdverseEvent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An untoward medical occurrence in a trial subject."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Adverse Event"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Outcome"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#AnalysisDataset",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An ADaM analysis dataset (e.g. ADSL, ADAE). Must declare prov:wasDerivedFrom its source so any result built on it is reproducible to source."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Analysis Dataset (ADaM)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#AnalysisRequest",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Binds an AnalysisService to a Specimen (the order)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Analysis Request"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#AnalysisService",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Catalog definition of a test/assay (e.g. a biomarker assay)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Analysis Service"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Arm",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A treatment arm of the study."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Arm"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#AssayResult",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A measured laboratory result on a Specimen, joined to the StudySubject."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Assay Result"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/hcls/v1#Observation"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Assessment",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A clinical assessment performed during the trial."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Assessment"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Attestation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A sworn, non-repudiable statement; the write-path that creates delegation/consent assertions."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Attestation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#AuditTrail",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Audit Trail"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "Secure, computer- or paper-generated documentation that allows reconstruction of the course of events around a record (paraphrased, ICH E6(R3)). In TOP, the bitemporal + PROV envelope realizes this by construction."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#BriefingBook",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A dossier submitted to the regulator ahead of a meeting (Pre-IND / EOP2)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Briefing Book"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CAPA",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Corrective And Preventive Action \u2014 the formal response to a deviation or finding (corrective: fix this occurrence; preventive: stop recurrence). Bitemporal + attested."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "CAPA"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CRO",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A contract research organization the sponsor delegates trial conduct to."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "CRO"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Organization"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CSR",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The definitive summary of a study's results (CSR)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Clinical Study Report"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Capability",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A delegable permission to perform a trial task (e.g. obtain informed consent)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Capability"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CaseReportForm",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A case report form \u2014 a collection of item groups capturing a visit's data."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Case Report Form"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CertifiedCopy",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Certified Copy"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A copy of original information verified (dated/signed or generated by a validated process) as a complete and accurate copy (paraphrased, ICH E6(R3))."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ClinicalHold",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An FDA order that halts or prevents a trial from proceeding."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Clinical Hold"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Outcome"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ClinicalObservation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A recorded value (ItemData) for a StudySubject at a StudyEvent, defined by a DataElementDef."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Clinical Observation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/hcls/v1#Observation"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ClinicalTrialAgreement",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Executed site contract (observedAt = execution date)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Clinical Trial Agreement (CTA)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Cohort",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A group of subjects sharing a dosing or treatment assignment."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Cohort"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CoverageAnalysis",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A Medicare/insurance coverage analysis for study procedures."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Coverage Analysis (MCA)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Credential",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An attested qualification/training record that gates a delegated capability."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Credential"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CriticalToQualityFactor",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A quality-critical aspect of the trial (e.g. primary endpoint integrity, consent validity, SAE reporting)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Critical-to-Quality Factor"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@value": "CtQ factor"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#CustodyEvent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A specimen state transition (SampleDue->Received->ToBeVerified->Verified->Published) \u2014 chain of custody."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Custody Event"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#DataElementDef",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A variable DEFINITION (ItemOID), independent of any form version; carries a PHI classification."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Data Element Definition"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Delegation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "PI delegates a Capability to a Person, gated by a Credential, attested. DOA/training logs are projections of this."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Delegation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#DeviationAntecedent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A latent operational condition that predisposes a deviation (e.g. a visit window too tight for the site's staffing). The missing middle between a critical-to-quality factor and the deviation event it manifests as; bitemporal (it exists, and is detected, over time)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Deviation Antecedent"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#DeviationEvent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A protocol deviation occurrence (departure from the protocol or GCP). Classified by materiality; significant deviations require a CAPA. Bitemporal + attested."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Deviation Event"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#DoseLevel",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A dose level in a dose-escalation design."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Dose Level"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#DoseLimitingToxicity",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Oncology dose-escalation: a DLT informs the next dose decision."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Dose-Limiting Toxicity"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#AdverseEvent"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#E6R3Glossary",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#ConceptScheme"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Definitional concepts cited to ICH E6(R3); related to the cr: class/relation that realizes each, where one exists."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "ICH E6(R3) glossary (selected terms)"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#EligibilityCriterion",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An inclusion/exclusion rule defining who may enroll."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Eligibility Criterion"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Endpoint",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A defined outcome measure the study evaluates."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Endpoint"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#EndpointResult",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A measured efficacy/safety result; must trace to its endpoint, estimand, and SAP."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Endpoint Result"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Outcome"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Enrollment",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The bitemporal act linking an hcls:Person to a cr:StudySubject in a cr:Study."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Enrollment"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#EssentialRecord",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The class the TMF artifact-type scheme (tmf:) classifies the documents of."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Essential Record"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@value": "Essential Document"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A record that, individually or collectively, permits evaluation of the conduct of a trial and the quality of the data produced (paraphrased, ICH E6(R3))."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Estimand",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The precise treatment-effect definition a result must trace to (overstatement guard)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Estimand"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#GLPToxReport",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A GLP toxicology study report supporting safe human dosing."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "GLP Toxicology Report"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#INDApplication",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The submission authorizing human dosing; starts a 30-day review clock (top:observedAt = submission) after which trials may proceed unless a clinical hold is placed."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "IND Application"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#IRB",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "IRB / IEC"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Organization"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#altLabel": [
      {
        "@value": "Independent Ethics Committee"
      },
      {
        "@value": "Institutional Review Board"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "An independent body that reviews and provides ongoing oversight to protect the rights, safety, and well-being of trial participants (paraphrased, ICH E6(R3))."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#IRBApproval",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Local IRB/IEC approval (observedAt = approval date)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "IRB/IEC Approval"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#InformedConsent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The act of obtaining a subject's informed consent."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Informed Consent"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#InvestigationalProduct",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The investigational drug or biologic being studied."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Investigational Product"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#MedicinalProduct"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ItemGroup",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A logical clustering of items (ItemGroupOID)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Item Group"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#MitigationPlan",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Mitigations for a risk, including the resulting monitoring strategy and SDV intensity."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Mitigation Plan"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#NonclinicalFinding",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An observed animal toxicity/finding that the clinical protocol must address."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Nonclinical Finding"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Outcome"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ParticipantSchedule",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The schedule projected for a specific subject from a ScheduleTimeline once an anchor date (e.g. enrollment) is known. Bitemporal: re-projected when the governing protocol version changes."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Participant Schedule"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Phase3Design",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A proposed Phase 3 trial design taken to the EOP2 meeting."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Proposed Phase 3 Design"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Scope"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#PlannedActivity",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A planned activity within an encounter (USDM ScheduledActivityInstance) \u2014 e.g. ECG, blood draw, PRO. Positioned by a cr:Timing and/or an ordering edge (cr:precedes)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Planned Activity"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#PlannedEncounter",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A planned visit slot on the timeline (USDM Encounter). Positioned by a cr:Timing relative to an anchor; actual cr:Visits are reconciled against it."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Planned Encounter"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#PlannedVisit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A projected planned visit for a subject: a target date and a resolved window (start/end dates), against which the actual visit is reconciled."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Planned Visit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ProtocolVersion",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An effective-dated protocol version (bitemporal): which version was valid for a given visit."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Protocol Version"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Query",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A discrepancy note / data query anchored to a data point or other entity; threaded."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Query"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#RegulatoryAgreement",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A binding FDA agreement (a commitment the program is held to)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Regulatory Agreement"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#RegulatoryInteraction",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Pre-IND / EOP2 meeting."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Regulatory Interaction"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#RegulatoryQuestion",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A briefing-book question; should carry a proposed position (FDA punishes vague questions)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Regulatory Question"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#RepeatingPlannedActivity",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A planned activity that recurs on an interval until a stop condition (e.g. a daily participant diary until Day N; dosing every 7 days)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Repeating Planned Activity"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#PlannedActivity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#RiskAssessment",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An assessment of risk to a CtQ factor (likelihood/impact/detectability -> level); bitemporal."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Risk Assessment"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#RiskRegister",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A record of risks and decisions captured at a regulatory gate."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Risk Register"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#RiskSignal",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A leading indicator (a trend or metric) that flags a deviation antecedent before it manifests \u2014 the signal a provenance-native graph can hold as low-trust, provenance-tagged evidence."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Risk Signal"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SafetyAssessment",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A clinical-protocol safety monitoring provision (e.g. CBC monitoring + dose-hold)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Safety Assessment"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Constraint"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SafetyReport",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Expedited report of an SAE to the regulator."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Safety Report"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ScheduleTimeline",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The planned Schedule of Activities for a protocol version, as a timeline of planned encounters and activities. Bitemporal: a protocol amendment supersedes it, so the schedule is reconstructable as-of any date."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Schedule Timeline"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SeriousAdverseEvent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "An adverse event meeting seriousness criteria (expedited reporting)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Serious Adverse Event"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#AdverseEvent"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ServiceProvider",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Service Provider"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Organization"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A party to whom a sponsor or investigator transfers specified trial-related duties and functions (paraphrased, ICH E6(R3)). The CRO is a specialized service provider."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteActivation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The green-light record (observedAt = activated date); must cite IRB approval, executed CTA, and SIV."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Activation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SiteInitiationVisit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The visit that prepares and activates a site for enrollment."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Site Initiation Visit (SIV)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#Temporal"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SourceData",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Source Data"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      },
      {
        "@id": "https://top.scientix.ai/core/v1#ProvenancedEntity"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "The original recorded information, and certified copies of it, needed to reconstruct and evaluate the trial (paraphrased, ICH E6(R3))."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#SourceDocument",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://www.ich.org/page/efficacy-guidelines"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Source Document"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#EssentialRecord"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "The original document/record holding source data (paraphrased, ICH E6(R3))."
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#Sponsor",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The organization that initiates and is accountable for the trial."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Sponsor"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Organization"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#StatisticalAnalysisPlan",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The pre-specified plan for analyzing the study's data."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Statistical Analysis Plan"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Evidence"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#StoppingRule",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A safety rule that halts dosing or enrollment when triggered."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Stopping Rule"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
