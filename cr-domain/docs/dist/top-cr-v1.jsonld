    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "The TOP/CR-core term (left side)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "subject id"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/crosswalk/v1#verificationStatus",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "verified | unverified | deprecated \u2014 whether the target IRI was confirmed against a primary source."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "verification status"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "Mid-layer specializing TOP Core for entities that recur across >=2 HCLS domains (clinical research, hospital, manufacturing, pharmacovigilance, RWE, commercialization). Seeded minimally; grows by promotion (rule of three). Standards projection target: FHIR, OMOP."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "HCLS-core"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#Condition",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A diagnosed state of a Person."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Condition"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://top.scientix.ai/core/v1#Outcome"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/hcls/v1#HealthcareFacility",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@value": "A physical place where care or research is conducted."
