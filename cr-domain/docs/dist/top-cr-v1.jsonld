        "@id": "https://top.scientix.ai/cr/v1#monitors"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "A person who oversees the progress of the trial and that it is conducted, recorded, and reported per protocol, SOPs, GCP, and regulation (paraphrased, ICH E6(R3))."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://top.scientix.ai/cr/v1#E6R3Glossary"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@value": "Monitor"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#term_QualityByDesign",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
