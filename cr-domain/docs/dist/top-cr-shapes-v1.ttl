@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix cx: <https://top.scientix.ai/crosswalk/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cr:ADaMTraceabilityShape a sh:NodeShape ;
    sh:property [ sh:message "Analysis dataset (ADaM) must declare prov:wasDerivedFrom its source (traceability)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path prov:wasDerivedFrom ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:AnalysisDataset .

cr:ActivationReadinessShape a sh:NodeShape ;
    rdfs:label "Activation requires complete regulatory + budget streams" ;
    sh:severity sh:Violation ;
    sh:sparql [ sh:message "Site activated without a complete Regulatory and Budget & Contracting work stream." ;
            sh:select """
            SELECT $this WHERE {
              $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?anyStream .
              FILTER (
                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?r .
                             ?r a <https://top.scientix.ai/cr/v1#RegulatoryWorkStream> ;
                                <https://top.scientix.ai/cr/v1#streamStatus> "complete" . }
                || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?b .
                             ?b a <https://top.scientix.ai/cr/v1#BudgetContractingWorkStream> ;
                                <https://top.scientix.ai/cr/v1#streamStatus> "complete" . }
              )
            }
        """ ] ;
    sh:targetClass cr:SiteActivation .

cr:ActivityOrderingShape a sh:NodeShape ;
    rdfs:label "Execution violates planned ordering (hard)" ;
    sh:severity sh:Violation ;
    sh:sparql [ sh:message "Acts executed out of the order their planned activities require (cr:precedes violated)." ;
            sh:select """
            SELECT $this WHERE {
              $this   <https://top.scientix.ai/cr/v1#realizes> ?pa ;
                      <https://top.scientix.ai/v1#observedAt> ?ta .
              ?pa     <https://top.scientix.ai/cr/v1#precedes> ?pb .
              ?other  <https://top.scientix.ai/cr/v1#realizes> ?pb ;
                      <https://top.scientix.ai/v1#observedAt> ?tb .
              FILTER ( ?ta > ?tb )
            }
        """ ] ;
    sh:targetSubjectsOf cr:realizes .

cr:AnalysisPopulationRequiredShape a sh:NodeShape ;
    rdfs:label "Analysis population required fields" ;
    sh:property [ sh:message "cr:AnalysisPopulation must link to a cr:DataCut via cr:populationForCut." ;
            sh:minCount 1 ;
            sh:path cr:populationForCut ],
        [ sh:in ( "ITT" "mITT" "PP" "safety" "other" ) ;
            sh:message "cr:AnalysisPopulation must carry cr:populationType: ITT, mITT, PP, safety, or other." ;
            sh:minCount 1 ;
            sh:path cr:populationType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:AnalysisPopulation .

cr:ArmStudyConsistencyShape a sh:NodeShape ;
    rdfs:label "Assigned arm must belong to Participant's Study (hard)" ;
    sh:severity sh:Violation ;
    sh:sparql [ sh:message "Participant.assignedToArm references an Arm whose parent Study does not match Participant.forStudy." ;
            sh:select """
            SELECT $this WHERE {
              $this <https://top.scientix.ai/cr/v1#assignedToArm> ?arm ;
                    <https://top.scientix.ai/cr/v1#forStudy> ?study .
              FILTER NOT EXISTS {
                ?study <https://top.scientix.ai/cr/v1#hasArm> ?arm .
              }
            }
        """ ] ;
    sh:targetClass cr:Participant .

cr:AssayResultShape a sh:NodeShape ;
    sh:property [ sh:class cr:AnalysisService ;
            sh:message "Assay result must reference the analysis service that produced it." ;
            sh:minCount 1 ;
            sh:path cr:fromService ],
        [ sh:class hcls:Specimen ;
            sh:message "Assay result must reference the sample analyzed." ;
            sh:minCount 1 ;
            sh:path cr:onSample ],
        [ sh:class cr:StudySubject ;
            sh:message "Assay result must join to the (pseudonymous) StudySubject." ;
            sh:minCount 1 ;
            sh:path cr:forSubject ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:AssayResult .

cr:AssessmentRequiredShape a sh:NodeShape ;
    rdfs:label "Assessment completeness (required fields)" ;
    sh:property [ sh:message "cr:Assessment must link to the visit during which it was performed (cr:assessedAt). Missing on this assessment." ;
            sh:minCount 1 ;
            sh:path cr:assessedAt ],
        [ sh:message "cr:Assessment must carry an assessmentType." ;
            sh:minCount 1 ;
            sh:path cr:assessmentType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Assessment .

cr:BiologicalSampleShape a sh:NodeShape ;
    sh:property [ sh:message "Biological sample must carry a collection date." ;
            sh:minCount 1 ;
            sh:path cr:collectionDate ],
        [ sh:message "Biological sample must carry a sample type." ;
            sh:minCount 1 ;
            sh:path cr:sampleType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:BiologicalSample .

cr:BiomarkerGroupShape a sh:NodeShape ;
    sh:property [ sh:message "Biomarker group must carry a group type label." ;
            sh:minCount 1 ;
            sh:path cr:biomarkerGroupType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:BiomarkerGroup .

cr:BiomarkerMeasurementShape a sh:NodeShape ;
    sh:property [ sh:class cr:BiomarkerPanel ;
            sh:message "Biomarker measurement must reference its panel." ;
            sh:minCount 1 ;
            sh:path cr:fromPanel ],
        [ sh:message "Biomarker measurement must carry a result value." ;
            sh:minCount 1 ;
            sh:path cr:resultValue ],
        [ sh:message "Biomarker measurement must carry a unit." ;
            sh:minCount 1 ;
            sh:path cr:resultUnit ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:BiomarkerMeasurement .

cr:BiomarkerPanelShape a sh:NodeShape ;
    sh:property [ sh:message "Biomarker panel must carry a panel type label." ;
            sh:minCount 1 ;
            sh:path cr:panelType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:BiomarkerPanel .

cr:BudgetContractingWorkStreamShape a sh:NodeShape ;
    sh:property [ sh:in ( "pending" "in-progress" "complete" "on-hold" ) ;
            sh:message "BudgetContractingWorkStream.streamStatus must be one of: pending, in-progress, complete, on-hold." ;
            sh:minCount 1 ;
            sh:path cr:streamStatus ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:BudgetContractingWorkStream .

cr:CRFCompletionRequiredShape a sh:NodeShape ;
    rdfs:label "CRF entry requires visit and subject" ;
    sh:property [ sh:class cr:Visit ;
            sh:message "CRF entry must reference the visit." ;
            sh:minCount 1 ;
            sh:path cr:forVisit ],
        [ sh:class cr:StudySubject ;
            sh:message "CRF entry must reference the study subject." ;
            sh:minCount 1 ;
            sh:path cr:forSubject ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:CRFEntry .

cr:ContractRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Contract must carry an execution date." ;
            sh:minCount 1 ;
            sh:path cr:executionDate ],
        [ sh:message "Contract must carry a contract type." ;
            sh:minCount 1 ;
            sh:path cr:contractType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Contract .

cr:DataCutRequiredShape a sh:NodeShape ;
    rdfs:label "DataCut required fields" ;
    sh:property [ sh:message "cr:DataCut must carry a cutDate." ;
            sh:minCount 1 ;
            sh:path cr:cutDate ],
        [ sh:message "cr:DataCut must carry a cutType." ;
            sh:minCount 1 ;
            sh:path cr:cutType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:DataCut .

cr:DeviationRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Protocol deviation must carry a deviation type." ;
            sh:minCount 1 ;
            sh:path cr:deviationType ],
        [ sh:message "Protocol deviation must carry a deviation date." ;
            sh:minCount 1 ;
            sh:path cr:deviationDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:ProtocolDeviation .

cr:DocumentVersionShape a sh:NodeShape ;
    sh:property [ sh:message "Document must carry a version string." ;
            sh:minCount 1 ;
            sh:path cr:documentVersion ],
        [ sh:message "Document must carry a document type." ;
            sh:minCount 1 ;
            sh:path cr:documentType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Document .

cr:EligibilityCriterionShape a sh:NodeShape ;
    sh:property [ sh:in ( "inclusion" "exclusion" ) ;
            sh:message "cr:criterionType must be 'inclusion' or 'exclusion'." ;
            sh:minCount 1 ;
            sh:path cr:criterionType ],
        [ sh:message "cr:criterionText is required." ;
            sh:minCount 1 ;
            sh:path cr:criterionText ] ;
    sh:targetClass cr:EligibilityCriterion .

cr:EnrollmentShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:date ;
            sh:message "cr:enrollmentDate (xsd:date) is required." ;
            sh:minCount 1 ;
            sh:path cr:enrollmentDate ],
        [ sh:datatype xsd:dateTime ;
            sh:message "top:validFrom (xsd:dateTime) is required on Enrollment." ;
            sh:minCount 1 ;
            sh:path top:validFrom ],
        [ sh:class cr:Arm ;
            sh:maxCount 1 ;
            sh:message "cr:enrolledInArm must point to exactly one cr:Arm." ;
            sh:minCount 1 ;
            sh:path cr:enrolledInArm ] ;
    sh:targetClass cr:Enrollment .

cr:ImagingResultRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Imaging result must carry a modality." ;
            sh:minCount 1 ;
            sh:path cr:modalityType ],
        [ sh:class cr:Visit ;
            sh:message "Imaging result must reference the visit." ;
            sh:minCount 1 ;
            sh:path cr:atVisit ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:ImagingResult .

cr:InformedConsentShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:date ;
            sh:message "cr:consentDate (xsd:date) is required." ;
            sh:minCount 1 ;
            sh:path cr:consentDate ],
        [ sh:in ( "active" "withdrawn" "expired" ) ;
            sh:message "cr:consentStatus must be one of: active, withdrawn, expired." ;
            sh:minCount 1 ;
            sh:path cr:consentStatus ],
        [ sh:datatype xsd:string ;
            sh:message "cr:consentVersion is required (US-500-003)." ;
            sh:minCount 1 ;
            sh:path cr:consentVersion ],
        [ sh:datatype xsd:anyURI ;
            sh:message "cr:consentFormIRI (xsd:anyURI) is required (US-500-003)." ;
            sh:minCount 1 ;
            sh:path cr:consentFormIRI ],
        [ sh:class hcls:Person ;
            sh:maxCount 1 ;
            sh:message "cr:witnessedBy must point to at most one hcls:Person." ;
            sh:minCount 0 ;
            sh:path cr:witnessedBy ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:message "cr:withdrawalDate (xsd:date) — optional, but must be a valid date if present." ;
            sh:minCount 0 ;
            sh:path cr:withdrawalDate ] ;
    sh:sparql [ sh:message "Violation: cr:withdrawalDate precedes top:validFrom — consent cannot be withdrawn before it was recorded." ;
            sh:prefixes <https://top.scientix.ai/shapes/participant-v1> ;
            sh:select """
            PREFIX cr:  <https://top.scientix.ai/cr/v1#>
            PREFIX top: <https://top.scientix.ai/v1#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            SELECT $this ?withdrawalDate ?validFrom
            WHERE {
                $this cr:withdrawalDate ?withdrawalDate ;
                      top:validFrom     ?validFrom .
                FILTER ( ?withdrawalDate < ?validFrom )
            }
        """ ;
            sh:severity sh:Violation ] ;
    sh:targetClass cr:InformedConsent .

cr:InterimAnalysisShape a sh:NodeShape ;
    sh:property [ sh:message "Interim analysis must carry an analysis date." ;
            sh:minCount 1 ;
            sh:path cr:analysisDate ],
        [ sh:class cr:DataCut ;
            sh:message "Interim analysis must reference its data cut." ;
            sh:minCount 1 ;
            sh:path cr:basedOnCut ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:InterimAnalysis .

cr:IRBApprovalRequiredShape a sh:NodeShape ;
    rdfs:label "IRB/EC approval required fields" ;
    sh:property [ sh:message "IRB/EC approval requires an approval date." ;
            sh:minCount 1 ;
            sh:path cr:approvalDate ],
        [ sh:message "IRB/EC approval requires a reference number." ;
            sh:minCount 1 ;
            sh:path cr:referenceNumber ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:IRBApproval .

cr:KeyMetricShape a sh:NodeShape ;
    sh:property [ sh:message "Key metric must carry a metric type." ;
            sh:minCount 1 ;
            sh:path cr:metricType ],
        [ sh:message "Key metric must carry a metric value." ;
            sh:minCount 1 ;
            sh:path cr:metricValue ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:KeyMetric .

cr:LabResultRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Lab result must carry a lab test code." ;
            sh:minCount 1 ;
            sh:path cr:labTestCode ],
        [ sh:message "Lab result must carry a result value." ;
            sh:minCount 1 ;
            sh:path cr:resultValue ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:LabResult .

cr:MilestoneRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Milestone must carry a milestone type." ;
            sh:minCount 1 ;
            sh:path cr:milestoneType ],
        [ sh:message "Milestone must carry a planned date." ;
            sh:minCount 1 ;
            sh:path cr:plannedDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Milestone .

cr:MonitoringVisitShape a sh:NodeShape ;
    sh:property [ sh:message "Monitoring visit must carry a visit date." ;
            sh:minCount 1 ;
            sh:path cr:visitDate ],
        [ sh:class cr:Site ;
            sh:message "Monitoring visit must reference the site." ;
            sh:minCount 1 ;
            sh:path cr:atSite ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:MonitoringVisit .

cr:ObservationRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Observation must carry an observed value." ;
            sh:minCount 1 ;
            sh:path cr:observedValue ],
        [ sh:message "Observation must carry an observation date." ;
            sh:minCount 1 ;
            sh:path cr:observationDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass hcls:Observation .

cr:ParticipantRequiredShape a sh:NodeShape ;
    rdfs:label "Participant required fields" ;
    sh:property [ sh:message "Participant must reference an Arm via cr:assignedToArm." ;
            sh:minCount 1 ;
            sh:path cr:assignedToArm ],
        [ sh:message "Participant must reference a Study via cr:forStudy." ;
            sh:minCount 1 ;
            sh:path cr:forStudy ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Participant .

cr:PatientReportedOutcomeShape a sh:NodeShape ;
    sh:property [ sh:message "Patient reported outcome must carry a questionnaire reference." ;
            sh:minCount 1 ;
            sh:path cr:questionnaireRef ],
        [ sh:message "Patient reported outcome must carry a submission date." ;
            sh:minCount 1 ;
            sh:path cr:submissionDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:PatientReportedOutcome .

cr:ProtocolVersionShape a sh:NodeShape ;
    sh:property [ sh:message "Protocol must carry a version number." ;
            sh:minCount 1 ;
            sh:path cr:protocolVersion ],
        [ sh:message "Protocol must carry an effective date." ;
            sh:minCount 1 ;
            sh:path cr:effectiveDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Protocol .

cr:QueryResolutionShape a sh:NodeShape ;
    sh:property [ sh:message "Data query must carry a query status." ;
            sh:minCount 1 ;
            sh:path cr:queryStatus ],
        [ sh:message "Data query must carry a raised date." ;
            sh:minCount 1 ;
            sh:path cr:raisedDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:DataQuery .

cr:RandomisationShape a sh:NodeShape ;
    sh:property [ sh:message "Randomisation must carry a randomisation date." ;
            sh:minCount 1 ;
            sh:path cr:randomisationDate ],
        [ sh:class cr:Arm ;
            sh:message "Randomisation must reference the assigned arm." ;
            sh:minCount 1 ;
            sh:path cr:assignedToArm ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Randomisation .

cr:RegulatorySubmissionShape a sh:NodeShape ;
    sh:property [ sh:message "Regulatory submission must carry a submission type." ;
            sh:minCount 1 ;
            sh:path cr:submissionType ],
        [ sh:message "Regulatory submission must carry a submission date." ;
            sh:minCount 1 ;
            sh:path cr:submissionDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:RegulatorySubmission .

cr:RegulatoryWorkStreamShape a sh:NodeShape ;
    sh:property [ sh:in ( "pending" "in-progress" "complete" "on-hold" ) ;
            sh:message "RegulatoryWorkStream.streamStatus must be one of: pending, in-progress, complete, on-hold." ;
            sh:minCount 1 ;
            sh:path cr:streamStatus ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:RegulatoryWorkStream .

cr:SafetyReportShape a sh:NodeShape ;
    sh:property [ sh:message "Safety report must carry a report type." ;
            sh:minCount 1 ;
            sh:path cr:reportType ],
        [ sh:message "Safety report must carry a report date." ;
            sh:minCount 1 ;
            sh:path cr:reportDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:SafetyReport .

cr:SiteActivationShape a sh:NodeShape ;
    sh:property [ sh:message "Site activation must reference the site being activated." ;
            sh:minCount 1 ;
            sh:path cr:activatedSite ],
        [ sh:message "Site activation must carry an activation date." ;
            sh:minCount 1 ;
            sh:path cr:activationDate ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:SiteActivation .

cr:SiteRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Site must carry a site identifier." ;
            sh:minCount 1 ;
            sh:path cr:siteId ],
        [ sh:message "Site must carry a country code." ;
            sh:minCount 1 ;
            sh:path cr:countryCode ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Site .

cr:StatisticalAnalysisPlanShape a sh:NodeShape ;
    sh:property [ sh:message "SAP must carry a version number." ;
            sh:minCount 1 ;
            sh:path cr:sapVersion ],
        [ sh:class cr:Study ;
            sh:message "SAP must reference the parent Study." ;
            sh:minCount 1 ;
            sh:path cr:forStudy ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:StatisticalAnalysisPlan .

cr:StudyRequiredShape a sh:NodeShape ;
    rdfs:label "Study required fields" ;
    sh:property [ sh:message "Study must carry a protocol version." ;
            sh:minCount 1 ;
            sh:path cr:protocolVersion ],
        [ sh:message "Study must carry a study phase." ;
            sh:minCount 1 ;
            sh:path cr:studyPhase ],
        [ sh:message "Study must carry a therapeutic area." ;
            sh:minCount 1 ;
            sh:path cr:therapeuticArea ],
        [ sh:message "Study must carry a sponsor name." ;
            sh:minCount 1 ;
            sh:path cr:sponsorName ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Study .

cr:StudySubjectShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "cr:subjectId is required." ;
            sh:minCount 1 ;
            sh:path cr:subjectId ],
        [ sh:datatype xsd:dateTime ;
            sh:message "top:validFrom (xsd:dateTime) is required on StudySubject." ;
            sh:minCount 1 ;
            sh:path top:validFrom ],
        [ sh:class cr:InformedConsent ;
            sh:message "cr:hasConsent must point to a cr:InformedConsent." ;
            sh:minCount 0 ;
            sh:path cr:hasConsent ],
        [ sh:class cr:Enrollment ;
            sh:message "cr:hasEnrollment must point to a cr:Enrollment." ;
            sh:minCount 0 ;
            sh:path cr:hasEnrollment ] ;
    sh:targetClass cr:StudySubject .

cr:SupplyChainShipmentShape a sh:NodeShape ;
    sh:property [ sh:message "Supply chain shipment must carry a shipment date." ;
            sh:minCount 1 ;
            sh:path cr:shipmentDate ],
        [ sh:message "Supply chain shipment must carry a shipment type." ;
            sh:minCount 1 ;
            sh:path cr:shipmentType ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:SupplyChainShipment .

cr:TemporalConsistencyShape a sh:NodeShape ;
    rdfs:label "Bitemporal consistency: observedAt must not precede validFrom" ;
    sh:severity sh:Violation ;
    sh:sparql [ sh:message "top:observedAt predates top:validFrom — transaction time cannot precede valid time." ;
            sh:select """
            SELECT $this ?validFrom ?observedAt
            WHERE {
              $this <https://top.scientix.ai/v1#validFrom> ?validFrom ;
                    <https://top.scientix.ai/v1#observedAt> ?observedAt .
              FILTER ( ?observedAt < ?validFrom )
            }
        """ ] ;
    sh:targetSubjectsOf top:validFrom .

cr:TrialMasterFileShape a sh:NodeShape ;
    sh:property [ sh:message "TMF entry must carry a document type." ;
            sh:minCount 1 ;
            sh:path cr:documentType ],
        [ sh:class cr:Study ;
            sh:message "TMF entry must reference the parent Study." ;
            sh:minCount 1 ;
            sh:path cr:forStudy ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:TrialMasterFile .

cr:VitalSignsRequiredShape a sh:NodeShape ;
    sh:property [ sh:message "Vital signs observation must carry a measurement type." ;
            sh:minCount 1 ;
            sh:path cr:measurementType ],
        [ sh:message "Vital signs observation must carry a result value." ;
            sh:minCount 1 ;
            sh:path cr:resultValue ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:VitalSigns .

cr:VisitScheduleShape a sh:NodeShape ;
    rdfs:label "Visit must be associated with a Study" ;
    sh:property [ sh:class cr:Study ;
            sh:message "Visit must reference its parent Study via cr:forStudy." ;
            sh:minCount 1 ;
            sh:path cr:forStudy ] ;
    sh:severity sh:Violation ;
    sh:targetClass cr:Visit .
