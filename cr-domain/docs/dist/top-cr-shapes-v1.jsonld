  {
    "@id": "_:cb221f5ce2135f4ba5769f26719a3f0bfdaa6d4621129033c4856fd652918af4da0",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#StatisticalAnalysisPlan"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
