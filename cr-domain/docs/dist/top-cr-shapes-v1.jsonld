[
  {
    "@id": "_:cb0",
    "http://www.w3.org/ns/shacl#alternativePath": [
      {
        "@list": [
          {
            "@id": "https://top.scientix.ai/tmf/v1#concerns"
          },
          {
            "@id": "https://top.scientix.ai/tmf/v1#defines"
          },
          {
            "@id": "https://top.scientix.ai/tmf/v1#documents"
          },
          {
            "@id": "https://top.scientix.ai/tmf/v1#records"
          }
        ]
      }
    ]
  },
  {
    "@id": "_:cb1052552a5fac75bb8a01850f7330e4a327a2e7d8f997dcee69813672e31d2c0c5",
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#collectedAt"
      }
    ]
  },
  {
    "@id": "_:cb10cc6e59a6d2db7613a5194050e0c4aa4f48010c50c278c5c003f4f0eb8cd8d15",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "PlannedActivity has neither a cr:timing nor an ordering edge (cr:precedes); it is unpositioned."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#timing> ?t . }\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#precedes> ?o . }\n              FILTER NOT EXISTS { ?p <https://top.scientix.ai/cr/v1#precedes> $this . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb10ed5cf425231f1e69ba12c515226b4b7c0fe6619117321758f382cb27a4a90e3",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "EOP2 meeting lacks a binding agreement and/or a risk register (readiness warning)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#meetingType> \"EOP2\" .\n              FILTER ( NOT EXISTS { $this <https://top.scientix.ai/cr/v1#producedAgreement> ?a }\n                       || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasRiskRegister> ?r } )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb113003e55aef8ced5782d7ccc9adceff02ed4a911755868bf2a05c741e0a8d042",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Participant.participantStatus=RANDOMIZED but missing assignedToArm or randomizationDate."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"RANDOMIZED\" .\n              FILTER (\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#assignedToArm> ?a . } ||\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#randomizationDate> ?d . }\n              )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb11334cb11ddf71ee5550f23e888f6dc1d69f871a4d0abf482bedddfe5dc286703",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Actual visit's observedAt falls outside the planned window of the visit it realizes (out-of-window) \u2014 review materiality."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#realizes> ?pv ;\n                    <https://top.scientix.ai/v1#observedAt> ?t .\n              ?pv a <https://top.scientix.ai/cr/v1#PlannedVisit> ;\n                  <https://top.scientix.ai/cr/v1#windowStart> ?ws ;\n                  <https://top.scientix.ai/cr/v1#windowEnd> ?we .\n              FILTER ( ?t < ?ws || ?t > ?we )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb12728f7cbc1e90c625b7791593fbb13da76d42e13f3eec64f594fca32a6a2645b",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Person"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Consent must record who performed it."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#performedBy"
      }
    ]
  },
  {
    "@id": "_:cb1288314901d10420dbe2a92f93eec43ae9f3f6f2a3ddf54129bdaac352c814c86",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Participant.participantStatus=SCREEN_FAILED but no ScreeningRecord with screeningOutcome=SCREEN_FAILED."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"SCREEN_FAILED\" .\n              FILTER NOT EXISTS {\n                $this <https://top.scientix.ai/cr/v1#hasScreeningRecord> ?r .\n                ?r <https://top.scientix.ai/cr/v1#screeningOutcome> \"SCREEN_FAILED\" .\n              }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1420056ecab70121706c3d6a0ed49d2f0afba89e1882f0a9d38dc5bb0d4306cff",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:RegulatoryInteraction must carry cr:meetingType (Pre-IND, EOP1, EOP2, Type-A/B/C)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#meetingType"
      }
    ]
  },
  {
    "@id": "_:cb14dcfc16ce9fad2423deaac47c6ab5a3cd864586eece468dd417b22399a1e45a7",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "SUSAR submitted after regulatory deadline (submissionDate > reportingDeadline)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#submissionDate> ?sub ;\n                    <https://top.scientix.ai/cr/v1#reportingDeadline> ?dl .\n              BIND(xsd:date(?dl) AS ?dlDate)\n              FILTER ( ?sub > ?dlDate )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb152d4881209cdbe7ea68b7ac8e8faaf50245e12603c6dde860513ff04d78c0188",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Participant.assignedToArm references an Arm whose parent Study does not match Participant.forStudy."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#assignedToArm> ?arm ;\n                    <https://top.scientix.ai/cr/v1#forStudy> ?study .\n              FILTER NOT EXISTS {\n                ?study <https://top.scientix.ai/cr/v1#hasArm> ?arm .\n              }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb162466372680d6d99144b6ea5daf104fd2138c5f8444a0039ada72ec7915c7eef",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "VisitOccurrence.visitStatus=COMPLETED but actualEndDate is missing."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#visitStatus> \"COMPLETED\" .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#actualEndDate> ?d . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb16520b85700cdba52aad1a51a3eee5a083dd69adddba7385fbd7018e47e9a9934",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "100% SDV applied to a low-risk factor (over-monitoring; consider risk-based reduction)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#sdvIntensity> ?i ;\n                    <https://top.scientix.ai/cr/v1#mitigates> ?ra .\n              ?ra <https://top.scientix.ai/cr/v1#riskLevel> \"low\" .\n              FILTER ( ?i = 1.0 )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb168087fed14dea848518f8565d1f91bf0d7df94404534ec4652f8555e32b99da4",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:Assessment must link to the visit during which it was performed (cr:assessedAt). Missing on this assessment."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#assessedAt"
      }
    ]
  },
  {
    "@id": "_:cb173a5627d86c02d46a6be82dfe16240a6999ea7b997b338da1572f3d85c3fbdcd",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#StudyEvent"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Observation must reference the StudyEvent it was captured at."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#capturedDuring"
      }
    ]
  },
  {
    "@id": "_:cb173dea6f33ef5651e5d7f36436f972d5f86165cf2ead2414216b8049128ea718b",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A work stream produces an output that does not trace (prov:wasDerivedFrom) to any input."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#produces> ?out .\n              FILTER NOT EXISTS { ?out <http://www.w3.org/ns/prov#wasDerivedFrom> ?in . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1753a5c21b33fe07f8e8c48a2c7eee87a8305e9b3308c98fad53483a036d84068",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:RegulatoryInteraction must carry cr:meetingDate."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#meetingDate"
      }
    ]
  },
  {
    "@id": "_:cb175daecd7329007ffc19c50bd96bb44db718e9b93cd8f498f128a85f48600f972",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Deviation event has no recorded antecedent (latent cause not captured)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              FILTER NOT EXISTS { ?a <https://top.scientix.ai/cr/v1#manifestsAs> $this . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb17945289ec22495a1672a0eaf4c9e263ecf897ea88c5b56f0a10674cf8bfeeb47",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Participant is in a post-consent state but has no InformedConsentAct with consentStatus=OBTAINED. ICH E6(R3) \u00a72.4 violation."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> ?s .\n              FILTER ( ?s IN (\n                \"ENROLLED\", \"RANDOMIZED\", \"ON_TREATMENT\",\n                \"IN_FOLLOW_UP\", \"COMPLETED\", \"WITHDRAWN\",\n                \"DISCONTINUED\", \"LOST_TO_FOLLOW_UP\"\n              ) )\n              FILTER NOT EXISTS {\n                $this <https://top.scientix.ai/cr/v1#hasInformedConsentAct> ?c .\n                ?c <https://top.scientix.ai/cr/v1#consentStatus> \"OBTAINED\" .\n              }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb17c55734a6a0e9fba298668509fafeb412a7b2e173e436afe8e432eef7be43392",
    "http://www.w3.org/ns/shacl#in": [
      {
        "@list": [
          {
            "@value": "critical"
          },
          {
            "@value": "major"
          },
          {
            "@value": "minor"
          }
        ]
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Deviation event must carry a category (critical/major/minor)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#deviationCategory"
      }
    ]
  },
  {
    "@id": "_:cb18136b029cfc971b212d580b79d4ad25974be3c02def3f067d9ec93d87badb070",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "ProtocolVersion declares no eligibility criteria (design-quality warning)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#hasEligibilityCriterion"
      }
    ],
    "http://www.w3.org/ns/shacl#severity": [
      {
        "@id": "http://www.w3.org/ns/shacl#Warning"
      }
    ]
  },
  {
    "@id": "_:cb18664b83a8841e8a83921b10f7af2207f2d9f99b6c5e25b7ada7c19ac22e2631a",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Participant.participantStatus=COMPLETED but completionDate is not populated."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"COMPLETED\" .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#completionDate> ?d . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb187edc77cc4b29e1cff0975bedc164cd8ccff2e2b8d8c44939b1dc417e4314b04",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Person"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Enrollment must reference the real Person (PII bridge)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#enrolledPerson"
      }
    ]
  },
  {
    "@id": "_:cb188312394ea2562a79cdbe68bf29a49024482b30c94a1fcccda3f876733bac61d",
    "http://www.w3.org/ns/shacl#in": [
      {
        "@list": [
          {
            "@value": "high"
          },
          {
            "@value": "low"
          },
          {
            "@value": "medium"
          }
        ]
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Risk assessment must carry a risk level (low/medium/high)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#riskLevel"
      }
    ]
  },
  {
    "@id": "_:cb1957d4145b1b114576f5253c3201d986c44db499d6bbeead9ec9126dc5c107775",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "An assessment carrying cr:assessmentResult should also carry cr:assessmentUnit (UCUM code)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#assessmentResult> ?v .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#assessmentUnit> ?u . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1969941568f6138f394bdc48706e1b0995d6e5cfd579405a244512449eb80c7f2",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Recruit.recruitStatus=CONVERTED_TO_PARTICIPANT but convertedToParticipant relationship is missing."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#recruitStatus> \"CONVERTED_TO_PARTICIPANT\" .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#convertedToParticipant> ?p . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb196bf80bc2cb2260f05c6b73ab2ab1cd49308f93022b7f955f971edbe96276284",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Universal DNA: every entity must carry a top:identifier."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/v1#identifier"
      }
    ]
  },
  {
    "@id": "_:cb1979cafd6867c1339f4d90831530d56b74217b540c20480b284c667709f0cd990",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#Delegation"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Consent must reference the authorizing Delegation."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#underDelegation"
      }
    ]
  },
  {
    "@id": "_:cb1a3ecf1f3af34f928c806c23b6d65e05dc10bb126741adec2fa018fcb1246cb1e",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "VisitOccurrence.atStudySite does not match the forParticipant's forStudySite."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#atStudySite> ?ss ;\n                    <https://top.scientix.ai/cr/v1#forParticipant> ?p .\n              ?p <https://top.scientix.ai/cr/v1#forStudySite> ?pss .\n              FILTER ( ?ss != ?pss )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1aad94d929e849c00e513de37760752bbbd86db6c671402a9fcfffde2c03b4219",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#IRBApproval"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Activation requires local IRB/IEC approval."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#irbApproval"
      }
    ]
  },
  {
    "@id": "_:cb1ac8e96128e2fafedaf74559c8d407dcc71bd750cc85209f103824648a9b587a3",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Source data has no audit trail (ALCOA++ reconstructability not explicitly asserted)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#hasAuditTrail"
      }
    ],
    "http://www.w3.org/ns/shacl#severity": [
      {
        "@id": "http://www.w3.org/ns/shacl#Warning"
      }
    ]
  },
  {
    "@id": "_:cb1b88aadf1ccbde2bc13d3a4f8ca47a341145986f2b087965f1a0e2ed741e9c345",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/hcls/v1#Person"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Delegation must name the responsible delegator (PI)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#delegator"
      }
    ]
  },
  {
    "@id": "_:cb1be24319a21f06bc50d846634d87464360418f5738a2491e37357fc9809d7b800",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Acts executed out of the order their planned activities require (cr:precedes violated)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this   <https://top.scientix.ai/cr/v1#realizes> ?pa ;\n                      <https://top.scientix.ai/v1#observedAt> ?ta .\n              ?pa     <https://top.scientix.ai/cr/v1#precedes> ?pb .\n              ?other  <https://top.scientix.ai/cr/v1#realizes> ?pb ;\n                      <https://top.scientix.ai/v1#observedAt> ?tb .\n              FILTER ( ?ta > ?tb )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1bea75ad16a18f3f546aa2ecba376e41ae6e87a29d8a522ebbcc5cb74d6353e14",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#SiteInitiationVisit"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Activation requires a completed Site Initiation Visit."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#siv"
      }
    ]
  },
  {
    "@id": "_:cb1bfaa973cec1498bb746ecc41b0d0cb511cd7300477cbdfb0911862cee83388a1",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "PlannedEncounter has no cr:timing (an encounter must be positioned on the timeline)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#timing"
      }
    ],
    "http://www.w3.org/ns/shacl#severity": [
      {
        "@id": "http://www.w3.org/ns/shacl#Violation"
      }
    ]
  },
  {
    "@id": "_:cb1cc8ab0a3a9692a6bf5a4d2d72eb1b56251c23c2905dd015280fca733d85b3c9d",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#Sponsor"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "A Study must have a Sponsor."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#sponsoredBy"
      }
    ]
  },
  {
    "@id": "_:cb1d136d9c1ecbd640b9944ff741f4c6e4c57098946be41c7a96ca930d84749f63b",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "PlannedVisit has no cr:windowStart."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#windowStart"
      }
    ],
    "http://www.w3.org/ns/shacl#severity": [
      {
        "@id": "http://www.w3.org/ns/shacl#Violation"
      }
    ]
  },
  {
    "@id": "_:cb1d5c87f9e95fd3b602cfbc8500c5d9e3655f18ffbe1cdb7de812447d95bd7f597",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:DoseLimitingToxicity must declare a CTCAE grade."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#ctcaeGrade"
      }
    ]
  },
  {
    "@id": "_:cb1da8ee017e86038dbd3ccded55d8d4c844a1d66dc3d3f94ccb2d590ec901eb209",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Nonclinical finding is not addressed by any clinical-protocol safety assessment (broken IND narrative -> clinical-hold risk)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this a <https://top.scientix.ai/cr/v1#NonclinicalFinding> .\n              FILTER NOT EXISTS {\n                ?sa a <https://top.scientix.ai/cr/v1#SafetyAssessment> ;\n                    <https://top.scientix.ai/cr/v1#addressesFinding> $this .\n              }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1dc9cc789e0635590d35f834a5208029273e7e5e9343d354110ef3ba99fac7703",
    "http://www.w3.org/ns/shacl#in": [
      {
        "@list": [
          {
            "@value": "definite"
          },
          {
            "@value": "possible"
          },
          {
            "@value": "probable"
          },
          {
            "@value": "unrelated"
          }
        ]
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:causalityVerdict must be one of: unrelated, possible, probable, definite."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#causalityVerdict"
      }
    ]
  },
  {
    "@id": "_:cb1de4b7ac2a1bc63d04e5fb708a59fbe2165b5a85194d54e742667fc76684c872b",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "VisitOccurrence.windowStatus=OUT_OF_WINDOW but no linked Deviation. Consider documenting as a protocol deviation per ICH E6(R3) \u00a74.5."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#windowStatus> \"OUT_OF_WINDOW\" .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#associatedDeviation> ?d . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1e3e7867fa99c43e1b41c38dead9447575fadd0385997a88f5538ba442c64b38f",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Universal DNA: every entity must carry a top:status."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/v1#status"
      }
    ]
  },
  {
    "@id": "_:cb1e5b19abc5df7cf6ac7bf001761f093d436640701a7021115b541f0927b800469",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#CriticalToQualityFactor"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Risk assessment must reference the critical-to-quality factor it assesses."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#assessesFactor"
      }
    ]
  },
  {
    "@id": "_:cb1e92c1606a67d2375dd99cf560c95231e7cc5699846d6a6ae7c3c4b61cfb0a835",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Recruit has 6+ contact attempts but is still in RESPONDED or CONTACTED state. Consider transitioning to DROPPED."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#contactAttempts> ?n ;\n                    <https://top.scientix.ai/cr/v1#recruitStatus> ?s .\n              FILTER ( ?n >= 6 && ?s IN (\"RESPONDED\", \"CONTACTED\") )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1eb1aa2e68ee1f474e67a2c18bd64ebdae998a6729bb840c62fbe300584558430",
    "http://www.w3.org/ns/shacl#datatype": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#dateTime"
      }
    ],
    "http://www.w3.org/ns/shacl#maxCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Must have exactly one transaction-time record (top:recordedAt)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/v1#recordedAt"
      }
    ]
  },
  {
    "@id": "_:cb1ecac955daf0f01fa8f8e563cebe59e298466158b9fb91cd2790e8ebc4058f260",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Site activated without a complete Regulatory and Budget & Contracting work stream."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?anyStream .\n              FILTER (\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?r .\n                             ?r a <https://top.scientix.ai/cr/v1#RegulatoryWorkStream> ;\n                                <https://top.scientix.ai/cr/v1#streamStatus> \"complete\" . }\n                || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?b .\n                             ?b a <https://top.scientix.ai/cr/v1#BudgetContractingWorkStream> ;\n                                <https://top.scientix.ai/cr/v1#streamStatus> \"complete\" . }\n              )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1f0603853530abc464eb6bf5ef79dff98b6c418e7c8590fe87c608a15c30b7122",
    "http://www.w3.org/ns/shacl#in": [
      {
        "@list": [
          {
            "@id": "https://w3id.org/semapv/vocab/LexicalMatching"
          },
          {
            "@id": "https://w3id.org/semapv/vocab/LogicalReasoning"
          },
          {
            "@id": "https://w3id.org/semapv/vocab/ManualMappingCuration"
          }
        ]
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Mapping justification must be a semapv justification IRI."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#nodeKind": [
      {
        "@id": "http://www.w3.org/ns/shacl#IRI"
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/crosswalk/v1#justification"
      }
    ]
  },
  {
    "@id": "_:cb1f859143603f709f9119ec0f138ee4d965f9388ea135ef3c96a62123ea33f8078",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Query must be anchored to a target entity (cr:queryOn)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#nodeKind": [
      {
        "@id": "http://www.w3.org/ns/shacl#IRI"
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#queryOn"
      }
    ]
  },
  {
    "@id": "_:cb1fe86d963d061bbfdef186fb16ad409a4dea911b1c19ddb7692ff760ca85533ff",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#StudySite"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Activation must name the site it activates."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#activates"
      }
    ]
  },
  {
    "@id": "_:cb20338b707d112c9a3834e58a4cee9a709b852ecfa643425b9659912ada4ce0ee3",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Significant deviation (critical/major) has no CAPA."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#deviationCategory> ?c .\n              FILTER ( ?c IN ( \"critical\", \"major\" ) )\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#triggers> ?capa . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb205557f025973cf8c64d7414c237afb6b638a68a8aaa88903eb6c2f9638191903",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Analysis dataset (ADaM) must declare prov:wasDerivedFrom its source (traceability)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#nodeKind": [
      {
        "@id": "http://www.w3.org/ns/shacl#IRI"
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "http://www.w3.org/ns/prov#wasDerivedFrom"
      }
    ]
  },
  {
    "@id": "_:cb214f24f50bfad9b6c941d964b7b73298fbd093c94bac19fc5a3066092d489ca2c",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Participant.participantStatus=WITHDRAWN but no WithdrawalRecord with withdrawalCategory=CONSENT_WITHDRAWN. WITHDRAWN is reserved for subject-initiated withdrawal; investigator-initiated uses DISCONTINUED."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"WITHDRAWN\" .\n              FILTER NOT EXISTS {\n                $this <https://top.scientix.ai/cr/v1#hasWithdrawalRecord> ?w .\n                ?w <https://top.scientix.ai/cr/v1#withdrawalCategory> \"CONSENT_WITHDRAWN\" .\n              }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb2165182e0ae310de0b4d6122217dbdaed931ed6d2bbe8b699e585dbe3f64eaaf6",
    "http://www.w3.org/ns/shacl#class": [
      {
        "@id": "https://top.scientix.ai/cr/v1#Capability"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Delegation must grant a Capability."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#delegatedCapability"
      }
    ]
  },
  {
    "@id": "_:cb21f6bc46899999f7a96720f80f0df411dac6dc2ebceeb085c477aa33cda906bdc",
    "http://www.w3.org/ns/shacl#in": [
      {
        "@list": [
          {
            "@value": "answered"
          },
          {
            "@value": "closed"
          },
          {
            "@value": "open"
          }
        ]
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Query must carry a resolution status (open/answered/closed)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
