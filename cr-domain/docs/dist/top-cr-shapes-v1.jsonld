      }
    ],
    "http://www.w3.org/ns/shacl#targetSubjectsOf": [
      {
        "@id": "https://top.scientix.ai/cr/v1#realizes"
      }
    ]
  },
  {
    "@id": "https://top.scientix.ai/cr/v1#ArmStudyConsistencyShape",
    "@type": [
      "http://www.w3.org/ns/shacl#NodeShape"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Assigned arm must belong to Participant's Study (hard)"
