      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#activates"
      }
    ]
  },
  {
    "@id": "_:cb20338b707d112c9a3834e58a4cee9a709b852ecfa643425b9659912ada4ce0ee3",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Significant deviation (critical/major) has no CAPA."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#deviationCategory> ?c .\n              FILTER ( ?c IN ( \"critical\", \"major\" ) )\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#triggers> ?capa . }\n            }\n        "
      }
    ]
  },
