    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/crosswalk/v1#justification"
      }
    ]
  },
  {
    "@id": "_:cb1f32fa017a1bf97bcbebf806c0f0338acf8f8715ea369a3f1841b782e5e8fee6d",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Acts executed out of the order their planned activities require (cr:precedes violated)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this   <https://top.scientix.ai/cr/v1#realizes> ?pa ;\n                      <https://top.scientix.ai/core/v1#observedAt> ?ta .\n              ?pa     <https://top.scientix.ai/cr/v1#precedes> ?pb .\n              ?other  <https://top.scientix.ai/cr/v1#realizes> ?pb ;\n                      <https://top.scientix.ai/core/v1#observedAt> ?tb .\n              FILTER ( ?ta > ?tb )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1f859143603f709f9119ec0f138ee4d965f9388ea135ef3c96a62123ea33f8078",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Query must be anchored to a target entity (cr:queryOn)."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#nodeKind": [
      {
        "@id": "http://www.w3.org/ns/shacl#IRI"
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#queryOn"
      }
    ]
  },
  {
    "@id": "_:cb1fb83067e2952a2cea415c6f14a04b4e67820c7a4009bfc818412bde7d09a0134",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Act performed outside the effective window of its delegation (timing gap) \u2014 review materiality."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#exercisesCapability> ?cap ;\n                    <https://top.scientix.ai/cr/v1#performedBy> ?p ;\n                    <https://top.scientix.ai/core/v1#observedAt> ?t .\n              ?d a <https://top.scientix.ai/cr/v1#Delegation> ;\n                 <https://top.scientix.ai/cr/v1#delegate> ?p ;\n                 <https://top.scientix.ai/cr/v1#delegatedCapability> ?cap ;\n                 <https://top.scientix.ai/core/v1#observedAt> ?df .\n              OPTIONAL { ?d <https://top.scientix.ai/core/v1#validTo> ?dt . }\n              FILTER ( ?t < ?df || ( BOUND(?dt) && ?t > ?dt ) )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb1fe86d963d061bbfdef186fb16ad409a4dea911b1c19ddb7692ff760ca85533ff",
