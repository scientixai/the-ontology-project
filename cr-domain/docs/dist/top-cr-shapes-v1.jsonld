    "@id": "_:cb2b7336b5fe6817a0d3591f762992c87feca78838ccfc907cb961248e24801f746",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Act performed outside the effective window of its delegation (timing gap) \u2014 review materiality."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#exercisesCapability> ?cap ;\n                    <https://top.scientix.ai/cr/v1#performedBy> ?p ;\n                    <https://top.scientix.ai/v1#observedAt> ?t .\n              ?d a <https://top.scientix.ai/cr/v1#Delegation> ;\n                 <https://top.scientix.ai/cr/v1#delegate> ?p ;\n                 <https://top.scientix.ai/cr/v1#delegatedCapability> ?cap ;\n                 <https://top.scientix.ai/v1#observedAt> ?df .\n              OPTIONAL { ?d <https://top.scientix.ai/v1#validTo> ?dt . }\n              FILTER ( ?t < ?df || ( BOUND(?dt) && ?t > ?dt ) )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb2bb74fea7af3bb592b7f6e93e08da217a67729e40191eefa55e1f2e9ceb76753e",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Pre-IND question lacks a proposed position (vague question)."
