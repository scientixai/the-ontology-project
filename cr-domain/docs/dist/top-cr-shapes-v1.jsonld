  {
    "@id": "_:cb4a432b5decf363c1980c782074abbe9787002ca02e118594a278bb174dbe471ac",
    "http://www.w3.org/ns/shacl#datatype": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#decimal"
      }
    ],
    "http://www.w3.org/ns/shacl#maxInclusive": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#decimal",
        "@value": "1.0"
      }
    ],
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Mapping must carry a confidence in [0,1]."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#minInclusive": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#decimal",
        "@value": "0.0"
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/crosswalk/v1#confidence"
      }
    ]
  },
  {
    "@id": "_:cb90b1a505a038831b9df7a16af04b2c6c731c4db823239d0820bb6671d8d25322",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:ctcaeGrade must be an integer between 1 and 5 inclusive."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#ctcaeGrade> ?g .\n              FILTER ( ?g < 1 || ?g > 5 )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cb9fdeefc9431e0f1510e342c2eec201fabbac3a2e14e1bf5df053969b06a783a7",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "VisitOccurrence.visitType=UNSCHEDULED but unscheduledReason is missing. Maps to SDTM SV SVUPDES."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#visitType> \"UNSCHEDULED\" .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#unscheduledReason> ?r . }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cba0ddb134d2a17aa04bd18fbf0985ba07820f918eb2c5f321167009506c4532ba",
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "http://www.w3.org/ns/prov#wasDerivedFrom"
      }
    ]
  },
  {
    "@id": "_:cbb476bb386eded0c72acab3c01c11f7d9e567fbd87d5ad1ce53862e176899adf4",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Participant.forStudySite references a StudySite whose forStudy does not match Participant.forStudy."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#forStudySite> ?ss ;\n                    <https://top.scientix.ai/cr/v1#forStudy> ?study .\n              FILTER NOT EXISTS {\n                ?ss <https://top.scientix.ai/cr/v1#forStudy> ?study .\n              }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cbc67162c71828f1cafe687ba91b15423271e8d31a82119dc41a8d11c0607dc2db",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:SeriousAdverseEvent lacks a cr:CausalityAssessment concluding about it."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              FILTER NOT EXISTS {\n                ?ca a <https://top.scientix.ai/cr/v1#CausalityAssessment> ;\n                     <https://top.scientix.ai/v1#concludesAbout> $this .\n              }\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cbcd4c95a7aee25cc953501ecc9cb29652c92f9106af3e3d02c26f8b8d7abb7748",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "Pre-IND meeting lacks a briefing book and/or specific questions (readiness warning)."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#meetingType> \"Pre-IND\" .\n              FILTER ( NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasBriefingBook> ?b }\n                       || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasQuestion> ?q } )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cbe1579e44002d98cc52a45915ba33972adca2f6427fdd33f1f6e6ec19b4c59ede",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:Assessment must declare its instrument (cr:assessmentInstrument). Missing on this assessment."
      }
    ],
    "http://www.w3.org/ns/shacl#minCount": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#integer",
        "@value": 1
      }
    ],
    "http://www.w3.org/ns/shacl#path": [
      {
        "@id": "https://top.scientix.ai/cr/v1#assessmentInstrument"
      }
    ]
  },
  {
    "@id": "_:cbe5f75c5d55e78cdb106daa781c7df64ab4f15ff811c077e38380d9524d22951a",
    "http://www.w3.org/ns/shacl#message": [
      {
        "@value": "cr:DoseLimitingToxicity must have cr:ctcaeGrade of 3, 4, or 5 to meet DLT criteria."
      }
    ],
    "http://www.w3.org/ns/shacl#select": [
      {
        "@value": "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#ctcaeGrade> ?g .\n              FILTER ( ?g < 3 )\n            }\n        "
      }
    ]
  },
  {
    "@id": "_:cbebe1b30c8eaa8bc4c5cc063d6ac4ee54455e007fb46af606ab761bf0e54a81d8",
