cr:activates a owl:ObjectProperty ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:activationPackage a owl:ObjectProperty ;
    rdfs:label "activation package" ;
    rdfs:comment "The start-up package this activation drew from (forward edge, for single-pull retrieval)." ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:StudyStartupPackage ;
    top:flavor "Additive" .

cr:addressesFinding a owl:ObjectProperty ;
    rdfs:domain cr:SafetyAssessment ;
    rdfs:range cr:NonclinicalFinding ;
    top:flavor "Additive" .

cr:analyzedUnder a owl:ObjectProperty ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:StatisticalAnalysisPlan ;
    top:flavor "Additive" .

cr:anchorDate a owl:DatatypeProperty ;
    rdfs:label "anchor date" ;
    rdfs:comment "The resolved anchor (e.g. the subject's enrollment date) from which target dates are computed." ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:asSubject a owl:ObjectProperty ;
    rdfs:domain cr:Enrollment ;
    rdfs:range cr:StudySubject ;
    top:flavor "Additive" .

cr:assessesFactor a owl:ObjectProperty ;
    rdfs:domain cr:RiskAssessment ;
    rdfs:range cr:CriticalToQualityFactor ;
    top:flavor "Additive" .

cr:atSite a owl:ObjectProperty ;
    rdfs:comment "The site a subject was enrolled at (enables the enroll-after-activation check)." ;
    rdfs:domain cr:Enrollment ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:atStudySite a owl:ObjectProperty ;
    rdfs:label "at study site" ;
    rdfs:comment "1..1. The StudySite that operationally owns this visit (in-person or remote). Redundant with Participant.forStudySite but kept direct for query convenience." ;
    rdfs:domain cr:VisitOccurrence ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:atVisit a owl:ObjectProperty ;
    rdfs:label "at visit" ;
    rdfs:comment "The actual visit an assessment was performed within." ;
    rdfs:domain cr:Assessment ;
    rdfs:range cr:Visit ;
    top:flavor "Additive" .

cr:attestedBy a owl:ObjectProperty ;
    rdfs:label "attested by" ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

cr:basedOnDoseOptimization a owl:ObjectProperty ;
    rdfs:comment "Project Optimus: the proposed Phase 3 dose should rest on dose-optimization work." ;
    rdfs:domain cr:Phase3Design ;
    rdfs:range top:Temporal ;
    top:flavor "Additive" .

cr:capaStatus a owl:DatatypeProperty ;
    rdfs:label "CAPA status" ;
    rdfs:comment "open | in-progress | closed." ;
    rdfs:domain cr:CAPA ;
    top:flavor "Additive" .

cr:capaType a owl:DatatypeProperty ;
    rdfs:label "CAPA type" ;
