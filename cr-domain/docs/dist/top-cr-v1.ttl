@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix cx: <https://top.scientix.ai/crosswalk/v1#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix ns1: <https://top.scientix.ai/tmf/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cr: a owl:Ontology ;
    rdfs:label "CR-core" ;
    rdfs:comment "Clinical-research domain core: entities recurring across >=2 CR workflows. Specializes TOP Core / HCLS-core. Scope: oncology Pre-IND -> EOP2. Standards projection target: CDISC (SDTM/CDASH/Define-XML), USDM, MedDRA." .

cr:AcknowledgeShipmentReceipt a hcls:Action ;
    rdfs:label "Acknowledge Shipment Receipt" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:VisitExecutionSubPhase ;
    hcls:operatesOn cr:ActivityOccurrence .

cr:ActivateSite a hcls:Action ;
    rdfs:label "Activate Site" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate,
        cr:SponsorOperationsStaff ;
    hcls:occursIn cr:ActivationSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:AddCountry a hcls:Action ;
    rdfs:label "Add Country" ;
    hcls:authorizedAgentType cr:RegulatoryAffairsSpecialist ;
    hcls:occursIn cr:SiteSelectionSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:AddTherapeuticArea a hcls:Action ;
    rdfs:label "Add Therapeutic Area" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:AdministerQuestionnaire a hcls:Action ;
    rdfs:label "Administer Questionnaire" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:VisitExecutionSubPhase ;
    hcls:operatesOn cr:ActivityOccurrence .

cr:Administration a owl:Class ;
    rdfs:label "Administration" ;
    rdfs:comment "A dosing event." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:AnalysisDataset a owl:Class ;
    rdfs:label "Analysis Dataset (ADaM)" ;
    rdfs:comment "An ADaM analysis dataset (e.g. ADSL, ADAE). Must declare prov:wasDerivedFrom its source so any result built on it is reproducible to source." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:ApproveAmendment a hcls:Action ;
    rdfs:label "Approve Amendment" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:RegulatorySubPhase ;
    hcls:operatesOn cr:ProtocolVersion .

cr:ApproveOrRejectDeviation a hcls:Action ;
    rdfs:label "Approve or Reject Deviation" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:ApproveRiskAssessment a hcls:Action ;
    rdfs:label "Approve Risk Assessment" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:Study .

cr:ArchiveLog a hcls:Action ;
    rdfs:label "Archive Log" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:ArchivalSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:AssignActionItem a hcls:Action ;
    rdfs:label "Assign Action Item" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:AssignCountryToRegion a hcls:Action ;
    rdfs:label "Assign Country to Region" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:SiteSelectionSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:AssignParticipantsToArm a hcls:Action ;
    rdfs:label "Assign Participants to Arm" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:RecruitmentSubPhase ;
    hcls:operatesOn cr:Arm .

cr:AssociateStudyToSponsor a hcls:Action ;
    rdfs:label "Associate or Remove Study" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:SiteSelectionSubPhase ;
    hcls:operatesOn cr:Study .

cr:Attestation a owl:Class ;
    rdfs:label "Attestation" ;
    rdfs:comment "A sworn, non-repudiable statement; the write-path that creates delegation/consent assertions." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:BudgetContractingWorkStream a owl:Class ;
    rdfs:label "Budget & Contracting Work Stream" ;
    rdfs:comment "Budget negotiation and contract (CTA) review and execution." ;
    rdfs:subClassOf cr:WorkStream .

cr:CDISC_CDASH a top:RegulatoryLaw ;
    rdfs:label "CDISC CDASH — Clinical Data Acquisition Standards Harmonization" ;
    rdfs:comment "CDISC standard defining the content of data collected on case report forms. Primary crosswalk target for cr:OperationalRecord field mapping." ;
    skos:notation "CDISC CDASH" ;
    top:status "active" .

cr:CDISC_SDTM a top:RegulatoryLaw ;
    rdfs:label "CDISC SDTM — Study Data Tabulation Model" ;
    rdfs:comment "CDISC standard for organizing and formatting clinical trial data for regulatory submissions (FDA/PMDA)." ;
    skos:notation "CDISC SDTM" ;
    top:status "active" .

cr:CFR_21_Part_11 a top:RegulatoryLaw ;
    rdfs:label "21 CFR Part 11 — Electronic Records and Signatures" ;
    rdfs:comment "US FDA regulation governing electronic records and electronic signatures in clinical data systems. Requires audit trails, access controls, and non-repudiable e-signatures." ;
    skos:notation "21 CFR Part 11" ;
    top:status "active" .

cr:CFR_21_Part_312 a top:RegulatoryLaw ;
    rdfs:label "21 CFR Part 312 — Investigational New Drug Application" ;
    rdfs:comment "US FDA IND regulations. Governs the submission, conduct, and reporting obligations of IND-enabling and IND-active clinical trials in the US." ;
    skos:notation "21 CFR Part 312" ;
    top:status "active" .

cr:CFR_21_Part_50 a top:RegulatoryLaw ;
    rdfs:label "21 CFR Part 50 — Protection of Human Subjects" ;
    rdfs:comment "US FDA informed consent regulations. Governs the process and documentation of consent from trial participants." ;
    skos:notation "21 CFR Part 50" ;
    top:status "active" .

cr:CFR_21_Part_56 a top:RegulatoryLaw ;
    rdfs:label "21 CFR Part 56 — Institutional Review Boards" ;
    rdfs:comment "US FDA IRB regulations. Governs the composition, operations, and responsibilities of IRBs that review clinical trials." ;
    skos:notation "21 CFR Part 56" ;
    top:status "active" .

cr:COORD-J01 a hcls:JobToBeDone ;
    rdfs:label "Screen and enroll a candidate participant" ;
    hcls:executesAction cr:CompleteCRF,
        cr:EnrollParticipant,
        cr:ObtainParticipantConsent,
        cr:ScheduleVisit,
        cr:ScreenParticipant,
        cr:UpdateEnrollmentStatus ;
    hcls:involvesObject cr:EnrollmentRecord,
        cr:InformedConsentAct,
        cr:Participant,
        cr:VisitOccurrence,
        cr:eCRF ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Candidate presents for screening; Informed Consent obtained." ;
    hcls:successSignal "All enrollment CRFs complete at baseline visit.",
        "Participant.participantStatus = ON_TREATMENT within eligibility window.",
        "Zero open queries on eligibility data at enrollment." .

cr:COORD-J02 a hcls:JobToBeDone ;
    rdfs:label "Run a protocol visit on schedule and within window" ;
    hcls:executesAction cr:CollectSample,
        cr:CompleteVisit,
        cr:StartVisit,
        cr:UpdateCRF ;
    hcls:involvesObject cr:ActivityOccurrence,
        cr:VisitOccurrence,
        cr:eCRF ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Visit.visitStatus = SCHEDULED; visit window approaching." ;
    hcls:successSignal "All per-protocol CRFs for the visit reach COMPLETED or VERIFIED.",
        "Samples shipped within chain-of-custody SLA.",
        "Visit.visitStatus = COMPLETED with windowStatus = IN_WINDOW." .

cr:COORD-J03 a hcls:JobToBeDone ;
    rdfs:label "Capture data cleanly and respond to queries" ;
    hcls:executesAction cr:RespondToQuery,
        cr:UpdateCRF ;
    hcls:involvesObject cr:eCRF ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Data Manager raises a query; Discrepancy.queryStatus = OPEN." ;
    hcls:successSignal "Coordinator response posted within sponsor target TTR.",
        "No repeated re-open on the same data point.",
        "Query moves to ANSWERED or CLOSED." .

cr:COORD-J04 a hcls:JobToBeDone ;
    rdfs:label "Report adverse events within sponsor-required timelines" ;
    hcls:executesAction cr:FollowUpAdverseEvent,
        cr:ReportAdverseEvent,
        cr:UpdateAdverseEventDetails ;
    hcls:involvesObject cr:AdverseEvent ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Adverse Event observed or reported by participant." ;
    hcls:successSignal "AE reported with reportedDate within 24h for SAEs.",
        "Investigator assessment completed within protocol timeline." .

cr:COORD-J05 a hcls:JobToBeDone ;
    rdfs:label "Keep the site regulatory binder and logs current" ;
    hcls:executesAction cr:AddLogEntry,
        cr:CreateLog,
        cr:LogCommunication ;
    hcls:involvesObject cr:Credential,
        cr:Delegation ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "New amendment approved, new staff onboarded, or monitoring visit upcoming." ;
    hcls:successSignal "Delegation, training, enrollment, and drug accountability logs up to date.",
        "Monitoring visit finds zero major findings in the binder category." .

cr:CRA-J01 a hcls:JobToBeDone ;
    rdfs:label "Get a site ready to enroll its first participant" ;
    hcls:executesAction cr:ConductMonitoringVisit,
        cr:InitiateSite,
        cr:SubmitMonitoringReport ;
    hcls:involvesObject cr:Credential,
        cr:Delegation,
        cr:StudySite ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Site.siteStatus enters READY_TO_INITIATE after Study Startup Package is ready." ;
    hcls:successSignal "First participant enrolled within sponsor target window after activation.",
        "Site activated on or before plannedActivationDate.",
        "Zero open regulatory or training deficiencies at SIV close." .

cr:CRA-J02 a hcls:JobToBeDone ;
    rdfs:label "Verify that site data matches source documents" ;
    hcls:executesAction cr:ConductMonitoringVisit,
        cr:CreateQuery,
        cr:RecordFinding,
        cr:SubmitMonitoringReport ;
    hcls:involvesObject cr:eCRF ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Monitoring visit scheduled or risk-based trigger fires." ;
    hcls:successSignal "CRFs reviewed during the visit left in VERIFIED status.",
        "No outstanding major findings recorded.",
        "SDV rate meets monitoring plan target for the window." .

cr:CRA-J03 a hcls:JobToBeDone ;
    rdfs:label "Catch and close protocol deviations early" ;
    hcls:executesAction cr:RecordFinding,
        cr:ReportDeviation ;
    hcls:involvesObject cr:Participant,
        cr:VisitOccurrence ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Deviation identified during a monitoring visit or pattern review." ;
    hcls:successSignal "Deviation moved to REVIEWED within sponsor target cycle time.",
        "IRB reporting deadline met." .

cr:CRA-J04 a hcls:JobToBeDone ;
    rdfs:label "Close the site cleanly at study end" ;
    hcls:executesAction cr:ConductMonitoringVisit,
        cr:SubmitMonitoringReport ;
    hcls:involvesObject cr:StudySite ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Site.siteStatus moves to CLOSED_TO_ENROLLMENT; close-out visit scheduled." ;
    hcls:successSignal "All essential documents transferred to sponsor eTMF.",
        "Close-out monitoring visit completed and signed by PI.",
        "Open findings and action items closed." .

cr:CRO a owl:Class ;
    rdfs:label "CRO" ;
    rdfs:comment "A contract research organization the sponsor delegates trial conduct to." ;
    rdfs:subClassOf hcls:Organization .

cr:CROBoundary a owl:NamedIndividual ;
    rdfs:label "CRO" .

cr:CalibrateEquipment a hcls:Action ;
    rdfs:label "Calibrate Equipment" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:StudySite .

cr:CancelActionItem a hcls:Action ;
    rdfs:label "Cancel Action Item" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:CancelPayment a hcls:Action ;
    rdfs:label "Cancel Payment" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:StudySite .

cr:CancelTask a hcls:Action ;
    rdfs:label "Cancel Task" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:CancelVisit a hcls:Action ;
    rdfs:label "Cancel Visit" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:VisitExecutionSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:ClinOpsWorkStream a owl:Class ;
    rdfs:label "Clinical Operations Work Stream" ;
    rdfs:comment "Enrollment and data-collection readiness from the protocol, SOPs, vendor manuals, monitoring plan, and schedule of activities." ;
    rdfs:subClassOf cr:WorkStream .

cr:CloseArm a hcls:Action ;
    rdfs:label "Close Arm" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:CloseoutPhase ;
    hcls:operatesOn cr:Arm .

cr:CloseAudit a hcls:Action ;
    rdfs:label "Close Audit" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:Study .

cr:CloseBudget a hcls:Action ;
    rdfs:label "Close Budget" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:ArchivalSubPhase ;
    hcls:operatesOn cr:Study .

cr:CloseCAPA a hcls:Action ;
    rdfs:label "Close CAPA" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:CloseDeviation a hcls:Action ;
    rdfs:label "Close Deviation" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:CloseFinding a hcls:Action ;
    rdfs:label "Close Finding" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:Study .

cr:CloseSAE a hcls:Action ;
    rdfs:label "Close SAE" ;
    hcls:authorizedAgentType cr:PharmacovigilianceSpecialist ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:Cohort a owl:Class ;
    rdfs:label "Cohort" ;
    rdfs:comment "A group of subjects sharing a dosing or treatment assignment." ;
    rdfs:subClassOf top:Scope .

cr:ConductAudit a hcls:Action ;
    rdfs:label "Conduct Audit" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:Study .

cr:ConductRiskAssessment a hcls:Action ;
    rdfs:label "Conduct Risk Assessment" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:Study .

cr:ConfigureDataQualityMetric a hcls:Action ;
    rdfs:label "Configure Data Quality Metric" ;
    hcls:authorizedAgentType cr:DataManager ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:Study .

cr:ConfigureSystemForStudy a hcls:Action ;
    rdfs:label "Configure System for Study" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff,
        cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:CoverageAnalysis a owl:Class ;
    rdfs:label "Coverage Analysis (MCA)" ;
    rdfs:comment "A Medicare/insurance coverage analysis for study procedures." ;
    rdfs:subClassOf top:Evidence .

cr:CreateCRF a hcls:Action ;
    rdfs:label "Create CRF" ;
    hcls:authorizedAgentType cr:DataManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:CreateRegulatorySubmission a hcls:Action ;
    rdfs:label "Create Regulatory Submission" ;
    hcls:authorizedAgentType cr:RegulatoryAffairsSpecialist ;
    hcls:occursIn cr:RegulatorySubPhase ;
    hcls:operatesOn cr:RegulatoryInteraction .

cr:CreateSite a hcls:Action ;
    rdfs:label "Create Site" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:SiteSelectionSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:DM-J01 a hcls:JobToBeDone ;
    rdfs:label "Resolve open queries and achieve clean data state" ;
    hcls:executesAction cr:AssignQuery,
        cr:CloseQuery,
        cr:CreateQuery,
        cr:ReopenQuery ;
    hcls:involvesObject cr:eCRF ;
    hcls:jobOfAgentType cr:DataManager ;
    hcls:jobTrigger "Query created on a CRF; or discrepancy detected in incoming data." ;
    hcls:successSignal "All queries on a CRF closed before CRF lock.",
        "Re-open rate below sponsor threshold." .

cr:DM-J02 a hcls:JobToBeDone ;
    rdfs:label "Lock CRFs and database for analysis" ;
    hcls:executesAction cr:LockUnlockCRF ;
    hcls:involvesObject cr:Study,
        cr:eCRF ;
    hcls:jobOfAgentType cr:DataManager ;
    hcls:jobTrigger "Last patient last visit completed; data cleaning cycle closed." ;
    hcls:successSignal "All CRFs in LOCKED state.",
        "Database lock confirmed by authorized Data Manager sign-off." .

cr:DefineRegion a hcls:Action ;
    rdfs:label "Define Region" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:SiteSelectionSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:DistributeReport a hcls:Action ;
    rdfs:label "Distribute Report" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ReportingSubPhase ;
    hcls:operatesOn cr:CSR .

cr:DoseLevel a owl:Class ;
    rdfs:label "Dose Level" ;
    rdfs:comment "A dose level in a dose-escalation design." ;
    rdfs:subClassOf top:Scope .

cr:DoseLimitingToxicity a owl:Class ;
    rdfs:label "Dose-Limiting Toxicity" ;
    rdfs:comment "Oncology dose-escalation: a DLT informs the next dose decision." ;
    rdfs:subClassOf cr:AdverseEvent .

cr:DraftAmendment a hcls:Action ;
    rdfs:label "Draft Amendment" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:ProtocolVersion .

cr:DrillIntoDataQualityMetric a hcls:Action ;
    rdfs:label "Drill Into Metric" ;
    hcls:authorizedAgentType cr:DataManager ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:Study .

cr:EU_CTR_536_2014 a top:RegulatoryLaw ;
    rdfs:label "EU Clinical Trials Regulation (EU) No 536/2014" ;
    rdfs:comment "European Union regulation governing clinical trials on medicinal products for human use. Replaces Directive 2001/20/EC. Requires submission via CTIS." ;
    skos:notation "EU CTR 536/2014" ;
    top:status "active" .

cr:EU_GDPR a top:RegulatoryLaw ;
    rdfs:label "EU General Data Protection Regulation (2016/679)" ;
    rdfs:comment "GDPR — governs processing of personal data for EU residents. Applies to any trial data linked to identifiable persons." ;
    skos:notation "GDPR 2016/679" ;
    top:status "active" .

cr:FIN-J01 a hcls:JobToBeDone ;
    rdfs:label "Create and approve budgets per study and per site" ;
    hcls:executesAction cr:AddBudgetLineItem,
        cr:ApproveBudget,
        cr:CreateBudget,
        cr:LockBudget ;
    hcls:involvesObject cr:Study,
        cr:StudySite ;
    hcls:jobOfAgentType cr:FinanceStaff ;
    hcls:jobTrigger "Study in IN_STARTUP; or new site activated." ;
    hcls:successSignal "Budget approved before first site activation.",
        "Line items match the SOA procedures and visit schedule.",
        "Site-level budget approved before first patient enrolled." .

cr:FIN-J02 a hcls:JobToBeDone ;
    rdfs:label "Issue payments to sites per budget and visit accrual" ;
    hcls:executesAction cr:ApprovePayment,
        cr:CreatePayment,
        cr:IssueSitePayment,
        cr:ProcessPayment ;
    hcls:involvesObject cr:StudySite,
        cr:VisitOccurrence ;
    hcls:jobOfAgentType cr:FinanceStaff ;
    hcls:jobTrigger "Visit.visitStatus = COMPLETED; accrual condition met; invoice received." ;
    hcls:successSignal "Payment issued within contract paymentTermsDays.",
        "complianceCheckStatus = PASSED (anti-kickback, Sunshine Act)." .

cr:FlagClinicallySignificant a hcls:Action ;
    rdfs:label "Flag Clinically Significant" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:ClinicalObservation .

cr:FlagForSponsorReport a hcls:Action ;
    rdfs:label "Flag for Sponsor Report" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:ClinicalObservation .

cr:GenerateBudgetForecast a hcls:Action ;
    rdfs:label "Generate Budget Forecast" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:GenerateReport a hcls:Action ;
    rdfs:label "Generate Report" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ReportingSubPhase ;
    hcls:operatesOn cr:CSR .

cr:ICH_E6_R3 a top:RegulatoryLaw ;
    rdfs:label "ICH E6(R3) — Good Clinical Practice" ;
    rdfs:comment "ICH E6(R3) GCP Guideline (Step 4, 2025). Governs the conduct of clinical trials to protect subjects and ensure data integrity. Primary governance document for CR domain actions." ;
    skos:notation "ICH E6(R3)" ;
    top:status "active" .

cr:ICH_E8_R1 a top:RegulatoryLaw ;
    rdfs:label "ICH E8(R1) — General Considerations for Clinical Studies" ;
    rdfs:comment "ICH E8(R1) (2021). Updated guidance on quality and risk-based approaches to clinical trial design. Companion to E6(R3)." ;
    skos:notation "ICH E8(R1)" ;
    top:status "active" .

cr:ICH_E9_R1 a top:RegulatoryLaw ;
    rdfs:label "ICH E9(R1) — Estimands and Sensitivity Analysis" ;
    rdfs:comment "ICH E9(R1) (2019). Addendum on estimands and sensitivity analysis in clinical trials." ;
    skos:notation "ICH E9(R1)" ;
    top:status "active" .

cr:IRB a owl:Class ;
    rdfs:label "IRB / IEC" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf hcls:Organization ;
    skos:altLabel "Independent Ethics Committee",
        "Institutional Review Board" ;
    skos:definition "An independent body that reviews and provides ongoing oversight to protect the rights, safety, and well-being of trial participants (paraphrased, ICH E6(R3))." .

cr:ImplementAmendment a hcls:Action ;
    rdfs:label "Implement Amendment" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:RegulatorySubPhase ;
    hcls:operatesOn cr:ProtocolVersion .

cr:IssueAuditFindings a hcls:Action ;
    rdfs:label "Issue Audit Findings" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:Study .

cr:MapTherapeuticAreaCodes a hcls:Action ;
    rdfs:label "Map Therapeutic Area Codes" ;
    hcls:authorizedAgentType cr:SponsorOperationsStaff ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:OpenCAPA a hcls:Action ;
    rdfs:label "Open CAPA" ;
    hcls:authorizedAgentType cr:SponsorQualityStaff ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:OperationalRecord a owl:Class ;
    rdfs:label "Operational Record" ;
    rdfs:comment "Non-clinical, non-GCP-governed data captured during trial operations — process metrics, site performance indicators, sponsor-defined operational fields (e.g. X_WHATEVER extensions in Medidata). Not an hcls:Observation (no clinical value) and not directly regulated by ICH E6; captured in operational CRFs or sponsor-specific payloads. Primary target for LLM-assisted field-mapping inference (cr:mappingConfidence)." ;
    rdfs:subClassOf top:Evidence .

cr:PI-J01 a hcls:JobToBeDone ;
    rdfs:label "Hold legal responsibility for trial conduct at the Site" ;
    hcls:executesAction cr:AddInvestigatorDelegation,
        cr:RefreshGCPTraining,
        cr:UpdateFCOIDisclosure ;
    hcls:involvesObject cr:Credential,
        cr:Delegation,
        cr:Study ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "Site selected for a Study; PI designated as Principal Investigator." ;
    hcls:successSignal "Form 1572 on file (US studies).",
        "GCP training current throughout the Study.",
        "No regulatory or sponsor actions escalated to debarment." .

cr:PI-J02 a hcls:JobToBeDone ;
    rdfs:label "Assess adverse events for causality and seriousness" ;
    hcls:executesAction cr:AssessAdverseEvent,
        cr:CloseAdverseEvent,
        cr:ReportSAE,
        cr:UpdateSAE ;
    hcls:involvesObject cr:AdverseEvent,
        cr:InvestigationalProduct ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "Site Coordinator reports an AE; or an SAE becomes known." ;
    hcls:successSignal "Causality and expectedness logged on every AE.",
        "Investigator assessment recorded within 24h of SAE awareness.",
        "Zero SAEs missed for expedited reporting." .

cr:PI-J03 a hcls:JobToBeDone ;
    rdfs:label "Review and sign CRFs" ;
    hcls:executesAction cr:ReviewCRF,
        cr:SignCRF ;
    hcls:involvesObject cr:eCRF ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "CRF status reaches COMPLETED; PI review required per protocol." ;
    hcls:successSignal "CRF electronicSignatureStatus = SIGNED within sponsor target TTR.",
        "Review and sign cycle does not block CRF lock." .

cr:PI-J04 a hcls:JobToBeDone ;
    rdfs:label "Delegate tasks to qualified site staff" ;
    hcls:executesAction cr:AddInvestigatorDelegation ;
    hcls:involvesObject cr:Credential,
        cr:Delegation ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "New staff onboarded; or protocol amendment changes delegation requirements." ;
    hcls:successSignal "Delegation of Authority log current and matches Person.delegatedBy.",
        "Each delegated task has a qualified delegate with training in place." .

cr:PI-J05 a hcls:JobToBeDone ;
    rdfs:label "Withdraw or close out a participant" ;
    hcls:executesAction cr:CompleteParticipantStudy,
        cr:WithdrawParticipant ;
    hcls:involvesObject cr:AdverseEvent,
        cr:InformedConsentAct,
        cr:Participant ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "Participant withdraws consent, completes study, or meets discontinuation criteria." ;
    hcls:successSignal "In-flight SAEs followed up post-withdrawal.",
        "Participant.participantStatus reflects correct end state (COMPLETED, WITHDRAWN).",
        "Withdrawal reason and date captured." .

cr:PM-J01 a hcls:JobToBeDone ;
    rdfs:label "Initialize a new study" ;
    hcls:executesAction cr:ActivateStudy,
        cr:CreateArm,
        cr:CreateMilestone,
        cr:CreateStudy,
        cr:UpdateStudyDetails ;
    hcls:involvesObject cr:Arm,
        cr:Study ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Program approval; Sponsor Exec authorises study start." ;
    hcls:successSignal "First site selected within target window.",
        "Protocol, SOA, CRFs, and Budget approved and locked.",
        "Study in ACTIVE status within sponsor target cycle time." .

cr:PM-J02 a hcls:JobToBeDone ;
    rdfs:label "Select and activate sites to hit enrollment plan" ;
    hcls:executesAction cr:AchieveMilestone,
        cr:SelectSiteForStudy ;
    hcls:involvesObject cr:StudySite ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Study in IN_STARTUP; feasibility responses in from candidate sites." ;
    hcls:successSignal "First site activated on or before plannedActivationDate.",
        "Target number of sites SELECTED within window." .

cr:PM-J03 a hcls:JobToBeDone ;
    rdfs:label "Manage enrollment across sites to meet plan" ;
    hcls:executesAction cr:CloseEnrollment,
        cr:DelayMilestone,
        cr:OpenEnrollment,
        cr:RebaselineTimeline ;
    hcls:involvesObject cr:Participant,
        cr:Study,
        cr:StudySite ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Study ENROLLING; enrollment plan and forecast in place." ;
    hcls:successSignal "Actual enrollmentCount tracks forecast within tolerance.",
        "Enrollment cycle time per site within sponsor target." .

cr:PM-J04 a hcls:JobToBeDone ;
    rdfs:label "Drive milestone achievement and timeline" ;
    hcls:executesAction cr:AchieveMilestone,
        cr:AssignTask,
        cr:DelayMilestone,
        cr:UpdateTimeline ;
    hcls:involvesObject cr:Study ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Milestone deadline approaches or slips." ;
    hcls:successSignal "Milestone moved to COMPLETED on or before plannedDate.",
        "Variance on Study Timeline within sponsor tolerance." .

cr:PM-J05 a hcls:JobToBeDone ;
    rdfs:label "Close study and archive cleanly" ;
    hcls:executesAction cr:ArchiveStudy,
        cr:CloseSite,
        cr:CloseSiteToEnrollment,
        cr:CloseStudy,
        cr:FinalizeReport ;
    hcls:involvesObject cr:CSR,
        cr:Study,
        cr:StudySite ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Last Patient Out (LPO) reached; database lock in progress." ;
    hcls:successSignal "All sites closed; all open Tasks and Findings resolved.",
        "CSR finalized and distributed.",
        "Study moves to COMPLETED then archived." .

cr:PV-J01 a hcls:JobToBeDone ;
    rdfs:label "Detect and evaluate emerging safety signals" ;
    hcls:executesAction cr:CloseSafetySignal,
        cr:EvaluateSafetySignal,
        cr:IdentifySafetySignal ;
    hcls:involvesObject cr:AdverseEvent ;
    hcls:jobOfAgentType cr:PharmacovigilianceSpecialist ;
    hcls:jobTrigger "Aggregate AE data shows unexpected frequency or severity pattern." ;
    hcls:successSignal "DSMB/IDMC notified if threshold met.",
        "Signal evaluated and action (escalate, monitor, or close) documented within SOP timeline." .

cr:PV-J02 a hcls:JobToBeDone ;
    rdfs:label "File expedited SAE reports within regulatory timelines" ;
    hcls:executesAction cr:ReconcileSAE,
        cr:SubmitExpeditedReport ;
    hcls:involvesObject cr:AdverseEvent ;
    hcls:jobOfAgentType cr:PharmacovigilianceSpecialist ;
    hcls:jobTrigger "SAE meets expedited reporting criteria (unexpected + possibly related)." ;
    hcls:successSignal "7-day initial or 15-day full report filed within regulatory deadline.",
        "Narrative and causality consistent across all SAE documents." .

