@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix cx: <https://top.scientix.ai/crosswalk/v1#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix ns1: <https://top.scientix.ai/tmf/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix top: <https://top.scientix.ai/core/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

top: a owl:Ontology ;
    rdfs:label "TOP Core (local working stub)" ;
    rdfs:comment "Local working stub of TOP Core: one root (top:Core) + eight Category-Level Objects (CLOs), aligned to the canonical Apache-2.0 TOP Core at github.com/scientixai/the-ontology-project. NOT authoritative; serves as the specialization anchor and carries TOP's Universal DNA (identifier + observedAt + status) plus the bitemporal + PROV convention vocabulary for the CR-domain build." .

top:identifier a owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:comment "A stable, dereferenceable identifier for the entity (the 'who/what is this' of the Universal DNA)." .

top:observedAt a owl:DatatypeProperty ;
    rdfs:label "observed at" ;
    rdfs:comment "Valid-time instant — when the fact became true in the world (NGSI-LD observedAt)." ;
    rdfs:range xsd:dateTime .

top:recordedAt a owl:DatatypeProperty ;
    rdfs:label "recorded at" ;
    rdfs:comment "Transaction-time instant — when the system first recorded the assertion (append-only)." ;
    rdfs:range xsd:dateTime .

top:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:comment "The lifecycle state of the entity (e.g. active, retired, superseded) — the 'where in its life' of the Universal DNA." .

top:supersededAt a owl:DatatypeProperty ;
    rdfs:label "superseded at" ;
    rdfs:comment "Transaction-time close — when a later assertion superseded this one." ;
    rdfs:range xsd:dateTime .

top:validTo a owl:DatatypeProperty ;
    rdfs:label "valid to" ;
    rdfs:comment "Valid-time close — when the fact stopped being true in the world." ;
    rdfs:range xsd:dateTime .

cr: a owl:Ontology ;
    rdfs:label "CR-core" ;
    rdfs:comment "Clinical-research domain core: entities recurring across >=2 CR workflows. Specializes TOP Core / HCLS-core. Scope: oncology Pre-IND -> EOP2. Standards projection target: CDISC (SDTM/CDASH/Define-XML), USDM, MedDRA." .

cr:Administration a owl:Class ;
    rdfs:label "Administration" ;
    rdfs:comment "A dosing event." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:AnalysisDataset a owl:Class ;
    rdfs:label "Analysis Dataset (ADaM)" ;
    rdfs:comment "An ADaM analysis dataset (e.g. ADSL, ADAE). Must declare prov:wasDerivedFrom its source so any result built on it is reproducible to source." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:Attestation a owl:Class ;
    rdfs:label "Attestation" ;
    rdfs:comment "A sworn, non-repudiable statement; the write-path that creates delegation/consent assertions." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:CRO a owl:Class ;
    rdfs:label "CRO" ;
    rdfs:comment "A contract research organization the sponsor delegates trial conduct to." ;
    rdfs:subClassOf hcls:Organization .

cr:CSR a owl:Class ;
    rdfs:label "Clinical Study Report" ;
    rdfs:comment "The definitive summary of a study's results (CSR)." ;
    rdfs:subClassOf top:Evidence .

cr:Cohort a owl:Class ;
    rdfs:label "Cohort" ;
    rdfs:comment "A group of subjects sharing a dosing or treatment assignment." ;
    rdfs:subClassOf top:Scope .

cr:CoverageAnalysis a owl:Class ;
    rdfs:label "Coverage Analysis (MCA)" ;
    rdfs:comment "A Medicare/insurance coverage analysis for study procedures." ;
    rdfs:subClassOf top:Evidence .

cr:DoseLevel a owl:Class ;
    rdfs:label "Dose Level" ;
    rdfs:comment "A dose level in a dose-escalation design." ;
    rdfs:subClassOf top:Scope .

cr:DoseLimitingToxicity a owl:Class ;
    rdfs:label "Dose-Limiting Toxicity" ;
    rdfs:comment "Oncology dose-escalation: a DLT informs the next dose decision." ;
    rdfs:subClassOf cr:AdverseEvent .

cr:IRB a owl:Class ;
    rdfs:label "IRB / IEC" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf hcls:Organization ;
    skos:altLabel "Independent Ethics Committee",
        "Institutional Review Board" ;
    skos:definition "An independent body that reviews and provides ongoing oversight to protect the rights, safety, and well-being of trial participants (paraphrased, ICH E6(R3))." .

cr:InvestigationalProduct a owl:Class ;
    rdfs:label "Investigational Product" ;
    rdfs:comment "The investigational drug or biologic being studied." ;
    rdfs:subClassOf hcls:MedicinalProduct .

cr:ServiceProvider a owl:Class ;
    rdfs:label "Service Provider" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf hcls:Organization ;
    skos:definition "A party to whom a sponsor or investigator transfers specified trial-related duties and functions (paraphrased, ICH E6(R3)). The CRO is a specialized service provider." .

cr:StoppingRule a owl:Class ;
    rdfs:label "Stopping Rule" ;
    rdfs:comment "A safety rule that halts dosing or enrollment when triggered." ;
    rdfs:subClassOf top:Constraint .

cr:activates a owl:ObjectProperty ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:StudySite .

cr:addressesFinding a owl:ObjectProperty ;
    rdfs:domain cr:SafetyAssessment ;
    rdfs:range cr:NonclinicalFinding .

cr:aliquotOf a owl:ObjectProperty ;
    rdfs:label "aliquot of" ;
    rdfs:comment "Partition/aliquot lineage (a kind of prov:wasDerivedFrom)." ;
    rdfs:domain hcls:Specimen ;
    rdfs:range hcls:Specimen ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

cr:analyzedUnder a owl:ObjectProperty ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:StatisticalAnalysisPlan .

cr:anchorDate a owl:DatatypeProperty ;
    rdfs:label "anchor date" ;
    rdfs:comment "The resolved anchor (e.g. the subject's enrollment date) from which target dates are computed." ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range xsd:dateTime .

cr:asSubject a owl:ObjectProperty ;
    rdfs:domain cr:Enrollment ;
    rdfs:range cr:StudySubject .

cr:assessesFactor a owl:ObjectProperty ;
    rdfs:domain cr:RiskAssessment ;
    rdfs:range cr:CriticalToQualityFactor .

cr:atSite a owl:ObjectProperty ;
    rdfs:comment "The site a subject was enrolled at (enables the enroll-after-activation check)." ;
    rdfs:domain cr:Enrollment ;
    rdfs:range cr:StudySite .

cr:atVisit a owl:ObjectProperty ;
    rdfs:label "at visit" ;
    rdfs:comment "The actual visit an assessment was performed within." ;
    rdfs:domain cr:Assessment ;
    rdfs:range cr:Visit .

cr:attestedBy a owl:ObjectProperty ;
    rdfs:label "attested by" ;
    rdfs:range hcls:Person .

cr:basedOnDoseOptimization a owl:ObjectProperty ;
    rdfs:comment "Project Optimus: the proposed Phase 3 dose should rest on dose-optimization work." ;
    rdfs:domain cr:Phase3Design ;
    rdfs:range top:Temporal .

cr:capaStatus a owl:DatatypeProperty ;
    rdfs:label "CAPA status" ;
    rdfs:comment "open | in-progress | closed." ;
    rdfs:domain cr:CAPA .

cr:capaType a owl:DatatypeProperty ;
    rdfs:label "CAPA type" ;
    rdfs:comment "corrective | preventive | corrective-and-preventive." ;
    rdfs:domain cr:CAPA .

cr:capturedDuring a owl:ObjectProperty ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:StudyEvent .

cr:certifiedCopyOf a owl:ObjectProperty ;
    rdfs:label "certified copy of" ;
    rdfs:comment "The source document this certified copy reproduces." ;
    rdfs:domain cr:CertifiedCopy ;
    rdfs:range cr:SourceDocument .

cr:collectedAt a owl:ObjectProperty ;
    rdfs:comment "The StudyEvent (e.g. blood draw) at which a primary specimen was collected." ;
    rdfs:domain hcls:Specimen ;
    rdfs:range cr:StudyEvent .

cr:conductedAt a owl:ObjectProperty ;
    rdfs:domain cr:Study ;
    rdfs:range cr:StudySite .

cr:containsSourceData a owl:ObjectProperty ;
    rdfs:label "contains source data" ;
    rdfs:domain cr:SourceDocument ;
    rdfs:range cr:SourceData .

cr:credentialOf a owl:ObjectProperty ;
    rdfs:domain cr:Credential ;
    rdfs:range hcls:Person .

cr:cta a owl:ObjectProperty ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:ClinicalTrialAgreement .

cr:definedBy a owl:ObjectProperty ;
    rdfs:comment "The value's variable definition (aboutness); decouples value from definition." ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:DataElementDef .

cr:delegate a owl:ObjectProperty ;
    rdfs:domain cr:Delegation ;
    rdfs:range hcls:Person .

cr:delegatedCapability a owl:ObjectProperty ;
    rdfs:domain cr:Delegation ;
    rdfs:range cr:Capability .

cr:delegator a owl:ObjectProperty ;
    rdfs:comment "The responsible agent (PI)." ;
    rdfs:domain cr:Delegation ;
    rdfs:range hcls:Person .

cr:deviationCategory a owl:DatatypeProperty ;
    rdfs:label "deviation category" ;
    rdfs:comment "Materiality: critical | major | minor. Critical/major are significant deviations requiring a CAPA." ;
    rdfs:domain cr:DeviationEvent .

cr:eCRF a owl:Class ;
    rdfs:label "eCRF" ;
    rdfs:comment "Electronic case report form — the data-collection instrument used at the site." ;
    rdfs:subClassOf top:Evidence,
        cr:CaseReportForm .

cr:enrolledPerson a owl:ObjectProperty ;
    rdfs:domain cr:Enrollment ;
    rdfs:range hcls:Person .

cr:exercisesCapability a owl:ObjectProperty ;
    rdfs:label "exercises capability" ;
    rdfs:comment "The capability a performed act requires." ;
    rdfs:range cr:Capability .

cr:flags a owl:ObjectProperty ;
    rdfs:label "flags" ;
    rdfs:comment "The antecedent this leading indicator points at." ;
    rdfs:domain cr:RiskSignal ;
    rdfs:range cr:DeviationAntecedent .

cr:forStudySite a owl:ObjectProperty ;
    rdfs:label "for study site" ;
    rdfs:range cr:StudySite .

cr:forSubject a owl:ObjectProperty ;
    rdfs:label "for subject" ;
    rdfs:range cr:StudySubject .

cr:fromService a owl:ObjectProperty ;
    rdfs:domain cr:AssayResult ;
    rdfs:range cr:AnalysisService .

cr:fromState a owl:DatatypeProperty ;
    rdfs:label "from state" ;
    rdfs:domain cr:CustodyEvent .

cr:fromTimeline a owl:ObjectProperty ;
    rdfs:label "from timeline" ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range cr:ScheduleTimeline .

cr:hasArm a owl:ObjectProperty ;
    rdfs:domain cr:Study ;
    rdfs:range cr:Arm .

cr:hasAuditTrail a owl:ObjectProperty ;
    rdfs:label "has audit trail" ;
    rdfs:comment "Links an essential record / source data to its audit trail (ALCOA++ reconstructable)." ;
    rdfs:domain top:Evidence ;
    rdfs:range cr:AuditTrail .

cr:hasBriefingBook a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:BriefingBook .

cr:hasEligibilityCriterion a owl:ObjectProperty ;
    rdfs:domain cr:ProtocolVersion ;
    rdfs:range cr:EligibilityCriterion .

cr:hasEndpoint a owl:ObjectProperty ;
    rdfs:domain cr:Study ;
    rdfs:range cr:Endpoint .

cr:hasItem a owl:ObjectProperty ;
    rdfs:domain cr:ItemGroup ;
    rdfs:range cr:DataElementDef .

cr:hasItemGroup a owl:ObjectProperty ;
    rdfs:domain cr:CaseReportForm ;
    rdfs:range cr:ItemGroup .

cr:hasPlannedActivity a owl:ObjectProperty ;
    rdfs:label "has planned activity" ;
    rdfs:domain cr:PlannedEncounter ;
    rdfs:range cr:PlannedActivity .

cr:hasPlannedEncounter a owl:ObjectProperty ;
    rdfs:label "has planned encounter" ;
    rdfs:domain cr:ScheduleTimeline ;
    rdfs:range cr:PlannedEncounter .

cr:hasPlannedVisit a owl:ObjectProperty ;
    rdfs:label "has planned visit" ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range cr:PlannedVisit .

cr:hasProtocolVersion a owl:ObjectProperty ;
    rdfs:domain cr:Study ;
    rdfs:range cr:ProtocolVersion .

cr:hasQuestion a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:RegulatoryQuestion .

cr:hasRiskRegister a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:RiskRegister .

cr:identifiedIn a owl:ObjectProperty ;
    rdfs:domain cr:NonclinicalFinding ;
    rdfs:range cr:GLPToxReport .

cr:identifiesAntecedent a owl:ObjectProperty ;
    rdfs:label "identifies antecedent" ;
    rdfs:comment "Links an RBQM risk assessment to the latent condition it identifies (integration with the RBQM module)." ;
    rdfs:domain cr:RiskAssessment ;
    rdfs:range cr:DeviationAntecedent .

cr:inItemGroup a owl:ObjectProperty ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:ItemGroup .

cr:intoStudy a owl:ObjectProperty ;
    rdfs:domain cr:Enrollment ;
    rdfs:range cr:Study .

cr:irbApproval a owl:ObjectProperty ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:IRBApproval .

cr:manifestsAs a owl:ObjectProperty ;
    rdfs:label "manifests as" ;
    rdfs:comment "The deviation event this antecedent produced under load." ;
    rdfs:domain cr:DeviationAntecedent ;
    rdfs:range cr:DeviationEvent .

cr:measuresEndpoint a owl:ObjectProperty ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:Endpoint .

cr:meetingType a owl:DatatypeProperty ;
    rdfs:label "meeting type" ;
    rdfs:domain cr:RegulatoryInteraction .

cr:mitigates a owl:ObjectProperty ;
    rdfs:domain cr:MitigationPlan ;
    rdfs:range cr:RiskAssessment .

cr:monitoringStrategy a owl:DatatypeProperty ;
    rdfs:label "monitoring strategy" ;
    rdfs:domain cr:MitigationPlan .

cr:odmOID a owl:DatatypeProperty ;
    rdfs:label "ODM OID" ;
    rdfs:comment "CDISC ODM OID for interoperability." .

cr:ofProtocolVersion a owl:ObjectProperty ;
    rdfs:label "of protocol version" ;
    rdfs:domain cr:ScheduleTimeline ;
    rdfs:range cr:ProtocolVersion .

cr:offsetDays a owl:DatatypeProperty ;
    rdfs:label "offset (days)" ;
    rdfs:domain cr:Timing ;
    rdfs:range xsd:decimal .

cr:offsetHours a owl:DatatypeProperty ;
    rdfs:label "offset (hours)" ;
    rdfs:comment "Sub-visit timing offset in hours (e.g. bloods 2h after the ECG)." ;
    rdfs:domain cr:Timing ;
    rdfs:range xsd:decimal .

cr:onForm a owl:ObjectProperty ;
    rdfs:domain cr:ItemGroup ;
    rdfs:range cr:CaseReportForm .

cr:onSample a owl:ObjectProperty ;
    rdfs:label "on sample" ;
    rdfs:range hcls:Specimen .

cr:overseesConductOf a owl:ObjectProperty ;
    rdfs:label "oversees conduct of" ;
    rdfs:comment "Sponsor oversight accountability for the trial (E6(R3) sponsor responsibility, as a relationship)." ;
    rdfs:domain cr:Sponsor ;
    rdfs:range cr:Study .

cr:perEstimand a owl:ObjectProperty ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:Estimand .

cr:performedBy a owl:ObjectProperty ;
    rdfs:label "performed by" ;
    rdfs:range hcls:Person .

cr:phiClassification a owl:DatatypeProperty ;
    rdfs:label "PHI classification" ;
    rdfs:comment "NotPHI | LimitedPHI | FullPHI | Restricted (drives ETL masking)." ;
    rdfs:domain cr:DataElementDef .

cr:placedOn a owl:ObjectProperty ;
    rdfs:domain cr:ClinicalHold ;
    rdfs:range cr:INDApplication .

cr:precedes a owl:ObjectProperty ;
    rdfs:label "precedes" ;
    rdfs:comment "Ordering-only constraint: this activity must occur before another, independent of clock timing (e.g. QS2 before ECG)." ;
    rdfs:domain cr:PlannedActivity ;
    rdfs:range cr:PlannedActivity .

cr:producedAgreement a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:RegulatoryAgreement .

cr:projectsEncounter a owl:ObjectProperty ;
    rdfs:label "projects encounter" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range cr:PlannedEncounter .

cr:proposedPosition a owl:DatatypeProperty ;
    rdfs:label "proposed position" ;
    rdfs:domain cr:RegulatoryQuestion .

cr:proposesDesign a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:Phase3Design .

cr:queryOn a owl:ObjectProperty ;
    rdfs:label "query on" ;
    rdfs:comment "The entity the query is anchored to (observation, event, form, subject...)." ;
    rdfs:domain cr:Query .

cr:realizes a owl:ObjectProperty ;
    rdfs:label "realizes" ;
    rdfs:comment "Links an actual execution event (cr:Visit, cr:Assessment) to the planned node it fulfils — the join for planned-vs-actual reconciliation." .

cr:recordedInTMF a owl:ObjectProperty ;
    rdfs:label "recorded in TMF" ;
    rdfs:domain cr:EssentialRecord ;
    rdfs:range cr:TrialMasterFile .

cr:relativeTo a owl:ObjectProperty ;
    rdfs:label "relative to" ;
    rdfs:comment "The anchor the offset is measured from: another planned node, or an anchor-event type (e.g. the enrollment act)." ;
    rdfs:domain cr:Timing .

cr:repeatIntervalDays a owl:DatatypeProperty ;
    rdfs:label "repeat interval (days)" ;
    rdfs:domain cr:RepeatingPlannedActivity ;
    rdfs:range xsd:decimal .

cr:repeatUntilDay a owl:DatatypeProperty ;
    rdfs:label "repeat until (study day)" ;
    rdfs:domain cr:RepeatingPlannedActivity ;
    rdfs:range xsd:integer .

cr:replyTo a owl:ObjectProperty ;
    rdfs:comment "Threaded discrepancy conversation (parent-child)." ;
    rdfs:domain cr:Query ;
    rdfs:range cr:Query .

cr:reportsEvent a owl:ObjectProperty ;
    rdfs:domain cr:SafetyReport ;
    rdfs:range cr:SeriousAdverseEvent .

cr:requestsService a owl:ObjectProperty ;
    rdfs:domain cr:AnalysisRequest ;
    rdfs:range cr:AnalysisService .

cr:requiresCredential a owl:ObjectProperty ;
    rdfs:domain cr:Delegation ;
    rdfs:range cr:Credential .

cr:resolutionStatus a owl:DatatypeProperty ;
    rdfs:label "resolution status" ;
    rdfs:domain cr:Query .

cr:riskLevel a owl:DatatypeProperty ;
    rdfs:label "risk level" ;
    rdfs:domain cr:RiskAssessment .

cr:riskScore a owl:DatatypeProperty ;
    rdfs:domain cr:RiskAssessment ;
    rdfs:range xsd:decimal .

cr:scheduleForSubject a owl:ObjectProperty ;
    rdfs:label "schedule for subject" ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range cr:StudySubject .

cr:sdvIntensity a owl:DatatypeProperty ;
    rdfs:comment "Fraction of data source-verified (1.0 = 100% SDV; reduced for low-risk)." ;
    rdfs:domain cr:MitigationPlan ;
    rdfs:range xsd:decimal .

cr:sdvStatus a owl:DatatypeProperty ;
    rdfs:label "SDV status" ;
    rdfs:domain cr:ClinicalObservation .

cr:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:domain cr:Query .

cr:siv a owl:ObjectProperty ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:SiteInitiationVisit .

cr:specimen a owl:ObjectProperty ;
    rdfs:domain cr:CustodyEvent ;
    rdfs:range hcls:Specimen .

cr:sponsorAwareAt a owl:DatatypeProperty ;
    rdfs:label "sponsor aware at" ;
    rdfs:domain cr:SeriousAdverseEvent ;
    rdfs:range xsd:dateTime .

cr:sponsoredBy a owl:ObjectProperty ;
    rdfs:domain cr:Study ;
    rdfs:range cr:Sponsor .

cr:submittedAt a owl:DatatypeProperty ;
    rdfs:label "submitted at" ;
    rdfs:domain cr:SafetyReport ;
    rdfs:range xsd:dateTime .

cr:targetAccrual a owl:DatatypeProperty ;
    rdfs:label "target accrual" ;
    rdfs:domain cr:StudySite ;
    rdfs:range xsd:integer .

cr:targetDate a owl:DatatypeProperty ;
    rdfs:label "target date" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime .

cr:term_ALCOAplus a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:AuditTrail ;
    skos:definition "Data-integrity expectations: attributable, legible, contemporaneous, original, accurate, plus complete, consistent, enduring, available (paraphrased, ICH E6(R3) data governance). Realized in TOP by the bitemporal + PROV envelope." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "ALCOA++" .

cr:term_Auditor a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:audits ;
    skos:definition "A person conducting a systematic, independent examination of trial activities and documents (paraphrased, ICH E6(R3))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Auditor" .

cr:term_Investigator a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:principalInvestigator ;
    skos:definition "The person responsible for the conduct of the trial at a trial site (paraphrased, ICH E6(R3))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Investigator" .

cr:term_Monitor a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:monitors ;
    skos:definition "A person who oversees the progress of the trial and that it is conducted, recorded, and reported per protocol, SOPs, GCP, and regulation (paraphrased, ICH E6(R3))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Monitor" .

cr:term_QualityByDesign a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:CriticalToQualityFactor ;
    skos:definition "Building quality into trial design and conduct by focusing on factors critical to quality (paraphrased, ICH E6(R3)/E8(R1))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Quality by Design" .

cr:threatens a owl:ObjectProperty ;
    rdfs:label "threatens" ;
    rdfs:comment "The critical-to-quality factor this latent condition endangers." ;
    rdfs:domain cr:DeviationAntecedent ;
    rdfs:range cr:CriticalToQualityFactor .

cr:timing a owl:ObjectProperty ;
    rdfs:label "timing" ;
    rdfs:comment "The relative-timing rule positioning a planned encounter or activity." ;
    rdfs:range cr:Timing .

cr:timingType a owl:DatatypeProperty ;
    rdfs:label "timing type" ;
    rdfs:comment "before | after | fixed — the sense of the offset relative to the anchor." ;
    rdfs:domain cr:Timing .

cr:toState a owl:DatatypeProperty ;
    rdfs:label "to state" ;
    rdfs:domain cr:CustodyEvent .

cr:tracesToNonclinical a owl:ObjectProperty ;
    rdfs:domain cr:INDApplication ;
    rdfs:range cr:GLPToxReport .

cr:triggers a owl:ObjectProperty ;
    rdfs:label "triggers" ;
    rdfs:comment "The corrective/preventive action this deviation triggered." ;
    rdfs:domain cr:DeviationEvent ;
    rdfs:range cr:CAPA .

cr:underDelegation a owl:ObjectProperty ;
    rdfs:label "under delegation" ;
    rdfs:comment "Links a performed act to the delegation authorizing it (delegation invariant)." ;
    rdfs:range cr:Delegation .

cr:verifiedBy a owl:ObjectProperty ;
    rdfs:comment "The monitor who source-verified the value (SDV)." ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range hcls:Person .

cr:window a owl:ObjectProperty ;
    rdfs:label "window" ;
    rdfs:domain cr:Timing ;
    rdfs:range cr:Window .

cr:windowEnd a owl:DatatypeProperty ;
    rdfs:label "window end" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime .

cr:windowLowerDays a owl:DatatypeProperty ;
    rdfs:label "window lower (days)" ;
    rdfs:domain cr:Window ;
    rdfs:range xsd:decimal .

cr:windowStart a owl:DatatypeProperty ;
    rdfs:label "window start" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime .

cr:windowUpperDays a owl:DatatypeProperty ;
    rdfs:label "window upper (days)" ;
    rdfs:domain cr:Window ;
    rdfs:range xsd:decimal .

<https://top.scientix.ai/cr/v1/gcp> a owl:Ontology ;
    rdfs:label "TOP CR — ICH E6(R3) GCP definitional layer" ;
    dcterms:rights "Independent derivative adaptation of the ICH E6(R3) Guideline. The classes, properties, and SKOS concepts here are an adaptation (structure + paraphrased definitions), not a reproduction. NOT endorsed or sponsored by ICH. The original ICH E6(R3) document is copyright © ICH." ;
    dcterms:source "ICH E6(R3) Good Clinical Practice (Step 4, adopted January 2025): Principles, Glossary, and Annex 1 (interventional trials). Annex 2 (additional/non-traditional data sources) is NOT modeled in this version." ;
    rdfs:comment "Changes made: ICH E6(R3) terms are reorganized into an OWL/SKOS structure, definitions are paraphrased, and obligations are expressed as SHACL shapes rather than encoded text. Each derived term carries rdfs:isDefinedBy the ICH efficacy-guidelines source." .

cx: a owl:Ontology ;
    rdfs:label "TOP crosswalk vocabulary (SSSOM-aligned)" ;
    rdfs:comment "OWNED, provenance-tagged crosswalks from TOP/CR-core to external ontologies. Aligns to SSSOM slots (subject_id/predicate_id/object_id/mapping_justification/confidence/author_id/mapping_date); an SSSOM TSV is an edge projection of these. Crosswalks are assertions WE own and curate, never imports of the external ontology." .

cx:Mapping a owl:Class ;
    rdfs:label "Crosswalk Mapping" ;
    rdfs:comment "A curated, provenanced correspondence from a TOP term to an external ontology term." ;
    rdfs:subClassOf top:Evidence .

cx:author a owl:ObjectProperty ;
    rdfs:label "author id" ;
    rdfs:comment "The curator/agent IRI (SSSOM author_id)." .

cx:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:range xsd:decimal .

cx:justification a owl:ObjectProperty ;
    rdfs:label "mapping justification" ;
    rdfs:comment "A semapv justification IRI (e.g. ManualMappingCuration)." .

cx:mappingDate a owl:DatatypeProperty ;
    rdfs:label "mapping date" ;
    rdfs:range xsd:date .

cx:objectId a owl:ObjectProperty ;
    rdfs:label "object id" ;
    rdfs:comment "The external ontology term (right side)." .

cx:predicateId a owl:ObjectProperty ;
    rdfs:label "predicate id" ;
    rdfs:comment "SKOS mapping predicate." .

cx:retrievedFrom a owl:DatatypeProperty ;
    rdfs:label "retrieved from" ;
    rdfs:comment "The primary source the target IRI was verified against (URL + retrieval date)." .

cx:subjectId a owl:ObjectProperty ;
    rdfs:label "subject id" ;
    rdfs:comment "The TOP/CR-core term (left side)." .

cx:verificationStatus a owl:DatatypeProperty ;
    rdfs:label "verification status" ;
    rdfs:comment "verified | unverified | deprecated — whether the target IRI was confirmed against a primary source." .

hcls: a owl:Ontology ;
    rdfs:label "HCLS-core" ;
    rdfs:comment "Mid-layer specializing TOP Core for entities that recur across >=2 HCLS domains (clinical research, hospital, manufacturing, pharmacovigilance, RWE, commercialization). Seeded minimally; grows by promotion (rule of three). Standards projection target: FHIR, OMOP." .

hcls:Condition a owl:Class ;
    rdfs:label "Condition" ;
    rdfs:comment "A diagnosed state of a Person." ;
    rdfs:subClassOf top:Outcome .

hcls:Lot a owl:Class ;
    rdfs:label "Lot" ;
    rdfs:comment "A manufactured batch/lot; the primary join to the manufacturing domain." ;
    rdfs:subClassOf top:Resource .

hcls:Practitioner a owl:Class ;
    rdfs:label "Practitioner" ;
    rdfs:comment "A healthcare professional." ;
    rdfs:subClassOf hcls:Person .

hcls:Substance a owl:Class ;
    rdfs:label "Substance" ;
    rdfs:comment "A chemical or biological substance." ;
    rdfs:subClassOf top:Resource .

hcls:affiliatedWith a owl:ObjectProperty ;
    rdfs:label "affiliated with" ;
    rdfs:domain hcls:Person ;
    rdfs:range hcls:Organization .

hcls:collectedFrom a owl:ObjectProperty ;
    rdfs:label "collected from" ;
    rdfs:domain hcls:Specimen ;
    rdfs:range hcls:Person .

hcls:locatedAt a owl:ObjectProperty ;
    rdfs:label "located at" ;
    rdfs:domain hcls:Organization ;
    rdfs:range hcls:HealthcareFacility .

ns1:CAPALog a ns1:TMFArtifactType ;
    rdfs:label "CAPA Log" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "CAPA Log" ;
    ns1:records cr:CAPA .

ns1:DelegationOfAuthorityLog a ns1:TMFArtifactType ;
    rdfs:label "Delegation of Authority Log" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Delegation of Authority Log" ;
    ns1:records cr:Delegation .

ns1:InformedConsentForm a ns1:TMFArtifactType ;
    rdfs:label "Informed Consent Form" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Informed Consent Form" ;
    ns1:documents cr:InformedConsent .

ns1:MonitoringPlan a ns1:TMFArtifactType ;
    rdfs:label "Monitoring Plan" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Monitoring Plan" ;
    ns1:documents cr:MitigationPlan,
        cr:RiskAssessment .

ns1:Protocol a ns1:TMFArtifactType ;
    rdfs:label "Protocol" ;
    skos:broader ns1:Zone_CentralTrialDocs ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Protocol" ;
    ns1:defines cr:CriticalToQualityFactor,
        cr:EligibilityCriterion,
        cr:Endpoint .

ns1:ProtocolDeviationLog a ns1:TMFArtifactType ;
    rdfs:label "Protocol Deviation Log" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Protocol Deviation Log" ;
    ns1:records cr:DeviationEvent .

ns1:SAEReport a ns1:TMFArtifactType ;
    rdfs:label "SAE Report" ;
    skos:broader ns1:Zone_SafetyReporting ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "SAE Report" ;
    ns1:records cr:SafetyReport .

ns1:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:comment "The artifact establishes/specifies the entity (e.g. a Protocol defines the CtQ factors)." ;
    rdfs:subPropertyOf ns1:concerns .

ns1:documents a owl:ObjectProperty ;
    rdfs:label "documents" ;
    rdfs:comment "The artifact describes/evidences the entity (e.g. a Monitoring Plan documents the mitigation plan)." ;
    rdfs:subPropertyOf ns1:concerns .

ns1:records a owl:ObjectProperty ;
    rdfs:label "records" ;
    rdfs:comment "The artifact is a running log of the entity's instances (e.g. a Deviation Log records deviation events)." ;
    rdfs:subPropertyOf ns1:concerns .

top:Location a owl:Class ;
    rdfs:label "Location" ;
    rdfs:comment "A place or spatial/jurisdictional region." ;
    rdfs:subClassOf top:Core .

<https://top.scientix.ai/cr/v1> a owl:Ontology ;
    rdfs:label "TOP — Clinical Research Reference Graph" ;
    dcterms:bibliographicCitation "ScientixAI (2026). TOP — Clinical Research Reference Graph (v1). The Ontology Project." ;
    dcterms:contributor "TOP Clinical Research working group" ;
    dcterms:creator "ScientixAI" ;
    dcterms:description "An inheritable, provenance-native, bitemporal reference knowledge graph for the clinical-research lifecycle (Pre-IND through End-of-Phase-2, plus site operations). The founding domain of TOP (The Ontology Project)." ;
    dcterms:issued "2026-06-22"^^xsd:date ;
    dcterms:license <https://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:publisher "ScientixAI" ;
    dcterms:rights "Includes an independent derivative adaptation of the ICH E6(R3) Good Clinical Practice Guideline (Step 4, 2025; Principles, Glossary, Annex 1) — paraphrased, not endorsed or sponsored by ICH, original copyright © ICH. TMF artifact types align by name to the DIA TMF Reference Model (licensed; no text reproduced). See the repository NOTICE file." ;
    dcterms:title "TOP — Clinical Research Reference Graph" ;
    owl:versionIRI <https://top.scientix.ai/cr/v1> ;
    owl:versionInfo "v1" .

cr:AnalysisRequest a owl:Class ;
    rdfs:label "Analysis Request" ;
    rdfs:comment "Binds an AnalysisService to a Specimen (the order)." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:Arm a owl:Class ;
    rdfs:label "Arm" ;
    rdfs:comment "A treatment arm of the study." ;
    rdfs:subClassOf top:Scope .

cr:AssayResult a owl:Class ;
    rdfs:label "Assay Result" ;
    rdfs:comment "A measured laboratory result on a Specimen, joined to the StudySubject." ;
    rdfs:subClassOf top:ProvenancedEntity,
        hcls:Observation .

cr:Assessment a owl:Class ;
    rdfs:label "Assessment" ;
    rdfs:comment "A clinical assessment performed during the trial." ;
    rdfs:subClassOf top:Temporal .

cr:BriefingBook a owl:Class ;
    rdfs:label "Briefing Book" ;
    rdfs:comment "A dossier submitted to the regulator ahead of a meeting (Pre-IND / EOP2)." ;
    rdfs:subClassOf top:Evidence .

cr:CertifiedCopy a owl:Class ;
    rdfs:label "Certified Copy" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity ;
    skos:definition "A copy of original information verified (dated/signed or generated by a validated process) as a complete and accurate copy (paraphrased, ICH E6(R3))." .

cr:ClinicalHold a owl:Class ;
    rdfs:label "Clinical Hold" ;
    rdfs:comment "An FDA order that halts or prevents a trial from proceeding." ;
    rdfs:subClassOf top:Outcome .

cr:ClinicalTrialAgreement a owl:Class ;
    rdfs:label "Clinical Trial Agreement (CTA)" ;
    rdfs:comment "Executed site contract (observedAt = execution date)." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:Estimand a owl:Class ;
    rdfs:label "Estimand" ;
    rdfs:comment "The precise treatment-effect definition a result must trace to (overstatement guard)." ;
    rdfs:subClassOf top:Scope .

cr:IRBApproval a owl:Class ;
    rdfs:label "IRB/IEC Approval" ;
    rdfs:comment "Local IRB/IEC approval (observedAt = approval date)." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:InformedConsent a owl:Class ;
    rdfs:label "Informed Consent" ;
    rdfs:comment "The act of obtaining a subject's informed consent." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:RegulatoryAgreement a owl:Class ;
    rdfs:label "Regulatory Agreement" ;
    rdfs:comment "A binding FDA agreement (a commitment the program is held to)." ;
    rdfs:subClassOf top:Constraint .

cr:RiskRegister a owl:Class ;
    rdfs:label "Risk Register" ;
    rdfs:comment "A record of risks and decisions captured at a regulatory gate." ;
    rdfs:subClassOf top:Evidence .

cr:RiskSignal a owl:Class ;
    rdfs:label "Risk Signal" ;
    rdfs:comment "A leading indicator (a trend or metric) that flags a deviation antecedent before it manifests — the signal a provenance-native graph can hold as low-trust, provenance-tagged evidence." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:SafetyAssessment a owl:Class ;
    rdfs:label "Safety Assessment" ;
    rdfs:comment "A clinical-protocol safety monitoring provision (e.g. CBC monitoring + dose-hold)." ;
    rdfs:subClassOf top:Constraint .

cr:SiteInitiationVisit a owl:Class ;
    rdfs:label "Site Initiation Visit (SIV)" ;
    rdfs:comment "The visit that prepares and activates a site for enrollment." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:SourceData a owl:Class ;
    rdfs:label "Source Data" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity ;
    skos:definition "The original recorded information, and certified copies of it, needed to reconstruct and evaluate the trial (paraphrased, ICH E6(R3))." .

cr:StatisticalAnalysisPlan a owl:Class ;
    rdfs:label "Statistical Analysis Plan" ;
    rdfs:comment "The pre-specified plan for analyzing the study's data." ;
    rdfs:subClassOf top:Evidence .

cr:TrialMasterFile a owl:Class ;
    rdfs:label "Trial Master File" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence ;
    skos:altLabel "TMF" ;
    skos:definition "The collection of essential records that allows the conduct of the trial and the quality of the data to be evaluated (paraphrased, ICH E6(R3))." .

cr:Visit a owl:Class ;
    rdfs:label "Trial Visit" ;
    rdfs:comment "A protocol visit — a kind of study event." ;
    rdfs:subClassOf top:Temporal,
        cr:StudyEvent .

cr:audits a owl:ObjectProperty ;
    rdfs:label "audits" ;
    rdfs:comment "Independent audit of trial conduct/records (the auditor function as a relationship)." .

cr:monitors a owl:ObjectProperty ;
    rdfs:label "monitors" ;
    rdfs:comment "Monitoring oversight of a site (the monitor function as a relationship)." ;
    rdfs:range cr:StudySite .

cr:principalInvestigator a owl:ObjectProperty ;
    rdfs:label "principal investigator" ;
    rdfs:comment "Role-as-relationship; bitemporal at instance level." ;
    rdfs:domain cr:StudySite ;
    rdfs:range hcls:Person .

hcls:HealthcareFacility a owl:Class ;
    rdfs:label "Healthcare Facility" ;
    rdfs:comment "A physical place where care or research is conducted." ;
    rdfs:subClassOf top:Location .

hcls:MedicinalProduct a owl:Class ;
    rdfs:label "Medicinal Product" ;
    rdfs:comment "A medicinal product (drug or biologic)." ;
    rdfs:subClassOf top:Resource .

ns1:Zone_CentralTrialDocs a skos:Concept ;
    skos:prefLabel "Central Trial Documents" ;
    skos:topConceptOf ns1:TMFReferenceModel .

ns1:Zone_SafetyReporting a skos:Concept ;
    skos:prefLabel "Safety Reporting" ;
    skos:topConceptOf ns1:TMFReferenceModel .

cr:AdverseEvent a owl:Class ;
    rdfs:label "Adverse Event" ;
    rdfs:comment "An untoward medical occurrence in a trial subject." ;
    rdfs:subClassOf top:Outcome,
        top:ProvenancedEntity .

cr:AnalysisService a owl:Class ;
    rdfs:label "Analysis Service" ;
    rdfs:comment "Catalog definition of a test/assay (e.g. a biomarker assay)." ;
    rdfs:subClassOf top:Evidence .

cr:AuditTrail a owl:Class ;
    rdfs:label "Audit Trail" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity ;
    skos:definition "Secure, computer- or paper-generated documentation that allows reconstruction of the course of events around a record (paraphrased, ICH E6(R3)). In TOP, the bitemporal + PROV envelope realizes this by construction." .

cr:Capability a owl:Class ;
    rdfs:label "Capability" ;
    rdfs:comment "A delegable permission to perform a trial task (e.g. obtain informed consent)." ;
    rdfs:subClassOf top:Constraint .

cr:Credential a owl:Class ;
    rdfs:label "Credential" ;
    rdfs:comment "An attested qualification/training record that gates a delegated capability." ;
    rdfs:subClassOf top:Evidence .

cr:EligibilityCriterion a owl:Class ;
    rdfs:label "Eligibility Criterion" ;
    rdfs:comment "An inclusion/exclusion rule defining who may enroll." ;
    rdfs:subClassOf top:Constraint .

cr:EssentialRecord a owl:Class ;
    rdfs:label "Essential Record" ;
    rdfs:comment "The class the TMF artifact-type scheme (tmf:) classifies the documents of." ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity ;
    skos:altLabel "Essential Document" ;
    skos:definition "A record that, individually or collectively, permits evaluation of the conduct of a trial and the quality of the data produced (paraphrased, ICH E6(R3))." .

cr:GLPToxReport a owl:Class ;
    rdfs:label "GLP Toxicology Report" ;
    rdfs:comment "A GLP toxicology study report supporting safe human dosing." ;
    rdfs:subClassOf top:Evidence .

cr:INDApplication a owl:Class ;
    rdfs:label "IND Application" ;
    rdfs:comment "The submission authorizing human dosing; starts a 30-day review clock (top:observedAt = submission) after which trials may proceed unless a clinical hold is placed." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:NonclinicalFinding a owl:Class ;
    rdfs:label "Nonclinical Finding" ;
    rdfs:comment "An observed animal toxicity/finding that the clinical protocol must address." ;
    rdfs:subClassOf top:Outcome .

cr:Phase3Design a owl:Class ;
    rdfs:label "Proposed Phase 3 Design" ;
    rdfs:comment "A proposed Phase 3 trial design taken to the EOP2 meeting." ;
    rdfs:subClassOf top:Scope .

cr:RegulatoryQuestion a owl:Class ;
    rdfs:label "Regulatory Question" ;
    rdfs:comment "A briefing-book question; should carry a proposed position (FDA punishes vague questions)." ;
    rdfs:subClassOf top:Evidence .

cr:RepeatingPlannedActivity a owl:Class ;
    rdfs:label "Repeating Planned Activity" ;
    rdfs:comment "A planned activity that recurs on an interval until a stop condition (e.g. a daily participant diary until Day N; dosing every 7 days)." ;
    rdfs:subClassOf cr:PlannedActivity .

cr:SeriousAdverseEvent a owl:Class ;
    rdfs:label "Serious Adverse Event" ;
    rdfs:comment "An adverse event meeting seriousness criteria (expedited reporting)." ;
    rdfs:subClassOf cr:AdverseEvent .

cr:SourceDocument a owl:Class ;
    rdfs:label "Source Document" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf cr:EssentialRecord ;
    skos:definition "The original document/record holding source data (paraphrased, ICH E6(R3))." .

cr:Sponsor a owl:Class ;
    rdfs:label "Sponsor" ;
    rdfs:comment "The organization that initiates and is accountable for the trial." ;
    rdfs:subClassOf hcls:Organization .

hcls:Observation a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "An information artifact recording a measured value; refersTo the Person/Specimen it is about." ;
    rdfs:subClassOf top:Evidence .

ns1:Zone_SiteManagement a skos:Concept ;
    skos:prefLabel "Site Management" ;
    skos:topConceptOf ns1:TMFReferenceModel .

top:Agent a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "Something that acts or bears responsibility (person, organization, system)." ;
    rdfs:subClassOf top:Core .

cr:CaseReportForm a owl:Class ;
    rdfs:label "Case Report Form" ;
    rdfs:comment "A case report form — a collection of item groups capturing a visit's data." ;
    rdfs:subClassOf top:Evidence .

cr:CustodyEvent a owl:Class ;
    rdfs:label "Custody Event" ;
    rdfs:comment "A specimen state transition (SampleDue->Received->ToBeVerified->Verified->Published) — chain of custody." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:DataElementDef a owl:Class ;
    rdfs:label "Data Element Definition" ;
    rdfs:comment "A variable DEFINITION (ItemOID), independent of any form version; carries a PHI classification." ;
    rdfs:subClassOf top:Evidence .

cr:Endpoint a owl:Class ;
    rdfs:label "Endpoint" ;
    rdfs:comment "A defined outcome measure the study evaluates." ;
    rdfs:subClassOf top:Scope .

cr:EndpointResult a owl:Class ;
    rdfs:label "Endpoint Result" ;
    rdfs:comment "A measured efficacy/safety result; must trace to its endpoint, estimand, and SAP." ;
    rdfs:subClassOf top:Outcome,
        top:ProvenancedEntity .

cr:PlannedEncounter a owl:Class ;
    rdfs:label "Planned Encounter" ;
    rdfs:comment "A planned visit slot on the timeline (USDM Encounter). Positioned by a cr:Timing relative to an anchor; actual cr:Visits are reconciled against it." ;
    rdfs:subClassOf top:Constraint .

cr:ProtocolVersion a owl:Class ;
    rdfs:label "Protocol Version" ;
    rdfs:comment "An effective-dated protocol version (bitemporal): which version was valid for a given visit." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:SafetyReport a owl:Class ;
    rdfs:label "Safety Report" ;
    rdfs:comment "Expedited report of an SAE to the regulator." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:ScheduleTimeline a owl:Class ;
    rdfs:label "Schedule Timeline" ;
    rdfs:comment "The planned Schedule of Activities for a protocol version, as a timeline of planned encounters and activities. Bitemporal: a protocol amendment supersedes it, so the schedule is reconstructable as-of any date." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:StudyEvent a owl:Class ;
    rdfs:label "Study Event" ;
    rdfs:comment "A scheduled or unscheduled timepoint (StudyEventOID) when data is captured." ;
    rdfs:subClassOf top:Temporal .

cr:StudySubject a owl:Class ;
    rdfs:label "Study Subject" ;
    rdfs:comment "The pseudonymous in-study participant identity. Linked to an hcls:Person via the bitemporal cr:Enrollment act (the sensitive bridge); carries no PII." ;
    rdfs:subClassOf top:Agent .

cr:Window a owl:Class ;
    rdfs:label "Window" ;
    rdfs:comment "An allowed tolerance around a planned time: a lower and an upper offset in days (e.g. [-2 days, +2 days])." ;
    rdfs:subClassOf top:Constraint .

ns1:Zone_TrialManagement a skos:Concept ;
    skos:prefLabel "Trial Management" ;
    skos:topConceptOf ns1:TMFReferenceModel .

ns1:concerns a owl:ObjectProperty ;
    rdfs:label "concerns" ;
    rdfs:comment "The domain class whose instances this artifact type carries (general bridge)." ;
    rdfs:domain ns1:TMFArtifactType ;
    rdfs:range owl:Class .

top:Resource a owl:Class ;
    rdfs:label "Resource" ;
    rdfs:comment "A persistent material or informational thing that is used or produced." ;
    rdfs:subClassOf top:Core .

cr:CAPA a owl:Class ;
    rdfs:label "CAPA" ;
    rdfs:comment "Corrective And Preventive Action — the formal response to a deviation or finding (corrective: fix this occurrence; preventive: stop recurrence). Bitemporal + attested." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:CriticalToQualityFactor a owl:Class ;
    rdfs:label "Critical-to-Quality Factor" ;
    rdfs:comment "A quality-critical aspect of the trial (e.g. primary endpoint integrity, consent validity, SAE reporting)." ;
    rdfs:subClassOf top:Constraint ;
    skos:altLabel "CtQ factor" .

cr:DeviationAntecedent a owl:Class ;
    rdfs:label "Deviation Antecedent" ;
    rdfs:comment "A latent operational condition that predisposes a deviation (e.g. a visit window too tight for the site's staffing). The missing middle between a critical-to-quality factor and the deviation event it manifests as; bitemporal (it exists, and is detected, over time)." ;
    rdfs:subClassOf top:Constraint,
        top:ProvenancedEntity .

cr:DeviationEvent a owl:Class ;
    rdfs:label "Deviation Event" ;
    rdfs:comment "A protocol deviation occurrence (departure from the protocol or GCP). Classified by materiality; significant deviations require a CAPA. Bitemporal + attested." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:Enrollment a owl:Class ;
    rdfs:label "Enrollment" ;
    rdfs:comment "The bitemporal act linking an hcls:Person to a cr:StudySubject in a cr:Study." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:ItemGroup a owl:Class ;
    rdfs:label "Item Group" ;
    rdfs:comment "A logical clustering of items (ItemGroupOID)." ;
    rdfs:subClassOf top:Evidence .

cr:MitigationPlan a owl:Class ;
    rdfs:label "Mitigation Plan" ;
    rdfs:comment "Mitigations for a risk, including the resulting monitoring strategy and SDV intensity." ;
    rdfs:subClassOf top:Constraint .

cr:ParticipantSchedule a owl:Class ;
    rdfs:label "Participant Schedule" ;
    rdfs:comment "The schedule projected for a specific subject from a ScheduleTimeline once an anchor date (e.g. enrollment) is known. Bitemporal: re-projected when the governing protocol version changes." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:PlannedActivity a owl:Class ;
    rdfs:label "Planned Activity" ;
    rdfs:comment "A planned activity within an encounter (USDM ScheduledActivityInstance) — e.g. ECG, blood draw, PRO. Positioned by a cr:Timing and/or an ordering edge (cr:precedes)." ;
    rdfs:subClassOf top:Constraint .

cr:SiteActivation a owl:Class ;
    rdfs:label "Site Activation" ;
    rdfs:comment "The green-light record (observedAt = activated date); must cite IRB approval, executed CTA, and SIV." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

top:Outcome a owl:Class ;
    rdfs:label "Outcome" ;
    rdfs:comment "A result, finding, or state produced by a process." ;
    rdfs:subClassOf top:Core .

cr:ClinicalObservation a owl:Class ;
    rdfs:label "Clinical Observation" ;
    rdfs:comment "A recorded value (ItemData) for a StudySubject at a StudyEvent, defined by a DataElementDef." ;
    rdfs:subClassOf top:ProvenancedEntity,
        hcls:Observation .

cr:E6R3Glossary a skos:ConceptScheme ;
    rdfs:label "ICH E6(R3) glossary (selected terms)" ;
    rdfs:comment "Definitional concepts cited to ICH E6(R3); related to the cr: class/relation that realizes each, where one exists." .

cr:PlannedVisit a owl:Class ;
    rdfs:label "Planned Visit" ;
    rdfs:comment "A projected planned visit for a subject: a target date and a resolved window (start/end dates), against which the actual visit is reconciled." ;
    rdfs:subClassOf top:Constraint .

cr:Query a owl:Class ;
    rdfs:label "Query" ;
    rdfs:comment "A discrepancy note / data query anchored to a data point or other entity; threaded." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:Delegation a owl:Class ;
    rdfs:label "Delegation" ;
    rdfs:comment "PI delegates a Capability to a Person, gated by a Credential, attested. DOA/training logs are projections of this." ;
    rdfs:subClassOf top:ProvenancedEntity,
        top:Temporal .

cr:RegulatoryInteraction a owl:Class ;
    rdfs:label "Regulatory Interaction" ;
    rdfs:comment "Pre-IND / EOP2 meeting." ;
    rdfs:subClassOf top:Temporal .

cr:RiskAssessment a owl:Class ;
    rdfs:label "Risk Assessment" ;
    rdfs:comment "An assessment of risk to a CtQ factor (likelihood/impact/detectability -> level); bitemporal." ;
    rdfs:subClassOf top:Evidence,
        top:ProvenancedEntity .

cr:Timing a owl:Class ;
    rdfs:label "Timing" ;
    rdfs:comment "A relative-timing rule: an offset (days or hours) from an anchor — another node, or an anchor event such as enrollment — with an allowed window. The footnote logic, made explicit." ;
    rdfs:subClassOf top:Constraint .

hcls:Specimen a owl:Class ;
    rdfs:label "Specimen" ;
    rdfs:comment "A biospecimen collected from a Person." ;
    rdfs:subClassOf top:Resource .

top:Scope a owl:Class ;
    rdfs:label "Scope" ;
    rdfs:comment "A bounded context of work (study, arm, population, indication)." ;
    rdfs:subClassOf top:Core .

cr:Study a owl:Class ;
    rdfs:label "Study" ;
    rdfs:comment "A clinical study — the unit of investigation the protocol defines." ;
    rdfs:subClassOf top:Scope .

cr:StudySite a owl:Class ;
    rdfs:label "Study Site" ;
    rdfs:comment "An investigative site conducting the study (an organization at a facility)." ;
    rdfs:subClassOf hcls:Organization .

hcls:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organization — sponsor, CRO, site, central lab, or regulator." ;
    rdfs:subClassOf top:Agent .

top:Core a owl:Class ;
    rdfs:label "Core" ;
    rdfs:comment "The single root of TOP. Everything modeled is, ultimately, a kind of top:Core, and so carries the Universal DNA (identifier + observedAt + status)." .

ns1:TMFArtifactType a owl:Class ;
    rdfs:label "TMF Artifact Type" ;
    rdfs:comment "A kind of trial-master-file document (the document-type binding target)." ;
    rdfs:subClassOf skos:Concept .

hcls:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human. BOUNDARY-ONLY / PII layer: an identifiable Person lives inside the source/site sovereign boundary. Downstream and shareable artifacts must attach to a pseudonymous cr:StudySubject, never to a Person. The only legal Person<->Subject link is the attested Enrollment bridge (cr:enrolledPerson). Clinical data is PSEUDONYMIZED, not anonymized: re-identification is preserved but controlled (safety / emergency unblinding)." ;
    rdfs:subClassOf top:Agent .

ns1:TMFReferenceModel a skos:ConceptScheme ;
    rdfs:label "TOP TMF artifact-type scheme" ;
    rdfs:comment "A SKOS scheme of trial-master-file artifact types, aligned by name to the DIA TMF Reference Model; each artifact type carries content bridges to the domain classes it concerns." .

top:Constraint a owl:Class ;
    rdfs:label "Constraint" ;
    rdfs:comment "A rule, criterion, bound, or commitment that admissibility is judged against." ;
    rdfs:subClassOf top:Core .

top:Temporal a owl:Class ;
    rdfs:label "Temporal" ;
    rdfs:comment "Processes, events, acts, and intervals that unfold in time." ;
    rdfs:subClassOf top:Core .

top:ProvenancedEntity a owl:Class ;
    rdfs:label "Provenanced Entity" ;
    rdfs:comment "Marker for any assertion/entity carrying the bitemporal + PROV envelope." .

top:Evidence a owl:Class ;
    rdfs:label "Evidence" ;
    rdfs:comment "An information artifact that asserts or records something." ;
    rdfs:subClassOf top:Core .

