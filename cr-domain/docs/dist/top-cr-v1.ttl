    hcls:operatesOn cr:StudySite .

cr:CloseStudy a hcls:Action ;
    rdfs:label "Close Study" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ArchivalSubPhase ;
    hcls:operatesOn cr:Study .

cr:CollectSample a hcls:Action ;
    rdfs:label "Collect Sample" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:VisitExecutionSubPhase ;
    hcls:operatesOn cr:ActivityOccurrence .

cr:CompleteCRF a hcls:Action ;
    rdfs:label "Complete CRF" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:CompleteParticipantStudy a hcls:Action ;
    rdfs:label "Complete Participant Study" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:CloseoutPhase ;
    hcls:operatesOn cr:Participant .

cr:CompleteVisit a hcls:Action ;
    rdfs:label "Complete Visit" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:VisitExecutionSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:CreateArm a hcls:Action ;
    rdfs:label "Create Arm" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Arm .

cr:CreateBudget a hcls:Action ;
    rdfs:label "Create Budget" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:StartupPhase ;
    hcls:operatesOn cr:Study .

cr:CreateLog a hcls:Action ;
    rdfs:label "Create Log" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:ActivationSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:CreateMilestone a hcls:Action ;
    rdfs:label "Create Milestone" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:StartupPhase ;
    hcls:operatesOn cr:Study .

cr:CreatePayment a hcls:Action ;
    rdfs:label "Create Payment" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:StudySite .

cr:CreateStudy a hcls:Action ;
    rdfs:label "Create Study" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:EnrollParticipant a hcls:Action ;
    rdfs:label "Enroll Participant" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:RecruitmentSubPhase ;
    hcls:operatesOn cr:Participant .

cr:Estimand a owl:Class ;
    rdfs:label "Estimand" ;
    rdfs:comment "The precise treatment-effect definition a result must trace to (overstatement guard)." ;
    rdfs:subClassOf top:Scope .

cr:EvaluateSafetySignal a hcls:Action ;
    rdfs:label "Evaluate Safety Signal" ;
    hcls:authorizedAgentType cr:PharmacovigilianceSpecialist ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:FinalizeReport a hcls:Action ;
    rdfs:label "Finalize Report" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ReportingSubPhase ;
    hcls:operatesOn cr:CSR .

cr:FollowUpAdverseEvent a hcls:Action ;
    rdfs:label "Follow Up on Adverse Event" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:FollowUpSubPhase a hcls:Phase ;
    rdfs:label "Follow-up" ;
    rdfs:comment "Post-treatment assessments, long-term safety evaluation, survival follow-up, adverse event monitoring through the follow-up window." .

cr:IdentifySafetySignal a hcls:Action ;
    rdfs:label "Identify Safety Signal" ;
    hcls:authorizedAgentType cr:PharmacovigilianceSpecialist ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:InitiateSite a hcls:Action ;
    rdfs:label "Initiate Site (SIV)" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate ;
    hcls:occursIn cr:ActivationSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:IssueSitePayment a hcls:Action ;
    rdfs:label "Issue Site Payment" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:StudySite .

cr:LockBudget a hcls:Action ;
    rdfs:label "Lock Budget" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:StartupPhase ;
    hcls:operatesOn cr:Study .

cr:LockUnlockCRF a hcls:Action ;
    rdfs:label "Lock / Unlock CRF" ;
    hcls:authorizedAgentType cr:DataManager ;
    hcls:occursIn cr:DataAnalysisSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:LogCommunication a hcls:Action ;
    rdfs:label "Log Communication" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:ObtainParticipantConsent a hcls:Action ;
    rdfs:label "Obtain Participant Consent" ;
    hcls:authorizedAgentType cr:Investigator,
        cr:SiteCoordinator ;
    hcls:occursIn cr:RecruitmentSubPhase ;
    hcls:operatesOn cr:InformedConsentAct .

cr:OpenEnrollment a hcls:Action ;
    rdfs:label "Open Enrollment" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:RecruitmentSubPhase ;
    hcls:operatesOn cr:Study .

cr:ProcessPayment a hcls:Action ;
    rdfs:label "Process Payment" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:StudySite .

cr:RebaselineTimeline a hcls:Action ;
    rdfs:label "Rebaseline Timeline" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:ReconcileSAE a hcls:Action ;
    rdfs:label "Reconcile SAE" ;
    hcls:authorizedAgentType cr:PharmacovigilianceSpecialist ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:RefreshGCPTraining a hcls:Action ;
    rdfs:label "Refresh GCP Training" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:ActivationSubPhase ;
    hcls:operatesOn cr:Credential .

cr:RegulatoryAgreement a owl:Class ;
    rdfs:label "Regulatory Agreement" ;
    rdfs:comment "A binding FDA agreement (a commitment the program is held to)." ;
    rdfs:subClassOf top:Constraint .

cr:ReopenQuery a hcls:Action ;
    rdfs:label "Reopen Query" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate,
        cr:DataManager ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:ReportAdverseEvent a hcls:Action ;
    rdfs:label "Report Adverse Event" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:ReportDeviation a hcls:Action ;
    rdfs:label "Report Deviation" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate,
        cr:SiteCoordinator ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:ReportSAE a hcls:Action ;
    rdfs:label "Report SAE" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:RespondToQuery a hcls:Action ;
    rdfs:label "Respond to Query" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:ReviewCRF a hcls:Action ;
    rdfs:label "Review CRF" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:RiskRegister a owl:Class ;
    rdfs:label "Risk Register" ;
    rdfs:comment "A record of risks and decisions captured at a regulatory gate." ;
    rdfs:subClassOf top:Evidence .

cr:SafetyAssessment a owl:Class ;
    rdfs:label "Safety Assessment" ;
    rdfs:comment "A clinical-protocol safety monitoring provision (e.g. CBC monitoring + dose-hold)." ;
    rdfs:subClassOf top:Constraint .

cr:ScheduleVisit a hcls:Action ;
    rdfs:label "Schedule Visit" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:VisitExecutionSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:ScreenParticipant a hcls:Action ;
    rdfs:label "Screen Participant" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:RecruitmentSubPhase ;
    hcls:operatesOn cr:Participant .

cr:SelectSiteForStudy a hcls:Action ;
    rdfs:label "Select Site for Study" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:SiteSelectionSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:SignCRF a hcls:Action ;
    rdfs:label "Sign CRF" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:SiteInitiationVisit a owl:Class ;
    rdfs:label "Site Initiation Visit (SIV)" ;
    rdfs:comment "The visit that prepares and activates a site for enrollment." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:SourceData a owl:Class ;
    rdfs:label "Source Data" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:Versioned ;
    skos:definition "The original recorded information, and certified copies of it, needed to reconstruct and evaluate the trial (paraphrased, ICH E6(R3))." .

cr:StartVisit a hcls:Action ;
    rdfs:label "Start Visit" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:VisitExecutionSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:StatisticalAnalysisPlan a owl:Class ;
    rdfs:label "Statistical Analysis Plan" ;
    rdfs:comment "The pre-specified plan for analyzing the study's data." ;
    rdfs:subClassOf top:Evidence .

cr:SubmitExpeditedReport a hcls:Action ;
    rdfs:label "Submit Expedited Report" ;
    hcls:authorizedAgentType cr:PharmacovigilianceSpecialist ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:TrialMasterFile a owl:Class ;
    rdfs:label "Trial Master File" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence ;
    skos:altLabel "TMF" ;
    skos:definition "The collection of essential records that allows the conduct of the trial and the quality of the data to be evaluated (paraphrased, ICH E6(R3))." .

cr:UpdateAdverseEventDetails a hcls:Action ;
    rdfs:label "Update Adverse Event Details" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:UpdateEnrollmentStatus a hcls:Action ;
    rdfs:label "Update Enrollment Status" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:RecruitmentSubPhase ;
    hcls:operatesOn cr:EnrollmentRecord .

cr:UpdateFCOIDisclosure a hcls:Action ;
    rdfs:label "Update FCOI Disclosure" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:ActivationSubPhase ;
    hcls:operatesOn cr:Credential .

cr:UpdateSAE a hcls:Action ;
    rdfs:label "Update SAE" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:UpdateStudyDetails a hcls:Action ;
    rdfs:label "Update Study Details" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:UpdateTimeline a hcls:Action ;
    rdfs:label "Update Timeline" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:Visit a owl:Class ;
    rdfs:label "Trial Visit" ;
    rdfs:comment "A protocol visit — a kind of study event." ;
    rdfs:subClassOf cr:StudyEvent,
        top:Temporal .

cr:WithdrawParticipant a hcls:Action ;
    rdfs:label "Withdraw Participant" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Participant .

cr:WithdrawalRecord a owl:Class ;
    rdfs:label "Withdrawal Record" ;
    rdfs:comment "One withdrawal or discontinuation event. WITHDRAWN = subject-initiated (CONSENT_WITHDRAWN); DISCONTINUED = investigator-initiated. Distinction is operator-meaningful and preserved in the substrate. SDTM DS: DSDECOD=WITHDRAWAL OF CONSENT / DISCONTINUED / LOST TO FOLLOW-UP." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:aliquotOf a owl:ObjectProperty ;
    rdfs:label "aliquot of" ;
    rdfs:comment "Partition/aliquot lineage (a kind of prov:wasDerivedFrom)." ;
    rdfs:domain hcls:Specimen ;
    rdfs:range hcls:Specimen ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    top:flavor "Additive" .

cr:audits a owl:ObjectProperty ;
    rdfs:label "audits" ;
    rdfs:comment "Independent audit of trial conduct/records (the auditor function as a relationship)." ;
    top:flavor "Additive" .

cr:certifiedCopyOf a owl:ObjectProperty ;
    rdfs:label "certified copy of" ;
    rdfs:comment "The source document this certified copy reproduces." ;
    rdfs:domain cr:CertifiedCopy ;
    rdfs:range cr:SourceDocument ;
    top:flavor "Additive" .

cr:collectedAt a owl:ObjectProperty ;
    rdfs:comment "The StudyEvent (e.g. blood draw) at which a primary specimen was collected." ;
    rdfs:domain hcls:Specimen ;
    rdfs:range cr:StudyEvent ;
    top:flavor "Additive" .

cr:derivedFromCollection a owl:ObjectProperty ;
    rdfs:label "derived from collection" ;
    rdfs:comment "The collection act a result ultimately traces to (lineage back-edge)." ;
    rdfs:domain cr:AssayResult ;
    rdfs:range cr:StudyEvent ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    top:flavor "Additive" .

cr:flags a owl:ObjectProperty ;
    rdfs:label "flags" ;
    rdfs:comment "The antecedent this leading indicator points at." ;
    rdfs:domain cr:RiskSignal ;
    rdfs:range cr:DeviationAntecedent ;
    top:flavor "Additive" .

cr:manifestsAs a owl:ObjectProperty ;
    rdfs:label "manifests as" ;
    rdfs:comment "The deviation event this antecedent produced under load." ;
    rdfs:domain cr:DeviationAntecedent ;
    rdfs:range cr:DeviationEvent ;
    top:flavor "Additive" .

cr:mitigates a owl:ObjectProperty ;
    rdfs:domain cr:MitigationPlan ;
    rdfs:range cr:RiskAssessment ;
    top:flavor "Additive" .

cr:monitors a owl:ObjectProperty ;
    rdfs:label "monitors" ;
    rdfs:comment "Monitoring oversight of a site (the monitor function as a relationship)." ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:principalInvestigator a owl:ObjectProperty ;
    rdfs:label "principal investigator" ;
    rdfs:comment "Role-as-relationship; bitemporal at instance level." ;
    rdfs:domain cr:StudySite ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

cr:queryOn a owl:ObjectProperty ;
    rdfs:label "query on" ;
    rdfs:comment "The entity the query is anchored to (observation, event, form, subject...)." ;
    rdfs:domain cr:Query ;
    top:flavor "Additive" .

cr:specimen a owl:ObjectProperty ;
    rdfs:domain cr:CustodyEvent ;
    rdfs:range hcls:Specimen ;
    top:flavor "Additive" .

hcls:Clinician a owl:Class ;
    rdfs:label "Clinician" ;
    rdfs:comment "A licensed clinician who provides or oversees clinical care or research. Specializes in sub-domains: Investigator (clinical research), Physician (clinical care), Pharmacist, etc." ;
    rdfs:subClassOf hcls:Practitioner .

hcls:HealthcareFacility a owl:Class ;
    rdfs:label "Healthcare Facility" ;
    rdfs:comment "A physical place where care or research is conducted." ;
    rdfs:subClassOf top:Location .

hcls:MedicinalProduct a owl:Class ;
    rdfs:label "Medicinal Product" ;
    rdfs:comment "A medicinal product (drug or biologic)." ;
    rdfs:subClassOf top:Resource .

ns1:Zone_SafetyReporting a skos:Concept ;
    skos:prefLabel "Safety Reporting" ;
    skos:topConceptOf ns1:TMFReferenceModel .

cr:AchieveMilestone a hcls:Action ;
    rdfs:label "Achieve Milestone" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:ActivityTemplate a owl:Class ;
    rdfs:label "Activity Template" ;
    rdfs:comment "The protocol-defined activity template: the procedure to perform at a visit. USDM-ingest-derivable from StudyDesign.activities[]. Carries the biomedical-concept code that determines what kind of data the activity collects. USDM: Activity." ;
    rdfs:subClassOf top:Scope .

cr:AddInvestigatorDelegation a hcls:Action ;
    rdfs:label "Add Investigator Delegation" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:ActivationSubPhase ;
    hcls:operatesOn cr:Delegation .

cr:AnalysisService a owl:Class ;
    rdfs:label "Analysis Service" ;
    rdfs:comment "Catalog definition of a test/assay (e.g. a biomarker assay)." ;
    rdfs:subClassOf top:Evidence .

cr:Assessment a owl:Class ;
    rdfs:label "Assessment" ;
    rdfs:comment "A clinical assessment performed during the trial." ;
    rdfs:subClassOf top:Temporal .

cr:AuditTrail a owl:Class ;
    rdfs:label "Audit Trail" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:Versioned ;
    skos:definition "Secure, computer- or paper-generated documentation that allows reconstruction of the course of events around a record (paraphrased, ICH E6(R3)). In TOP, the bitemporal + PROV envelope realizes this by construction." .

cr:Capability a owl:Class ;
    rdfs:label "Capability" ;
    rdfs:comment "A delegable permission to perform a trial task (e.g. obtain informed consent)." ;
    rdfs:subClassOf top:Constraint .

cr:CertifiedCopy a owl:Class ;
    rdfs:label "Certified Copy" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:Versioned ;
    skos:definition "A copy of original information verified (dated/signed or generated by a validated process) as a complete and accurate copy (paraphrased, ICH E6(R3))." .

cr:ClinicalTrialAgreement a owl:Class ;
    rdfs:label "Clinical Trial Agreement (CTA)" ;
    rdfs:comment "Executed site contract (observedAt = execution date)." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:CreateQuery a hcls:Action ;
    rdfs:label "Create Query" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate,
        cr:DataManager ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:DataAnalysisSubPhase a hcls:Phase ;
    rdfs:label "Data Analysis" ;
    rdfs:comment "Database lock, data cleaning and validation, statistical analysis planning execution, longitudinal analysis, survival analysis, interim and final analyses." .

cr:DelayMilestone a hcls:Action ;
    rdfs:label "Delay Milestone" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:EligibilityCriterion a owl:Class ;
    rdfs:label "Eligibility Criterion" ;
    rdfs:comment "An inclusion/exclusion rule defining who may enroll." ;
    rdfs:subClassOf top:Constraint .

cr:EssentialRecord a owl:Class ;
    rdfs:label "Essential Record" ;
    rdfs:comment "The class the TMF artifact-type scheme (tmf:) classifies the documents of." ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf top:Evidence,
        top:Versioned ;
    skos:altLabel "Essential Document" ;
    skos:definition "A record that, individually or collectively, permits evaluation of the conduct of a trial and the quality of the data produced (paraphrased, ICH E6(R3))." .

cr:GLPToxReport a owl:Class ;
    rdfs:label "GLP Toxicology Report" ;
    rdfs:comment "A GLP toxicology study report supporting safe human dosing." ;
    rdfs:subClassOf top:Evidence .

cr:INDApplication a owl:Class ;
    rdfs:label "IND Application" ;
    rdfs:comment "The submission authorizing human dosing; starts a 30-day review clock (top:observedAt = submission) after which trials may proceed unless a clinical hold is placed." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:IRBApproval a owl:Class ;
    rdfs:label "IRB/IEC Approval" ;
    rdfs:comment "Local IRB/IEC approval (observedAt = approval date)." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:InformedConsent a owl:Class ;
    rdfs:label "Informed Consent" ;
    rdfs:comment "The act of obtaining a subject's informed consent." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:InvestigationalProduct a owl:Class ;
    rdfs:label "Investigational Product" ;
    rdfs:comment "The investigational drug or biologic being studied." ;
    rdfs:subClassOf hcls:MedicinalProduct .

cr:NonclinicalFinding a owl:Class ;
    rdfs:label "Nonclinical Finding" ;
    rdfs:comment "An observed animal toxicity/finding that the clinical protocol must address." ;
    rdfs:subClassOf top:Outcome .

cr:Phase3Design a owl:Class ;
    rdfs:label "Proposed Phase 3 Design" ;
    rdfs:comment "A proposed Phase 3 trial design taken to the EOP2 meeting." ;
    rdfs:subClassOf top:Scope .

cr:RecordFinding a hcls:Action ;
    rdfs:label "Record Finding" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:RegulatoryQuestion a owl:Class ;
    rdfs:label "Regulatory Question" ;
    rdfs:comment "A briefing-book question; should carry a proposed position (FDA punishes vague questions)." ;
    rdfs:subClassOf top:Evidence .

cr:RepeatingPlannedActivity a owl:Class ;
    rdfs:label "Repeating Planned Activity" ;
    rdfs:comment "A planned activity that recurs on an interval until a stop condition (e.g. a daily participant diary until Day N; dosing every 7 days)." ;
    rdfs:subClassOf cr:PlannedActivity .

cr:RiskSignal a owl:Class ;
    rdfs:label "Risk Signal" ;
    rdfs:comment "A leading indicator (a trend or metric) that flags a deviation antecedent before it manifests — the signal a provenance-native graph can hold as low-trust, provenance-tagged evidence." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:SeriousAdverseEvent a owl:Class ;
    rdfs:label "Serious Adverse Event" ;
    rdfs:comment "An adverse event meeting seriousness criteria (expedited reporting)." ;
    rdfs:subClassOf cr:AdverseEvent .

cr:Sponsor a owl:Class ;
    rdfs:label "Sponsor" ;
    rdfs:comment "The organization that initiates and is accountable for the trial." ;
    rdfs:subClassOf hcls:Organization .

cr:UpdateCRF a hcls:Action ;
    rdfs:label "Update CRF" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

hcls:Consent a owl:Class ;
    rdfs:label "Consent" ;
    rdfs:comment "An act of agreement by a Person authorizing an action or use of their data/person. HCLS-universal: permutates to cr:InformedConsentAct (clinical trial enrollment), HIPAA Authorization (data use), Treatment Consent (clinical care). Carries valid-time (when consent was given, when it expires) and transaction-time (when it was recorded)." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

hcls:Observation a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "An information artifact recording a measured value; refersTo the Person/Specimen it is about." ;
    rdfs:subClassOf top:Evidence .

hcls:Practitioner a owl:Class ;
    rdfs:label "Practitioner" ;
    rdfs:comment "A healthcare professional." ;
    rdfs:subClassOf hcls:Person .

cr:AssayResult a owl:Class ;
    rdfs:label "Assay Result" ;
    rdfs:comment "A measured laboratory result on a Specimen, joined to the StudySubject." ;
    rdfs:subClassOf hcls:Observation,
        top:Versioned .

cr:CaseReportForm a owl:Class ;
    rdfs:label "Case Report Form" ;
    rdfs:comment "A case report form — a collection of item groups capturing a visit's data." ;
    rdfs:subClassOf top:Evidence .

cr:ConductMonitoringVisit a hcls:Action ;
    rdfs:label "Conduct Monitoring Visit" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:Endpoint a owl:Class ;
    rdfs:label "Endpoint" ;
    rdfs:comment "A defined outcome measure the study evaluates." ;
    rdfs:subClassOf top:Scope .

cr:EnrollmentRecord a owl:Class ;
    rdfs:label "Enrollment Record" ;
    rdfs:comment "The enrollment event — eligibility confirmed, subject formally on the trial. SDTM DS: DSDECOD=ENROLLED. FHIR: ResearchSubject.status=on-study." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:PlannedEncounter a owl:Class ;
    rdfs:label "Planned Encounter" ;
    rdfs:comment "A planned visit slot on the timeline (USDM Encounter). Positioned by a cr:Timing relative to an anchor; actual cr:Visits are reconciled against it." ;
    rdfs:subClassOf top:Constraint .

cr:SafetyReport a owl:Class ;
    rdfs:label "Safety Report" ;
    rdfs:comment "Expedited report of an SAE to the regulator." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:SourceDocument a owl:Class ;
    rdfs:label "Source Document" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:subClassOf cr:EssentialRecord ;
    skos:definition "The original document/record holding source data (paraphrased, ICH E6(R3))." .

cr:SubmitMonitoringReport a hcls:Action ;
    rdfs:label "Submit Monitoring Report" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate ;
    hcls:occursIn cr:OversightSubPhase ;
    hcls:operatesOn cr:VisitOccurrence .

cr:VisitDefinition a owl:Class ;
    rdfs:label "Visit Definition" ;
    rdfs:comment "The protocol-defined visit template: what is SUPPOSED to happen (type, window, mode, ordering). USDM-ingest-derivable from StudyDesign.encounters[]. UNSCHEDULED visits (urgent care, AE workup) have no VisitDefinition; their VisitOccurrence.definedBy is absent. USDM: Encounter. SDTM projection: SE (Study Elements) domain." ;
    rdfs:subClassOf prov:Entity,
        top:Scope .

cr:Window a owl:Class ;
    rdfs:label "Window" ;
    rdfs:comment "An allowed tolerance around a planned time: a lower and an upper offset in days (e.g. [-2 days, +2 days])." ;
    rdfs:subClassOf top:Constraint .

ns1:Zone_CentralTrialDocs a skos:Concept ;
    skos:prefLabel "Central Trial Documents" ;
    skos:topConceptOf ns1:TMFReferenceModel .

ns1:concerns a owl:ObjectProperty ;
    rdfs:label "concerns" ;
    rdfs:comment "The domain class whose instances this artifact type carries (general bridge)." ;
    rdfs:domain ns1:TMFArtifactType ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

cr:CAPA a owl:Class ;
    rdfs:label "CAPA" ;
    rdfs:comment "Corrective And Preventive Action — the formal response to a deviation or finding (corrective: fix this occurrence; preventive: stop recurrence). Bitemporal + attested." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:CriticalToQualityFactor a owl:Class ;
    rdfs:label "Critical-to-Quality Factor" ;
    rdfs:comment "A quality-critical aspect of the trial (e.g. primary endpoint integrity, consent validity, SAE reporting)." ;
    rdfs:subClassOf top:Constraint ;
    skos:altLabel "CtQ factor" .

cr:CustodyEvent a owl:Class ;
    rdfs:label "Custody Event" ;
    rdfs:comment "A specimen state transition (SampleDue->Received->ToBeVerified->Verified->Published) — chain of custody." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:DataElementDef a owl:Class ;
    rdfs:label "Data Element Definition" ;
    rdfs:comment "A variable DEFINITION (ItemOID), independent of any form version; carries a PHI classification." ;
    rdfs:subClassOf top:Evidence .

cr:EndpointResult a owl:Class ;
    rdfs:label "Endpoint Result" ;
    rdfs:comment "A measured efficacy/safety result; must trace to its endpoint, estimand, and SAP." ;
    rdfs:subClassOf top:Outcome,
        top:Versioned .

cr:Enrollment a owl:Class ;
    rdfs:label "Enrollment" ;
    rdfs:comment "The bitemporal act linking an hcls:Person to a cr:StudySubject in a cr:Study." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:ItemGroup a owl:Class ;
    rdfs:label "Item Group" ;
    rdfs:comment "A logical clustering of items (ItemGroupOID)." ;
    rdfs:subClassOf top:Evidence .

cr:ParticipantSchedule a owl:Class ;
    rdfs:label "Participant Schedule" ;
    rdfs:comment "The schedule projected for a specific subject from a ScheduleTimeline once an anchor date (e.g. enrollment) is known. Bitemporal: re-projected when the governing protocol version changes." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:PlannedActivity a owl:Class ;
    rdfs:label "Planned Activity" ;
    rdfs:comment "A planned activity within an encounter (USDM ScheduledActivityInstance) — e.g. ECG, blood draw, PRO. Positioned by a cr:Timing and/or an ordering edge (cr:precedes)." ;
    rdfs:subClassOf top:Constraint .

cr:ScheduleTimeline a owl:Class ;
    rdfs:label "Schedule Timeline" ;
    rdfs:comment "The planned Schedule of Activities for a protocol version, as a timeline of planned encounters and activities. Bitemporal: a protocol amendment supersedes it, so the schedule is reconstructable as-of any date." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:ScreeningRecord a owl:Class ;
    rdfs:label "Screening Record" ;
    rdfs:comment "One eligibility-screening attempt (ICH E6(R3) §2.5). Re-screening = additional ScreeningRecord. SDTM DS: DSDECOD=SCREEN FAILURE / ENROLLED. SDTM IE: failed criteria." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:StartupArtifact a owl:Class ;
    rdfs:label "Start-up Artifact" ;
    rdfs:comment "A document instance in (or produced from) the start-up package, classified to a TMF artifact type. Carries the data that the work streams consume and transform." ;
    rdfs:subClassOf top:Evidence .

cr:StudyStartupPackage a owl:Class ;
    rdfs:label "Study Start-up Package" ;
    rdfs:comment "The bundle of document artifacts a site receives on being awarded a study. Not a singular item — a set of typed artifacts; in practice fetched one-by-one from sponsor portals." ;
    rdfs:subClassOf top:Evidence .

cr:StudySubject a owl:Class ;
    rdfs:label "Study Subject" ;
    rdfs:comment "The pseudonymous in-study participant identity. Linked to an hcls:Person via the bitemporal cr:Enrollment act (the sensitive bridge); carries no PII." ;
    rdfs:subClassOf top:Agent .

cr:CloseoutPhase a hcls:Phase ;
    rdfs:label "Closeout" ;
    rdfs:comment "From last patient last visit (LPLV) through regulatory submission and study archival. Includes database lock, CSR, and eTMF finalization." ;
    hcls:contains cr:ArchivalSubPhase,
        cr:DataAnalysisSubPhase,
        cr:FollowUpSubPhase,
        cr:ReportingSubPhase .

cr:DeviationEvent a owl:Class ;
    rdfs:label "Deviation Event" ;
    rdfs:comment "A protocol deviation occurrence (departure from the protocol or GCP). Classified by materiality; significant deviations require a CAPA. Bitemporal + attested." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:E6R3Glossary a skos:ConceptScheme ;
    rdfs:label "ICH E6(R3) glossary (selected terms)" ;
    rdfs:comment "Definitional concepts cited to ICH E6(R3); related to the cr: class/relation that realizes each, where one exists." .

cr:MitigationPlan a owl:Class ;
    rdfs:label "Mitigation Plan" ;
    rdfs:comment "Mitigations for a risk, including the resulting monitoring strategy and SDV intensity." ;
    rdfs:subClassOf top:Constraint .

cr:PlannedVisit a owl:Class ;
    rdfs:label "Planned Visit" ;
    rdfs:comment "A projected planned visit for a subject: a target date and a resolved window (start/end dates), against which the actual visit is reconciled." ;
    rdfs:subClassOf top:Constraint .

cr:Recruit a owl:Class ;
    rdfs:label "Recruit" ;
    rdfs:comment "A human in the recruitment realm, pre-consent. Separate entity from Participant (recruiter is a distinct operator role; data is lighter; PHI boundary differs). Transitions to Participant when consent is obtained. Fuels twin-for-enrollment analytics." ;
    rdfs:subClassOf top:Agent .

cr:SiteSelectionDecision a owl:Class ;
    rdfs:label "Site Selection Decision" ;
    rdfs:comment "A recorded, provenance-tagged decision about a study site at a specific lifecycle transition. Captures both positive (Selected, Reserve) and negative (Dropped) outcomes with mandatory rationale. The negative path — why a site was not selected — is institutional intelligence that is almost never captured in practice today but is essential for: (a) sponsor learning across studies, (b) avoiding repeat qualification of unsuitable sites, (c) CRO accountability. Bitemporal (top:Versioned) because decisions can be revised (a Dropped site can become Reserve under rescue conditions)." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

ns1:Zone_TrialManagement a skos:Concept ;
    skos:prefLabel "Trial Management" ;
    skos:topConceptOf ns1:TMFReferenceModel .

cr:ArchivalSubPhase a hcls:Phase ;
    rdfs:label "Archival" ;
    rdfs:comment "Site close-out visits, eTMF finalization, study archival, storage period compliance per country regulations." .

cr:Arm a owl:Class ;
    rdfs:label "Arm" ;
    rdfs:comment "A treatment arm of the study." ;
    rdfs:subClassOf top:Scope .

cr:DeviationAntecedent a owl:Class ;
    rdfs:label "Deviation Antecedent" ;
    rdfs:comment "A latent operational condition that predisposes a deviation (e.g. a visit window too tight for the site's staffing). The missing middle between a critical-to-quality factor and the deviation event it manifests as; bitemporal (it exists, and is detected, over time)." ;
    rdfs:subClassOf top:Constraint,
        top:Versioned .

cr:InformedConsentAct a owl:Class ;
    rdfs:label "Informed Consent Act" ;
    rdfs:comment "One consent event (ICH E6(R3) §2.4 GCP-required). Supports re-consent after protocol amendment or ICF version change. SDTM DS: DSDECOD=INFORMED CONSENT OBTAINED. FHIR: ResearchSubject.progress entry with subjectState=pending-on-study." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:Query a owl:Class ;
    rdfs:label "Query" ;
    rdfs:comment "A discrepancy note / data query anchored to a data point or other entity; threaded." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:StartupPhase a hcls:Phase ;
    rdfs:label "Startup" ;
    rdfs:comment "Everything from initial protocol design through first-patient-in (FPI). Gate condition: first participant randomized. Canonical ICH E6(R3) pre-trial period." ;
    hcls:contains cr:ActivationSubPhase,
        cr:DesignSubPhase,
        cr:RegulatorySubPhase,
        cr:SiteSelectionSubPhase ;
    hcls:precedes cr:ConductPhase .

cr:Timing a owl:Class ;
    rdfs:label "Timing" ;
    rdfs:comment "A relative-timing rule: an offset (days or hours) from an anchor — another node, or an anchor event such as enrollment — with an allowed window. The footnote logic, made explicit." ;
    rdfs:subClassOf top:Constraint .

cr:CSR a owl:Class ;
    rdfs:label "Clinical Study Report" ;
    rdfs:comment "The definitive summary of a study's results (CSR)." ;
    rdfs:subClassOf top:Evidence .

cr:RegulatoryAffairsSpecialist a owl:Class ;
    rdfs:label "Regulatory Affairs Specialist" ;
    rdfs:comment "Manages regulatory submissions (IND, CTA, BLA/NDA/MAA), country configuration, and regulatory authority relationships." ;
    rdfs:subClassOf hcls:Person .

cr:ReportingSubPhase a hcls:Phase ;
    rdfs:label "Reporting" ;
    rdfs:comment "Clinical Study Report (CSR) authoring, regulatory submission package preparation, safety reporting, data disclosure." .

cr:RiskAssessment a owl:Class ;
    rdfs:label "Risk Assessment" ;
    rdfs:comment "An assessment of risk to a CtQ factor (likelihood/impact/detectability -> level); bitemporal." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:SiteActivation a owl:Class ;
    rdfs:label "Site Activation" ;
    rdfs:comment "The green-light record (observedAt = activated date); must cite IRB approval, executed CTA, and SIV." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

hcls:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organization — sponsor, CRO, site, central lab, or regulator." ;
    rdfs:subClassOf top:Agent .

ns1:Zone_SiteManagement a skos:Concept ;
    skos:prefLabel "Site Management" ;
    skos:topConceptOf ns1:TMFReferenceModel .

cr:ProtocolVersion a owl:Class ;
    rdfs:label "Protocol Version" ;
    rdfs:comment "An effective-dated protocol version (bitemporal): which version was valid for a given visit." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:SiteSelectionSubPhase a hcls:Phase ;
    rdfs:label "Site Selection" ;
    rdfs:comment "Feasibility assessment, site evaluation, qualification visit (SQV), site selection committee review. Output: selected site list with signed contracts." .

cr:StudyEvent a owl:Class ;
    rdfs:label "Study Event" ;
    rdfs:comment "A scheduled or unscheduled timepoint (StudyEventOID) when data is captured." ;
    rdfs:subClassOf top:Temporal .

cr:WorkStream a owl:Class ;
    rdfs:label "Activation Work Stream" ;
    rdfs:comment "A site-level stream of work triggered by a study award: consumes package documents and produces outputs. Specialized into the three streams below." ;
    rdfs:subClassOf top:Temporal .

cr:Credential a owl:Class ;
    rdfs:label "Credential" ;
    rdfs:comment "An attested qualification/training record that gates a delegated capability." ;
    rdfs:subClassOf top:Evidence .

cr:PharmacovigilianceSpecialist a owl:Class ;
    rdfs:label "Pharmacovigilance Specialist" ;
    rdfs:comment "Manages safety signal detection, expedited SAE reporting, safety line listings, and periodic safety reports (DSUR, PSUR). OOUX persona aliases: Pharmacovigilance, PV." ;
    rdfs:subClassOf hcls:Person .

hcls:Specimen a owl:Class ;
    rdfs:label "Specimen" ;
    rdfs:comment "A biospecimen collected from a Person." ;
    rdfs:subClassOf top:Resource .

cr:Delegation a owl:Class ;
    rdfs:label "Delegation" ;
    rdfs:comment "PI delegates a Capability to a Person, gated by a Credential, attested. DOA/training logs are projections of this." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:DesignSubPhase a hcls:Phase ;
    rdfs:label "Design" ;
    rdfs:comment "Protocol authoring, statistical analysis plan, SOA construction, CRF design, arm configuration, endpoint definition. Output: approved protocol version." .

cr:RegulatorySubPhase a hcls:Phase ;
    rdfs:label "Regulatory Submissions" ;
    rdfs:comment "IND/CTA filing, IRB/EC review, country-level submissions, amendment management. Output: regulatory clearance per country." .

cr:VisitExecutionSubPhase a hcls:Phase ;
    rdfs:label "Visit Execution" ;
    rdfs:comment "Scheduled and unscheduled visit conduct: actuals vs. SOA, activity completion, IP administration, sample collection, CRF completion at visit level." .

cr:ActivationSubPhase a hcls:Phase ;
    rdfs:label "Site Activation" ;
    rdfs:comment "Study Startup Package readiness, Site Initiation Visit (SIV), training, delegation of authority, equipment qualification. Output: site activated and ready to enroll." .

cr:ActivityOccurrence a owl:Class ;
    rdfs:label "Activity Occurrence" ;
    rdfs:comment "One performed activity within a VisitOccurrence. Uses the universal substrate pattern: any assessment (vitals, MRI, ePRO, biopsy, IP administration) uses the same entity shape; content specialisation is via biomedicalConceptCode and taskValueType. FHIR R5: Procedure / Observation / MedicationAdministration (per activity type). SDTM: domain depends on type (VS, LB, EG, EX, PE, etc.)." ;
    rdfs:subClassOf prov:Activity,
        top:Temporal,
        top:Versioned .

cr:ClinicalObservation a owl:Class ;
    rdfs:label "Clinical Observation" ;
    rdfs:comment "A recorded value (ItemData) for a StudySubject at a StudyEvent, defined by a DataElementDef.",
        "A structured result attached to an ActivityOccurrence. Carries the measured value, unit, reference range, interpretation, and derivedFrom provenance. FHIR R5: Observation. SDTM: one row in the domain matching the parent activity type." ;
    rdfs:subClassOf prov:Entity,
        hcls:Observation,
        top:Evidence,
        top:Versioned .

cr:RecruitmentSubPhase a hcls:Phase ;
    rdfs:label "Recruitment" ;
    rdfs:comment "Recruit identification, screening, informed consent, eligibility assessment, enrollment, randomization. Operator primary: Site Coordinator + Investigator." .

cr:ClinicalResearchAssociate a owl:Class ;
    rdfs:label "Clinical Research Associate" ;
    rdfs:comment "Sponsor-side field monitor. Conducts monitoring visits, source data verification, deviation identification, and monitoring report submission. OOUX persona aliases: CRA, Monitor, Site Monitor." ;
    rdfs:subClassOf hcls:Person .

cr:RegulatoryInteraction a owl:Class ;
    rdfs:label "Regulatory Interaction" ;
    rdfs:comment "Pre-IND / EOP2 meeting." ;
    rdfs:subClassOf top:Temporal .

cr:SafetySubPhase a hcls:Phase ;
    rdfs:label "Safety" ;
    rdfs:comment "Adverse event reporting, SAE expedited reporting, investigator causality assessment, pharmacovigilance line listing, safety signal detection. Always concurrent with other sub-phases." .

cr:FinanceStaff a owl:Class ;
    rdfs:label "Finance" ;
    rdfs:comment "Creates and approves budgets, issues site payments, and processes participant reimbursements. OOUX persona aliases: Finance, Sponsor Finance, Finance Manager." ;
    rdfs:subClassOf hcls:Person .

cr:DataManager a owl:Class ;
    rdfs:label "Data Manager" ;
    rdfs:comment "Creates and locks CRFs, manages queries, reconciles lab and date data, and manages data transfers. Dual-lens: sees CRF as data source for analysis (sponsor perspective)." ;
    rdfs:subClassOf hcls:Person .

cr:SponsorQualityStaff a owl:Class ;
    rdfs:label "Sponsor Quality" ;
    rdfs:comment "Classifies, approves, and closes deviations. Conducts audits and risk assessments; manages CAPAs. OOUX persona aliases: Sponsor Quality, Quality, Auditor." ;
    rdfs:subClassOf hcls:Person .

cr:SponsorOperationsStaff a owl:Class ;
    rdfs:label "Sponsor Operations" ;
    rdfs:comment "Manages protocol amendments, site network structure, regions, country configuration, site activation mechanics, and system configuration. OOUX persona aliases: Sponsor Operations, Sponsor Ops, Site Activation Manager." ;
    rdfs:subClassOf hcls:Person .

ns1:TMFArtifactType a owl:Class ;
    rdfs:label "TMF Artifact Type" ;
    rdfs:comment "A kind of trial-master-file document (the document-type binding target)." ;
    rdfs:subClassOf skos:Concept .

cr:Participant a owl:Class ;
    rdfs:label "Participant" ;
    rdfs:comment "A human subject enrolled in a clinical trial at a specific StudySite for a specific Study. One entity per Study participation; multi-Study = separate Participant records. FHIR R5: ResearchSubject. SDTM projection: DM domain (demographics) + DS domain (disposition events)." ;
    rdfs:subClassOf prov:Agent,
        top:Agent .

cr:eCRF a owl:Class ;
    rdfs:label "eCRF" ;
    rdfs:comment "Electronic case report form — the data-collection instrument used at the site." ;
    rdfs:subClassOf cr:CaseReportForm,
        top:Evidence .

ns1:TMFReferenceModel a skos:ConceptScheme ;
    rdfs:label "TOP TMF artifact-type scheme" ;
    rdfs:comment "A SKOS scheme of trial-master-file artifact types, aligned by name to the DIA TMF Reference Model; each artifact type carries content bridges to the domain classes it concerns." .

hcls:Phase a owl:Class ;
    rdfs:label "Phase" ;
    rdfs:comment "A bounded, sequenced stage of a process lifecycle within an HCLS domain. Phases form a containment tree (hcls:contains) and a precedence chain (hcls:precedes). Permutates to: cr:StartupPhase/ConductPhase/CloseoutPhase (clinical research); Admission/Inpatient/Discharge (clinical care); Formulation/Fill-Finish/Release (manufacturing)." ;
    rdfs:subClassOf top:Scope .

cr:OversightSubPhase a hcls:Phase ;
    rdfs:label "Oversight" ;
    rdfs:comment "Risk-based monitoring, interim monitoring visits, source data verification, deviation identification and classification, CAPA management, audit. Operator primary: CRA + Sponsor Quality." .

cr:AdverseEvent a owl:Class ;
    rdfs:label "Adverse Event" ;
    rdfs:comment "An untoward medical occurrence in a trial subject." ;
    rdfs:subClassOf top:Outcome,
        top:Versioned .

cr:Investigator a owl:Class ;
    rdfs:label "Investigator" ;
    rdfs:comment "A licensed clinician designated as PI or Sub-I at a Site. Holds legal responsibility for trial conduct, GCP compliance, AE causality assessment, CRF sign-off, and delegation of authority. OOUX persona aliases: PI, Investigator, Site PI." ;
    rdfs:subClassOf hcls:Clinician .

hcls:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human. BOUNDARY-ONLY / PII layer: an identifiable Person lives inside the source/site sovereign boundary. Downstream and shareable artifacts must attach to a pseudonymous cr:StudySubject, never to a Person. The only legal Person<->Subject link is the attested Enrollment bridge (cr:enrolledPerson). Clinical data is PSEUDONYMIZED, not anonymized: re-identification is preserved but controlled (safety / emergency unblinding)." ;
    rdfs:subClassOf top:Agent .

cr:DataCollectionSubPhase a hcls:Phase ;
    rdfs:label "Data Collection" ;
    rdfs:comment "EDC data entry and CRF completion, query management, lab reconciliation, concomitant medication and medical history recording. Dual-lens: site captures, sponsor/DM validates." .

cr:VisitOccurrence a owl:Class ;
    rdfs:label "Visit Occurrence" ;
    rdfs:comment "An actual protocol visit: what DID happen. Anchored at Participant (1..1) and StudySite (1..1). Optionally definedBy a VisitDefinition (absent for unscheduled visits). FHIR R5: Encounter. SDTM: SV domain (SVSTDTC / SVENDTC / VISITNUM / VISIT). OMOP: VISIT_OCCURRENCE." ;
    rdfs:subClassOf prov:Activity,
        top:Temporal,
        top:Versioned .

hcls:JobToBeDone a owl:Class ;
    rdfs:label "Job to Be Done" ;
    rdfs:comment "A bounded unit of operator intent: the goal an agent type is trying to achieve, with a trigger condition and measurable success signals. Scoped to an agent type (OWL class) and a Phase. References the object graph and authorized Actions involved. Derived from OOUX JTBD blocks." ;
    rdfs:subClassOf top:Scope .

cr:ConductPhase a hcls:Phase ;
    rdfs:label "Conduct" ;
    rdfs:comment "From first patient in (FPI) through last patient out (LPO) / database lock (DBL). The operational execution window of the trial." ;
    hcls:contains cr:DataCollectionSubPhase,
        cr:OversightSubPhase,
        cr:RecruitmentSubPhase,
        cr:SafetySubPhase,
        cr:VisitExecutionSubPhase ;
    hcls:precedes cr:CloseoutPhase .

cr:SponsorProjectManager a owl:Class ;
    rdfs:label "Sponsor Project Manager" ;
    rdfs:comment "Creates and activates studies, selects and manages sites, tracks milestones and enrollment, and closes studies. OOUX persona aliases: Sponsor PM, Study PM, Project Manager, Study Manager." ;
    rdfs:subClassOf hcls:Person .

cr:StudySite a owl:Class ;
    rdfs:label "Study Site" ;
    rdfs:comment "An investigative site conducting the study (an organization at a facility)." ;
    rdfs:subClassOf hcls:Organization .

cr:SiteCoordinator a owl:Class ;
    rdfs:label "Site Coordinator" ;
    rdfs:comment "The day-to-day clinical operations professional at a Site. Screens and enrolls participants, executes visits, completes CRFs, manages AE reporting, and maintains site logs. Also known as Clinical Research Coordinator (CRC). OOUX persona aliases: Coordinator, Study Coordinator, CRC." ;
    rdfs:subClassOf hcls:Practitioner .

cr:Study a owl:Class ;
    rdfs:label "Study" ;
    rdfs:comment "A clinical study — the unit of investigation the protocol defines." ;
    rdfs:subClassOf top:Scope .

hcls:Action a owl:Class ;
    rdfs:label "Action" ;
    rdfs:comment "A named, authorized operation (Call To Action in OOUX terms) that an agent of a given type may perform in a given Phase. Actions are reference-graph archetypes (top:Constraint: they specify what is authorized). Realized occurrences in instance graphs are prov:Activity individuals linked back via hcls:realizationOf." ;
    rdfs:subClassOf top:Constraint .

