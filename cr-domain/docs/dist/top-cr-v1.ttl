    rdfs:label "stream for site" ;
    rdfs:domain cr:WorkStream ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:streamStatus a owl:DatatypeProperty ;
    rdfs:label "stream status" ;
    rdfs:comment "planned | active | complete." ;
    rdfs:domain cr:WorkStream ;
    top:flavor "Additive" .

cr:submittedAt a owl:DatatypeProperty ;
    rdfs:label "submitted at" ;
    rdfs:domain cr:SafetyReport ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:targetAccrual a owl:DatatypeProperty ;
    rdfs:label "target accrual" ;
    rdfs:domain cr:StudySite ;
    rdfs:range xsd:integer ;
    top:flavor "Additive" .

cr:targetDate a owl:DatatypeProperty ;
    rdfs:label "target date" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:term_ALCOAplus a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:AuditTrail ;
    skos:definition "Data-integrity expectations: attributable, legible, contemporaneous, original, accurate, plus complete, consistent, enduring, available (paraphrased, ICH E6(R3) data governance). Realized in TOP by the bitemporal + PROV envelope." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "ALCOA++" .

cr:term_Auditor a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:audits ;
    skos:definition "A person conducting a systematic, independent examination of trial activities and documents (paraphrased, ICH E6(R3))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Auditor" .

cr:term_Investigator a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:principalInvestigator ;
    skos:definition "The person responsible for the conduct of the trial at a trial site (paraphrased, ICH E6(R3))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Investigator" .

cr:term_Monitor a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:monitors ;
    skos:definition "A person who oversees the progress of the trial and that it is conducted, recorded, and reported per protocol, SOPs, GCP, and regulation (paraphrased, ICH E6(R3))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Monitor" .

cr:term_QualityByDesign a skos:Concept ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    rdfs:seeAlso cr:CriticalToQualityFactor ;
    skos:definition "Building quality into trial design and conduct by focusing on factors critical to quality (paraphrased, ICH E6(R3)/E8(R1))." ;
    skos:inScheme cr:E6R3Glossary ;
    skos:prefLabel "Quality by Design" .

cr:threatens a owl:ObjectProperty ;
    rdfs:label "threatens" ;
    rdfs:comment "The critical-to-quality factor this latent condition endangers." ;
    rdfs:domain cr:DeviationAntecedent ;
    rdfs:range cr:CriticalToQualityFactor ;
    top:flavor "Additive" .

cr:timing a owl:ObjectProperty ;
    rdfs:label "timing" ;
    rdfs:comment "The relative-timing rule positioning a planned encounter or activity." ;
    rdfs:range cr:Timing ;
    top:flavor "Additive" .

cr:timingType a owl:DatatypeProperty ;
    rdfs:label "timing type" ;
    rdfs:comment "before | after | fixed — the sense of the offset relative to the anchor." ;
    rdfs:domain cr:Timing ;
    top:flavor "Additive" .

cr:toState a owl:DatatypeProperty ;
    rdfs:label "to state" ;
    rdfs:domain cr:CustodyEvent ;
    top:flavor "Additive" .

cr:tracesToNonclinical a owl:ObjectProperty ;
    rdfs:domain cr:INDApplication ;
    rdfs:range cr:GLPToxReport ;
    top:flavor "Additive" .

cr:triggers a owl:ObjectProperty ;
    rdfs:label "triggers" ;
    rdfs:comment "The corrective/preventive action this deviation triggered." ;
    rdfs:domain cr:DeviationEvent ;
    rdfs:range cr:CAPA ;
    top:flavor "Additive" .

cr:underDelegation a owl:ObjectProperty ;
    rdfs:label "under delegation" ;
    rdfs:comment "Links a performed act to the delegation authorizing it (delegation invariant)." ;
    rdfs:range cr:Delegation ;
    top:flavor "Additive" .

cr:verifiedBy a owl:ObjectProperty ;
    rdfs:comment "The monitor who source-verified the value (SDV)." ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

cr:window a owl:ObjectProperty ;
    rdfs:label "window" ;
    rdfs:domain cr:Timing ;
    rdfs:range cr:Window ;
    top:flavor "Additive" .

cr:windowEnd a owl:DatatypeProperty ;
    rdfs:label "window end" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:windowLowerDays a owl:DatatypeProperty ;
    rdfs:label "window lower (days)" ;
    rdfs:domain cr:Window ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:windowStart a owl:DatatypeProperty ;
    rdfs:label "window start" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:windowUpperDays a owl:DatatypeProperty ;
    rdfs:label "window upper (days)" ;
    rdfs:domain cr:Window ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:yieldsResult a owl:ObjectProperty ;
    rdfs:label "yields result" ;
    rdfs:comment "An assay result that traces to this collection act (forward of cr:derivedFromCollection)." ;
    rdfs:domain cr:StudyEvent ;
    rdfs:range cr:AssayResult ;
    owl:inverseOf cr:derivedFromCollection ;
    top:flavor "Additive" .

<https://top.scientix.ai/cr/v1/gcp> a owl:Ontology ;
    rdfs:label "TOP CR — ICH E6(R3) GCP definitional layer" ;
    dcterms:rights "Independent derivative adaptation of the ICH E6(R3) Guideline. The classes, properties, and SKOS concepts here are an adaptation (structure + paraphrased definitions), not a reproduction. NOT endorsed or sponsored by ICH. The original ICH E6(R3) document is copyright © ICH." ;
    dcterms:source "ICH E6(R3) Good Clinical Practice (Step 4, adopted January 2025): Principles, Glossary, and Annex 1 (interventional trials). Annex 2 (additional/non-traditional data sources) is NOT modeled in this version." ;
    rdfs:comment "Changes made: ICH E6(R3) terms are reorganized into an OWL/SKOS structure, definitions are paraphrased, and obligations are expressed as SHACL shapes rather than encoded text. Each derived term carries rdfs:isDefinedBy the ICH efficacy-guidelines source." .

cx: a owl:Ontology ;
    rdfs:label "TOP crosswalk vocabulary (SSSOM-aligned)" ;
    rdfs:comment "OWNED, provenance-tagged crosswalks from TOP/CR-core to external ontologies. Aligns to SSSOM slots (subject_id/predicate_id/object_id/mapping_justification/confidence/author_id/mapping_date); an SSSOM TSV is an edge projection of these. Crosswalks are assertions WE own and curate, never imports of the external ontology." .

cx:Mapping a owl:Class ;
    rdfs:label "Crosswalk Mapping" ;
    rdfs:comment "A curated, provenanced correspondence from a TOP term to an external ontology term." ;
    rdfs:subClassOf top:Evidence .

cx:author a owl:ObjectProperty ;
    rdfs:label "author id" ;
    rdfs:comment "The curator/agent IRI (SSSOM author_id)." ;
    top:flavor "Additive" .

cx:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cx:confirmedAt a owl:DatatypeProperty ;
    rdfs:label "confirmed at" ;
    rdfs:comment "Timestamp when a mapping was confirmed by a human reviewer. Together with cx:confirmedBy, closes the audit trail for human-in-the-loop validation." ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cx:confirmedBy a owl:ObjectProperty ;
    rdfs:label "confirmed by" ;
    rdfs:comment "The human agent (or committee) that reviewed and confirmed a proposed mapping. Required for promotion from 'under_review' to 'confirmed'." ;
    top:flavor "Additive" .

cx:inferredBy a owl:ObjectProperty ;
    rdfs:label "inferred by" ;
    rdfs:comment "The top:AutonomousAgent instance that proposed this mapping via LLM inference. Enables provenance tracing back to the agent model and prompt version." ;
    top:flavor "Additive" .

cx:justification a owl:ObjectProperty ;
    rdfs:label "mapping justification" ;
    rdfs:comment "A semapv justification IRI (e.g. ManualMappingCuration)." ;
    top:flavor "Additive" .

cx:mappingDate a owl:DatatypeProperty ;
    rdfs:label "mapping date" ;
    rdfs:range xsd:date ;
    top:flavor "Additive" .

cx:mappingMethod a owl:DatatypeProperty ;
    rdfs:label "mapping method" ;
    rdfs:comment "How the mapping was produced: ManualCuration | LLMInference | RuleBasedExtraction | HybridReview. Drives downstream trust and routing." ;
    top:flavor "Additive" .

cx:mappingRationale a owl:DatatypeProperty ;
    rdfs:label "mapping rationale" ;
    rdfs:comment "Human-readable explanation of why this mapping was proposed, especially for LLM-inferred mappings. Mirrors top:rationale on a Conclusion." ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

cx:objectId a owl:ObjectProperty ;
    rdfs:label "object id" ;
    rdfs:comment "The external ontology term (right side)." ;
    top:flavor "Additive" .

cx:predicateId a owl:ObjectProperty ;
    rdfs:label "predicate id" ;
    rdfs:comment "SKOS mapping predicate." ;
    top:flavor "Additive" .

cx:retrievedFrom a owl:DatatypeProperty ;
    rdfs:label "retrieved from" ;
    rdfs:comment "The primary source the target IRI was verified against (URL + retrieval date)." ;
    top:flavor "Additive" .

cx:reviewStatus a owl:DatatypeProperty ;
    rdfs:label "review status" ;
    rdfs:comment "Lifecycle state of the mapping: proposed | under_review | confirmed | rejected | deprecated. Confirmed mappings graduate from ephemeral inference to Layer-2 crosswalk." ;
    top:flavor "Additive" .

cx:subjectId a owl:ObjectProperty ;
    rdfs:label "subject id" ;
    rdfs:comment "The TOP/CR-core term (left side)." ;
    top:flavor "Additive" .

cx:verificationStatus a owl:DatatypeProperty ;
    rdfs:label "verification status" ;
    rdfs:comment "verified | unverified | deprecated — whether the target IRI was confirmed against a primary source." ;
    top:flavor "Additive" .

hcls: a owl:Ontology ;
    rdfs:label "HCLS-core" ;
    rdfs:comment "Mid-layer specializing TOP Core for entities that recur across >=2 HCLS domains (clinical research, hospital, manufacturing, pharmacovigilance, RWE, commercialization). Seeded minimally; grows by promotion (rule of three). Standards projection target: FHIR, OMOP." .

hcls:Condition a owl:Class ;
    rdfs:label "Condition" ;
    rdfs:comment "A diagnosed state of a Person." ;
    rdfs:subClassOf top:Outcome .

hcls:Lot a owl:Class ;
    rdfs:label "Lot" ;
    rdfs:comment "A manufactured batch/lot; the primary join to the manufacturing domain." ;
    rdfs:subClassOf top:Resource .

hcls:Substance a owl:Class ;
    rdfs:label "Substance" ;
    rdfs:comment "A chemical or biological substance." ;
    rdfs:subClassOf top:Resource .

hcls:actsAs a owl:DatatypeProperty ;
    rdfs:label "acts as" ;
    rdfs:comment "At instance-graph time, a human-readable label for the contextual role a Person plays within a Scope (Study, Site, Care Episode). Not a class; purely a string annotation on the Person-Scope binding. Example value: 'Principal Investigator'." ;
    rdfs:domain hcls:Person ;
    top:flavor "Additive" .

hcls:affiliatedWith a owl:ObjectProperty ;
    rdfs:label "affiliated with" ;
    rdfs:domain hcls:Person ;
    rdfs:range hcls:Organization ;
    top:flavor "Additive" .

hcls:authorizedAgentType a owl:ObjectProperty ;
    rdfs:label "authorized agent type" ;
    rdfs:comment "The OWL class of agent authorized to execute this Action. Authorization binds directly to agent type — no OperatorRole intermediary. Multi-valued: an Action may be authorized for more than one agent type." ;
    rdfs:domain hcls:Action ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:collectedFrom a owl:ObjectProperty ;
    rdfs:label "collected from" ;
    rdfs:domain hcls:Specimen ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

hcls:consentSubject a owl:ObjectProperty ;
    rdfs:label "consent subject" ;
    rdfs:domain hcls:Consent ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

hcls:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:comment "Containment: a phase contains its named sub-phases. Transitive; used to derive the top-level phase for any sub-phase." ;
    rdfs:domain hcls:Phase ;
    rdfs:range hcls:Phase ;
    top:flavor "Additive" .

hcls:executesAction a owl:ObjectProperty ;
    rdfs:label "executes action" ;
    rdfs:comment "An Action performed as part of accomplishing this job." ;
    rdfs:domain hcls:JobToBeDone ;
    rdfs:range hcls:Action ;
    top:flavor "Additive" .

hcls:givesConsent a owl:ObjectProperty ;
    rdfs:label "gives consent" ;
    rdfs:domain hcls:Person ;
    rdfs:range hcls:Consent ;
    top:flavor "Additive" .

hcls:involvesObject a owl:ObjectProperty ;
    rdfs:label "involves object" ;
    rdfs:comment "An entity class that participates in this job's object graph." ;
    rdfs:domain hcls:JobToBeDone ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:jobOfAgentType a owl:ObjectProperty ;
    rdfs:label "job of agent type" ;
    rdfs:comment "The OWL class of agent this job belongs to." ;
    rdfs:domain hcls:JobToBeDone ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:jobTrigger a owl:DatatypeProperty ;
    rdfs:label "job trigger" ;
    rdfs:comment "The condition or event that initiates this job (from OOUX JTBD 'trigger' field)." ;
    rdfs:domain hcls:JobToBeDone ;
    top:flavor "Additive" .

hcls:locatedAt a owl:ObjectProperty ;
    rdfs:label "located at" ;
    rdfs:domain hcls:Organization ;
    rdfs:range hcls:HealthcareFacility ;
    top:flavor "Additive" .

hcls:occursIn a owl:ObjectProperty ;
    rdfs:label "occurs in" ;
    rdfs:comment "The lifecycle phase in which this Action is typically performed." ;
    rdfs:domain hcls:Action ;
    rdfs:range hcls:Phase ;
    top:flavor "Additive" .

hcls:operatesOn a owl:ObjectProperty ;
    rdfs:label "operates on" ;
    rdfs:comment "The OWL class of the primary entity this Action targets. Enables querying: what Actions are available on a given entity type for a given agent type in a given phase?" ;
    rdfs:domain hcls:Action ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:precedes a owl:ObjectProperty ;
    rdfs:label "precedes" ;
    rdfs:comment "Temporal sequencing: Phase A precedes Phase B means B cannot begin before A's gate conditions are met." ;
    rdfs:domain hcls:Phase ;
    rdfs:range hcls:Phase ;
    top:flavor "Additive" .

hcls:realizationOf a owl:ObjectProperty ;
    rdfs:label "realization of" ;
    rdfs:comment "Links a prov:Activity instance (an occurrence that actually happened) to the hcls:Action archetype it realizes. Instance-to-archetype traceability link." ;
    rdfs:range hcls:Action ;
    top:flavor "Additive" .

hcls:successSignal a owl:DatatypeProperty ;
    rdfs:label "success signal" ;
    rdfs:comment "A measurable indicator that the job has been completed. Multi-valued." ;
    rdfs:domain hcls:JobToBeDone ;
    top:flavor "Additive" .

ns1:CAPALog a ns1:TMFArtifactType ;
    rdfs:label "CAPA Log" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "CAPA Log" ;
    ns1:records cr:CAPA .

ns1:ClinicalTrialAgreementDoc a ns1:TMFArtifactType ;
    rdfs:label "Clinical Trial Agreement (artifact)" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Clinical Trial Agreement" ;
    ns1:documents cr:ClinicalTrialAgreement .

ns1:CurriculumVitae a ns1:TMFArtifactType ;
    rdfs:label "Curriculum Vitae" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Curriculum Vitae" ;
    ns1:documents cr:Credential .

ns1:DataManagementPlan a ns1:TMFArtifactType ;
    rdfs:label "Data Management Plan" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Data Management Plan" ;
    ns1:documents cr:DataElementDef .

ns1:DelegationOfAuthorityLog a ns1:TMFArtifactType ;
    rdfs:label "Delegation of Authority Log" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Delegation of Authority Log" ;
    ns1:records cr:Delegation .

ns1:FinancialDisclosureForm a ns1:TMFArtifactType ;
    rdfs:label "Financial Disclosure Form" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Financial Disclosure Form" ;
    ns1:documents cr:StudySite .

ns1:Form1572 a ns1:TMFArtifactType ;
    rdfs:label "Form FDA 1572" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Form FDA 1572" ;
    ns1:documents cr:StudySite .

ns1:IRBApprovalLetter a ns1:TMFArtifactType ;
    rdfs:label "IRB/IEC Approval Letter" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "IRB/IEC Approval Letter" ;
    ns1:documents cr:IRBApproval .

ns1:InformedConsentForm a ns1:TMFArtifactType ;
    rdfs:label "Informed Consent Form" ;
    skos:broader ns1:Zone_SiteManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Informed Consent Form" ;
    ns1:documents cr:InformedConsent .

ns1:InvestigatorBrochure a ns1:TMFArtifactType ;
    rdfs:label "Investigator Brochure" ;
    skos:broader ns1:Zone_CentralTrialDocs ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Investigator Brochure" ;
    ns1:documents cr:InvestigationalProduct .

ns1:MonitoringPlan a ns1:TMFArtifactType ;
    rdfs:label "Monitoring Plan" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Monitoring Plan" ;
    ns1:documents cr:MitigationPlan,
        cr:RiskAssessment .

ns1:Protocol a ns1:TMFArtifactType ;
    rdfs:label "Protocol" ;
    skos:broader ns1:Zone_CentralTrialDocs ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Protocol" ;
    ns1:defines cr:CriticalToQualityFactor,
        cr:EligibilityCriterion,
        cr:Endpoint .

ns1:ProtocolDeviationLog a ns1:TMFArtifactType ;
    rdfs:label "Protocol Deviation Log" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Protocol Deviation Log" ;
    ns1:records cr:DeviationEvent .

ns1:SAEReport a ns1:TMFArtifactType ;
    rdfs:label "SAE Report" ;
    skos:broader ns1:Zone_SafetyReporting ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "SAE Report" ;
    ns1:records cr:SafetyReport .

ns1:ScheduleOfActivities a ns1:TMFArtifactType ;
    rdfs:label "Schedule of Activities" ;
    skos:broader ns1:Zone_CentralTrialDocs ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Schedule of Activities" ;
    ns1:defines cr:ScheduleTimeline .

ns1:SiteActivationManual a ns1:TMFArtifactType ;
    rdfs:label "Site Activation Manual" ;
    skos:broader ns1:Zone_TrialManagement ;
    skos:inScheme ns1:TMFReferenceModel ;
    skos:prefLabel "Site Activation Manual" ;
    ns1:documents cr:SiteActivation .

ns1:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:comment "The artifact establishes/specifies the entity (e.g. a Protocol defines the CtQ factors)." ;
    rdfs:subPropertyOf ns1:concerns ;
    top:flavor "Additive" .

ns1:documents a owl:ObjectProperty ;
    rdfs:label "documents" ;
    rdfs:comment "The artifact describes/evidences the entity (e.g. a Monitoring Plan documents the mitigation plan)." ;
    rdfs:subPropertyOf ns1:concerns ;
    top:flavor "Additive" .

ns1:records a owl:ObjectProperty ;
    rdfs:label "records" ;
    rdfs:comment "The artifact is a running log of the entity's instances (e.g. a Deviation Log records deviation events)." ;
    rdfs:subPropertyOf ns1:concerns ;
    top:flavor "Additive" .

<https://top.scientix.ai/cr/v1> a owl:Ontology ;
    rdfs:label "TOP — Clinical Research Reference Graph" ;
    dcterms:bibliographicCitation "ScientixAI (2026). TOP — Clinical Research Reference Graph (v1). The Ontology Project." ;
    dcterms:contributor "TOP Clinical Research working group" ;
    dcterms:creator "ScientixAI" ;
    dcterms:description "An inheritable, provenance-native, bitemporal reference knowledge graph for the clinical-research lifecycle (Pre-IND through End-of-Phase-2, plus site operations). The founding domain of TOP (The Ontology Project)." ;
    dcterms:issued "2026-06-22"^^xsd:date ;
    dcterms:license <https://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:publisher "ScientixAI" ;
    dcterms:rights "Includes an independent derivative adaptation of the ICH E6(R3) Good Clinical Practice Guideline (Step 4, 2025; Principles, Glossary, Annex 1) — paraphrased, not endorsed or sponsored by ICH, original copyright © ICH. TMF artifact types align by name to the DIA TMF Reference Model (licensed; no text reproduced). See the repository NOTICE file." ;
    dcterms:title "TOP — Clinical Research Reference Graph" ;
    owl:versionIRI <https://top.scientix.ai/cr/v1> ;
    owl:versionInfo "v1" .

cr:ActivateStudy a hcls:Action ;
    rdfs:label "Activate Study" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:AddBudgetLineItem a hcls:Action ;
    rdfs:label "Add Budget Line Item" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:StartupPhase ;
    hcls:operatesOn cr:Study .

cr:AddLogEntry a hcls:Action ;
    rdfs:label "Add Log Entry" ;
    hcls:authorizedAgentType cr:SiteCoordinator ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:StudySite .

cr:AnalysisRequest a owl:Class ;
    rdfs:label "Analysis Request" ;
    rdfs:comment "Binds an AnalysisService to a Specimen (the order)." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:ApproveBudget a hcls:Action ;
    rdfs:label "Approve Budget" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:StartupPhase ;
    hcls:operatesOn cr:Study .

cr:ApprovePayment a hcls:Action ;
    rdfs:label "Approve Payment" ;
    hcls:authorizedAgentType cr:FinanceStaff ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:StudySite .

cr:ArchiveStudy a hcls:Action ;
    rdfs:label "Archive Study" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ArchivalSubPhase ;
    hcls:operatesOn cr:Study .

cr:AssessAdverseEvent a hcls:Action ;
    rdfs:label "Assess Adverse Event" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:AssignQuery a hcls:Action ;
    rdfs:label "Assign Query" ;
    hcls:authorizedAgentType cr:DataManager ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:AssignTask a hcls:Action ;
    rdfs:label "Assign Task" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:BriefingBook a owl:Class ;
    rdfs:label "Briefing Book" ;
    rdfs:comment "A dossier submitted to the regulator ahead of a meeting (Pre-IND / EOP2)." ;
    rdfs:subClassOf top:Evidence .

cr:ClinicalHold a owl:Class ;
    rdfs:label "Clinical Hold" ;
    rdfs:comment "An FDA order that halts or prevents a trial from proceeding." ;
    rdfs:subClassOf top:Outcome .

cr:CloseAdverseEvent a hcls:Action ;
    rdfs:label "Close Adverse Event" ;
    hcls:authorizedAgentType cr:Investigator ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:CloseEnrollment a hcls:Action ;
    rdfs:label "Close Enrollment" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:ConductPhase ;
    hcls:operatesOn cr:Study .

cr:CloseQuery a hcls:Action ;
    rdfs:label "Close Query" ;
    hcls:authorizedAgentType cr:DataManager ;
    hcls:occursIn cr:DataCollectionSubPhase ;
    hcls:operatesOn cr:eCRF .

cr:CloseSafetySignal a hcls:Action ;
    rdfs:label "Close Safety Signal" ;
    hcls:authorizedAgentType cr:PharmacovigilianceSpecialist ;
    hcls:occursIn cr:SafetySubPhase ;
    hcls:operatesOn cr:AdverseEvent .

cr:CloseSite a hcls:Action ;
    rdfs:label "Close Site" ;
    hcls:authorizedAgentType cr:ClinicalResearchAssociate,
        cr:SponsorProjectManager ;
    hcls:occursIn cr:ArchivalSubPhase ;
    hcls:operatesOn cr:StudySite .

cr:CloseSiteToEnrollment a hcls:Action ;
