_:cb1288314901d10420dbe2a92f93eec43ae9f3f6f2a3ddf54129bdaac352c814c86 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"SCREEN_FAILED\" .\n              FILTER NOT EXISTS {\n                $this <https://top.scientix.ai/cr/v1#hasScreeningRecord> ?r .\n                ?r <https://top.scientix.ai/cr/v1#screeningOutcome> \"SCREEN_FAILED\" .\n              }\n            }\n        " .
