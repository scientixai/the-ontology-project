_:cb1c9df96b256d230fd8805990405d7e7bb43cda872d3a0c066997cd1cb440f6cfd <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/v1#validFrom> ?obsDate .\n              ?withdrawal a <https://top.scientix.ai/cr/v1#ConsentWithdrawal> ;\n                          <https://top.scientix.ai/cr/v1#closesConsent> ?consent .\n              ?consent <https://top.scientix.ai/cr/v1#withdrawalDate> ?wd .\n              FILTER ( xsd:date(?obsDate) > ?wd )\n            }\n        " .
