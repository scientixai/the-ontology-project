_:cb173dea6f33ef5651e5d7f36436f972d5f86165cf2ead2414216b8049128ea718b <http://www.w3.org/ns/shacl#message> "A work stream produces an output that does not trace (prov:wasDerivedFrom) to any input." .
_:cb173dea6f33ef5651e5d7f36436f972d5f86165cf2ead2414216b8049128ea718b <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#produces> ?out .\n              FILTER NOT EXISTS { ?out <http://www.w3.org/ns/prov#wasDerivedFrom> ?in . }\n            }\n        " .
_:cb1753a5c21b33fe07f8e8c48a2c7eee87a8305e9b3308c98fad53483a036d84068 <http://www.w3.org/ns/shacl#message> "cr:RegulatoryInteraction must carry cr:meetingDate." .
_:cb1753a5c21b33fe07f8e8c48a2c7eee87a8305e9b3308c98fad53483a036d84068 <http://www.w3.org/ns/shacl#minCount> "1"^^<http://www.w3.org/2001/XMLSchema#integer> .
