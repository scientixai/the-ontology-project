_:cbc67162c71828f1cafe687ba91b15423271e8d31a82119dc41a8d11c0607dc2db <http://www.w3.org/ns/shacl#message> "cr:SeriousAdverseEvent lacks a cr:CausalityAssessment concluding about it." .
_:cbc67162c71828f1cafe687ba91b15423271e8d31a82119dc41a8d11c0607dc2db <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              FILTER NOT EXISTS {\n                ?ca a <https://top.scientix.ai/cr/v1#CausalityAssessment> ;\n                     <https://top.scientix.ai/v1#concludesAbout> $this .\n              }\n            }\n        " .
