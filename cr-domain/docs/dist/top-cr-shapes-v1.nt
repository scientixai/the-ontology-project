_:cb10cc6e59a6d2db7613a5194050e0c4aa4f48010c50c278c5c003f4f0eb8cd8d15 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#timing> ?t . }\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#precedes> ?o . }\n              FILTER NOT EXISTS { ?p <https://top.scientix.ai/cr/v1#precedes> $this . }\n            }\n        " .
_:cb10ed5cf425231f1e69ba12c515226b4b7c0fe6619117321758f382cb27a4a90e3 <http://www.w3.org/ns/shacl#message> "EOP2 meeting lacks a binding agreement and/or a risk register (readiness warning)." .
_:cb10ed5cf425231f1e69ba12c515226b4b7c0fe6619117321758f382cb27a4a90e3 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#meetingType> \"EOP2\" .\n              FILTER ( NOT EXISTS { $this <https://top.scientix.ai/cr/v1#producedAgreement> ?a }\n                       || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasRiskRegister> ?r } )\n            }\n        " .
_:cb113003e55aef8ced5782d7ccc9adceff02ed4a911755868bf2a05c741e0a8d042 <http://www.w3.org/ns/shacl#message> "Participant.participantStatus=RANDOMIZED but missing assignedToArm or randomizationDate." .
_:cb113003e55aef8ced5782d7ccc9adceff02ed4a911755868bf2a05c741e0a8d042 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"RANDOMIZED\" .\n              FILTER (\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#assignedToArm> ?a . } ||\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#randomizationDate> ?d . }\n              )\n            }\n        " .
_:cb11334cb11ddf71ee5550f23e888f6dc1d69f871a4d0abf482bedddfe5dc286703 <http://www.w3.org/ns/shacl#message> "Actual visit's observedAt falls outside the planned window of the visit it realizes (out-of-window) — review materiality." .
_:cb11334cb11ddf71ee5550f23e888f6dc1d69f871a4d0abf482bedddfe5dc286703 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#realizes> ?pv ;\n                    <https://top.scientix.ai/v1#observedAt> ?t .\n              ?pv a <https://top.scientix.ai/cr/v1#PlannedVisit> ;\n                  <https://top.scientix.ai/cr/v1#windowStart> ?ws ;\n                  <https://top.scientix.ai/cr/v1#windowEnd> ?we .\n              FILTER ( ?t < ?ws || ?t > ?we )\n            }\n        " .
_:cb12728f7cbc1e90c625b7791593fbb13da76d42e13f3eec64f594fca32a6a2645b <http://www.w3.org/ns/shacl#class> <https://top.scientix.ai/hcls/v1#Person> .
_:cb12728f7cbc1e90c625b7791593fbb13da76d42e13f3eec64f594fca32a6a2645b <http://www.w3.org/ns/shacl#message> "Consent must record who performed it." .
_:cb12728f7cbc1e90c625b7791593fbb13da76d42e13f3eec64f594fca32a6a2645b <http://www.w3.org/ns/shacl#minCount> "1"^^<http://www.w3.org/2001/XMLSchema#integer> .
_:cb12728f7cbc1e90c625b7791593fbb13da76d42e13f3eec64f594fca32a6a2645b <http://www.w3.org/ns/shacl#path> <https://top.scientix.ai/cr/v1#performedBy> .
_:cb128557a8faf8c41a5c51db41ac897caed1fc25c6b9fd34bd794a553d2e25bcf8 <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://www.w3.org/2004/02/skos/core#closeMatch> .
_:cb128557a8faf8c41a5c51db41ac897caed1fc25c6b9fd34bd794a553d2e25bcf8 <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest> _:cb617d55059e888dc79e1b06aaba9d096eb76ebe0a5230fc8a71c35e332ffae95e .
_:cb1288314901d10420dbe2a92f93eec43ae9f3f6f2a3ddf54129bdaac352c814c86 <http://www.w3.org/ns/shacl#message> "Participant.participantStatus=SCREEN_FAILED but no ScreeningRecord with screeningOutcome=SCREEN_FAILED." .
_:cb1288314901d10420dbe2a92f93eec43ae9f3f6f2a3ddf54129bdaac352c814c86 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"SCREEN_FAILED\" .\n              FILTER NOT EXISTS {\n                $this <https://top.scientix.ai/cr/v1#hasScreeningRecord> ?r .\n                ?r <https://top.scientix.ai/cr/v1#screeningOutcome> \"SCREEN_FAILED\" .\n              }\n            }\n        " .
_:cb1420056ecab70121706c3d6a0ed49d2f0afba89e1882f0a9d38dc5bb0d4306cff <http://www.w3.org/ns/shacl#message> "cr:RegulatoryInteraction must carry cr:meetingType (Pre-IND, EOP1, EOP2, Type-A/B/C)." .
_:cb1420056ecab70121706c3d6a0ed49d2f0afba89e1882f0a9d38dc5bb0d4306cff <http://www.w3.org/ns/shacl#minCount> "1"^^<http://www.w3.org/2001/XMLSchema#integer> .
_:cb1420056ecab70121706c3d6a0ed49d2f0afba89e1882f0a9d38dc5bb0d4306cff <http://www.w3.org/ns/shacl#path> <https://top.scientix.ai/cr/v1#meetingType> .
_:cb14dcfc16ce9fad2423deaac47c6ab5a3cd864586eece468dd417b22399a1e45a7 <http://www.w3.org/ns/shacl#message> "SUSAR submitted after regulatory deadline (submissionDate > reportingDeadline)." .
_:cb14dcfc16ce9fad2423deaac47c6ab5a3cd864586eece468dd417b22399a1e45a7 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#submissionDate> ?sub ;\n                    <https://top.scientix.ai/cr/v1#reportingDeadline> ?dl .\n              BIND(xsd:date(?dl) AS ?dlDate)\n              FILTER ( ?sub > ?dlDate )\n            }\n        " .
_:cb152d4881209cdbe7ea68b7ac8e8faaf50245e12603c6dde860513ff04d78c0188 <http://www.w3.org/ns/shacl#message> "Participant.assignedToArm references an Arm whose parent Study does not match Participant.forStudy." .
_:cb152d4881209cdbe7ea68b7ac8e8faaf50245e12603c6dde860513ff04d78c0188 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#assignedToArm> ?arm ;\n                    <https://top.scientix.ai/cr/v1#forStudy> ?study .\n              FILTER NOT EXISTS {\n                ?study <https://top.scientix.ai/cr/v1#hasArm> ?arm .\n              }\n            }\n        " .
_:cb154ff4740596af0d78244808fa81924490f09c3151e4cf0e6d10bca960f5031d5 <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> "deprecated" .
_:cb154ff4740596af0d78244808fa81924490f09c3151e4cf0e6d10bca960f5031d5 <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest> <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> .
_:cb162466372680d6d99144b6ea5daf104fd2138c5f8444a0039ada72ec7915c7eef <http://www.w3.org/ns/shacl#message> "VisitOccurrence.visitStatus=COMPLETED but actualEndDate is missing." .
_:cb162466372680d6d99144b6ea5daf104fd2138c5f8444a0039ada72ec7915c7eef <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#visitStatus> \"COMPLETED\" .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#actualEndDate> ?d . }\n            }\n        " .
_:cb16520b85700cdba52aad1a51a3eee5a083dd69adddba7385fbd7018e47e9a9934 <http://www.w3.org/ns/shacl#message> "100% SDV applied to a low-risk factor (over-monitoring; consider risk-based reduction)." .
_:cb16520b85700cdba52aad1a51a3eee5a083dd69adddba7385fbd7018e47e9a9934 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#sdvIntensity> ?i ;\n                    <https://top.scientix.ai/cr/v1#mitigates> ?ra .\n              ?ra <https://top.scientix.ai/cr/v1#riskLevel> \"low\" .\n              FILTER ( ?i = 1.0 )\n            }\n        " .
_:cb168087fed14dea848518f8565d1f91bf0d7df94404534ec4652f8555e32b99da4 <http://www.w3.org/ns/shacl#message> "cr:Assessment must link to the visit during which it was performed (cr:assessedAt). Missing on this assessment." .
_:cb168087fed14dea848518f8565d1f91bf0d7df94404534ec4652f8555e32b99da4 <http://www.w3.org/ns/shacl#minCount> "1"^^<http://www.w3.org/2001/XMLSchema#integer> .
_:cb168087fed14dea848518f8565d1f91bf0d7df94404534ec4652f8555e32b99da4 <http://www.w3.org/ns/shacl#path> <https://top.scientix.ai/cr/v1#assessedAt> .
_:cb16e8a89f3380cd45c36e3f9af59c4ddf4623146ec9b95970321aa897521415dac <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <https://top.scientix.ai/tmf/v1#documents> .
_:cb16e8a89f3380cd45c36e3f9af59c4ddf4623146ec9b95970321aa897521415dac <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest> <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> .
_:cb1728a52fee8b8451ea01a1188bc5216422f92636d4de6ba8729f9fd289ce5af2d <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> "minor" .
_:cb1728a52fee8b8451ea01a1188bc5216422f92636d4de6ba8729f9fd289ce5af2d <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest> <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> .
_:cb173a5627d86c02d46a6be82dfe16240a6999ea7b997b338da1572f3d85c3fbdcd <http://www.w3.org/ns/shacl#class> <https://top.scientix.ai/cr/v1#StudyEvent> .
_:cb173a5627d86c02d46a6be82dfe16240a6999ea7b997b338da1572f3d85c3fbdcd <http://www.w3.org/ns/shacl#message> "Observation must reference the StudyEvent it was captured at." .
_:cb173a5627d86c02d46a6be82dfe16240a6999ea7b997b338da1572f3d85c3fbdcd <http://www.w3.org/ns/shacl#minCount> "1"^^<http://www.w3.org/2001/XMLSchema#integer> .
