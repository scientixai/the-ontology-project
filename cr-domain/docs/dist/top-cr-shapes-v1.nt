_:cb14dcfc16ce9fad2423deaac47c6ab5a3cd864586eece468dd417b22399a1e45a7 <http://www.w3.org/ns/shacl#message> "SUSAR submitted after regulatory deadline (submissionDate > reportingDeadline)." .
_:cb14dcfc16ce9fad2423deaac47c6ab5a3cd864586eece468dd417b22399a1e45a7 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#submissionDate> ?sub ;\n                    <https://top.scientix.ai/cr/v1#reportingDeadline> ?dl .\n              BIND(xsd:date(?dl) AS ?dlDate)\n              FILTER ( ?sub > ?dlDate )\n            }\n        " .
_:cb152d4881209cdbe7ea68b7ac8e8faaf50245e12603c6dde860513ff04d78c0188 <http://www.w3.org/ns/shacl#message> "Participant.assignedToArm references an Arm whose parent Study does not match Participant.forStudy." .
_:cb152d4881209cdbe7ea68b7ac8e8faaf50245e12603c6dde860513ff04d78c0188 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#assignedToArm> ?arm ;\n                    <https://top.scientix.ai/cr/v1#forStudy> ?study .\n              FILTER NOT EXISTS {\n                ?study <https://top.scientix.ai/cr/v1#hasArm> ?arm .\n              }\n            }\n        " .
