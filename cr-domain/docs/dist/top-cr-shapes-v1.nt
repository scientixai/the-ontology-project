_:cb1eb1aa2e68ee1f474e67a2c18bd64ebdae998a6729bb840c62fbe300584558430 <http://www.w3.org/ns/shacl#minCount> "1"^^<http://www.w3.org/2001/XMLSchema#integer> .
_:cb1eb1aa2e68ee1f474e67a2c18bd64ebdae998a6729bb840c62fbe300584558430 <http://www.w3.org/ns/shacl#path> <https://top.scientix.ai/v1#recordedAt> .
_:cb1ecac955daf0f01fa8f8e563cebe59e298466158b9fb91cd2790e8ebc4058f260 <http://www.w3.org/ns/shacl#message> "Site activated without a complete Regulatory and Budget & Contracting work stream." .
_:cb1ecac955daf0f01fa8f8e563cebe59e298466158b9fb91cd2790e8ebc4058f260 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?anyStream .\n              FILTER (\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?r .\n                             ?r a <https://top.scientix.ai/cr/v1#RegulatoryWorkStream> ;\n                                <https://top.scientix.ai/cr/v1#streamStatus> \"complete\" . }\n                || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasWorkStream> ?b .\n                             ?b a <https://top.scientix.ai/cr/v1#BudgetContractingWorkStream> ;\n                                <https://top.scientix.ai/cr/v1#streamStatus> \"complete\" . }\n              )\n            }\n        " .
