_:cb1da8ee017e86038dbd3ccded55d8d4c844a1d66dc3d3f94ccb2d590ec901eb209 <http://www.w3.org/ns/shacl#message> "Nonclinical finding is not addressed by any clinical-protocol safety assessment (broken IND narrative -> clinical-hold risk)." .
_:cb1da8ee017e86038dbd3ccded55d8d4c844a1d66dc3d3f94ccb2d590ec901eb209 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this a <https://top.scientix.ai/cr/v1#NonclinicalFinding> .\n              FILTER NOT EXISTS {\n                ?sa a <https://top.scientix.ai/cr/v1#SafetyAssessment> ;\n                    <https://top.scientix.ai/cr/v1#addressesFinding> $this .\n              }\n            }\n        " .
