_:cb214f24f50bfad9b6c941d964b7b73298fbd093c94bac19fc5a3066092d489ca2c <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"WITHDRAWN\" .\n              FILTER NOT EXISTS {\n                $this <https://top.scientix.ai/cr/v1#hasWithdrawalRecord> ?w .\n                ?w <https://top.scientix.ai/cr/v1#withdrawalCategory> \"CONSENT_WITHDRAWN\" .\n              }\n            }\n        " .
