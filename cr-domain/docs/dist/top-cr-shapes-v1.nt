_:cbd767fcb98266bbe97cd87afe50fd55acae273f28c2b3a25d7b7a26ac2c229e79 <http://www.w3.org/ns/shacl#message> "cr:withdrawalDate precedes the consent top:validFrom — withdrawal cannot predate the consent itself." .
_:cbd767fcb98266bbe97cd87afe50fd55acae273f28c2b3a25d7b7a26ac2c229e79 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#withdrawalDate> ?wd ;\n                    <https://top.scientix.ai/v1#validFrom> ?vf .\n              FILTER ( ?wd < xsd:date(?vf) )\n            }\n        " .
