_:cb10cc6e59a6d2db7613a5194050e0c4aa4f48010c50c278c5c003f4f0eb8cd8d15 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#timing> ?t . }\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#precedes> ?o . }\n              FILTER NOT EXISTS { ?p <https://top.scientix.ai/cr/v1#precedes> $this . }\n            }\n        " .
_:cb10ed5cf425231f1e69ba12c515226b4b7c0fe6619117321758f382cb27a4a90e3 <http://www.w3.org/ns/shacl#message> "EOP2 meeting lacks a binding agreement and/or a risk register (readiness warning)." .
_:cb10ed5cf425231f1e69ba12c515226b4b7c0fe6619117321758f382cb27a4a90e3 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#meetingType> \"EOP2\" .\n              FILTER ( NOT EXISTS { $this <https://top.scientix.ai/cr/v1#producedAgreement> ?a }\n                       || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasRiskRegister> ?r } )\n            }\n        " .
_:cb113003e55aef8ced5782d7ccc9adceff02ed4a911755868bf2a05c741e0a8d042 <http://www.w3.org/ns/shacl#message> "Participant.participantStatus=RANDOMIZED but missing assignedToArm or randomizationDate." .
_:cb113003e55aef8ced5782d7ccc9adceff02ed4a911755868bf2a05c741e0a8d042 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> \"RANDOMIZED\" .\n              FILTER (\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#assignedToArm> ?a . } ||\n                NOT EXISTS { $this <https://top.scientix.ai/cr/v1#randomizationDate> ?d . }\n              )\n            }\n        " .
_:cb11334cb11ddf71ee5550f23e888f6dc1d69f871a4d0abf482bedddfe5dc286703 <http://www.w3.org/ns/shacl#message> "Actual visit's observedAt falls outside the planned window of the visit it realizes (out-of-window) — review materiality." .
_:cb11334cb11ddf71ee5550f23e888f6dc1d69f871a4d0abf482bedddfe5dc286703 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#realizes> ?pv ;\n                    <https://top.scientix.ai/v1#observedAt> ?t .\n              ?pv a <https://top.scientix.ai/cr/v1#PlannedVisit> ;\n                  <https://top.scientix.ai/cr/v1#windowStart> ?ws ;\n                  <https://top.scientix.ai/cr/v1#windowEnd> ?we .\n              FILTER ( ?t < ?ws || ?t > ?we )\n            }\n        " .
