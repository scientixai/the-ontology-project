_:cb1de4b7ac2a1bc63d04e5fb708a59fbe2165b5a85194d54e742667fc76684c872b <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#windowStatus> \"OUT_OF_WINDOW\" .\n              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#associatedDeviation> ?d . }\n            }\n        " .
