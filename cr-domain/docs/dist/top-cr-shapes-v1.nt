_:cb1be24319a21f06bc50d846634d87464360418f5738a2491e37357fc9809d7b800 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this   <https://top.scientix.ai/cr/v1#realizes> ?pa ;\n                      <https://top.scientix.ai/v1#observedAt> ?ta .\n              ?pa     <https://top.scientix.ai/cr/v1#precedes> ?pb .\n              ?other  <https://top.scientix.ai/cr/v1#realizes> ?pb ;\n                      <https://top.scientix.ai/v1#observedAt> ?tb .\n              FILTER ( ?ta > ?tb )\n            }\n        " .
