_:cb175daecd7329007ffc19c50bd96bb44db718e9b93cd8f498f128a85f48600f972 <http://www.w3.org/ns/shacl#message> "Deviation event has no recorded antecedent (latent cause not captured)." .
_:cb175daecd7329007ffc19c50bd96bb44db718e9b93cd8f498f128a85f48600f972 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              FILTER NOT EXISTS { ?a <https://top.scientix.ai/cr/v1#manifestsAs> $this . }\n            }\n        " .
_:cb17945289ec22495a1672a0eaf4c9e263ecf897ea88c5b56f0a10674cf8bfeeb47 <http://www.w3.org/ns/shacl#message> "Participant is in a post-consent state but has no InformedConsentAct with consentStatus=OBTAINED. ICH E6(R3) §2.4 violation." .
_:cb17945289ec22495a1672a0eaf4c9e263ecf897ea88c5b56f0a10674cf8bfeeb47 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#participantStatus> ?s .\n              FILTER ( ?s IN (\n                \"ENROLLED\", \"RANDOMIZED\", \"ON_TREATMENT\",\n                \"IN_FOLLOW_UP\", \"COMPLETED\", \"WITHDRAWN\",\n                \"DISCONTINUED\", \"LOST_TO_FOLLOW_UP\"\n              ) )\n              FILTER NOT EXISTS {\n                $this <https://top.scientix.ai/cr/v1#hasInformedConsentAct> ?c .\n                ?c <https://top.scientix.ai/cr/v1#consentStatus> \"OBTAINED\" .\n              }\n            }\n        " .
_:cb17c55734a6a0e9fba298668509fafeb412a7b2e173e436afe8e432eef7be43392 <http://www.w3.org/ns/shacl#in> _:cbac5719d2335c0df721046582fda2316c468675d72e8c0a786e52f9c8fc971060 .
_:cb17c55734a6a0e9fba298668509fafeb412a7b2e173e436afe8e432eef7be43392 <http://www.w3.org/ns/shacl#message> "Deviation event must carry a category (critical/major/minor)." .
_:cb17c55734a6a0e9fba298668509fafeb412a7b2e173e436afe8e432eef7be43392 <http://www.w3.org/ns/shacl#minCount> "1"^^<http://www.w3.org/2001/XMLSchema#integer> .
_:cb17c55734a6a0e9fba298668509fafeb412a7b2e173e436afe8e432eef7be43392 <http://www.w3.org/ns/shacl#path> <https://top.scientix.ai/cr/v1#deviationCategory> .
