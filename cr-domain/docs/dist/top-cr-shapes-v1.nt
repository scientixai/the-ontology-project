_:cbcd4c95a7aee25cc953501ecc9cb29652c92f9106af3e3d02c26f8b8d7abb7748 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#meetingType> \"Pre-IND\" .\n              FILTER ( NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasBriefingBook> ?b }\n                       || NOT EXISTS { $this <https://top.scientix.ai/cr/v1#hasQuestion> ?q } )\n            }\n        " .
