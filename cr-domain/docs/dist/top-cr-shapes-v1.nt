_:cb1e92c1606a67d2375dd99cf560c95231e7cc5699846d6a6ae7c3c4b61cfb0a835 <http://www.w3.org/ns/shacl#message> "Recruit has 6+ contact attempts but is still in RESPONDED or CONTACTED state. Consider transitioning to DROPPED." .
_:cb1e92c1606a67d2375dd99cf560c95231e7cc5699846d6a6ae7c3c4b61cfb0a835 <http://www.w3.org/ns/shacl#select> "\n            SELECT $this WHERE {\n              $this <https://top.scientix.ai/cr/v1#contactAttempts> ?n ;\n                    <https://top.scientix.ai/cr/v1#recruitStatus> ?s .\n              FILTER ( ?n >= 6 && ?s IN (\"RESPONDED\", \"CONTACTED\") )\n            }\n        " .
