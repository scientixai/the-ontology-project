@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top: <https://top.scientix.ai/v1#> .

cr:addressesFinding a owl:ObjectProperty ;
    rdfs:domain cr:SafetyAssessment ;
    rdfs:range cr:NonclinicalFinding ;
    top:flavor "Additive" .

cr:hasBriefingBook a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:BriefingBook ;
    top:flavor "Additive" .

cr:hasQuestion a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:RegulatoryQuestion ;
    top:flavor "Additive" .

cr:identifiedIn a owl:ObjectProperty ;
    rdfs:domain cr:NonclinicalFinding ;
    rdfs:range cr:GLPToxReport ;
    top:flavor "Additive" .

cr:placedOn a owl:ObjectProperty ;
    rdfs:domain cr:ClinicalHold ;
    rdfs:range cr:INDApplication ;
    top:flavor "Additive" .

cr:proposedPosition a owl:DatatypeProperty ;
    rdfs:label "proposed position" ;
    rdfs:domain cr:RegulatoryQuestion ;
    top:flavor "Additive" .

cr:tracesToNonclinical a owl:ObjectProperty ;
    rdfs:domain cr:INDApplication ;
    rdfs:range cr:GLPToxReport ;
    top:flavor "Additive" .

cr:ClinicalHold a owl:Class ;
    rdfs:label "Clinical Hold" ;
    rdfs:comment "An FDA order that halts or prevents a trial from proceeding." ;
    rdfs:subClassOf top:Outcome .

cr:SafetyAssessment a owl:Class ;
    rdfs:label "Safety Assessment" ;
    rdfs:comment "A clinical-protocol safety monitoring provision (e.g. CBC monitoring + dose-hold)." ;
    rdfs:subClassOf top:Constraint .

cr:GLPToxReport a owl:Class ;
    rdfs:label "GLP Toxicology Report" ;
    rdfs:comment "A GLP toxicology study report supporting safe human dosing." ;
    rdfs:subClassOf top:Evidence .

cr:INDApplication a owl:Class ;
    rdfs:label "IND Application" ;
    rdfs:comment "The submission authorizing human dosing; starts a 30-day review clock (top:observedAt = submission) after which trials may proceed unless a clinical hold is placed." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:NonclinicalFinding a owl:Class ;
    rdfs:label "Nonclinical Finding" ;
    rdfs:comment "An observed animal toxicity/finding that the clinical protocol must address." ;
    rdfs:subClassOf top:Outcome .

cr:RegulatoryQuestion a owl:Class ;
    rdfs:label "Regulatory Question" ;
    rdfs:comment "A briefing-book question; should carry a proposed position (FDA punishes vague questions)." ;
    rdfs:subClassOf top:Evidence .

