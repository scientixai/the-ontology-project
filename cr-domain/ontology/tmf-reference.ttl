@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tmf: <https://top.scientix.ai/tmf/v1#> .
@prefix top: <https://top.scientix.ai/v1#> .

tmf:CAPALog a tmf:TMFArtifactType ;
    rdfs:label "CAPA Log" ;
    skos:broader tmf:Zone_TrialManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "CAPA Log" ;
    tmf:records cr:CAPA .

tmf:ClinicalTrialAgreementDoc a tmf:TMFArtifactType ;
    rdfs:label "Clinical Trial Agreement (artifact)" ;
    skos:broader tmf:Zone_SiteManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Clinical Trial Agreement" ;
    tmf:documents cr:ClinicalTrialAgreement .

tmf:CurriculumVitae a tmf:TMFArtifactType ;
    rdfs:label "Curriculum Vitae" ;
    skos:broader tmf:Zone_SiteManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Curriculum Vitae" ;
    tmf:documents cr:Credential .

tmf:DataManagementPlan a tmf:TMFArtifactType ;
    rdfs:label "Data Management Plan" ;
    skos:broader tmf:Zone_TrialManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Data Management Plan" ;
    tmf:documents cr:DataElementDef .

tmf:DelegationOfAuthorityLog a tmf:TMFArtifactType ;
    rdfs:label "Delegation of Authority Log" ;
    skos:broader tmf:Zone_SiteManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Delegation of Authority Log" ;
    tmf:records cr:Delegation .

tmf:FinancialDisclosureForm a tmf:TMFArtifactType ;
    rdfs:label "Financial Disclosure Form" ;
    skos:broader tmf:Zone_SiteManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Financial Disclosure Form" ;
    tmf:documents cr:StudySite .

tmf:Form1572 a tmf:TMFArtifactType ;
    rdfs:label "Form FDA 1572" ;
    skos:broader tmf:Zone_SiteManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Form FDA 1572" ;
    tmf:documents cr:StudySite .

tmf:IRBApprovalLetter a tmf:TMFArtifactType ;
    rdfs:label "IRB/IEC Approval Letter" ;
    skos:broader tmf:Zone_SiteManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "IRB/IEC Approval Letter" ;
    tmf:documents cr:IRBApproval .

tmf:InformedConsentForm a tmf:TMFArtifactType ;
    rdfs:label "Informed Consent Form" ;
    skos:broader tmf:Zone_SiteManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Informed Consent Form" ;
    tmf:documents cr:InformedConsent .

tmf:InvestigatorBrochure a tmf:TMFArtifactType ;
    rdfs:label "Investigator Brochure" ;
    skos:broader tmf:Zone_CentralTrialDocs ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Investigator Brochure" ;
    tmf:documents cr:InvestigationalProduct .

tmf:MonitoringPlan a tmf:TMFArtifactType ;
    rdfs:label "Monitoring Plan" ;
    skos:broader tmf:Zone_TrialManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Monitoring Plan" ;
    tmf:documents cr:MitigationPlan,
        cr:RiskAssessment .

tmf:Protocol a tmf:TMFArtifactType ;
    rdfs:label "Protocol" ;
    skos:broader tmf:Zone_CentralTrialDocs ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Protocol" ;
    tmf:defines cr:CriticalToQualityFactor,
        cr:EligibilityCriterion,
        cr:Endpoint .

tmf:ProtocolDeviationLog a tmf:TMFArtifactType ;
    rdfs:label "Protocol Deviation Log" ;
    skos:broader tmf:Zone_TrialManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Protocol Deviation Log" ;
    tmf:records cr:DeviationEvent .

tmf:SAEReport a tmf:TMFArtifactType ;
    rdfs:label "SAE Report" ;
    skos:broader tmf:Zone_SafetyReporting ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "SAE Report" ;
    tmf:records cr:SafetyReport .

tmf:ScheduleOfActivities a tmf:TMFArtifactType ;
    rdfs:label "Schedule of Activities" ;
    skos:broader tmf:Zone_CentralTrialDocs ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Schedule of Activities" ;
    tmf:defines cr:ScheduleTimeline .

tmf:SiteActivationManual a tmf:TMFArtifactType ;
    rdfs:label "Site Activation Manual" ;
    skos:broader tmf:Zone_TrialManagement ;
    skos:inScheme tmf:TMFReferenceModel ;
    skos:prefLabel "Site Activation Manual" ;
    tmf:documents cr:SiteActivation .

tmf:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:comment "The artifact establishes/specifies the entity (e.g. a Protocol defines the CtQ factors)." ;
    rdfs:subPropertyOf tmf:concerns ;
    top:flavor "Additive" .

tmf:documents a owl:ObjectProperty ;
    rdfs:label "documents" ;
    rdfs:comment "The artifact describes/evidences the entity (e.g. a Monitoring Plan documents the mitigation plan)." ;
    rdfs:subPropertyOf tmf:concerns ;
    top:flavor "Additive" .

tmf:records a owl:ObjectProperty ;
    rdfs:label "records" ;
    rdfs:comment "The artifact is a running log of the entity's instances (e.g. a Deviation Log records deviation events)." ;
    rdfs:subPropertyOf tmf:concerns ;
    top:flavor "Additive" .

tmf:Zone_SafetyReporting a skos:Concept ;
    skos:prefLabel "Safety Reporting" ;
    skos:topConceptOf tmf:TMFReferenceModel .

tmf:Zone_CentralTrialDocs a skos:Concept ;
    skos:prefLabel "Central Trial Documents" ;
    skos:topConceptOf tmf:TMFReferenceModel .

tmf:concerns a owl:ObjectProperty ;
    rdfs:label "concerns" ;
    rdfs:comment "The domain class whose instances this artifact type carries (general bridge)." ;
    rdfs:domain tmf:TMFArtifactType ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

tmf:Zone_TrialManagement a skos:Concept ;
    skos:prefLabel "Trial Management" ;
    skos:topConceptOf tmf:TMFReferenceModel .

tmf:Zone_SiteManagement a skos:Concept ;
    skos:prefLabel "Site Management" ;
    skos:topConceptOf tmf:TMFReferenceModel .

tmf:TMFArtifactType a owl:Class ;
    rdfs:label "TMF Artifact Type" ;
    rdfs:comment "A kind of trial-master-file document (the document-type binding target)." ;
    rdfs:subClassOf skos:Concept .

tmf:TMFReferenceModel a skos:ConceptScheme ;
    rdfs:label "TOP TMF artifact-type scheme" ;
    rdfs:comment "A SKOS scheme of trial-master-file artifact types, aligned by name to the DIA TMF Reference Model; each artifact type carries content bridges to the domain classes it concerns." .

