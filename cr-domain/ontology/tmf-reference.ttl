@prefix tmf:  <https://top.scientix.ai/tmf/v1#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# TMF-to-ontology binding (the document boundary). Two bindings, kept distinct:
#   1. document-type binding — "this artifact is a Protocol Deviation Log" (a SKOS concept
#      aligned to the DIA TMF Reference Model). The filing-cabinet half.
#   2. content binding — "the facts inside it mean cr:DeviationEvent" (a bridge property to
#      the domain class). The comprehension half, and the reason the ontology exists.
#
# COMMONS-vs-SYSTEM SEAM: this file is the MAP only — the artifact taxonomy (align) and the
# artifact-to-domain bridges (build). The runtime — classifying a document to its artifact
# type, extracting its facts, and asserting prov:wasDerivedFrom — is the consuming system,
# deliberately NOT modeled here.
#
# LICENSING FLAG (like ICH): the DIA TMF Reference Model is a licensed artifact. We align by
# zone/artifact NAME with our own stable IRIs; exact DIA artifact numbering is to be reconciled
# against the licensed model, not transcribed here.

tmf:TMFReferenceModel a skos:ConceptScheme ;
    rdfs:label "TOP TMF artifact-type scheme" ;
    rdfs:comment "A SKOS scheme of trial-master-file artifact types, aligned by name to the DIA TMF Reference Model; each artifact type carries content bridges to the domain classes it concerns." .

tmf:TMFArtifactType a owl:Class ; rdfs:subClassOf skos:Concept ;
    rdfs:label "TMF Artifact Type" ;
    rdfs:comment "A kind of trial-master-file document (the document-type binding target)." .

# ---- Bridge properties: the content binding (artifact type -> domain class it concerns) ----
tmf:concerns a owl:ObjectProperty ; rdfs:domain tmf:TMFArtifactType ; rdfs:range owl:Class ;
    rdfs:label "concerns" ; rdfs:comment "The domain class whose instances this artifact type carries (general bridge)." .
tmf:defines a owl:ObjectProperty ; rdfs:subPropertyOf tmf:concerns ;
    rdfs:label "defines" ; rdfs:comment "The artifact establishes/specifies the entity (e.g. a Protocol defines the CtQ factors)." .
tmf:records a owl:ObjectProperty ; rdfs:subPropertyOf tmf:concerns ;
    rdfs:label "records" ; rdfs:comment "The artifact is a running log of the entity's instances (e.g. a Deviation Log records deviation events)." .
tmf:documents a owl:ObjectProperty ; rdfs:subPropertyOf tmf:concerns ;
    rdfs:label "documents" ; rdfs:comment "The artifact describes/evidences the entity (e.g. a Monitoring Plan documents the mitigation plan)." .

# ---- Zones (broader groupings; DIA zone names) ----
tmf:Zone_TrialManagement     a skos:Concept ; skos:topConceptOf tmf:TMFReferenceModel ; skos:prefLabel "Trial Management" .
tmf:Zone_CentralTrialDocs    a skos:Concept ; skos:topConceptOf tmf:TMFReferenceModel ; skos:prefLabel "Central Trial Documents" .
tmf:Zone_SiteManagement      a skos:Concept ; skos:topConceptOf tmf:TMFReferenceModel ; skos:prefLabel "Site Management" .
tmf:Zone_SafetyReporting     a skos:Concept ; skos:topConceptOf tmf:TMFReferenceModel ; skos:prefLabel "Safety Reporting" .

# ---- Artifact types + their content bridges to cr: domain classes ----
tmf:Protocol a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_CentralTrialDocs ;
    skos:prefLabel "Protocol" ; rdfs:label "Protocol" ;
    tmf:defines cr:CriticalToQualityFactor, cr:EligibilityCriterion, cr:Endpoint .

tmf:ProtocolDeviationLog a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_TrialManagement ;
    skos:prefLabel "Protocol Deviation Log" ; rdfs:label "Protocol Deviation Log" ;
    tmf:records cr:DeviationEvent .

tmf:CAPALog a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_TrialManagement ;
    skos:prefLabel "CAPA Log" ; rdfs:label "CAPA Log" ;
    tmf:records cr:CAPA .

tmf:MonitoringPlan a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_TrialManagement ;
    skos:prefLabel "Monitoring Plan" ; rdfs:label "Monitoring Plan" ;
    tmf:documents cr:MitigationPlan, cr:RiskAssessment .

tmf:DelegationOfAuthorityLog a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SiteManagement ;
    skos:prefLabel "Delegation of Authority Log" ; rdfs:label "Delegation of Authority Log" ;
    tmf:records cr:Delegation .

tmf:InformedConsentForm a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SiteManagement ;
    skos:prefLabel "Informed Consent Form" ; rdfs:label "Informed Consent Form" ;
    tmf:documents cr:InformedConsent .

tmf:SAEReport a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SafetyReporting ;
    skos:prefLabel "SAE Report" ; rdfs:label "SAE Report" ;
    tmf:records cr:SafetyReport .

# ---- Study start-up package artifact types (the documents a site receives at award) ----
tmf:InvestigatorBrochure a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_CentralTrialDocs ;
    skos:prefLabel "Investigator Brochure" ; rdfs:label "Investigator Brochure" ;
    tmf:documents cr:InvestigationalProduct .
tmf:ScheduleOfActivities a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_CentralTrialDocs ;
    skos:prefLabel "Schedule of Activities" ; rdfs:label "Schedule of Activities" ;
    tmf:defines cr:ScheduleTimeline .
tmf:ClinicalTrialAgreementDoc a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SiteManagement ;
    skos:prefLabel "Clinical Trial Agreement" ; rdfs:label "Clinical Trial Agreement (artifact)" ;
    tmf:documents cr:ClinicalTrialAgreement .
tmf:FinancialDisclosureForm a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SiteManagement ;
    skos:prefLabel "Financial Disclosure Form" ; rdfs:label "Financial Disclosure Form" ;
    tmf:documents cr:StudySite .
tmf:Form1572 a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SiteManagement ;
    skos:prefLabel "Form FDA 1572" ; rdfs:label "Form FDA 1572" ;
    tmf:documents cr:StudySite .
tmf:CurriculumVitae a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SiteManagement ;
    skos:prefLabel "Curriculum Vitae" ; rdfs:label "Curriculum Vitae" ;
    tmf:documents cr:Credential .
tmf:IRBApprovalLetter a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_SiteManagement ;
    skos:prefLabel "IRB/IEC Approval Letter" ; rdfs:label "IRB/IEC Approval Letter" ;
    tmf:documents cr:IRBApproval .
tmf:SiteActivationManual a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_TrialManagement ;
    skos:prefLabel "Site Activation Manual" ; rdfs:label "Site Activation Manual" ;
    tmf:documents cr:SiteActivation .
tmf:DataManagementPlan a tmf:TMFArtifactType ; skos:inScheme tmf:TMFReferenceModel ; skos:broader tmf:Zone_TrialManagement ;
    skos:prefLabel "Data Management Plan" ; rdfs:label "Data Management Plan" ;
    tmf:documents cr:DataElementDef .
