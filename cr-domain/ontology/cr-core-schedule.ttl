@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cr:anchorDate a owl:DatatypeProperty ;
    rdfs:label "anchor date" ;
    rdfs:comment "The resolved anchor (e.g. the subject's enrollment date) from which target dates are computed." ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:atVisit a owl:ObjectProperty ;
    rdfs:label "at visit" ;
    rdfs:comment "The actual visit an assessment was performed within." ;
    rdfs:domain cr:Assessment ;
    rdfs:range cr:Visit ;
    top:flavor "Additive" .

cr:fromTimeline a owl:ObjectProperty ;
    rdfs:label "from timeline" ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range cr:ScheduleTimeline ;
    top:flavor "Additive" .

cr:hasPlannedActivity a owl:ObjectProperty ;
    rdfs:label "has planned activity" ;
    rdfs:domain cr:PlannedEncounter ;
    rdfs:range cr:PlannedActivity ;
    top:flavor "Additive" .

cr:hasPlannedEncounter a owl:ObjectProperty ;
    rdfs:label "has planned encounter" ;
    rdfs:domain cr:ScheduleTimeline ;
    rdfs:range cr:PlannedEncounter ;
    top:flavor "Additive" .

cr:hasPlannedVisit a owl:ObjectProperty ;
    rdfs:label "has planned visit" ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range cr:PlannedVisit ;
    top:flavor "Additive" .

cr:ofProtocolVersion a owl:ObjectProperty ;
    rdfs:label "of protocol version" ;
    rdfs:domain cr:ScheduleTimeline ;
    rdfs:range cr:ProtocolVersion ;
    top:flavor "Additive" .

cr:offsetDays a owl:DatatypeProperty ;
    rdfs:label "offset (days)" ;
    rdfs:domain cr:Timing ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:offsetHours a owl:DatatypeProperty ;
    rdfs:label "offset (hours)" ;
    rdfs:comment "Sub-visit timing offset in hours (e.g. bloods 2h after the ECG)." ;
    rdfs:domain cr:Timing ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:precedes a owl:ObjectProperty ;
    rdfs:label "precedes" ;
    rdfs:comment "Ordering-only constraint: this activity must occur before another, independent of clock timing (e.g. QS2 before ECG)." ;
    rdfs:domain cr:PlannedActivity ;
    rdfs:range cr:PlannedActivity ;
    top:flavor "Additive" .

cr:projectsEncounter a owl:ObjectProperty ;
    rdfs:label "projects encounter" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range cr:PlannedEncounter ;
    top:flavor "Additive" .

cr:realizes a owl:ObjectProperty ;
    rdfs:label "realizes" ;
    rdfs:comment "Links an actual execution event (cr:Visit, cr:Assessment) to the planned node it fulfils — the join for planned-vs-actual reconciliation." ;
    top:flavor "Additive" .

cr:relativeTo a owl:ObjectProperty ;
    rdfs:label "relative to" ;
    rdfs:comment "The anchor the offset is measured from: another planned node, or an anchor-event type (e.g. the enrollment act)." ;
    rdfs:domain cr:Timing ;
    top:flavor "Additive" .

cr:repeatIntervalDays a owl:DatatypeProperty ;
    rdfs:label "repeat interval (days)" ;
    rdfs:domain cr:RepeatingPlannedActivity ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:repeatUntilDay a owl:DatatypeProperty ;
    rdfs:label "repeat until (study day)" ;
    rdfs:domain cr:RepeatingPlannedActivity ;
    rdfs:range xsd:integer ;
    top:flavor "Additive" .

cr:scheduleForSubject a owl:ObjectProperty ;
    rdfs:label "schedule for subject" ;
    rdfs:domain cr:ParticipantSchedule ;
    rdfs:range cr:StudySubject ;
    top:flavor "Additive" .

cr:targetDate a owl:DatatypeProperty ;
    rdfs:label "target date" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:timing a owl:ObjectProperty ;
    rdfs:label "timing" ;
    rdfs:comment "The relative-timing rule positioning a planned encounter or activity." ;
    rdfs:range cr:Timing ;
    top:flavor "Additive" .

cr:timingType a owl:DatatypeProperty ;
    rdfs:label "timing type" ;
    rdfs:comment "before | after | fixed — the sense of the offset relative to the anchor." ;
    rdfs:domain cr:Timing ;
    top:flavor "Additive" .

cr:window a owl:ObjectProperty ;
    rdfs:label "window" ;
    rdfs:domain cr:Timing ;
    rdfs:range cr:Window ;
    top:flavor "Additive" .

cr:windowEnd a owl:DatatypeProperty ;
    rdfs:label "window end" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:windowLowerDays a owl:DatatypeProperty ;
    rdfs:label "window lower (days)" ;
    rdfs:domain cr:Window ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:windowStart a owl:DatatypeProperty ;
    rdfs:label "window start" ;
    rdfs:domain cr:PlannedVisit ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:windowUpperDays a owl:DatatypeProperty ;
    rdfs:label "window upper (days)" ;
    rdfs:domain cr:Window ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:RepeatingPlannedActivity a owl:Class ;
    rdfs:label "Repeating Planned Activity" ;
    rdfs:comment "A planned activity that recurs on an interval until a stop condition (e.g. a daily participant diary until Day N; dosing every 7 days)." ;
    rdfs:subClassOf cr:PlannedActivity .

cr:PlannedEncounter a owl:Class ;
    rdfs:label "Planned Encounter" ;
    rdfs:comment "A planned visit slot on the timeline (USDM Encounter). Positioned by a cr:Timing relative to an anchor; actual cr:Visits are reconciled against it." ;
    rdfs:subClassOf top:Constraint .

cr:ScheduleTimeline a owl:Class ;
    rdfs:label "Schedule Timeline" ;
    rdfs:comment "The planned Schedule of Activities for a protocol version, as a timeline of planned encounters and activities. Bitemporal: a protocol amendment supersedes it, so the schedule is reconstructable as-of any date." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:Window a owl:Class ;
    rdfs:label "Window" ;
    rdfs:comment "An allowed tolerance around a planned time: a lower and an upper offset in days (e.g. [-2 days, +2 days])." ;
    rdfs:subClassOf top:Constraint .

cr:ParticipantSchedule a owl:Class ;
    rdfs:label "Participant Schedule" ;
    rdfs:comment "The schedule projected for a specific subject from a ScheduleTimeline once an anchor date (e.g. enrollment) is known. Bitemporal: re-projected when the governing protocol version changes." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:PlannedActivity a owl:Class ;
    rdfs:label "Planned Activity" ;
    rdfs:comment "A planned activity within an encounter (USDM ScheduledActivityInstance) — e.g. ECG, blood draw, PRO. Positioned by a cr:Timing and/or an ordering edge (cr:precedes)." ;
    rdfs:subClassOf top:Constraint .

cr:PlannedVisit a owl:Class ;
    rdfs:label "Planned Visit" ;
    rdfs:comment "A projected planned visit for a subject: a target date and a resolved window (start/end dates), against which the actual visit is reconciled." ;
    rdfs:subClassOf top:Constraint .

cr:Timing a owl:Class ;
    rdfs:label "Timing" ;
    rdfs:comment "A relative-timing rule: an offset (days or hours) from an anchor — another node, or an anchor event such as enrollment — with an allowed window. The footnote logic, made explicit." ;
    rdfs:subClassOf top:Constraint .

