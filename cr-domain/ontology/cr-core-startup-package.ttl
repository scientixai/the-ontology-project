@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tmf: <https://top.scientix.ai/tmf/v1#> .
@prefix top: <https://top.scientix.ai/v1#> .

cr:BudgetContractingWorkStream a owl:Class ;
    rdfs:label "Budget & Contracting Work Stream" ;
    rdfs:comment "Budget negotiation and contract (CTA) review and execution." ;
    rdfs:subClassOf cr:WorkStream .

cr:ClinOpsWorkStream a owl:Class ;
    rdfs:label "Clinical Operations Work Stream" ;
    rdfs:comment "Enrollment and data-collection readiness from the protocol, SOPs, vendor manuals, monitoring plan, and schedule of activities." ;
    rdfs:subClassOf cr:WorkStream .

cr:RegulatoryWorkStream a owl:Class ;
    rdfs:label "Regulatory Work Stream" ;
    rdfs:comment "IRB submission, ICF customization, and Investigator Site File preparation (CVs/licenses, Form 1572, Delegation-of-Authority log, IRB approval)." ;
    rdfs:subClassOf cr:WorkStream .

cr:activationPackage a owl:ObjectProperty ;
    rdfs:label "activation package" ;
    rdfs:comment "The start-up package this activation drew from (forward edge, for single-pull retrieval)." ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:StudyStartupPackage ;
    top:flavor "Additive" .

cr:consumes a owl:ObjectProperty ;
    rdfs:label "consumes" ;
    rdfs:comment "An input package document the stream uses (its data)." ;
    rdfs:domain cr:WorkStream ;
    rdfs:range cr:StartupArtifact ;
    top:flavor "Additive" .

cr:hasWorkStream a owl:ObjectProperty ;
    rdfs:label "has work stream" ;
    rdfs:comment "The activation work streams whose completion gates this activation." ;
    rdfs:domain cr:SiteActivation ;
    rdfs:range cr:WorkStream ;
    top:flavor "Additive" .

cr:includesArtifact a owl:ObjectProperty ;
    rdfs:label "includes artifact" ;
    rdfs:domain cr:StudyStartupPackage ;
    rdfs:range cr:StartupArtifact ;
    top:flavor "Additive" .

cr:ofArtifactType a owl:ObjectProperty ;
    rdfs:label "of artifact type" ;
    rdfs:comment "Classifies a document instance to its TMF artifact type (the document-type binding)." ;
    rdfs:domain cr:StartupArtifact ;
    rdfs:range tmf:TMFArtifactType ;
    top:flavor "Additive" .

cr:packageForSite a owl:ObjectProperty ;
    rdfs:label "package for site" ;
    rdfs:domain cr:StudyStartupPackage ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:packageForStudy a owl:ObjectProperty ;
    rdfs:label "package for study" ;
    rdfs:domain cr:StudyStartupPackage ;
    rdfs:range cr:Study ;
    top:flavor "Additive" .

cr:produces a owl:ObjectProperty ;
    rdfs:label "produces" ;
    rdfs:comment "A site-specific output the stream generates from the inputs (customized ICF, DoA log, signed CTA...)." ;
    rdfs:domain cr:WorkStream ;
    rdfs:range cr:StartupArtifact ;
    top:flavor "Additive" .

cr:streamForSite a owl:ObjectProperty ;
    rdfs:label "stream for site" ;
    rdfs:domain cr:WorkStream ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:streamStatus a owl:DatatypeProperty ;
    rdfs:label "stream status" ;
    rdfs:comment "planned | active | complete." ;
    rdfs:domain cr:WorkStream ;
    top:flavor "Additive" .

cr:StartupArtifact a owl:Class ;
    rdfs:label "Start-up Artifact" ;
    rdfs:comment "A document instance in (or produced from) the start-up package, classified to a TMF artifact type. Carries the data that the work streams consume and transform." ;
    rdfs:subClassOf top:Evidence .

cr:StudyStartupPackage a owl:Class ;
    rdfs:label "Study Start-up Package" ;
    rdfs:comment "The bundle of document artifacts a site receives on being awarded a study. Not a singular item — a set of typed artifacts; in practice fetched one-by-one from sponsor portals." ;
    rdfs:subClassOf top:Evidence .

cr:WorkStream a owl:Class ;
    rdfs:label "Activation Work Stream" ;
    rdfs:comment "A site-level stream of work triggered by a study award: consumes package documents and produces outputs. Specialized into the three streams below." ;
    rdfs:subClassOf top:Temporal .

