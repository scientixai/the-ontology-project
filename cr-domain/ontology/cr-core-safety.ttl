@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cr:reportsEvent a owl:ObjectProperty ;
    rdfs:domain cr:SafetyReport ;
    rdfs:range cr:SeriousAdverseEvent ;
    top:flavor "Additive" .

cr:sponsorAwareAt a owl:DatatypeProperty ;
    rdfs:label "sponsor aware at" ;
    rdfs:domain cr:SeriousAdverseEvent ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:submittedAt a owl:DatatypeProperty ;
    rdfs:label "submitted at" ;
    rdfs:domain cr:SafetyReport ;
    rdfs:range xsd:dateTime ;
    top:flavor "Additive" .

cr:SafetyReport a owl:Class ;
    rdfs:label "Safety Report" ;
    rdfs:comment "Expedited report of an SAE to the regulator." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:SeriousAdverseEvent a owl:Class ;
    rdfs:label "Serious Adverse Event" ;
    rdfs:comment "An adverse event meeting seriousness criteria (expedited reporting)." ;
    rdfs:subClassOf cr:AdverseEvent .

