@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Pharmacovigilance: expedited SAE reporting clock (bitemporal).

cr:SeriousAdverseEvent a owl:Class ; rdfs:subClassOf cr:AdverseEvent ;
    rdfs:label "Serious Adverse Event" ; rdfs:comment "An adverse event meeting seriousness criteria (expedited reporting)." .
cr:SafetyReport a owl:Class ; rdfs:subClassOf top:Evidence, top:ProvenancedEntity ;
    rdfs:label "Safety Report" ; rdfs:comment "Expedited report of an SAE to the regulator." .

# The clock has three instants: occurrence (top:observedAt on the SAE),
# sponsor awareness, and submission. Compliance = submitted within 15 days of awareness.
cr:sponsorAwareAt a owl:DatatypeProperty ; rdfs:domain cr:SeriousAdverseEvent ;
    rdfs:range xsd:dateTime ; rdfs:label "sponsor aware at" .
cr:reportsEvent a owl:ObjectProperty ; rdfs:domain cr:SafetyReport ; rdfs:range cr:SeriousAdverseEvent .
cr:submittedAt a owl:DatatypeProperty ; rdfs:domain cr:SafetyReport ;
    rdfs:range xsd:dateTime ; rdfs:label "submitted at" .
