######################################################################
# Concepts (permissible values)
######################################################################

ct:C104504 a skos:Concept ;
    skos:prefLabel "Batch Number" ;
    skos:inScheme ct:C215484 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C104504> ;
    skos:definition "A distinctive alpha-numeric identification code assigned by the manufacturer or distributor to a specific quantity of manufactured material or product that is produced in a manner that is expected to render it homogeneous." .

ct:C112279 a skos:Concept ;
    skos:prefLabel "FDA Unique Device Identification" ;
    skos:inScheme ct:C215484 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C112279> ;
    skos:definition "A UDI is a unique numeric or alphanumeric code that includes a device identifier, which is specific to a device model, and a production identifier, which includes the current production information for that specific device, such as the lot or batch number, the serial number and/or expiration date. (FDA)" .

ct:C139173 a skos:Concept ;
    skos:prefLabel "Secondary Endpoint" ;
    skos:inScheme ct:C188726 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C139173> ;
    skos:definition "Endpoint(s) that may provide supportive information about the effect of the study intervention(s) on the primary endpoint or demonstrate additional effects on the disease or condition. (After FDA-NIH Protocol Template)" .

ct:C142424 a skos:Concept ;
    skos:prefLabel "Clinical Development Plan" ;
    skos:inScheme ct:C215478 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C142424> ;
    skos:definition "A document that describes the collection of clinical studies that are to be performed in sequence, or in parallel, with a particular active substance, device, procedure, or treatment strategy, typically with the intention of submitting them as part of an application for a marketing authorization. (CDISC Glossary)" .

ct:C142489 a skos:Concept ;
    skos:prefLabel "Data Safety Monitoring Board" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C142489> ;
    skos:definition "A group of independent experts who are appointed to monitor the safety and scientific integrity of a research intervention, protect the confidentiality of participant data, and to make recommendations to the sponsor regarding the stopping of the trial for safety, efficacy, or for futility. (clinicaltrials.gov)" .

ct:C142578 a skos:Concept ;
    skos:prefLabel "Independent Data Monitoring Committee" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C142578> ;
    skos:definition "A committee established by the sponsor to assess at intervals the progress of a clinical trial, safety data, and critical efficacy variables and recommend to the sponsor whether to continue, modify, or terminate the trial. [ICH E9] (CDISC Glossary)" .

ct:C147145 a skos:Concept ;
    skos:prefLabel "Stratified Randomisation" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C147145> ;
    skos:definition "The process of grouping trial participants into strata according to important prognostic factors and then assigning participants within each stratum to different treatment or control groups using an element of chance and in order to reduce bias." .

ct:C156473 a skos:Concept ;
    skos:prefLabel "NIMP" ;
    skos:inScheme ct:C207418 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C156473> ;
    skos:definition "A medicinal product that is related to the specific needs of the clinical trial as described in the protocol, but not as an investigational medicinal product. NOTE: Auxiliary medicinal products may be authorised for marketing in a country or region or non-authorised. [after EU-CTR]" .

ct:C158128 a skos:Concept ;
    skos:prefLabel "Challenge Agent" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C158128> ;
    skos:definition "A non-investigational medicinal product (NIMP) given to trial subjects to produce a physiological response that is necessary before the pharmacological action of the investigational medicinal product can be assessed. [After Recommendations from the expert group on clinical trials for the implementation of Regulation (EU) No 536/2014' dd 28 June 2017]" .

ct:C163559 a skos:Concept ;
    skos:prefLabel "Exploratory Objective" ;
    skos:inScheme ct:C188725 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C163559> ;
    skos:definition "Additional scientific question(s) within the study that enable further discovery research, beyond the primary and secondary objectives." .

ct:C165822 a skos:Concept ;
    skos:prefLabel "Background Treatment" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C165822> ;
    skos:definition "Medicinal products that are administered to each clinical trial subject, regardless of randomization group, a) to treat the indication which is the object of the study, or b) required in the protocol as part of standard care for a condition that is not the indication under investigation, and is relevant for the clinical trial design. [After Recommendations from the expert group on clinical trials for the implementation of Regulation (EU) No 536/2014' dd 28 June 2017]" .

ct:C165830 a skos:Concept ;
    skos:prefLabel "Real World Data" ;
    skos:inScheme ct:C188727 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C165830> ;
    skos:definition "Data relating to patient health status and/or the delivery of health care routinely collected from sources other than traditional clinical trials. NOTE: Examples of sources include data derived from electronic health records (EHRs); medical claims and billing data; data from product and disease registries; patient-generated data, including from in-home-use settings; and data gathered from other sources that can inform on health status, such as mobile devices. [After 21 U.S.C. 355g(b)).5 and Framework for FDA's Real-World Evidence Program December 2018] See also Real-World Evidence (RWE)" .

ct:C165835 a skos:Concept ;
    skos:prefLabel "Rescue Medicine" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C165835> ;
    skos:definition "Medicinal products identified in the protocol as those that may be administered to subjects when the efficacy of the investigational medicinal product (IMP) is not satisfactory, the effect of the IMP is too great and is likely to cause a hazard to the patient, or to manage an emergency situation. [After EU-CTR Recommendations from the expert group on clinical trials for the implementation of Regulation (EU) No 536/2014' dd 28 June 2017]" .

ct:C170559 a skos:Concept ;
    skos:prefLabel "Exploratory Endpoint" ;
    skos:inScheme ct:C188726 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C170559> ;
    skos:definition "Endpoint(s) that may include clinically important events that are expected to occur too infrequently to show a treatment effect or endpoints that for other reasons are thought to be less likely to show an effect but are included to explore new hypotheses. (After FDA-NIH Protocol Template)" .

ct:C17445 a skos:Concept ;
    skos:prefLabel "Care Provider" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C17445> ;
    skos:definition "The primary person in charge of the care of a patient, usually a family member or a designated health care professional. (NCI)" .

ct:C176263 a skos:Concept ;
    skos:prefLabel "Synthetic Data" ;
    skos:inScheme ct:C188727 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C176263> ;
    skos:definition "Data that are artificially created rather than being generated by actual events. NOTE: Data are often created with the help of algorithms and used for a wide range of activities, including as test data for new products and tools, for model validation, and in AI optimization. [After The Ultimate Guide to Synthetic Data in 2020, August 29, 2020]. See also artificial intelligence." .

ct:C17649 a skos:Concept ;
    skos:prefLabel "Other" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C17649> ;
    skos:definition "Different than the one(s) previously specified or mentioned. (NCI)" .

ct:C18020 a skos:Concept ;
    skos:prefLabel "Diagnostic" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C18020> ;
    skos:definition "Any procedure or test to diagnose a disease or disorder." .

ct:C18240 a skos:Concept ;
    skos:prefLabel "Academic Institution" ;
    skos:inScheme ct:C188724 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C18240> ;
    skos:definition "An organization, such as a college or university, established for the purpose of scholastic pursuit, education, granting degrees, and research." .

ct:C188862 a skos:Concept ;
    skos:prefLabel "Pending Review" ;
    skos:inScheme ct:C188723 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C188862> ;
    skos:definition "A preliminary version of a written work, design, or picture that is awaiting review." .

ct:C188863 a skos:Concept ;
    skos:prefLabel "Regulatory Agency" ;
    skos:inScheme ct:C188724, ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C188863> ;
    skos:definition "An organization (typically a government agency) that is responsible for implementing and enforcing laws, licensing and regulating products and services, promoting the use of standards, and ensuring safety and consumer protections." .

ct:C188864 a skos:Concept ;
    skos:prefLabel "Historical Data" ;
    skos:inScheme ct:C188727 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C188864> ;
    skos:definition "Data from studies that have occurred in the past." .

ct:C188866 a skos:Concept ;
    skos:prefLabel "Data Generated Within Study" ;
    skos:inScheme ct:C188727 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C188866> ;
    skos:definition "Data that are generated from within the current study." .

ct:C199144 a skos:Concept ;
    skos:prefLabel "Government Institute" ;
    skos:inScheme ct:C188724 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C199144> ;
    skos:definition "An organization established, funded, and overseen by a government, which has a specific purpose or intent." .

ct:C19924 a skos:Concept ;
    skos:prefLabel "Principal investigator" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C19924> ;
    skos:definition "A person who has the primary responsibility for the conduct of a clinical study and study-related personnel at a study site. While a single-center study would not include a coordinating investigator, the investigator at the site would fulfill the same responsibilities as a principal investigator." .

ct:C201352 a skos:Concept ;
    skos:prefLabel "End to End" ;
    skos:inScheme ct:C201265 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201352> ;
    skos:definition "A timing relationship defined as the end of one event to the end of another event." .

ct:C201353 a skos:Concept ;
    skos:prefLabel "End to Start" ;
    skos:inScheme ct:C201265 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201353> ;
    skos:definition "A timing relationship defined as the end of one event to the start of another event." .

ct:C201354 a skos:Concept ;
    skos:prefLabel "Start to End" ;
    skos:inScheme ct:C201265 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201354> ;
    skos:definition "A timing relationship defined as the start of one event to the end of another event." .

ct:C201355 a skos:Concept ;
    skos:prefLabel "Start to Start" ;
    skos:inScheme ct:C201265 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201355> ;
    skos:definition "A timing relationship defined as the start of one event to the start of another event." .

ct:C201356 a skos:Concept ;
    skos:prefLabel "After" ;
    skos:inScheme ct:C201264 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201356> ;
    skos:definition "A type of time point relationship that follows a point or period of time within a timeline." .

ct:C201357 a skos:Concept ;
    skos:prefLabel "Before" ;
    skos:inScheme ct:C201264 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201357> ;
    skos:definition "A type of time point relationship that comes before a point or period of time within a timeline." .

ct:C201358 a skos:Concept ;
    skos:prefLabel "Fixed Reference" ;
    skos:inScheme ct:C201264 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201358> ;
    skos:definition "A type of time point relationship that is fixed with respect to a timeline." .

ct:C202579 a skos:Concept ;
    skos:prefLabel "IMP" ;
    skos:inScheme ct:C207418 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C202579> ;
    skos:definition "A medicinal product which is being tested or used as a reference, including as a placebo, in a clinical trial. (Regulation (EU) No 536/2014 Article 2 (5))" .

ct:C207599 a skos:Concept ;
    skos:prefLabel "Outcomes Assessor" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207599> ;
    skos:definition "The individual who evaluates the outcome(s) of interest. (Clinicaltrials.gov)" .

ct:C207600 a skos:Concept ;
    skos:prefLabel "Change In Standard Of Care" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207600> ;
    skos:definition "A change in the standard of care necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207601 a skos:Concept ;
    skos:prefLabel "Change In Strategy" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207601> ;
    skos:definition "A change in the study purpose or intent of the scientific plan necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207602 a skos:Concept ;
    skos:prefLabel "IMP Addition" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207602> ;
    skos:definition "The addition of an investigational medicinal product to a clinical trial design necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207603 a skos:Concept ;
    skos:prefLabel "Inconsistency And/Or Error In The Protocol" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207603> ;
    skos:definition "An error or inconsistency in the protocol necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207604 a skos:Concept ;
    skos:prefLabel "Investigator/Site Feedback" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207604> ;
    skos:definition "Feedback from the investigator or study site necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207605 a skos:Concept ;
    skos:prefLabel "IRB/IEC Feedback" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207605> ;
    skos:definition "Feedback from the institutional review board or independent ethics committee necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207606 a skos:Concept ;
    skos:prefLabel "Manufacturing Change" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207606> ;
    skos:definition "A change to manufacturing processes of the study agents necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207607 a skos:Concept ;
    skos:prefLabel "New Data Available (Other Than Safety Data)" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207607> ;
    skos:definition "Previously unavailable data (other than safety data) becomes available, which necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207608 a skos:Concept ;
    skos:prefLabel "New Regulatory Guidance" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207608> ;
    skos:definition "A regulatory agency has published a guidance document that necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207609 a skos:Concept ;
    skos:prefLabel "New Safety Information Available" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207609> ;
    skos:definition "Previously unavailable safety data becomes available, which necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207610 a skos:Concept ;
    skos:prefLabel "Protocol Design Error" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207610> ;
    skos:definition "A protocol design error necessitates a change(s) to, or formal clarification of, a document." .

ct:C207611 a skos:Concept ;
    skos:prefLabel "Recruitment Difficulty" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207611> ;
    skos:definition "Challenges with subject recruitment necessitates a change(s) to, or formal clarification of, the protocol." .

ct:C207612 a skos:Concept ;
    skos:prefLabel "Regulatory Agency Request To Amend" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207612> ;
    skos:definition "A regulatory agency has expressed a need for a change(s) to, or formal clarification of, the protocol." .

ct:C207613 a skos:Concept ;
    skos:prefLabel "Extension" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207613> ;
    skos:definition "A study design in which subjects enrolled in one study are subsequently continued into a related study for longer term safety, tolerability, and/or effectiveness monitoring." .

ct:C207614 a skos:Concept ;
    skos:prefLabel "Additional Required Treatment" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207614> ;
    skos:definition "A medicinal product that must be administered along with the experimental treatment (e.g., drug studies wherein opioid blockers are administered to prevent overdose)." .

ct:C207615 a skos:Concept ;
    skos:prefLabel "Brief Study Title" ;
    skos:inScheme ct:C207419 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207615> ;
    skos:definition "The short descriptive name for the study." .

ct:C207616 a skos:Concept ;
    skos:prefLabel "Official Study Title" ;
    skos:inScheme ct:C207419 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207616> ;
    skos:definition "The formal descriptive name for the study." .

ct:C207617 a skos:Concept ;
    skos:prefLabel "Public Study Title" ;
    skos:inScheme ct:C207419 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207617> ;
    skos:definition "The descriptive name of the study that is intended for the lay public, written in easily understood language." .

ct:C207618 a skos:Concept ;
    skos:prefLabel "Scientific Study Title" ;
    skos:inScheme ct:C207419 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207618> ;
    skos:definition "A more extensive descriptive name of the study that is intended for medical professionals, written using medical and scientific language." .

ct:C21541 a skos:Concept ;
    skos:prefLabel "Healthcare Facility" ;
    skos:inScheme ct:C188724 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C21541> ;
    skos:definition "The buildings and organizations where healthcare services are provided." .

ct:C215653 a skos:Concept ;
    skos:prefLabel "Disease Incidence" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215653> ;
    skos:definition "A study that assesses the occurrence of new cases of disease, condition, or injury in a defined population over a specified period of time." .

ct:C215654 a skos:Concept ;
    skos:prefLabel "Disease Determinants" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215654> ;
    skos:definition "A study that assesses the variables that influence the occurrence frequency and/or population distribution of a given disease, condition, or injury" .

ct:C215655 a skos:Concept ;
    skos:prefLabel "Disease Prognosis" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215655> ;
    skos:definition "A study that assesses the prediction of the probable course and outcome of a disease, condition, or injury." .

ct:C215656 a skos:Concept ;
    skos:prefLabel "Drug Utilization" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215656> ;
    skos:definition "A study that assesses drug usage patterns for prophylaxis or treatment of health problems, or promoting maintenance of health and well-being." .

ct:C215657 a skos:Concept ;
    skos:prefLabel "Clinical Education" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215657> ;
    skos:definition "A study that assesses the effectiveness of health information on reducing ill health and enhancing good health by influencing beliefs, attitudes, and behavior of individuals and communities." .

ct:C215658 a skos:Concept ;
    skos:prefLabel "Disease Etiology" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215658> ;
    skos:definition "A study that assesses the causative factors associated with a disease, condition, or injury." .

ct:C215659 a skos:Concept ;
    skos:prefLabel "Centrally Sourced" ;
    skos:inScheme ct:C215482, ct:C215483 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215659> ;
    skos:definition "An indication that the entity is obtained from a central source." .

ct:C215660 a skos:Concept ;
    skos:prefLabel "Locally Sourced" ;
    skos:inScheme ct:C215482, ct:C215483 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215660> ;
    skos:definition "An indication that the entity is obtained from a local source." .

ct:C215661 a skos:Concept ;
    skos:prefLabel "Medical Device Company" ;
    skos:inScheme ct:C188724 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215661> ;
    skos:definition "A company licensed to discover, develop, market, and/or distribute medical devices." .

ct:C215662 a skos:Concept ;
    skos:prefLabel "Contract Research" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215662> ;
    skos:definition "Research that is conducted by an individual or organization on behalf of another organization through a contracting mechanism." .

ct:C215663 a skos:Concept ;
    skos:prefLabel "Effective Date" ;
    skos:inScheme ct:C207413 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215663> ;
    skos:definition "The date on which the entity becomes active, goes into effect, or is slated to begin use." .

ct:C215664 a skos:Concept ;
    skos:prefLabel "Issued Date" ;
    skos:inScheme ct:C207413 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215664> ;
    skos:definition "The date on which the entity is officially released, made available, or delivered to its intended recipient." .

ct:C215665 a skos:Concept ;
    skos:prefLabel "Study Subject Safety" ;
    skos:inScheme ct:C215481 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215665> ;
    skos:definition "The condition in which a study subject is free from harmful effects which may arise as a result of study participation." .

ct:C215666 a skos:Concept ;
    skos:prefLabel "Study Subject Rights" ;
    skos:inScheme ct:C215481 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215666> ;
    skos:definition "A study subject's moral, ethical, and legal entitlements before, during, and after the study." .

ct:C215667 a skos:Concept ;
    skos:prefLabel "Study Data Reliability" ;
    skos:inScheme ct:C215481 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215667> ;
    skos:definition "The completeness and accuracy of data as a measure of how well it can be counted on to be consistent and free from errors across time and sources. (IBM)" .

ct:C215668 a skos:Concept ;
    skos:prefLabel "Study Data Robustness" ;
    skos:inScheme ct:C215481 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215668> ;
    skos:definition "The data's ability to remain accurate and relevant despite changes or disruptions to the data environment." .

ct:C215669 a skos:Concept ;
    skos:prefLabel "Co-Sponsor" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215669> ;
    skos:definition "An individual, company, institution, or organization that is designated by the study sponsor as a vested partner in the study." .

ct:C215670 a skos:Concept ;
    skos:prefLabel "Local Sponsor" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215670> ;
    skos:definition "The sponsor's legal representative at a geographical region within which the sponsor has no legal presence. (ICH M11)" .

ct:C215671 a skos:Concept ;
    skos:prefLabel "Dose Escalation Committee" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215671> ;
    skos:definition "A committee established to assess whether a dose adjustment is appropriate and to determine whether the maximum-tolerated dose had been attained, based on a review of available safety and efficacy data at specified time points." .

ct:C215672 a skos:Concept ;
    skos:prefLabel "Clinical Trial Physician" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215672> ;
    skos:definition "Any physician that is associated with clinical trial." .

ct:C215673 a skos:Concept ;
    skos:prefLabel "Pharmacovigilance" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215673> ;
    skos:definition "A group that is responsible for monitoring the safety of medicines and taking action to reduce their risks and increase their benefits." .

ct:C215674 a skos:Concept ;
    skos:prefLabel "Pediatric Investigation Plan" ;
    skos:inScheme ct:C215478 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215674> ;
    skos:definition "A development plan aimed at ensuring that the necessary data are obtained to support the authorisation of a medicine for children, through studies in children. (EMA)" .

ct:C215675 a skos:Concept ;
    skos:prefLabel "Disease Prevalence" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215675> ;
    skos:definition "A study that assesses the proportion of persons in a population who have a particular disease, condition, or injury at a specified point in time or over a specified period of time. (CDC)" .

ct:C217004 a skos:Concept ;
    skos:prefLabel "Single-Centre" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C217004> ;
    skos:definition "A clinical study that is conducted at a single study site." .

ct:C217005 a skos:Concept ;
    skos:prefLabel "Multicentre" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C217005> ;
    skos:definition "A clinical study that is conducted at a single study site." .

ct:C217006 a skos:Concept ;
    skos:prefLabel "Single Country" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C217006> ;
    skos:definition "Of, or pertaining to, an occurrence in one country." .

ct:C217007 a skos:Concept ;
    skos:prefLabel "Multiple Countries" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C217007> ;
    skos:definition "Of, or pertaining to, an occurrence in more than one country." .

ct:C25392 a skos:Concept ;
    skos:prefLabel "Manufacturer" ;
    skos:inScheme ct:C215480, ct:C215485 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C25392> ;
    skos:definition "The organization defined as being responsible for creating the product as stated on the package in which the product is supplied. (BRIDG)" .

ct:C25425 a skos:Concept ;
    skos:prefLabel "Approved" ;
    skos:inScheme ct:C188723 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C25425> ;
    skos:definition "Acceptance as satisfactory by an authoritative body; established by authority; given authoritative approval." .

ct:C25464 a skos:Concept ;
    skos:prefLabel "Country" ;
    skos:inScheme ct:C207412 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C25464> ;
    skos:definition "A sovereign nation occupying a distinct territory and ruled by an autonomous government." .

ct:C25508 a skos:Concept ;
    skos:prefLabel "Final" ;
    skos:inScheme ct:C188723 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C25508> ;
    skos:definition "Conclusive in a process or progression." .

ct:C25689 a skos:Concept ;
    skos:prefLabel "Stratification" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C25689> ;
    skos:definition "Grouping defined by important prognostic factors measured at baseline. (ICH E9)" .

ct:C25716 a skos:Concept ;
    skos:prefLabel "Visit" ;
    skos:inScheme ct:C188728 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C25716> ;
    skos:definition "The act of going to see some person or place or thing; it can cover a short or long period but refers to a non-permanent arrangement." .

ct:C25936 a skos:Concept ;
    skos:prefLabel "Investigator" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C25936> ;
    skos:definition "A person responsible for the conduct of the clinical trial at a trial site. If a trial is conducted by a team of individuals at the trial site, the investigator is the responsible leader of the team and may be called the principal investigator. [ICH E6]" .

ct:C37984 a skos:Concept ;
    skos:prefLabel "Laboratory" ;
    skos:inScheme ct:C188724, ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C37984> ;
    skos:definition "An organization with the capability and competency to perform scientific research, experiments, and measurements. (BRIDG)" .

ct:C41129 a skos:Concept ;
    skos:prefLabel "Region" ;
    skos:inScheme ct:C207412 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C41129> ;
    skos:definition "An area or portion of something with more or less definite boundaries designed or specified according to some established criteria." .

ct:C41161 a skos:Concept ;
    skos:prefLabel "Experimental Intervention" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C41161> ;
    skos:definition "The drug, device, therapy, procedure, or process under investigation in a clinical study that is believed to have an effect on outcomes of interest in a study (e.g., health-related quality of life, efficacy, safety, pharmacoeconomics). [After https://grants.nih.gov/grants/policy/faq_clinical_trial_definition.htm#5224; https://grants.nih.gov/policy/clinical-trials/protocol-template.htm] See also test articles, devices, drug product, combination product, treatment, diagnosis. Contrast with investigational medicinal product." .

ct:C41189 a skos:Concept ;
    skos:prefLabel "Study Subject" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C41189> ;
    skos:definition "An individual who is observed, analyzed, examined, investigated, experimented upon, or/and treated in the course of a particular study." .

ct:C43530 a skos:Concept ;
    skos:prefLabel "Supplier" ;
    skos:inScheme ct:C215485 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C43530> ;
    skos:definition "An individual or organization whose business is to supply a particular service or commodity." .

ct:C45997 a skos:Concept ;
    skos:prefLabel "pH" ;
    skos:inScheme ct:C215479 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C45997> ;
    skos:definition "The negative logarithm (base 10) of the concentration of hydronium ions, which is used as a measure of the acidity or alkalinity of a fluid." .

ct:C46079 a skos:Concept ;
    skos:prefLabel "Randomized" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C46079> ;
    skos:definition "A study design in which interventions are assigned to subjects according to randomization principles." .

ct:C48660 a skos:Concept ;
    skos:prefLabel "Not Applicable" ;
    skos:inScheme ct:C207415 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C48660> ;
    skos:definition "Determination of a value is not relevant in the current context. (NCI)" .

ct:C49667 a skos:Concept ;
    skos:prefLabel "Safety" ;
    skos:inScheme ct:C215486 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C49667> ;
    skos:definition "A study that assesses the medical risks to a subject. Safety is usually assessed by examining a wide range of clinical parameters, including adverse events, vital signs, physical exam, laboratory tests." .

ct:C51851 a skos:Concept ;
    skos:prefLabel "Project Manager" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C51851> ;
    skos:definition "A staff member who is responsible for the overall integration and interaction of different people and different components of subject matter associated with a specific project." .

ct:C51876 a skos:Concept ;
    skos:prefLabel "Medical Expert" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C51876> ;
    skos:definition "A physician or health care provider selected by the sponsor to be readily available to advise clinical trial officials on trial related medical questions or problems." .

ct:C51877 a skos:Concept ;
    skos:prefLabel "Statistician" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C51877> ;
    skos:definition "A professional who specializes in applying statistical principles to experimental design and data analysis." .

ct:C54148 a skos:Concept ;
    skos:prefLabel "Contract Research Organization" ;
    skos:inScheme ct:C188724 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C54148> ;
    skos:definition "A person or an organization (commercial, academic, or other) contracted by the sponsor to perform one or more of a sponsor's trial-related duties and functions. [ICH E6 Glossary]" .

ct:C54149 a skos:Concept ;
    skos:prefLabel "Pharmaceutical Company" ;
    skos:inScheme ct:C188724 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C54149> ;
    skos:definition "A company licensed to discover, develop, market, and/or distribute drugs." .

ct:C63553 a skos:Concept ;
    skos:prefLabel "Obsolete" ;
    skos:inScheme ct:C188723 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C63553> ;
    skos:definition "No longer in use or valid; old." .

ct:C68609 a skos:Concept ;
    skos:prefLabel "Active Comparator" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C68609> ;
    skos:definition "A type of control, which has a demonstrated effect, administered as a comparator to subjects in a clinical trial. [From ICH E10]" .

ct:C68846 a skos:Concept ;
    skos:prefLabel "Global" ;
    skos:inScheme ct:C207412 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C68846> ;
    skos:definition "Covering or affecting the whole of a system." .

ct:C70793 a skos:Concept ;
    skos:prefLabel "Sponsor" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C70793> ;
    skos:definition "An individual, company, institution, or organization that takes responsibility for the initiation, management, and/or financing of a clinical study. [After ICH E6, WHO, 21 CFR 50.3 (e), and after IDMP]" .

ct:C70817 a skos:Concept ;
    skos:prefLabel "Protocol" ;
    skos:inScheme ct:C215477 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C70817> ;
    skos:definition "The formal plan of an experiment or research activity, including the objective, rationale, design, materials and methods for the conduct of the study, intervention description, and method of data analysis." .

ct:C70848 a skos:Concept ;
    skos:prefLabel "Lot Number" ;
    skos:inScheme ct:C215484 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C70848> ;
    skos:definition "A distinctive alpha-numeric identification code assigned by the manufacturer or distributor to a specific quantity of manufactured material or product within a batch." .

ct:C71476 a skos:Concept ;
    skos:prefLabel "Approval Date" ;
    skos:inScheme ct:C207413 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C71476> ;
    skos:definition "The date on which the entity receives official approbation, recognition, or acceptance as satisfactory." .

ct:C753 a skos:Concept ;
    skos:prefLabel "Placebo" ;
    skos:inScheme ct:C207417 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C753> ;
    skos:definition "A pharmaceutical preparation that does not contain the investigational agent and is generally prepared to be physically indistinguishable from the preparation containing the investigational product." .

ct:C78726 a skos:Concept ;
    skos:prefLabel "Adjudication Committee" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C78726> ;
    skos:definition "An external committee whose purpose is to evaluate study data and decide whether a study endpoint or other criterion has been met. (NCI)" .

ct:C80403 a skos:Concept ;
    skos:prefLabel "Study Site" ;
    skos:inScheme ct:C215480 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C80403> ;
    skos:definition "The location at which a study investigator conducts study activities." .

ct:C85255 a skos:Concept ;
    skos:prefLabel "Draft" ;
    skos:inScheme ct:C188723 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C85255> ;
    skos:definition "A preliminary version of a written work, design, or picture." .

ct:C85826 a skos:Concept ;
    skos:prefLabel "Primary Objective" ;
    skos:inScheme ct:C188725 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C85826> ;
    skos:definition "The main scientific question(s) the study is designed to answer. [After ICH E8; ICH E6 6.3] (CDISC Glossary)" .

ct:C85827 a skos:Concept ;
    skos:prefLabel "Secondary Objective" ;
    skos:inScheme ct:C188725 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C85827> ;
    skos:definition "The supportive or ancillary scientific question(s) the study is designed to answer. [After ICH E8] (CDISC Glossary)" .

ct:C93453 a skos:Concept ;
    skos:prefLabel "Clinical Study Registry" ;
    skos:inScheme ct:C188724 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C93453> ;
    skos:definition "An organization (typically a government agency) that administers the registration of studies. (BRIDG)" .

ct:C94108 a skos:Concept ;
    skos:prefLabel "Study Acronym" ;
    skos:inScheme ct:C207419 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C94108> ;
    skos:definition "A word or words formed from the beginning letters or a combination of syllables and letters of a compound term, which identifies a clinical study." .

ct:C94496 a skos:Concept ;
    skos:prefLabel "Primary Endpoint" ;
    skos:inScheme ct:C188726 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C94496> ;
    skos:definition "Endpoint(s) of greatest importance that is the basis for concluding whether the study met its objective(s) and provides a clinically relevant, valid, and reliable measure of the primary objective(s). (After FDA-NIH Protocol Template)" .

ct:C98704 a skos:Concept ;
    skos:prefLabel "Adaptive" ;
    skos:inScheme ct:C207416 ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C98704> ;
    skos:definition "A study design that allows for prospectively planned modifications to one or more aspects of the design based on accumulating data from subjects in the trial. (FDA)" .

