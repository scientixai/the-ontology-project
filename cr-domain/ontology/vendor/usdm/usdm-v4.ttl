    rdfs:range usdm:ExtensionAttribute ;
    rdfs:label "extensionAttributes" .
usdm:Timing-id a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "id" .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-id ; owl:cardinality 1 ] .
usdm:Timing-instanceType a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "instanceType" ;
    rdfs:comment "Allowed: Timing" .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-instanceType ; owl:cardinality 1 ] .
usdm:Timing-label a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "label" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207583> ;
    rdfs:comment "The short descriptive designation for the timing." .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-label ; owl:maxCardinality 1 ] .
usdm:Timing-name a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "name" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207584> ;
    rdfs:comment "The literal identifier (i.e., distinctive designation) of the timing." .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-name ; owl:cardinality 1 ] .
usdm:Timing-relativeFromScheduledInstanceId a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "relativeFromScheduledInstanceId" .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-relativeFromScheduledInstanceId ; owl:cardinality 1 ] .
usdm:Timing-relativeToFrom a owl:ObjectProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range usdm:Code ;
    rdfs:label "relativeToFrom" .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-relativeToFrom ; owl:cardinality 1 ] .
usdm:Timing-relativeToScheduledInstanceId a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "relativeToScheduledInstanceId" .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-relativeToScheduledInstanceId ; owl:maxCardinality 1 ] .
usdm:Timing-type a owl:ObjectProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range usdm:Code ;
    rdfs:label "type" .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-type ; owl:cardinality 1 ] .
usdm:Timing-value a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "value" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201341> ;
    rdfs:comment "The temporal value of the chronological relationship between temporal events." .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-value ; owl:cardinality 1 ] .
usdm:Timing-valueLabel a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "valueLabel" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207585> ;
    rdfs:comment "The short descriptive designation for the timing value." .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-valueLabel ; owl:cardinality 1 ] .
usdm:Timing-windowLabel a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "windowLabel" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207586> ;
    rdfs:comment "The short descriptive designation for a time period, or other type of interval, during which a temporal event may be achieved, obtained, or observed." .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-windowLabel ; owl:maxCardinality 1 ] .
usdm:Timing-windowLower a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "windowLower" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201342> ;
    rdfs:comment "The earliest chronological value of an allowable period of time during which a temporal event takes place." .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-windowLower ; owl:maxCardinality 1 ] .
usdm:Timing-windowUpper a owl:DatatypeProperty ;
    rdfs:domain usdm:Timing ;
    rdfs:range xsd:string ;
    rdfs:label "windowUpper" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C201343> ;
    rdfs:comment "The latest chronological value of an allowable period of time during which a temporal event takes place." .
usdm:Timing rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Timing-windowUpper ; owl:maxCardinality 1 ] .

usdm:TransitionRule a owl:Class ;
    rdfs:label "TransitionRule" ;
    skos:prefLabel "Transition Rule" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C82567> ;
    rdfs:comment "A guide that governs the allocation of subjects to operational options at a discrete decision point or branch (e.g., assignment to a particular arm, discontinuation) within a clinical trial plan." .
usdm:TransitionRule-description a owl:DatatypeProperty ;
    rdfs:domain usdm:TransitionRule ;
    rdfs:range xsd:string ;
    rdfs:label "description" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C188835> ;
    rdfs:comment "A narrative representation of the transition rule." .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-description ; owl:maxCardinality 1 ] .
usdm:TransitionRule-extensionAttributes a owl:ObjectProperty ;
    rdfs:domain usdm:TransitionRule ;
    rdfs:range usdm:ExtensionAttribute ;
    rdfs:label "extensionAttributes" .
usdm:TransitionRule-id a owl:DatatypeProperty ;
    rdfs:domain usdm:TransitionRule ;
    rdfs:range xsd:string ;
    rdfs:label "id" .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-id ; owl:cardinality 1 ] .
usdm:TransitionRule-instanceType a owl:DatatypeProperty ;
    rdfs:domain usdm:TransitionRule ;
    rdfs:range xsd:string ;
    rdfs:label "instanceType" ;
    rdfs:comment "Allowed: TransitionRule" .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-instanceType ; owl:cardinality 1 ] .
usdm:TransitionRule-label a owl:DatatypeProperty ;
    rdfs:domain usdm:TransitionRule ;
    rdfs:range xsd:string ;
    rdfs:label "label" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207587> ;
    rdfs:comment "The short descriptive designation for the transition rule." .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-label ; owl:maxCardinality 1 ] .
usdm:TransitionRule-name a owl:DatatypeProperty ;
    rdfs:domain usdm:TransitionRule ;
    rdfs:range xsd:string ;
    rdfs:label "name" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207588> ;
    rdfs:comment "The literal identifier (i.e., distinctive designation) of the transition rule." .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-name ; owl:cardinality 1 ] .
usdm:TransitionRule-text a owl:DatatypeProperty ;
    rdfs:domain usdm:TransitionRule ;
    rdfs:range xsd:string ;
    rdfs:label "text" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C207589> ;
    rdfs:comment "An instance of unstructured text that represents the transition rule." .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-text ; owl:cardinality 1 ] .

usdm:Wrapper a owl:Class ;
    rdfs:label "Wrapper" .
usdm:Wrapper-study a owl:ObjectProperty ;
    rdfs:domain usdm:Wrapper ;
    rdfs:range usdm:Study ;
    rdfs:label "study" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-study ; owl:cardinality 1 ] .
usdm:Wrapper-systemName a owl:DatatypeProperty ;
    rdfs:domain usdm:Wrapper ;
    rdfs:range xsd:string ;
    rdfs:label "systemName" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-systemName ; owl:maxCardinality 1 ] .
usdm:Wrapper-systemVersion a owl:DatatypeProperty ;
    rdfs:domain usdm:Wrapper ;
    rdfs:range xsd:string ;
    rdfs:label "systemVersion" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-systemVersion ; owl:maxCardinality 1 ] .
usdm:Wrapper-usdmVersion a owl:DatatypeProperty ;
    rdfs:domain usdm:Wrapper ;
    rdfs:range xsd:string ;
    rdfs:label "usdmVersion" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-usdmVersion ; owl:cardinality 1 ] .
