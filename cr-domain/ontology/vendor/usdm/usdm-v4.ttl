    skos:prefLabel "Masking" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C191278> ;
    rdfs:comment "The mechanism used to obscure the distinctive characteristics of the study intervention or procedure to make it indistinguishable from a comparator. (CDISC Glossary)" .
usdm:Masking-extensionAttributes a owl:ObjectProperty ;
    rdfs:domain usdm:Masking ;
    rdfs:range usdm:ExtensionAttribute ;
    rdfs:label "extensionAttributes" .
usdm:Masking-id a owl:DatatypeProperty ;
    rdfs:domain usdm:Masking ;
    rdfs:range xsd:string ;
    rdfs:label "id" .
usdm:Masking rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Masking-id ; owl:cardinality 1 ] .
usdm:Masking-instanceType a owl:DatatypeProperty ;
    rdfs:domain usdm:Masking ;
    rdfs:range xsd:string ;
    rdfs:label "instanceType" ;
    rdfs:comment "Allowed: Masking" .
usdm:Masking rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Masking-instanceType ; owl:cardinality 1 ] .
usdm:Masking-isMasked a owl:DatatypeProperty ;
    rdfs:domain usdm:Masking ;
    rdfs:range xsd:boolean ;
    rdfs:label "isMasked" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215554> ;
    rdfs:comment "An indication as to whether the study role is masked." .
usdm:Masking rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Masking-isMasked ; owl:cardinality 1 ] .
usdm:Masking-text a owl:DatatypeProperty ;
    rdfs:domain usdm:Masking ;
    rdfs:range xsd:string ;
    rdfs:label "text" ;
    skos:exactMatch <http://purl.obolibrary.org/obo/NCIT_C215553> ;
    rdfs:comment "An instance of unstructured text that represents how the masking is performed and maintained." .
usdm:Masking rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Masking-text ; owl:cardinality 1 ] .

usdm:MedicalDevice a owl:Class ;
