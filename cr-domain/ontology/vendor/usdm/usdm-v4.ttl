usdm:TransitionRule-name a owl:DatatypeProperty ; rdfs:domain usdm:TransitionRule ; rdfs:range xsd:string ; rdfs:label "name" .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-name ; owl:cardinality 1 ] .
usdm:TransitionRule-text a owl:DatatypeProperty ; rdfs:domain usdm:TransitionRule ; rdfs:range xsd:string ; rdfs:label "text" .
usdm:TransitionRule rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:TransitionRule-text ; owl:cardinality 1 ] .

usdm:Wrapper a owl:Class ; rdfs:label "Wrapper" .
usdm:Wrapper-study a owl:ObjectProperty ; rdfs:domain usdm:Wrapper ; rdfs:range usdm:Study ; rdfs:label "study" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-study ; owl:cardinality 1 ] .
usdm:Wrapper-systemName a owl:DatatypeProperty ; rdfs:domain usdm:Wrapper ; rdfs:range xsd:string ; rdfs:label "systemName" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-systemName ; owl:maxCardinality 1 ] .
usdm:Wrapper-systemVersion a owl:DatatypeProperty ; rdfs:domain usdm:Wrapper ; rdfs:range xsd:string ; rdfs:label "systemVersion" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-systemVersion ; owl:maxCardinality 1 ] .
usdm:Wrapper-usdmVersion a owl:DatatypeProperty ; rdfs:domain usdm:Wrapper ; rdfs:range xsd:string ; rdfs:label "usdmVersion" .
usdm:Wrapper rdfs:subClassOf [ a owl:Restriction ; owl:onProperty usdm:Wrapper-usdmVersion ; owl:cardinality 1 ] .
