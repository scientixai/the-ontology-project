@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top: <https://top.scientix.ai/v1#> .

cr:atStudySite a owl:ObjectProperty ;
    rdfs:label "at study site" ;
    rdfs:comment "1..1. The StudySite that operationally owns this visit (in-person or remote). Redundant with Participant.forStudySite but kept direct for query convenience." ;
    rdfs:domain cr:VisitOccurrence ;
    rdfs:range cr:StudySite ;
    top:flavor "Additive" .

cr:definedBy a owl:ObjectProperty ;
    rdfs:label "defined by" ;
    rdfs:comment "0..1. The protocol template this occurrence instantiates. Absent for unscheduled visits." ;
    rdfs:domain cr:VisitOccurrence ;
    rdfs:range cr:VisitDefinition ;
    top:flavor "Additive" .

cr:forParticipant a owl:ObjectProperty ;
    rdfs:label "for participant" ;
    rdfs:comment "1..1. Whose visit this is." ;
    rdfs:domain cr:VisitOccurrence ;
    rdfs:range cr:Participant ;
    top:flavor "Additive" .

cr:hasActivityOccurrence a owl:ObjectProperty ;
    rdfs:label "has activity occurrence" ;
    rdfs:domain cr:VisitOccurrence ;
    rdfs:range cr:ActivityOccurrence ;
    top:flavor "Additive" .

cr:hasActivityTemplate a owl:ObjectProperty ;
    rdfs:label "has activity template" ;
    rdfs:domain cr:VisitDefinition ;
    rdfs:range cr:ActivityTemplate ;
    top:flavor "Additive" .

cr:hasObservation a owl:ObjectProperty ;
    rdfs:label "has observation" ;
    rdfs:domain cr:ActivityOccurrence ;
    rdfs:range cr:ClinicalObservation ;
    top:flavor "Additive" .

cr:hasVisitDefinition a owl:ObjectProperty ;
    rdfs:label "has visit definition" ;
    rdfs:comment "Links a Study to its protocol visit templates (via the SOA / ScheduleTimeline chain)." ;
    rdfs:domain cr:Study ;
    rdfs:range cr:VisitDefinition ;
    top:flavor "Additive" .

cr:instantiatesTemplate a owl:ObjectProperty ;
    rdfs:label "instantiates template" ;
    rdfs:comment "0..1. Links to the protocol-defined activity template. Absent for unscheduled activities." ;
    rdfs:domain cr:ActivityOccurrence ;
    rdfs:range cr:ActivityTemplate ;
    top:flavor "Additive" .

cr:observationForSubject a owl:ObjectProperty ;
    rdfs:label "observation for subject" ;
    rdfs:comment "The pseudonymous StudySubject this observation is about. Never links to hcls:Person directly (PII containment)." ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:StudySubject ;
    top:flavor "Additive" .

cr:performedInVisit a owl:ObjectProperty ;
    rdfs:label "performed in visit" ;
    rdfs:domain cr:ActivityOccurrence ;
    rdfs:range cr:VisitOccurrence ;
    top:flavor "Additive" .

cr:ActivityTemplate a owl:Class ;
    rdfs:label "Activity Template" ;
    rdfs:comment "The protocol-defined activity template: the procedure to perform at a visit. USDM-ingest-derivable from StudyDesign.activities[]. Carries the biomedical-concept code that determines what kind of data the activity collects. USDM: Activity." ;
    rdfs:subClassOf top:Scope .

cr:ClinicalObservation a owl:Class ;
    rdfs:label "Clinical Observation" ;
    rdfs:comment "A structured result attached to an ActivityOccurrence. Carries the measured value, unit, reference range, interpretation, and derivedFrom provenance. FHIR R5: Observation. SDTM: one row in the domain matching the parent activity type." ;
    rdfs:subClassOf prov:Entity,
        top:Evidence,
        top:Versioned .

cr:VisitDefinition a owl:Class ;
    rdfs:label "Visit Definition" ;
    rdfs:comment "The protocol-defined visit template: what is SUPPOSED to happen (type, window, mode, ordering). USDM-ingest-derivable from StudyDesign.encounters[]. UNSCHEDULED visits (urgent care, AE workup) have no VisitDefinition; their VisitOccurrence.definedBy is absent. USDM: Encounter. SDTM projection: SE (Study Elements) domain." ;
    rdfs:subClassOf prov:Entity,
        top:Scope .

cr:ActivityOccurrence a owl:Class ;
    rdfs:label "Activity Occurrence" ;
    rdfs:comment "One performed activity within a VisitOccurrence. Uses the universal substrate pattern: any assessment (vitals, MRI, ePRO, biopsy, IP administration) uses the same entity shape; content specialisation is via biomedicalConceptCode and taskValueType. FHIR R5: Procedure / Observation / MedicationAdministration (per activity type). SDTM: domain depends on type (VS, LB, EG, EX, PE, etc.)." ;
    rdfs:subClassOf prov:Activity,
        top:Temporal,
        top:Versioned .

cr:VisitOccurrence a owl:Class ;
    rdfs:label "Visit Occurrence" ;
    rdfs:comment "An actual protocol visit: what DID happen. Anchored at Participant (1..1) and StudySite (1..1). Optionally definedBy a VisitDefinition (absent for unscheduled visits). FHIR R5: Encounter. SDTM: SV domain (SVSTDTC / SVENDTC / VISITNUM / VISIT). OMOP: VISIT_OCCURRENCE." ;
    rdfs:subClassOf prov:Activity,
        top:Temporal,
        top:Versioned .

