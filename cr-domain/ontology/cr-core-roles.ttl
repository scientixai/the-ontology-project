@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Clinical Research Agent Types and Jobs to Be Done
#
# Agent types are OWL classes specializing hcls-core agent types.
# A real Person is typed as one of these classes at instance-graph time;
# their contextual role within a specific Study is carried as hcls:actsAs
# (a string annotation on the Person-Scope binding).
#
# Authorization is declared on Action individuals (cr-core-actions.ttl)
# via hcls:authorizedAgentType pointing at these classes. No separate
# OperatorRole intermediary.
#
# Organization affiliation named individuals (annotation values only):

cr:SiteBoundary     a owl:NamedIndividual ; rdfs:label "Site" .
cr:SponsorBoundary  a owl:NamedIndividual ; rdfs:label "Sponsor" .
cr:CROBoundary      a owl:NamedIndividual ; rdfs:label "CRO" .
cr:RegulatorBoundary a owl:NamedIndividual ; rdfs:label "Regulator" .

#################################################################
# Agent type taxonomy
#################################################################

cr:Investigator a owl:Class ; rdfs:subClassOf hcls:Clinician ;
    rdfs:label "Investigator" ;
    rdfs:comment "A licensed clinician designated as PI or Sub-I at a Site. Holds legal responsibility for trial conduct, GCP compliance, AE causality assessment, CRF sign-off, and delegation of authority. OOUX persona aliases: PI, Investigator, Site PI." .

cr:SiteCoordinator a owl:Class ; rdfs:subClassOf hcls:Practitioner ;
    rdfs:label "Site Coordinator" ;
    rdfs:comment "The day-to-day clinical operations professional at a Site. Screens and enrolls participants, executes visits, completes CRFs, manages AE reporting, and maintains site logs. Also known as Clinical Research Coordinator (CRC). OOUX persona aliases: Coordinator, Study Coordinator, CRC." .

cr:ClinicalResearchAssociate a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Clinical Research Associate" ;
    rdfs:comment "Sponsor-side field monitor. Conducts monitoring visits, source data verification, deviation identification, and monitoring report submission. OOUX persona aliases: CRA, Monitor, Site Monitor." .

cr:SponsorProjectManager a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Sponsor Project Manager" ;
    rdfs:comment "Creates and activates studies, selects and manages sites, tracks milestones and enrollment, and closes studies. OOUX persona aliases: Sponsor PM, Study PM, Project Manager, Study Manager." .

cr:SponsorOperationsStaff a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Sponsor Operations" ;
    rdfs:comment "Manages protocol amendments, site network structure, regions, country configuration, site activation mechanics, and system configuration. OOUX persona aliases: Sponsor Operations, Sponsor Ops, Site Activation Manager." .

cr:DataManager a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Data Manager" ;
    rdfs:comment "Creates and locks CRFs, manages queries, reconciles lab and date data, and manages data transfers. Dual-lens: sees CRF as data source for analysis (sponsor perspective)." .

cr:SponsorQualityStaff a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Sponsor Quality" ;
    rdfs:comment "Classifies, approves, and closes deviations. Conducts audits and risk assessments; manages CAPAs. OOUX persona aliases: Sponsor Quality, Quality, Auditor." .

cr:RegulatoryAffairsSpecialist a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Regulatory Affairs Specialist" ;
    rdfs:comment "Manages regulatory submissions (IND, CTA, BLA/NDA/MAA), country configuration, and regulatory authority relationships." .

cr:PharmacovigilianceSpecialist a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Pharmacovigilance Specialist" ;
    rdfs:comment "Manages safety signal detection, expedited SAE reporting, safety line listings, and periodic safety reports (DSUR, PSUR). OOUX persona aliases: Pharmacovigilance, PV." .

cr:FinanceStaff a owl:Class ; rdfs:subClassOf hcls:Person ;
    rdfs:label "Finance" ;
    rdfs:comment "Creates and approves budgets, issues site payments, and processes participant reimbursements. OOUX persona aliases: Finance, Sponsor Finance, Finance Manager." .

#################################################################
# Jobs to Be Done — Investigator
#################################################################

cr:PI-J01 a hcls:JobToBeDone ;
    rdfs:label "Hold legal responsibility for trial conduct at the Site" ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "Site selected for a Study; PI designated as Principal Investigator." ;
    hcls:successSignal "Form 1572 on file (US studies)." ;
    hcls:successSignal "GCP training current throughout the Study." ;
    hcls:successSignal "No regulatory or sponsor actions escalated to debarment." ;
    hcls:involvesObject cr:Study , cr:Credential , cr:Delegation ;
    hcls:executesAction cr:RefreshGCPTraining , cr:UpdateFCOIDisclosure , cr:AddInvestigatorDelegation .

cr:PI-J02 a hcls:JobToBeDone ;
    rdfs:label "Assess adverse events for causality and seriousness" ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "Site Coordinator reports an AE; or an SAE becomes known." ;
    hcls:successSignal "Investigator assessment recorded within 24h of SAE awareness." ;
    hcls:successSignal "Causality and expectedness logged on every AE." ;
    hcls:successSignal "Zero SAEs missed for expedited reporting." ;
    hcls:involvesObject cr:AdverseEvent , cr:InvestigationalProduct ;
    hcls:executesAction cr:AssessAdverseEvent , cr:CloseAdverseEvent , cr:ReportSAE , cr:UpdateSAE .

cr:PI-J03 a hcls:JobToBeDone ;
    rdfs:label "Review and sign CRFs" ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "CRF status reaches COMPLETED; PI review required per protocol." ;
    hcls:successSignal "CRF electronicSignatureStatus = SIGNED within sponsor target TTR." ;
    hcls:successSignal "Review and sign cycle does not block CRF lock." ;
    hcls:involvesObject cr:eCRF ;
    hcls:executesAction cr:ReviewCRF , cr:SignCRF .

cr:PI-J04 a hcls:JobToBeDone ;
    rdfs:label "Delegate tasks to qualified site staff" ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "New staff onboarded; or protocol amendment changes delegation requirements." ;
    hcls:successSignal "Delegation of Authority log current and matches Person.delegatedBy." ;
    hcls:successSignal "Each delegated task has a qualified delegate with training in place." ;
    hcls:involvesObject cr:Delegation , cr:Credential ;
    hcls:executesAction cr:AddInvestigatorDelegation .

cr:PI-J05 a hcls:JobToBeDone ;
    rdfs:label "Withdraw or close out a participant" ;
    hcls:jobOfAgentType cr:Investigator ;
    hcls:jobTrigger "Participant withdraws consent, completes study, or meets discontinuation criteria." ;
    hcls:successSignal "Participant.participantStatus reflects correct end state (COMPLETED, WITHDRAWN)." ;
    hcls:successSignal "Withdrawal reason and date captured." ;
    hcls:successSignal "In-flight SAEs followed up post-withdrawal." ;
    hcls:involvesObject cr:Participant , cr:AdverseEvent , cr:InformedConsentAct ;
    hcls:executesAction cr:WithdrawParticipant , cr:CompleteParticipantStudy .

#################################################################
# Jobs to Be Done — Site Coordinator
#################################################################

cr:COORD-J01 a hcls:JobToBeDone ;
    rdfs:label "Screen and enroll a candidate participant" ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Candidate presents for screening; Informed Consent obtained." ;
    hcls:successSignal "Participant.participantStatus = ON_TREATMENT within eligibility window." ;
    hcls:successSignal "All enrollment CRFs complete at baseline visit." ;
    hcls:successSignal "Zero open queries on eligibility data at enrollment." ;
    hcls:involvesObject cr:Participant , cr:InformedConsentAct , cr:VisitOccurrence , cr:eCRF , cr:EnrollmentRecord ;
    hcls:executesAction
        cr:ObtainParticipantConsent ,
        cr:ScreenParticipant ,
        cr:ScheduleVisit ,
        cr:CompleteCRF ,
        cr:EnrollParticipant ,
        cr:UpdateEnrollmentStatus .

cr:COORD-J02 a hcls:JobToBeDone ;
    rdfs:label "Run a protocol visit on schedule and within window" ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Visit.visitStatus = SCHEDULED; visit window approaching." ;
    hcls:successSignal "Visit.visitStatus = COMPLETED with windowStatus = IN_WINDOW." ;
    hcls:successSignal "All per-protocol CRFs for the visit reach COMPLETED or VERIFIED." ;
    hcls:successSignal "Samples shipped within chain-of-custody SLA." ;
    hcls:involvesObject cr:VisitOccurrence , cr:ActivityOccurrence , cr:eCRF ;
    hcls:executesAction cr:StartVisit , cr:UpdateCRF , cr:CollectSample , cr:CompleteVisit .

cr:COORD-J03 a hcls:JobToBeDone ;
    rdfs:label "Capture data cleanly and respond to queries" ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Data Manager raises a query; Discrepancy.queryStatus = OPEN." ;
    hcls:successSignal "Coordinator response posted within sponsor target TTR." ;
    hcls:successSignal "Query moves to ANSWERED or CLOSED." ;
    hcls:successSignal "No repeated re-open on the same data point." ;
    hcls:involvesObject cr:eCRF ;
    hcls:executesAction cr:RespondToQuery , cr:UpdateCRF .

cr:COORD-J04 a hcls:JobToBeDone ;
    rdfs:label "Report adverse events within sponsor-required timelines" ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "Adverse Event observed or reported by participant." ;
    hcls:successSignal "AE reported with reportedDate within 24h for SAEs." ;
    hcls:successSignal "Investigator assessment completed within protocol timeline." ;
    hcls:involvesObject cr:AdverseEvent ;
    hcls:executesAction cr:ReportAdverseEvent , cr:UpdateAdverseEventDetails , cr:FollowUpAdverseEvent .

cr:COORD-J05 a hcls:JobToBeDone ;
    rdfs:label "Keep the site regulatory binder and logs current" ;
    hcls:jobOfAgentType cr:SiteCoordinator ;
    hcls:jobTrigger "New amendment approved, new staff onboarded, or monitoring visit upcoming." ;
    hcls:successSignal "Delegation, training, enrollment, and drug accountability logs up to date." ;
    hcls:successSignal "Monitoring visit finds zero major findings in the binder category." ;
    hcls:involvesObject cr:Delegation , cr:Credential ;
    hcls:executesAction cr:CreateLog , cr:AddLogEntry , cr:LogCommunication .

#################################################################
# Jobs to Be Done — Clinical Research Associate
#################################################################

cr:CRA-J01 a hcls:JobToBeDone ;
    rdfs:label "Get a site ready to enroll its first participant" ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Site.siteStatus enters READY_TO_INITIATE after Study Startup Package is ready." ;
    hcls:successSignal "Site activated on or before plannedActivationDate." ;
    hcls:successSignal "Zero open regulatory or training deficiencies at SIV close." ;
    hcls:successSignal "First participant enrolled within sponsor target window after activation." ;
    hcls:involvesObject cr:StudySite , cr:Credential , cr:Delegation ;
    hcls:executesAction cr:ConductMonitoringVisit , cr:InitiateSite , cr:SubmitMonitoringReport .

cr:CRA-J02 a hcls:JobToBeDone ;
    rdfs:label "Verify that site data matches source documents" ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Monitoring visit scheduled or risk-based trigger fires." ;
    hcls:successSignal "SDV rate meets monitoring plan target for the window." ;
    hcls:successSignal "CRFs reviewed during the visit left in VERIFIED status." ;
    hcls:successSignal "No outstanding major findings recorded." ;
    hcls:involvesObject cr:eCRF ;
    hcls:executesAction cr:ConductMonitoringVisit , cr:CreateQuery , cr:RecordFinding , cr:SubmitMonitoringReport .

cr:CRA-J03 a hcls:JobToBeDone ;
    rdfs:label "Catch and close protocol deviations early" ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Deviation identified during a monitoring visit or pattern review." ;
    hcls:successSignal "Deviation moved to REVIEWED within sponsor target cycle time." ;
    hcls:successSignal "IRB reporting deadline met." ;
    hcls:involvesObject cr:VisitOccurrence , cr:Participant ;
    hcls:executesAction cr:ReportDeviation , cr:RecordFinding .

cr:CRA-J04 a hcls:JobToBeDone ;
    rdfs:label "Close the site cleanly at study end" ;
    hcls:jobOfAgentType cr:ClinicalResearchAssociate ;
    hcls:jobTrigger "Site.siteStatus moves to CLOSED_TO_ENROLLMENT; close-out visit scheduled." ;
    hcls:successSignal "Close-out monitoring visit completed and signed by PI." ;
    hcls:successSignal "All essential documents transferred to sponsor eTMF." ;
    hcls:successSignal "Open findings and action items closed." ;
    hcls:involvesObject cr:StudySite ;
    hcls:executesAction cr:ConductMonitoringVisit , cr:SubmitMonitoringReport .

#################################################################
# Jobs to Be Done — Sponsor Project Manager
#################################################################

cr:PM-J01 a hcls:JobToBeDone ;
    rdfs:label "Initialize a new study" ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Program approval; Sponsor Exec authorises study start." ;
    hcls:successSignal "Study in ACTIVE status within sponsor target cycle time." ;
    hcls:successSignal "Protocol, SOA, CRFs, and Budget approved and locked." ;
    hcls:successSignal "First site selected within target window." ;
    hcls:involvesObject cr:Study , cr:Arm ;
    hcls:executesAction cr:CreateStudy , cr:UpdateStudyDetails , cr:CreateArm , cr:CreateMilestone , cr:ActivateStudy .

cr:PM-J02 a hcls:JobToBeDone ;
    rdfs:label "Select and activate sites to hit enrollment plan" ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Study in IN_STARTUP; feasibility responses in from candidate sites." ;
    hcls:successSignal "Target number of sites SELECTED within window." ;
    hcls:successSignal "First site activated on or before plannedActivationDate." ;
    hcls:involvesObject cr:StudySite ;
    hcls:executesAction cr:SelectSiteForStudy , cr:AchieveMilestone .

cr:PM-J03 a hcls:JobToBeDone ;
    rdfs:label "Manage enrollment across sites to meet plan" ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Study ENROLLING; enrollment plan and forecast in place." ;
    hcls:successSignal "Actual enrollmentCount tracks forecast within tolerance." ;
    hcls:successSignal "Enrollment cycle time per site within sponsor target." ;
    hcls:involvesObject cr:Study , cr:StudySite , cr:Participant ;
    hcls:executesAction cr:OpenEnrollment , cr:CloseEnrollment , cr:DelayMilestone , cr:RebaselineTimeline .

cr:PM-J04 a hcls:JobToBeDone ;
    rdfs:label "Drive milestone achievement and timeline" ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Milestone deadline approaches or slips." ;
    hcls:successSignal "Milestone moved to COMPLETED on or before plannedDate." ;
    hcls:successSignal "Variance on Study Timeline within sponsor tolerance." ;
    hcls:involvesObject cr:Study ;
    hcls:executesAction cr:AchieveMilestone , cr:DelayMilestone , cr:UpdateTimeline , cr:AssignTask .

cr:PM-J05 a hcls:JobToBeDone ;
    rdfs:label "Close study and archive cleanly" ;
    hcls:jobOfAgentType cr:SponsorProjectManager ;
    hcls:jobTrigger "Last Patient Out (LPO) reached; database lock in progress." ;
    hcls:successSignal "CSR finalized and distributed." ;
    hcls:successSignal "All sites closed; all open Tasks and Findings resolved." ;
    hcls:successSignal "Study moves to COMPLETED then archived." ;
    hcls:involvesObject cr:Study , cr:StudySite , cr:CSR ;
    hcls:executesAction cr:CloseSiteToEnrollment , cr:CloseSite , cr:CloseStudy , cr:FinalizeReport , cr:ArchiveStudy .

#################################################################
# Jobs to Be Done — Data Manager
#################################################################

cr:DM-J01 a hcls:JobToBeDone ;
    rdfs:label "Resolve open queries and achieve clean data state" ;
    hcls:jobOfAgentType cr:DataManager ;
    hcls:jobTrigger "Query created on a CRF; or discrepancy detected in incoming data." ;
    hcls:successSignal "All queries on a CRF closed before CRF lock." ;
    hcls:successSignal "Re-open rate below sponsor threshold." ;
    hcls:involvesObject cr:eCRF ;
    hcls:executesAction cr:CreateQuery , cr:AssignQuery , cr:CloseQuery , cr:ReopenQuery .

cr:DM-J02 a hcls:JobToBeDone ;
    rdfs:label "Lock CRFs and database for analysis" ;
    hcls:jobOfAgentType cr:DataManager ;
    hcls:jobTrigger "Last patient last visit completed; data cleaning cycle closed." ;
    hcls:successSignal "All CRFs in LOCKED state." ;
    hcls:successSignal "Database lock confirmed by authorized Data Manager sign-off." ;
    hcls:involvesObject cr:eCRF , cr:Study ;
    hcls:executesAction cr:LockUnlockCRF .

#################################################################
# Jobs to Be Done — Pharmacovigilance Specialist
#################################################################

cr:PV-J01 a hcls:JobToBeDone ;
    rdfs:label "Detect and evaluate emerging safety signals" ;
    hcls:jobOfAgentType cr:PharmacovigilianceSpecialist ;
    hcls:jobTrigger "Aggregate AE data shows unexpected frequency or severity pattern." ;
    hcls:successSignal "Signal evaluated and action (escalate, monitor, or close) documented within SOP timeline." ;
    hcls:successSignal "DSMB/IDMC notified if threshold met." ;
    hcls:involvesObject cr:AdverseEvent ;
    hcls:executesAction cr:IdentifySafetySignal , cr:EvaluateSafetySignal , cr:CloseSafetySignal .

cr:PV-J02 a hcls:JobToBeDone ;
    rdfs:label "File expedited SAE reports within regulatory timelines" ;
    hcls:jobOfAgentType cr:PharmacovigilianceSpecialist ;
    hcls:jobTrigger "SAE meets expedited reporting criteria (unexpected + possibly related)." ;
    hcls:successSignal "7-day initial or 15-day full report filed within regulatory deadline." ;
    hcls:successSignal "Narrative and causality consistent across all SAE documents." ;
    hcls:involvesObject cr:AdverseEvent ;
    hcls:executesAction cr:SubmitExpeditedReport , cr:ReconcileSAE .

#################################################################
# Jobs to Be Done — Finance
#################################################################

cr:FIN-J01 a hcls:JobToBeDone ;
    rdfs:label "Create and approve budgets per study and per site" ;
    hcls:jobOfAgentType cr:FinanceStaff ;
    hcls:jobTrigger "Study in IN_STARTUP; or new site activated." ;
    hcls:successSignal "Budget approved before first site activation." ;
    hcls:successSignal "Site-level budget approved before first patient enrolled." ;
    hcls:successSignal "Line items match the SOA procedures and visit schedule." ;
    hcls:involvesObject cr:Study , cr:StudySite ;
    hcls:executesAction cr:CreateBudget , cr:AddBudgetLineItem , cr:ApproveBudget , cr:LockBudget .

cr:FIN-J02 a hcls:JobToBeDone ;
    rdfs:label "Issue payments to sites per budget and visit accrual" ;
    hcls:jobOfAgentType cr:FinanceStaff ;
    hcls:jobTrigger "Visit.visitStatus = COMPLETED; accrual condition met; invoice received." ;
    hcls:successSignal "Payment issued within contract paymentTermsDays." ;
    hcls:successSignal "complianceCheckStatus = PASSED (anti-kickback, Sunshine Act)." ;
    hcls:involvesObject cr:StudySite , cr:VisitOccurrence ;
    hcls:executesAction cr:IssueSitePayment , cr:CreatePayment , cr:ApprovePayment , cr:ProcessPayment .
