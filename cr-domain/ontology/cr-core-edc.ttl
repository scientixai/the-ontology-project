@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top: <https://top.scientix.ai/v1#> .

cr:Visit rdfs:subClassOf cr:StudyEvent .

cr:capturedDuring a owl:ObjectProperty ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:StudyEvent ;
    top:flavor "Additive" .

cr:definedBy a owl:ObjectProperty ;
    rdfs:comment "The value's variable definition (aboutness); decouples value from definition." ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:DataElementDef ;
    top:flavor "Additive" .

cr:eCRF rdfs:subClassOf cr:CaseReportForm .

cr:hasItem a owl:ObjectProperty ;
    rdfs:domain cr:ItemGroup ;
    rdfs:range cr:DataElementDef ;
    top:flavor "Additive" .

cr:hasItemGroup a owl:ObjectProperty ;
    rdfs:domain cr:CaseReportForm ;
    rdfs:range cr:ItemGroup ;
    top:flavor "Additive" .

cr:hasQuery a owl:ObjectProperty ;
    rdfs:label "has query" ;
    rdfs:comment "A data query raised on this value (forward of cr:queryOn, for single-pull retrieval)." ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:Query ;
    owl:inverseOf cr:queryOn ;
    top:flavor "Additive" .

cr:inItemGroup a owl:ObjectProperty ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range cr:ItemGroup ;
    top:flavor "Additive" .

cr:odmOID a owl:DatatypeProperty ;
    rdfs:label "ODM OID" ;
    rdfs:comment "CDISC ODM OID for interoperability." ;
    top:flavor "Additive" .

cr:onForm a owl:ObjectProperty ;
    rdfs:domain cr:ItemGroup ;
    rdfs:range cr:CaseReportForm ;
    top:flavor "Additive" .

cr:phiClassification a owl:DatatypeProperty ;
    rdfs:label "PHI classification" ;
    rdfs:comment "NotPHI | LimitedPHI | FullPHI | Restricted (drives ETL masking)." ;
    rdfs:domain cr:DataElementDef ;
    top:flavor "Additive" .

cr:replyTo a owl:ObjectProperty ;
    rdfs:comment "Threaded discrepancy conversation (parent-child)." ;
    rdfs:domain cr:Query ;
    rdfs:range cr:Query ;
    top:flavor "Additive" .

cr:resolutionStatus a owl:DatatypeProperty ;
    rdfs:label "resolution status" ;
    rdfs:domain cr:Query ;
    top:flavor "Additive" .

cr:sdvStatus a owl:DatatypeProperty ;
    rdfs:label "SDV status" ;
    rdfs:domain cr:ClinicalObservation ;
    top:flavor "Additive" .

cr:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:domain cr:Query ;
    top:flavor "Additive" .

cr:verifiedBy a owl:ObjectProperty ;
    rdfs:comment "The monitor who source-verified the value (SDV)." ;
    rdfs:domain cr:ClinicalObservation ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

cr:queryOn a owl:ObjectProperty ;
    rdfs:label "query on" ;
    rdfs:comment "The entity the query is anchored to (observation, event, form, subject...)." ;
    rdfs:domain cr:Query ;
    top:flavor "Additive" .

cr:StudyEvent a owl:Class ;
    rdfs:label "Study Event" ;
    rdfs:comment "A scheduled or unscheduled timepoint (StudyEventOID) when data is captured." ;
    rdfs:subClassOf top:Temporal .

cr:CaseReportForm a owl:Class ;
    rdfs:label "Case Report Form" ;
    rdfs:comment "A case report form — a collection of item groups capturing a visit's data." ;
    rdfs:subClassOf top:Evidence .

cr:DataElementDef a owl:Class ;
    rdfs:label "Data Element Definition" ;
    rdfs:comment "A variable DEFINITION (ItemOID), independent of any form version; carries a PHI classification." ;
    rdfs:subClassOf top:Evidence .

cr:ItemGroup a owl:Class ;
    rdfs:label "Item Group" ;
    rdfs:comment "A logical clustering of items (ItemGroupOID)." ;
    rdfs:subClassOf top:Evidence .

cr:ClinicalObservation a owl:Class ;
    rdfs:label "Clinical Observation" ;
    rdfs:comment "A recorded value (ItemData) for a StudySubject at a StudyEvent, defined by a DataElementDef." ;
    rdfs:subClassOf hcls:Observation,
        top:Versioned .

cr:Query a owl:Class ;
    rdfs:label "Query" ;
    rdfs:comment "A discrepancy note / data query anchored to a data point or other entity; threaded." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

