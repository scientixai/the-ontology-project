@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cr:analyzedUnder a owl:ObjectProperty ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:StatisticalAnalysisPlan ;
    top:flavor "Additive" .

cr:basedOnDoseOptimization a owl:ObjectProperty ;
    rdfs:comment "Project Optimus: the proposed Phase 3 dose should rest on dose-optimization work." ;
    rdfs:domain cr:Phase3Design ;
    rdfs:range top:Temporal ;
    top:flavor "Additive" .

cr:concernsStudy a owl:ObjectProperty ;
    rdfs:label "concerns study" ;
    rdfs:comment "The study the regulatory interaction concerns." ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:Study ;
    top:flavor "Additive" .

cr:hasEndpoint a owl:ObjectProperty ;
    rdfs:domain cr:Study ;
    rdfs:range cr:Endpoint ;
    top:flavor "Additive" .

cr:hasRiskRegister a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:RiskRegister ;
    top:flavor "Additive" .

cr:measuresEndpoint a owl:ObjectProperty ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:Endpoint ;
    top:flavor "Additive" .

cr:meetingType a owl:DatatypeProperty ;
    rdfs:label "meeting type" ;
    rdfs:comment "Coded type: Pre-IND, EOP1, EOP2, Type-A, Type-B, Type-C." ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

# RegulatoryInteraction enrichment (US-200-004)
cr:meetingAgency a owl:ObjectProperty ;
    rdfs:label "meeting agency" ;
    rdfs:comment "The regulatory agency conducting the meeting (e.g. FDA, EMA, PMDA)." ;
    rdfs:domain cr:RegulatoryInteraction ;
    top:flavor "Additive" .

cr:meetingDate a owl:DatatypeProperty ;
    rdfs:label "meeting date" ;
    rdfs:comment "The scheduled or actual date of the regulatory meeting." ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range xsd:date ;
    top:flavor "Additive" .

cr:meetingOutcome a owl:DatatypeProperty ;
    rdfs:label "meeting outcome" ;
    rdfs:comment "Summary of the meeting outcome or FDA response (e.g. 'agreed on Phase 3 design', 'additional data requested')." ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

cr:perEstimand a owl:ObjectProperty ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:Estimand ;
    top:flavor "Additive" .

cr:producedAgreement a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:RegulatoryAgreement ;
    top:flavor "Additive" .

cr:proposesDesign a owl:ObjectProperty ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:Phase3Design ;
    top:flavor "Additive" .

cr:reviewsResult a owl:ObjectProperty ;
    rdfs:label "reviews result" ;
    rdfs:comment "The endpoint result the regulatory interaction reviewed (forward edge, for single-pull retrieval)." ;
    rdfs:domain cr:RegulatoryInteraction ;
    rdfs:range cr:EndpointResult ;
    top:flavor "Additive" .

cr:Estimand a owl:Class ;
    rdfs:label "Estimand" ;
    rdfs:comment "The precise treatment-effect definition a result must trace to (overstatement guard)." ;
    rdfs:subClassOf top:Scope .

cr:RegulatoryAgreement a owl:Class ;
    rdfs:label "Regulatory Agreement" ;
    rdfs:comment "A binding FDA agreement (a commitment the program is held to)." ;
    rdfs:subClassOf top:Constraint .

cr:RiskRegister a owl:Class ;
    rdfs:label "Risk Register" ;
    rdfs:comment "A record of risks and decisions captured at a regulatory gate." ;
    rdfs:subClassOf top:Evidence .

cr:StatisticalAnalysisPlan a owl:Class ;
    rdfs:label "Statistical Analysis Plan" ;
    rdfs:comment "The pre-specified plan for analyzing the study's data." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

# SAP property enrichment (US-400-001)
cr:sapVersion a owl:DatatypeProperty ;
    rdfs:label "SAP version" ;
    rdfs:comment "Version identifier for this SAP (e.g. 'v1.0', 'v2.1-amendment')." ;
    rdfs:domain cr:StatisticalAnalysisPlan ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

cr:sapGovernsStudy a owl:ObjectProperty ;
    rdfs:label "SAP governs study" ;
    rdfs:comment "The study this statistical analysis plan governs." ;
    rdfs:domain cr:StatisticalAnalysisPlan ;
    rdfs:range cr:Study ;
    top:flavor "Additive" .

cr:sapAmends a owl:ObjectProperty ;
    rdfs:label "SAP amends" ;
    rdfs:comment "The prior version of the SAP that this document amends." ;
    rdfs:domain cr:StatisticalAnalysisPlan ;
    rdfs:range cr:StatisticalAnalysisPlan ;
    top:flavor "Additive" .

# Estimand ICH E9(R1) components (US-400-002)
cr:estimandPopulation a owl:ObjectProperty ;
    rdfs:label "estimand population" ;
    rdfs:comment "The analysis population to which the estimand applies." ;
    rdfs:domain cr:Estimand ;
    top:flavor "Additive" .

cr:estimandVariable a owl:ObjectProperty ;
    rdfs:label "estimand variable" ;
    rdfs:comment "The endpoint variable the estimand is defined on." ;
    rdfs:domain cr:Estimand ;
    rdfs:range cr:Endpoint ;
    top:flavor "Additive" .

cr:intercurrentEventStrategy a owl:DatatypeProperty ;
    rdfs:label "intercurrent event strategy" ;
    rdfs:comment "ICH E9(R1) strategy for handling intercurrent events: treatment-policy, hypothetical, composite, while-on-treatment, or principal-stratum." ;
    rdfs:domain cr:Estimand ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

cr:populationLevelSummary a owl:DatatypeProperty ;
    rdfs:label "population level summary" ;
    rdfs:comment "The statistical estimand statement (e.g. 'difference in means at week 26 in the ITT population')." ;
    rdfs:domain cr:Estimand ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

# DataCut entity (US-400-003)
cr:DataCut a owl:Class ;
    rdfs:label "Data Cut" ;
    rdfs:comment "A database lock event defining the analysis-eligible data for a study." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:cutDate a owl:DatatypeProperty ;
    rdfs:label "cut date" ;
    rdfs:comment "The database lock date for this data cut." ;
    rdfs:domain cr:DataCut ;
    rdfs:range xsd:date ;
    top:flavor "Additive" .

cr:cutForStudy a owl:ObjectProperty ;
    rdfs:label "cut for study" ;
    rdfs:comment "The study this data cut applies to." ;
    rdfs:domain cr:DataCut ;
    rdfs:range cr:Study ;
    top:flavor "Additive" .

cr:cutType a owl:DatatypeProperty ;
    rdfs:label "cut type" ;
    rdfs:comment "Coded type: primary, interim, or safety-review." ;
    rdfs:domain cr:DataCut ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

# AnalysisPopulation entity (US-400-004)
cr:AnalysisPopulation a owl:Class ;
    rdfs:label "Analysis Population" ;
    rdfs:comment "A named, versioned population definition (ITT, mITT, PP, safety) anchored to a data cut." ;
    rdfs:subClassOf top:Scope,
        top:Versioned .

cr:populationType a owl:DatatypeProperty ;
    rdfs:label "population type" ;
    rdfs:comment "Coded population type: ITT, mITT, PP, safety, or other." ;
    rdfs:domain cr:AnalysisPopulation ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

cr:populationForCut a owl:ObjectProperty ;
    rdfs:label "population for cut" ;
    rdfs:comment "The data cut that anchors this analysis population definition." ;
    rdfs:domain cr:AnalysisPopulation ;
    rdfs:range cr:DataCut ;
    top:flavor "Additive" .

cr:populationCriteria a owl:ObjectProperty ;
    rdfs:label "population criteria" ;
    rdfs:comment "The eligibility criterion or rule defining membership in this analysis population." ;
    rdfs:domain cr:AnalysisPopulation ;
    rdfs:range cr:EligibilityCriterion ;
    top:flavor "Additive" .

cr:analysisBasis a owl:ObjectProperty ;
    rdfs:label "analysis basis" ;
    rdfs:comment "The analysis population this endpoint result was computed in." ;
    rdfs:domain cr:EndpointResult ;
    rdfs:range cr:AnalysisPopulation ;
    top:flavor "Additive" .

cr:Phase3Design a owl:Class ;
    rdfs:label "Proposed Phase 3 Design" ;
    rdfs:comment "A proposed Phase 3 trial design taken to the EOP2 meeting." ;
    rdfs:subClassOf top:Scope .

cr:EndpointResult a owl:Class ;
    rdfs:label "Endpoint Result" ;
    rdfs:comment "A measured efficacy/safety result; must trace to its endpoint, estimand, and SAP." ;
    rdfs:subClassOf top:Outcome,
        top:Versioned .
