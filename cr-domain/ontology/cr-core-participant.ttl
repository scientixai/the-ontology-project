@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

<https://top.scientix.ai/cr/v1> a owl:Ontology ;
    owl:versionInfo "1.4" ;
    dct:title "CR-core ontology — participant & consent module" ;
    dct:description "Extends CR-core with InformedConsent enrichment (US-500-003): consentVersion, consentFormIRI, witnessedBy, withdrawalDate." .

#
# ── InformedConsent (enriched, US-500-003) ───────────────────────────────────
#
cr:InformedConsent a owl:Class ;
    rdfs:label "Informed Consent" ;
    rdfs:comment "A participant's documented agreement to take part in a study, including version, form IRI, witness, and optional withdrawal." ;
    rdfs:subClassOf top:BitemporalEntity ;
    skos:definition "The act and record of a study participant voluntarily agreeing to participate after being informed of all relevant aspects of the study." .

# — core properties (pre-existing) ——————————————————————————————————————————
cr:consentDate a owl:DatatypeProperty ;
    rdfs:domain cr:InformedConsent ;
    rdfs:range  xsd:date ;
    rdfs:label  "consent date" ;
    rdfs:comment "Calendar date on which consent was obtained." .

cr:consentStatus a owl:DatatypeProperty ;
    rdfs:domain cr:InformedConsent ;
    rdfs:range  xsd:string ;
    rdfs:label  "consent status" ;
    rdfs:comment "Workflow status of the consent (e.g. active, withdrawn, expired)." .

# — new properties (US-500-003) ——————————————————————————————————————————————
cr:consentVersion a owl:DatatypeProperty ;
    rdfs:domain cr:InformedConsent ;
    rdfs:range  xsd:string ;
    rdfs:label  "consent version" ;
    rdfs:comment "Version identifier of the consent form (e.g. 'v2.1')." .

cr:consentFormIRI a owl:DatatypeProperty ;
    rdfs:domain cr:InformedConsent ;
    rdfs:range  xsd:anyURI ;
    rdfs:label  "consent form IRI" ;
    rdfs:comment "Dereferenceable IRI to the consent form document." .

cr:witnessedBy a owl:ObjectProperty ;
    rdfs:domain cr:InformedConsent ;
    rdfs:range  hcls:Person ;
    rdfs:label  "witnessed by" ;
    rdfs:comment "The person who witnessed the consent signing." .

cr:withdrawalDate a owl:DatatypeProperty ;
    rdfs:domain cr:InformedConsent ;
    rdfs:range  xsd:date ;
    rdfs:label  "withdrawal date" ;
    rdfs:comment "Calendar date on which consent was withdrawn, if applicable." .

#
# ── StudySubject ─────────────────────────────────────────────────────────────
#
cr:StudySubject a owl:Class ;
    rdfs:label   "Study Subject" ;
    rdfs:comment "A person enrolled in or being considered for a study." ;
    rdfs:subClassOf top:BitemporalEntity .

cr:subjectId a owl:DatatypeProperty ;
    rdfs:domain cr:StudySubject ;
    rdfs:range  xsd:string ;
    rdfs:label  "subject identifier" ;
    rdfs:comment "Site-assigned identifier for the study subject." .

cr:hasConsent a owl:ObjectProperty ;
    rdfs:domain cr:StudySubject ;
    rdfs:range  cr:InformedConsent ;
    rdfs:label  "has consent" ;
    rdfs:comment "Links a study subject to their informed consent record." .

cr:hasEnrollment a owl:ObjectProperty ;
    rdfs:domain cr:StudySubject ;
    rdfs:range  cr:Enrollment ;
    rdfs:label  "has enrollment" ;
    rdfs:comment "Links a study subject to their enrollment record." .

#
# ── Enrollment ───────────────────────────────────────────────────────────────
#
cr:Enrollment a owl:Class ;
    rdfs:label   "Enrollment" ;
    rdfs:comment "The formal registration of a subject into a study arm." ;
    rdfs:subClassOf top:BitemporalEntity .

cr:enrollmentDate a owl:DatatypeProperty ;
    rdfs:domain cr:Enrollment ;
    rdfs:range  xsd:date ;
    rdfs:label  "enrollment date" .

cr:enrolledInArm a owl:ObjectProperty ;
    rdfs:domain cr:Enrollment ;
    rdfs:range  cr:Arm ;
    rdfs:label  "enrolled in arm" .

#
# ── EligibilityCriterion ─────────────────────────────────────────────────────
#
cr:EligibilityCriterion a owl:Class ;
    rdfs:label   "Eligibility Criterion" ;
    rdfs:comment "An inclusion or exclusion criterion for study participation." .

cr:criterionType a owl:DatatypeProperty ;
    rdfs:domain cr:EligibilityCriterion ;
    rdfs:range  xsd:string ;
    rdfs:label  "criterion type" ;
    rdfs:comment "'inclusion' or 'exclusion'." .

cr:criterionText a owl:DatatypeProperty ;
    rdfs:domain cr:EligibilityCriterion ;
    rdfs:range  xsd:string ;
    rdfs:label  "criterion text" .
