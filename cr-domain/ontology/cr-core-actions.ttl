@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Clinical Research Action Catalog
#
# Named individuals — one per CTA in the TOP Clinical Research OOUX Map v0.2.
# Each Action carries:
#   hcls:authorizedAgentType  — role(s) from cr-core-roles.ttl
#   hcls:occursIn       — primary phase/sub-phase from cr-core-phases.ttl
#   hcls:operatesOn     — primary object class (OWL class IRI)
#   rdfs:label         — human-readable CTA name matching the OOUX map
#
# Naming convention: CamelCase IRI = concatenated CTA words.
# Multi-role authorization: hcls:authorizedAgentType may appear multiple times on one Action.
# Organization by section below matches the phase taxonomy.
#
# Source: ALL 78-object CTAs extracted from OOUX Map v0.2 objects/*.yaml.
# This file is the machine-readable CTA registry; the OOUX YAML files are the
# authoritative human-readable source.

#################################################################
# A. Startup — Design Sub-phase
#################################################################

cr:CreateStudy a hcls:Action ;
    rdfs:label "Create Study" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:UpdateStudyDetails a hcls:Action ;
    rdfs:label "Update Study Details" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:ActivateStudy a hcls:Action ;
    rdfs:label "Activate Study" ;
    hcls:authorizedAgentType cr:SponsorProjectManager ;
    hcls:occursIn cr:DesignSubPhase ;
    hcls:operatesOn cr:Study .

cr:PutStudyOnHold a hcls:Action ;
    rdfs:label "Put Study on Hold" ;
    hcls:authorizedAgentType cr:SponsorProjectManager , cr:SponsorOperationsStaff ;
