@prefix cr: <https://top.scientix.ai/cr/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cr:assessesFactor a owl:ObjectProperty ;
    rdfs:domain cr:RiskAssessment ;
    rdfs:range cr:CriticalToQualityFactor ;
    top:flavor "Additive" .

cr:hasMitigationPlan a owl:ObjectProperty ;
    rdfs:label "has mitigation plan" ;
    rdfs:comment "The mitigation/monitoring plan addressing this assessment (forward of cr:mitigates, for single-pull retrieval)." ;
    rdfs:domain cr:RiskAssessment ;
    rdfs:range cr:MitigationPlan ;
    owl:inverseOf cr:mitigates ;
    top:flavor "Additive" .

cr:monitoringStrategy a owl:DatatypeProperty ;
    rdfs:label "monitoring strategy" ;
    rdfs:domain cr:MitigationPlan ;
    top:flavor "Additive" .

cr:riskLevel a owl:DatatypeProperty ;
    rdfs:label "risk level" ;
    rdfs:domain cr:RiskAssessment ;
    top:flavor "Additive" .

cr:riskScore a owl:DatatypeProperty ;
    rdfs:domain cr:RiskAssessment ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:sdvIntensity a owl:DatatypeProperty ;
    rdfs:comment "Fraction of data source-verified (1.0 = 100% SDV; reduced for low-risk)." ;
    rdfs:domain cr:MitigationPlan ;
    rdfs:range xsd:decimal ;
    top:flavor "Additive" .

cr:CriticalToQualityFactor a owl:Class ;
    rdfs:label "Critical-to-Quality Factor" ;
    rdfs:comment "A quality-critical aspect of the trial (e.g. primary endpoint integrity, consent validity, SAE reporting)." ;
    rdfs:subClassOf top:Constraint ;
    skos:altLabel "CtQ factor" .

cr:mitigates a owl:ObjectProperty ;
    rdfs:domain cr:MitigationPlan ;
    rdfs:range cr:RiskAssessment ;
    top:flavor "Additive" .

cr:MitigationPlan a owl:Class ;
    rdfs:label "Mitigation Plan" ;
    rdfs:comment "Mitigations for a risk, including the resulting monitoring strategy and SDV intensity." ;
    rdfs:subClassOf top:Constraint .

cr:RiskAssessment a owl:Class ;
    rdfs:label "Risk Assessment" ;
    rdfs:comment "An assessment of risk to a CtQ factor (likelihood/impact/detectability -> level); bitemporal." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

