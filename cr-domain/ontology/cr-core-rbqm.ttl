@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Risk-Based Quality Management (ICH E6(R2)/(R3), TransCelerate).
# Targets monitoring at critical-to-quality factors by risk, replacing blanket 100% SDV.
# Risk assessments are bitemporal (re-assessed as data accumulates).

cr:CriticalToQualityFactor a owl:Class ; rdfs:subClassOf top:Constraint ;
    rdfs:label "Critical-to-Quality Factor" ; skos:altLabel "CtQ factor" ;
    rdfs:comment "A quality-critical aspect of the trial (e.g. primary endpoint integrity, consent validity, SAE reporting)." .
cr:RiskAssessment a owl:Class ; rdfs:subClassOf top:Evidence, top:ProvenancedEntity ;
    rdfs:label "Risk Assessment" ;
    rdfs:comment "An assessment of risk to a CtQ factor (likelihood/impact/detectability -> level); bitemporal." .
cr:MitigationPlan a owl:Class ; rdfs:subClassOf top:Constraint ;
    rdfs:label "Mitigation Plan" ;
    rdfs:comment "Mitigations for a risk, including the resulting monitoring strategy and SDV intensity." .

cr:assessesFactor   a owl:ObjectProperty ; rdfs:domain cr:RiskAssessment ; rdfs:range cr:CriticalToQualityFactor .
cr:mitigates        a owl:ObjectProperty ; rdfs:domain cr:MitigationPlan ; rdfs:range cr:RiskAssessment .
cr:riskLevel        a owl:DatatypeProperty ; rdfs:domain cr:RiskAssessment ; rdfs:label "risk level" .
cr:riskScore        a owl:DatatypeProperty ; rdfs:domain cr:RiskAssessment ; rdfs:range xsd:decimal .
cr:monitoringStrategy a owl:DatatypeProperty ; rdfs:domain cr:MitigationPlan ; rdfs:label "monitoring strategy" .
cr:sdvIntensity     a owl:DatatypeProperty ; rdfs:domain cr:MitigationPlan ; rdfs:range xsd:decimal ;
    rdfs:comment "Fraction of data source-verified (1.0 = 100% SDV; reduced for low-risk)." .
