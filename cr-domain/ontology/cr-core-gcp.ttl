@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# ICH E6(R3) GCP definitional layer — the governance vocabulary between OCRe (study-design
# science) and BRIDG (operational data) that no published ontology owns. DESCRIPTIVE only:
# we encode the entities and terms E6(R3) presupposes (actors, essential records, quality
# constructs). The OBLIGATIONS ("you should/shall ...") are NOT classes — they live in the
# constraints layer (SHACL shapes), per the descriptive-vs-deontic split.
#
# LICENSING — cleared. ICH permits adaptation/modification of its guidelines under a public
# license, subject to three conditions, all met here: (1) attribution + clear labeling that
# changes were made (this header + per-term rdfs:isDefinedBy + the repo NOTICE); (2) no
# impression of ICH endorsement/sponsorship (stated below and in NOTICE); (3) no use of the
# ICH logo (none present). Definitions are PARAPHRASED, never copied verbatim. See ./NOTICE.

<https://top.scientix.ai/cr/v1/gcp> a owl:Ontology ;
    rdfs:label "TOP CR — ICH E6(R3) GCP definitional layer" ;
    dcterms:source "ICH E6(R3) Good Clinical Practice (Step 4, adopted January 2025): Principles, Glossary, and Annex 1 (interventional trials). Annex 2 (additional/non-traditional data sources) is NOT modeled in this version." ;
    dcterms:rights "Independent derivative adaptation of the ICH E6(R3) Guideline. The classes, properties, and SKOS concepts here are an adaptation (structure + paraphrased definitions), not a reproduction. NOT endorsed or sponsored by ICH. The original ICH E6(R3) document is copyright © ICH." ;
    rdfs:comment "Changes made: ICH E6(R3) terms are reorganized into an OWL/SKOS structure, definitions are paraphrased, and obligations are expressed as SHACL shapes rather than encoded text. Each derived term carries rdfs:isDefinedBy the ICH efficacy-guidelines source." .

#################################################################
# Record model — the essential-records vocabulary (the authoritative
# anchor under the TMF binding in tmf-reference.ttl)
#################################################################

cr:EssentialRecord a owl:Class ; rdfs:subClassOf top:Evidence, top:Versioned ;
    rdfs:label "Essential Record" ; skos:altLabel "Essential Document" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "A record that, individually or collectively, permits evaluation of the conduct of a trial and the quality of the data produced (paraphrased, ICH E6(R3))." ;
    rdfs:comment "The class the TMF artifact-type scheme (tmf:) classifies the documents of." .
cr:SourceData a owl:Class ; rdfs:subClassOf top:Evidence, top:Versioned ;
    rdfs:label "Source Data" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "The original recorded information, and certified copies of it, needed to reconstruct and evaluate the trial (paraphrased, ICH E6(R3))." .
cr:SourceDocument a owl:Class ; rdfs:subClassOf cr:EssentialRecord ;
    rdfs:label "Source Document" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "The original document/record holding source data (paraphrased, ICH E6(R3))." .
cr:AuditTrail a owl:Class ; rdfs:subClassOf top:Evidence, top:Versioned ;
    rdfs:label "Audit Trail" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "Secure, computer- or paper-generated documentation that allows reconstruction of the course of events around a record (paraphrased, ICH E6(R3)). In TOP, the bitemporal + PROV envelope realizes this by construction." .
cr:CertifiedCopy a owl:Class ; rdfs:subClassOf top:Evidence, top:Versioned ;
    rdfs:label "Certified Copy" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "A copy of original information verified (dated/signed or generated by a validated process) as a complete and accurate copy (paraphrased, ICH E6(R3))." .
cr:TrialMasterFile a owl:Class ; rdfs:subClassOf top:Evidence ;
    rdfs:label "Trial Master File" ; skos:altLabel "TMF" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "The collection of essential records that allows the conduct of the trial and the quality of the data to be evaluated (paraphrased, ICH E6(R3))." .

# Record relations.
cr:hasAuditTrail a owl:ObjectProperty ; rdfs:domain top:Evidence ; rdfs:range cr:AuditTrail ;
    rdfs:label "has audit trail" ; rdfs:comment "Links an essential record / source data to its audit trail (ALCOA++ reconstructable)." .
cr:certifiedCopyOf a owl:ObjectProperty ; rdfs:domain cr:CertifiedCopy ; rdfs:range cr:SourceDocument ;
    rdfs:label "certified copy of" ; rdfs:comment "The source document this certified copy reproduces." .
cr:hasCertifiedCopy a owl:ObjectProperty ; owl:inverseOf cr:certifiedCopyOf ;
    rdfs:domain cr:SourceDocument ; rdfs:range cr:CertifiedCopy ;
    rdfs:label "has certified copy" ; rdfs:comment "A certified copy made of this source document (forward of cr:certifiedCopyOf, for single-pull retrieval)." .
cr:containsSourceData a owl:ObjectProperty ; rdfs:domain cr:SourceDocument ; rdfs:range cr:SourceData ;
    rdfs:label "contains source data" .
cr:recordedInTMF a owl:ObjectProperty ; rdfs:domain cr:EssentialRecord ; rdfs:range cr:TrialMasterFile ;
    rdfs:label "recorded in TMF" .

#################################################################
# Actor model — the institutional actors E6(R3) defines that we
# were missing (Sponsor/CRO are already in cr-core; person-roles
# like investigator/monitor stay relationships, never reified Role)
#################################################################

cr:IRB a owl:Class ; rdfs:subClassOf hcls:Organization ;
    rdfs:label "IRB / IEC" ; skos:altLabel "Institutional Review Board" ; skos:altLabel "Independent Ethics Committee" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "An independent body that reviews and provides ongoing oversight to protect the rights, safety, and well-being of trial participants (paraphrased, ICH E6(R3))." .
cr:ServiceProvider a owl:Class ; rdfs:subClassOf hcls:Organization ;
    rdfs:label "Service Provider" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "A party to whom a sponsor or investigator transfers specified trial-related duties and functions (paraphrased, ICH E6(R3)). The CRO is a specialized service provider." .

# Oversight relations (the act/relationship, not a reified role).
cr:monitors a owl:ObjectProperty ; rdfs:range cr:StudySite ;
    rdfs:label "monitors" ; rdfs:comment "Monitoring oversight of a site (the monitor function as a relationship)." .
cr:audits a owl:ObjectProperty ;
    rdfs:label "audits" ; rdfs:comment "Independent audit of trial conduct/records (the auditor function as a relationship)." .
cr:overseesConductOf a owl:ObjectProperty ; rdfs:domain cr:Sponsor ; rdfs:range cr:Study ;
    rdfs:label "oversees conduct of" ; rdfs:comment "Sponsor oversight accountability for the trial (E6(R3) sponsor responsibility, as a relationship)." .

#################################################################
# Glossary — E6(R3) terms we cite but model as relationships /
# conventions rather than instantiable classes (SKOS, isDefinedBy)
#################################################################

cr:E6R3Glossary a skos:ConceptScheme ; rdfs:label "ICH E6(R3) glossary (selected terms)" ;
    rdfs:comment "Definitional concepts cited to ICH E6(R3); related to the cr: class/relation that realizes each, where one exists." .

cr:term_Investigator a skos:Concept ; skos:inScheme cr:E6R3Glossary ; skos:prefLabel "Investigator" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "The person responsible for the conduct of the trial at a trial site (paraphrased, ICH E6(R3))." ;
    rdfs:seeAlso cr:principalInvestigator .
cr:term_Monitor a skos:Concept ; skos:inScheme cr:E6R3Glossary ; skos:prefLabel "Monitor" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "A person who oversees the progress of the trial and that it is conducted, recorded, and reported per protocol, SOPs, GCP, and regulation (paraphrased, ICH E6(R3))." ;
    rdfs:seeAlso cr:monitors .
cr:term_Auditor a skos:Concept ; skos:inScheme cr:E6R3Glossary ; skos:prefLabel "Auditor" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "A person conducting a systematic, independent examination of trial activities and documents (paraphrased, ICH E6(R3))." ;
    rdfs:seeAlso cr:audits .
cr:term_ALCOAplus a skos:Concept ; skos:inScheme cr:E6R3Glossary ; skos:prefLabel "ALCOA++" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "Data-integrity expectations: attributable, legible, contemporaneous, original, accurate, plus complete, consistent, enduring, available (paraphrased, ICH E6(R3) data governance). Realized in TOP by the bitemporal + PROV envelope." ;
    rdfs:seeAlso cr:AuditTrail .
cr:term_QualityByDesign a skos:Concept ; skos:inScheme cr:E6R3Glossary ; skos:prefLabel "Quality by Design" ;
    rdfs:isDefinedBy <https://www.ich.org/page/efficacy-guidelines> ;
    skos:definition "Building quality into trial design and conduct by focusing on factors critical to quality (paraphrased, ICH E6(R3)/E8(R1))." ;
    rdfs:seeAlso cr:CriticalToQualityFactor .
