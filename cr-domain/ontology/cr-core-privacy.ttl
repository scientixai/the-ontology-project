@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top:  <https://top.scientix.ai/v1#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Privacy & Compliance Architecture (US-600-001 through US-600-004)

# ConsentWithdrawal (US-600-001)
cr:ConsentWithdrawal a owl:Class ;
    rdfs:label "Consent Withdrawal" ;
    rdfs:comment "The temporal act of a subject withdrawing informed consent, closing the consent valid-time interval." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

cr:closesConsent a owl:ObjectProperty ;
    rdfs:label "closes consent" ;
    rdfs:comment "Links the withdrawal event to the cr:InformedConsent it terminates." ;
    rdfs:domain cr:ConsentWithdrawal ;
    rdfs:range cr:InformedConsent ;
    top:flavor "Additive" .

cr:withdrawalReason a owl:DatatypeProperty ;
    rdfs:label "withdrawal reason" ;
    rdfs:comment "Coded reason: subject-decision, AE, lost-to-follow-up, or other." ;
    rdfs:domain cr:ConsentWithdrawal ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

# LawfulBasis (US-600-002)
cr:LawfulBasis a owl:Class ;
    rdfs:label "Lawful Basis" ;
    rdfs:comment "A GDPR lawful basis for processing personal data (Articles 6 and 9)." ;
    rdfs:subClassOf top:RegulatoryLaw .

cr:lawfulBasisDescription a owl:DatatypeProperty ;
    rdfs:label "lawful basis description" ;
    rdfs:comment "Human-readable description of the lawful basis." ;
    rdfs:domain cr:LawfulBasis ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

# GDPR Article named individuals
cr:GDPR_Art6_1_a a owl:NamedIndividual, cr:LawfulBasis ;
    rdfs:label "GDPR Art 6(1)(a) — Consent" ;
    cr:lawfulBasisDescription "Processing is based on the data subject's consent (Art 6(1)(a) GDPR)." .

cr:GDPR_Art9_2_a a owl:NamedIndividual, cr:LawfulBasis ;
    rdfs:label "GDPR Art 9(2)(a) — Explicit Consent (special categories)" ;
    cr:lawfulBasisDescription "Processing of special category data with explicit consent of the data subject (Art 9(2)(a) GDPR)." .

cr:GDPR_Art9_2_j a owl:NamedIndividual, cr:LawfulBasis ;
    rdfs:label "GDPR Art 9(2)(j) — Scientific Research" ;
    cr:lawfulBasisDescription "Processing necessary for scientific or historical research purposes (Art 9(2)(j) GDPR)." .

# DataProcessingAgreement (US-600-003)
cr:DataProcessingAgreement a owl:Class ;
    rdfs:label "Data Processing Agreement" ;
    rdfs:comment "A GDPR-required agreement between a data controller (sponsor) and data processor (CRO, central lab), versioned and effective-dated." ;
    rdfs:subClassOf top:Evidence,
        top:Versioned .

cr:processorOrg a owl:ObjectProperty ;
    rdfs:label "processor organization" ;
    rdfs:comment "The data processor organization (CRO, central lab) party to this DPA." ;
    rdfs:domain cr:DataProcessingAgreement ;
    rdfs:range hcls:Organization ;
    top:flavor "Additive" .

cr:controllerOrg a owl:ObjectProperty ;
    rdfs:label "controller organization" ;
    rdfs:comment "The data controller (sponsor) party to this DPA." ;
    rdfs:domain cr:DataProcessingAgreement ;
    rdfs:range cr:Sponsor ;
    top:flavor "Additive" .

cr:dpaEffectiveDate a owl:DatatypeProperty ;
    rdfs:label "DPA effective date" ;
    rdfs:comment "The date the Data Processing Agreement came into force." ;
    rdfs:domain cr:DataProcessingAgreement ;
    rdfs:range xsd:date ;
    top:flavor "Additive" .

cr:processingPurposes a owl:ObjectProperty ;
    rdfs:label "processing purposes" ;
    rdfs:comment "The lawful basis under which processing is authorised by this DPA." ;
    rdfs:domain cr:DataProcessingAgreement ;
    rdfs:range cr:LawfulBasis ;
    top:flavor "Additive" .

# RetentionPolicy (US-600-004)
cr:RetentionPolicy a owl:Class ;
    rdfs:label "Retention Policy" ;
    rdfs:comment "A regulatory or sponsor-mandated data retention period (e.g. ICH E6(R3): 25 years for essential documents)." ;
    rdfs:subClassOf top:Constraint .

cr:retentionPeriod a owl:DatatypeProperty ;
    rdfs:label "retention period" ;
    rdfs:comment "ISO 8601 duration of the required retention period (e.g. 'P15Y' = 15 years)." ;
    rdfs:domain cr:RetentionPolicy ;
    rdfs:range xsd:duration ;
    top:flavor "Additive" .

cr:retentionBasis a owl:ObjectProperty ;
    rdfs:label "retention basis" ;
    rdfs:comment "The regulatory law mandating this retention period." ;
    rdfs:domain cr:RetentionPolicy ;
    rdfs:range top:RegulatoryLaw ;
    top:flavor "Additive" .

# DataSubjectRequest (US-600-004)
cr:DataSubjectRequest a owl:Class ;
    rdfs:label "Data Subject Request" ;
    rdfs:comment "A GDPR data subject right exercise: access, erasure, rectification, or portability." ;
    rdfs:subClassOf top:Temporal .

cr:dsrType a owl:DatatypeProperty ;
    rdfs:label "DSR type" ;
    rdfs:comment "Coded type: access, erasure, rectification, or portability." ;
    rdfs:domain cr:DataSubjectRequest ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

cr:dsrDeadline a owl:DatatypeProperty ;
    rdfs:label "DSR deadline" ;
    rdfs:comment "Response deadline (GDPR: 30 days from request receipt)." ;
    rdfs:domain cr:DataSubjectRequest ;
    rdfs:range xsd:date ;
    top:flavor "Additive" .

cr:dsrStatus a owl:DatatypeProperty ;
    rdfs:label "DSR status" ;
    rdfs:comment "Coded status: open, in-progress, fulfilled, or rejected." ;
    rdfs:domain cr:DataSubjectRequest ;
    rdfs:range xsd:string ;
    top:flavor "Additive" .

cr:dsrForSubject a owl:ObjectProperty ;
    rdfs:label "DSR for subject" ;
    rdfs:comment "The person this data subject request concerns." ;
    rdfs:domain cr:DataSubjectRequest ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .
