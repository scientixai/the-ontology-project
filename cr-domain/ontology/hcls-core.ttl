@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix top: <https://top.scientix.ai/v1#> .

hcls: a owl:Ontology ;
    rdfs:label "HCLS-core" ;
    rdfs:comment "Mid-layer specializing TOP Core for entities that recur across >=2 HCLS domains (clinical research, hospital, manufacturing, pharmacovigilance, RWE, commercialization). Seeded minimally; grows by promotion (rule of three). Standards projection target: FHIR, OMOP." .

hcls:Clinician a owl:Class ;
    rdfs:label "Clinician" ;
    rdfs:comment "A licensed clinician who provides or oversees clinical care or research. Specializes in sub-domains: Investigator (clinical research), Physician (clinical care), Pharmacist, etc." ;
    rdfs:subClassOf hcls:Practitioner .

hcls:Condition a owl:Class ;
    rdfs:label "Condition" ;
    rdfs:comment "A diagnosed state of a Person." ;
    rdfs:subClassOf top:Outcome .

hcls:Lot a owl:Class ;
    rdfs:label "Lot" ;
    rdfs:comment "A manufactured batch/lot; the primary join to the manufacturing domain." ;
    rdfs:subClassOf top:Resource .

hcls:MedicinalProduct a owl:Class ;
    rdfs:label "Medicinal Product" ;
    rdfs:comment "A medicinal product (drug or biologic)." ;
    rdfs:subClassOf top:Resource .

hcls:Observation a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "An information artifact recording a measured value; refersTo the Person/Specimen it is about." ;
    rdfs:subClassOf top:Evidence .

hcls:Substance a owl:Class ;
    rdfs:label "Substance" ;
    rdfs:comment "A chemical or biological substance." ;
    rdfs:subClassOf top:Resource .

hcls:actsAs a owl:DatatypeProperty ;
    rdfs:label "acts as" ;
    rdfs:comment "At instance-graph time, a human-readable label for the contextual role a Person plays within a Scope (Study, Site, Care Episode). Not a class; purely a string annotation on the Person-Scope binding. Example value: 'Principal Investigator'." ;
    rdfs:domain hcls:Person ;
    top:flavor "Additive" .

hcls:affiliatedWith a owl:ObjectProperty ;
    rdfs:label "affiliated with" ;
    rdfs:domain hcls:Person ;
    rdfs:range hcls:Organization ;
    top:flavor "Additive" .

hcls:authorizedAgentType a owl:ObjectProperty ;
    rdfs:label "authorized agent type" ;
    rdfs:comment "The OWL class of agent authorized to execute this Action. Authorization binds directly to agent type — no OperatorRole intermediary. Multi-valued: an Action may be authorized for more than one agent type." ;
    rdfs:domain hcls:Action ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:collectedFrom a owl:ObjectProperty ;
    rdfs:label "collected from" ;
    rdfs:domain hcls:Specimen ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

hcls:consentSubject a owl:ObjectProperty ;
    rdfs:label "consent subject" ;
    rdfs:domain hcls:Consent ;
    rdfs:range hcls:Person ;
    top:flavor "Additive" .

hcls:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:comment "Containment: a phase contains its named sub-phases. Transitive; used to derive the top-level phase for any sub-phase." ;
    rdfs:domain hcls:Phase ;
    rdfs:range hcls:Phase ;
    top:flavor "Additive" .

hcls:executesAction a owl:ObjectProperty ;
    rdfs:label "executes action" ;
    rdfs:comment "An Action performed as part of accomplishing this job." ;
    rdfs:domain hcls:JobToBeDone ;
    rdfs:range hcls:Action ;
    top:flavor "Additive" .

hcls:givesConsent a owl:ObjectProperty ;
    rdfs:label "gives consent" ;
    rdfs:domain hcls:Person ;
    rdfs:range hcls:Consent ;
    top:flavor "Additive" .

hcls:involvesObject a owl:ObjectProperty ;
    rdfs:label "involves object" ;
    rdfs:comment "An entity class that participates in this job's object graph." ;
    rdfs:domain hcls:JobToBeDone ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:jobOfAgentType a owl:ObjectProperty ;
    rdfs:label "job of agent type" ;
    rdfs:comment "The OWL class of agent this job belongs to." ;
    rdfs:domain hcls:JobToBeDone ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:jobTrigger a owl:DatatypeProperty ;
    rdfs:label "job trigger" ;
    rdfs:comment "The condition or event that initiates this job (from OOUX JTBD 'trigger' field)." ;
    rdfs:domain hcls:JobToBeDone ;
    top:flavor "Additive" .

hcls:locatedAt a owl:ObjectProperty ;
    rdfs:label "located at" ;
    rdfs:domain hcls:Organization ;
    rdfs:range hcls:HealthcareFacility ;
    top:flavor "Additive" .

hcls:occursIn a owl:ObjectProperty ;
    rdfs:label "occurs in" ;
    rdfs:comment "The lifecycle phase in which this Action is typically performed." ;
    rdfs:domain hcls:Action ;
    rdfs:range hcls:Phase ;
    top:flavor "Additive" .

hcls:operatesOn a owl:ObjectProperty ;
    rdfs:label "operates on" ;
    rdfs:comment "The OWL class of the primary entity this Action targets. Enables querying: what Actions are available on a given entity type for a given agent type in a given phase?" ;
    rdfs:domain hcls:Action ;
    rdfs:range owl:Class ;
    top:flavor "Additive" .

hcls:precedes a owl:ObjectProperty ;
    rdfs:label "precedes" ;
    rdfs:comment "Temporal sequencing: Phase A precedes Phase B means B cannot begin before A's gate conditions are met." ;
    rdfs:domain hcls:Phase ;
    rdfs:range hcls:Phase ;
    top:flavor "Additive" .

hcls:realizationOf a owl:ObjectProperty ;
    rdfs:label "realization of" ;
    rdfs:comment "Links a prov:Activity instance (an occurrence that actually happened) to the hcls:Action archetype it realizes. Instance-to-archetype traceability link." ;
    rdfs:range hcls:Action ;
    top:flavor "Additive" .

hcls:successSignal a owl:DatatypeProperty ;
    rdfs:label "success signal" ;
    rdfs:comment "A measurable indicator that the job has been completed. Multi-valued." ;
    rdfs:domain hcls:JobToBeDone ;
    top:flavor "Additive" .

hcls:HealthcareFacility a owl:Class ;
    rdfs:label "Healthcare Facility" ;
    rdfs:comment "A physical place where care or research is conducted." ;
    rdfs:subClassOf top:Location .

hcls:Practitioner a owl:Class ;
    rdfs:label "Practitioner" ;
    rdfs:comment "A healthcare professional." ;
    rdfs:subClassOf hcls:Person .

hcls:Specimen a owl:Class ;
    rdfs:label "Specimen" ;
    rdfs:comment "A biospecimen collected from a Person." ;
    rdfs:subClassOf top:Resource .

hcls:Consent a owl:Class ;
    rdfs:label "Consent" ;
    rdfs:comment "An act of agreement by a Person authorizing an action or use of their data/person. HCLS-universal: permutates to cr:InformedConsentAct (clinical trial enrollment), HIPAA Authorization (data use), Treatment Consent (clinical care). Carries valid-time (when consent was given, when it expires) and transaction-time (when it was recorded)." ;
    rdfs:subClassOf top:Temporal,
        top:Versioned .

hcls:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organization — sponsor, CRO, site, central lab, or regulator." ;
    rdfs:subClassOf top:Agent .

hcls:Action a owl:Class ;
    rdfs:label "Action" ;
    rdfs:comment "A named, authorized operation (Call To Action in OOUX terms) that an agent of a given type may perform in a given Phase. Actions are reference-graph archetypes (top:Constraint: they specify what is authorized). Realized occurrences in instance graphs are prov:Activity individuals linked back via hcls:realizationOf." ;
    rdfs:subClassOf top:Constraint .

hcls:JobToBeDone a owl:Class ;
    rdfs:label "Job to Be Done" ;
    rdfs:comment "A bounded unit of operator intent: the goal an agent type is trying to achieve, with a trigger condition and measurable success signals. Scoped to an agent type (OWL class) and a Phase. References the object graph and authorized Actions involved. Derived from OOUX JTBD blocks." ;
    rdfs:subClassOf top:Scope .

hcls:Phase a owl:Class ;
    rdfs:label "Phase" ;
    rdfs:comment "A bounded, sequenced stage of a process lifecycle within an HCLS domain. Phases form a containment tree (hcls:contains) and a precedence chain (hcls:precedes). Permutates to: cr:StartupPhase/ConductPhase/CloseoutPhase (clinical research); Admission/Inpatient/Discharge (clinical care); Formulation/Fill-Finish/Release (manufacturing)." ;
    rdfs:subClassOf top:Scope .

hcls:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human. BOUNDARY-ONLY / PII layer: an identifiable Person lives inside the source/site sovereign boundary. Downstream and shareable artifacts must attach to a pseudonymous cr:StudySubject, never to a Person. The only legal Person<->Subject link is the attested Enrollment bridge (cr:enrolledPerson). Clinical data is PSEUDONYMIZED, not anonymized: re-identification is preserved but controlled (safety / emergency unblinding)." ;
    rdfs:subClassOf top:Agent .

