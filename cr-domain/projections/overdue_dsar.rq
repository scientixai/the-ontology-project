# overdue_dsar.rq — Data Subject Requests past their deadline and not yet fulfilled.
# Useful for compliance dashboards and audit trails.

PREFIX cr:  <https://top.scientix.ai/cr/v1#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?dsr ?dsrType ?deadline ?status ?subject
WHERE {
    ?dsr  a              cr:DataSubjectRequest ;
          cr:dsrType     ?dsrType ;
          cr:dsrDeadline ?deadline ;
          cr:dsrStatus   ?status ;
          cr:dsrForSubject ?subject .

    FILTER ( ?status NOT IN ("Fulfilled", "Denied") )
    FILTER ( ?deadline < NOW() )
}
ORDER BY ASC(?deadline)
