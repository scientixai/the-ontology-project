# Blood-draw traceback — an assay result -> sample -> (aliquot/derivation)* -> primary
# specimen -> the collection event. "Trace this result to the draw" is a query.
PREFIX cr:   <https://top.scientix.ai/cr/v1#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?result ?event WHERE {
  ?r a cr:AssayResult ; rdfs:label ?result ; cr:onSample ?s .
  ?s prov:wasDerivedFrom* ?root .
  ?root cr:collectedAt ?ev .
  ?ev rdfs:label ?event .
}
