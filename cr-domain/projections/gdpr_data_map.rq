# gdpr_data_map.rq — All graph entities transitively linked to a given hcls:Person (US-600-004).
# Use for GDPR DSAR Art 15 (right of access) — enumerate all personal data held.
# Substitute ?personIRI with the IRI of the subject of the request.
PREFIX cr:    <https://top.scientix.ai/cr/v1#>
PREFIX hcls:  <https://top.scientix.ai/hcls/v1#>
PREFIX top:   <https://top.scientix.ai/v1#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?entity ?entityType ?entityLabel
WHERE {
  BIND ( <urn:example:person/P001> AS ?person )
  {
    ?entity cr:forSubject ?person .
  } UNION {
    ?entity cr:dsrForSubject ?person .
  } UNION {
    ?consent cr:forSubject ?person .
    ?entity cr:closesConsent ?consent .
  } UNION {
    ?entity cr:enrolledSubject ?person .
  }
  OPTIONAL { ?entity a ?entityType . }
  OPTIONAL { ?entity rdfs:label ?entityLabel . }
}
ORDER BY ?entityType ?entity
