# gdpr_data_map.rq — All graph entities transitively linked to a given hcls:Person (US-600-004).
# Use for GDPR DSAR Art 15 (right of access) — enumerate all personal data held.
# Substitute ?personIRI with the target person's IRI.
PREFIX cr:   <https://top.scientix.ai/cr/v1#>
PREFIX hcls: <https://top.scientix.ai/hcls/v1#>
PREFIX top:  <https://top.scientix.ai/v1#>

SELECT DISTINCT ?entity ?entityType
WHERE {
  VALUES ?person { <urn:person:REPLACE_WITH_PERSON_IRI> }

  {
    # Direct: entities that reference the person
    ?entity ?p ?person .
  } UNION {
    # Via StudySubject (pseudonymous bridge)
    ?enrollment a cr:Enrollment ;
                cr:enrolledPerson ?person ;
                cr:asSubject ?subject .
    ?entity ?p2 ?subject .
  } UNION {
    # Via Participant
    ?participant a cr:Participant ;
                 cr:personRef ?person .
    ?entity ?p3 ?participant .
  }

  ?entity a ?entityType .
}
ORDER BY ?entityType ?entity
