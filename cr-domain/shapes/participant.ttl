@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix top:  <https://top.scientix.ai/v1#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix dct:  <http://purl.org/dc/terms/> .

<https://top.scientix.ai/shapes/participant-v1> a owl:Ontology ;
    owl:versionInfo "1.2" ;
    dct:title "SHACL shapes — participant & consent (US-500-003)" .

# ── InformedConsent shape ────────────────────────────────────────────────────

cr:InformedConsentShape a sh:NodeShape ;
    sh:targetClass cr:InformedConsent ;

    # pre-existing constraints
    sh:property [
        sh:path     cr:consentDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:message  "cr:consentDate (xsd:date) is required." ;
    ] ;
    sh:property [
        sh:path     cr:consentStatus ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in       ( "active" "withdrawn" "expired" ) ;
        sh:message  "cr:consentStatus must be one of: active, withdrawn, expired." ;
    ] ;

    # new constraints (US-500-003)
    sh:property [
        sh:path     cr:consentVersion ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message  "cr:consentVersion is required (US-500-003)." ;
    ] ;
    sh:property [
        sh:path     cr:consentFormIRI ;
        sh:datatype xsd:anyURI ;
        sh:minCount 1 ;
        sh:message  "cr:consentFormIRI (xsd:anyURI) is required (US-500-003)." ;
    ] ;
    sh:property [
        sh:path     cr:witnessedBy ;
        sh:class    hcls:Person ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:message  "cr:witnessedBy must point to at most one hcls:Person." ;
    ] ;
    sh:property [
        sh:path     cr:withdrawalDate ;
        sh:datatype xsd:date ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:message  "cr:withdrawalDate (xsd:date) — optional, but must be a valid date if present." ;
    ] ;

    # cross-property constraint: withdrawalDate must be >= validFrom
    sh:sparql [
        sh:message  "Violation: cr:withdrawalDate precedes top:validFrom — consent cannot be withdrawn before it was recorded." ;
        sh:severity sh:Violation ;
        sh:prefixes <https://top.scientix.ai/shapes/participant-v1> ;
        sh:select   """
            PREFIX cr:  <https://top.scientix.ai/cr/v1#>
            PREFIX top: <https://top.scientix.ai/v1#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            SELECT $this ?withdrawalDate ?validFrom
            WHERE {
                $this cr:withdrawalDate ?withdrawalDate ;
                      top:validFrom     ?validFrom .
                FILTER ( ?withdrawalDate < ?validFrom )
            }
        """ ;
    ] .

# ── StudySubject shape ───────────────────────────────────────────────────────

cr:StudySubjectShape a sh:NodeShape ;
    sh:targetClass cr:StudySubject ;
    sh:property [
        sh:path     cr:subjectId ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message  "cr:subjectId is required." ;
    ] ;
    sh:property [
        sh:path     top:validFrom ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:message  "top:validFrom (xsd:dateTime) is required on StudySubject." ;
    ] ;
    sh:property [
        sh:path     cr:hasConsent ;
        sh:class    cr:InformedConsent ;
        sh:minCount 0 ;
        sh:message  "cr:hasConsent must point to a cr:InformedConsent." ;
    ] ;
    sh:property [
        sh:path     cr:hasEnrollment ;
        sh:class    cr:Enrollment ;
        sh:minCount 0 ;
        sh:message  "cr:hasEnrollment must point to a cr:Enrollment." ;
    ] .

# ── Enrollment shape ─────────────────────────────────────────────────────────

cr:EnrollmentShape a sh:NodeShape ;
    sh:targetClass cr:Enrollment ;
    sh:property [
        sh:path     cr:enrollmentDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:message  "cr:enrollmentDate (xsd:date) is required." ;
    ] ;
    sh:property [
        sh:path     top:validFrom ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:message  "top:validFrom (xsd:dateTime) is required on Enrollment." ;
    ] ;
    sh:property [
        sh:path     cr:enrolledInArm ;
        sh:class    cr:Arm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "cr:enrolledInArm must point to exactly one cr:Arm." ;
    ] .

# ── EligibilityCriterion shape ───────────────────────────────────────────────

cr:EligibilityCriterionShape a sh:NodeShape ;
    sh:targetClass cr:EligibilityCriterion ;
    sh:property [
        sh:path     cr:criterionType ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in       ( "inclusion" "exclusion" ) ;
        sh:message  "cr:criterionType must be 'inclusion' or 'exclusion'." ;
    ] ;
    sh:property [
        sh:path     cr:criterionText ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message  "cr:criterionText is required." ;
    ] .
