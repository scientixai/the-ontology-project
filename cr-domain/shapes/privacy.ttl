@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/v1#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Privacy & Compliance SHACL shapes (US-600-001 through US-600-004).

# US-600-001: Post-withdrawal observations are violations.
cr:PostWithdrawalObservationShape a sh:NodeShape ;
    rdfs:label "Observation recorded after consent withdrawal" ;
    sh:targetClass hcls:Observation ;
    sh:severity sh:Violation ;
    sh:sparql [
        sh:message "Observation recorded after the subject's consent withdrawal date (GDPR / ICH E6(R3) concern)." ;
        sh:select """
            SELECT $this WHERE {
              $this <https://top.scientix.ai/v1#validFrom> ?obsDate .
              ?withdrawal a <https://top.scientix.ai/cr/v1#ConsentWithdrawal> ;
                          <https://top.scientix.ai/cr/v1#closesConsent> ?consent .
              ?consent <https://top.scientix.ai/cr/v1#withdrawalDate> ?wd .
              FILTER ( xsd:date(?obsDate) > ?wd )
            }
        """ ;
    ] .

# US-600-001: ConsentWithdrawal reason must be coded.
cr:WithdrawalReasonShape a sh:NodeShape ;
    rdfs:label "Withdrawal reason must be coded" ;
    sh:targetClass cr:ConsentWithdrawal ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path cr:withdrawalReason ;
        sh:minCount 1 ;
        sh:in ("subject-decision" "AE" "lost-to-follow-up" "other") ;
        sh:message "cr:withdrawalReason must be one of: subject-decision, AE, lost-to-follow-up, other." ;
    ] .

# US-600-002: EU-governed studies must declare a lawful basis.
cr:LawfulBasisRequiredShape a sh:NodeShape ;
    rdfs:label "EU-governed study must declare lawful basis" ;
    sh:targetClass cr:Study ;
    sh:severity sh:Violation ;
    sh:sparql [
        sh:message "Study governed by EU_GDPR must declare a cr:LawfulBasis via top:governedBy." ;
        sh:select """
            SELECT $this WHERE {
              $this <https://top.scientix.ai/v1#governedBy> <https://top.scientix.ai/v1#EU_GDPR> .
              FILTER NOT EXISTS {
                $this <https://top.scientix.ai/v1#governedBy> ?basis .
                ?basis a <https://top.scientix.ai/cr/v1#LawfulBasis> .
              }
            }
        """ ;
    ] .

# US-600-003: DPA completeness.
cr:DPARequiredShape a sh:NodeShape ;
    rdfs:label "Data Processing Agreement required fields" ;
    sh:targetClass cr:DataProcessingAgreement ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path cr:processorOrg ;
        sh:minCount 1 ;
        sh:message "cr:DataProcessingAgreement must link to a processor organization via cr:processorOrg." ;
    ] ;
    sh:property [
        sh:path cr:controllerOrg ;
        sh:minCount 1 ;
        sh:message "cr:DataProcessingAgreement must link to a controller (sponsor) via cr:controllerOrg." ;
    ] ;
    sh:property [
        sh:path cr:dpaEffectiveDate ;
        sh:minCount 1 ;
        sh:message "cr:DataProcessingAgreement must carry cr:dpaEffectiveDate." ;
    ] .

# US-600-004: DSR type must be coded.
cr:DSRTypeShape a sh:NodeShape ;
    rdfs:label "Data Subject Request type must be coded" ;
    sh:targetClass cr:DataSubjectRequest ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path cr:dsrType ;
        sh:minCount 1 ;
        sh:in ("access" "erasure" "rectification" "portability") ;
        sh:message "cr:dsrType must be one of: access, erasure, rectification, portability." ;
    ] .
