@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/v1#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# US-600-001: ConsentWithdrawal shape
cr:ConsentWithdrawalShape a sh:NodeShape ;
    sh:targetClass cr:ConsentWithdrawal ;
    sh:property [
        sh:path cr:closesConsent ;
        sh:minCount 1 ;
        sh:class cr:InformedConsent ;
        sh:message "A ConsentWithdrawal must link to the InformedConsent it closes via cr:closesConsent." ;
    ] ;
    sh:property [
        sh:path cr:withdrawalReason ;
        sh:minCount 1 ;
        sh:in ( "subject-decision" "AE" "lost-to-follow-up" "other" ) ;
        sh:message "withdrawalReason must be one of: subject-decision, AE, lost-to-follow-up, other." ;
    ] .

# US-600-001: Post-withdrawal observation violation
cr:PostWithdrawalObservationShape a sh:NodeShape ;
    sh:targetClass cr:Observation ;
    sh:sparql [
        sh:message "Observation collected after subject withdrew consent." ;
        sh:prefixes cr: ;
        sh:select """
            SELECT $this
            WHERE {
                $this cr:forSubject ?subj .
                $this cr:collectionDate ?obsDate .
                ?withdrawal a cr:ConsentWithdrawal ;
                    cr:closesConsent ?consent .
                ?consent cr:forSubject ?subj ;
                    cr:consentDate ?consentDate .
                FILTER ( ?obsDate > ?consentDate )
            }
        """ ;
    ] .

# US-600-002: LawfulBasis shape
cr:LawfulBasisShape a sh:NodeShape ;
    sh:targetClass cr:LawfulBasis ;
    sh:property [
        sh:path cr:lawfulBasisDescription ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "A LawfulBasis must have a lawfulBasisDescription." ;
    ] .

# US-600-002: EU-governed studies must declare lawful basis
cr:EUStudyLawfulBasisShape a sh:NodeShape ;
    sh:targetClass cr:ClinicalStudy ;
    sh:sparql [
        sh:message "EU-governed ClinicalStudy must declare at least one cr:LawfulBasis via cr:hasLawfulBasis." ;
        sh:prefixes cr: ;
        sh:select """
            SELECT $this
            WHERE {
                $this cr:regulatoryJurisdiction "EU" .
                FILTER NOT EXISTS {
                    $this cr:hasLawfulBasis ?basis .
                    ?basis a cr:LawfulBasis .
                }
            }
        """ ;
    ] .

# US-600-003: DataProcessingAgreement shape
cr:DataProcessingAgreementShape a sh:NodeShape ;
    sh:targetClass cr:DataProcessingAgreement ;
    sh:property [
        sh:path cr:processorOrg ;
        sh:minCount 1 ;
        sh:class hcls:Organization ;
        sh:message "A DPA must identify the processor organization." ;
    ] ;
    sh:property [
        sh:path cr:controllerOrg ;
        sh:minCount 1 ;
        sh:class cr:Sponsor ;
        sh:message "A DPA must identify the controller (sponsor) organization." ;
    ] ;
    sh:property [
        sh:path cr:dpaEffectiveDate ;
        sh:minCount 1 ;
        sh:datatype xsd:date ;
        sh:message "A DPA must have an effective date." ;
    ] ;
    sh:property [
        sh:path cr:processingPurposes ;
        sh:minCount 1 ;
        sh:class cr:LawfulBasis ;
        sh:message "A DPA must declare at least one processing purpose (LawfulBasis)." ;
    ] .

# US-600-004: RetentionPolicy shape
cr:RetentionPolicyShape a sh:NodeShape ;
    sh:targetClass cr:RetentionPolicy ;
    sh:property [
        sh:path cr:retentionPeriod ;
        sh:minCount 1 ;
        sh:datatype xsd:duration ;
        sh:message "A RetentionPolicy must specify a retention period as an xsd:duration." ;
    ] ;
    sh:property [
        sh:path cr:retentionBasis ;
        sh:minCount 1 ;
        sh:message "A RetentionPolicy must link to a regulatory law as its basis." ;
    ] .

# US-600-004: DataSubjectRequest shape
cr:DataSubjectRequestShape a sh:NodeShape ;
    sh:targetClass cr:DataSubjectRequest ;
    sh:property [
        sh:path cr:dsrType ;
        sh:minCount 1 ;
        sh:in ( "access" "erasure" "rectification" "portability" ) ;
        sh:message "dsrType must be one of: access, erasure, rectification, portability." ;
    ] ;
    sh:property [
        sh:path cr:dsrDeadline ;
        sh:minCount 1 ;
        sh:datatype xsd:date ;
        sh:message "A DataSubjectRequest must have a response deadline." ;
    ] ;
    sh:property [
        sh:path cr:dsrStatus ;
        sh:minCount 1 ;
        sh:in ( "open" "in-progress" "fulfilled" "rejected" ) ;
        sh:message "dsrStatus must be one of: open, in-progress, fulfilled, rejected." ;
    ] ;
    sh:property [
        sh:path cr:dsrForSubject ;
        sh:minCount 1 ;
        sh:class hcls:Person ;
        sh:message "A DataSubjectRequest must be linked to the data subject it concerns." ;
    ] .
