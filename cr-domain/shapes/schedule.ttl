@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Graded reconciliation of the planned schedule against what actually happened.
# Structural shapes (Violation) keep the timeline well-formed; reconciliation shapes
# grade the planned-vs-actual gap by materiality — an out-of-window visit is a
# deviation candidate (Warning, cf. cr:DelegationTimingShape), a broken hard ordering
# constraint is a fatal finding (Violation).

# STRUCTURAL (Violation): a planned encounter must be positioned (carry a timing).
cr:PlannedEncounterTimingShape a sh:NodeShape ;
    rdfs:label "Planned encounter must be positioned" ;
    sh:targetClass cr:PlannedEncounter ;
    sh:property [
        sh:path cr:timing ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "PlannedEncounter has no cr:timing (an encounter must be positioned on the timeline)." ;
    ] .

# STRUCTURAL (Violation): a planned activity must be positioned EITHER by a timing
# OR by an ordering edge — "no timing, just imposing the order" is legitimate, but
# an activity positioned by neither is floating.
cr:PlannedActivityPositionShape a sh:NodeShape ;
    rdfs:label "Planned activity must be positioned (timing or ordering)" ;
    sh:severity sh:Violation ;
    sh:targetClass cr:PlannedActivity ;
    sh:sparql [
        sh:message "PlannedActivity has neither a cr:timing nor an ordering edge (cr:precedes); it is unpositioned." ;
        sh:select """
            SELECT $this WHERE {
              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#timing> ?t . }
              FILTER NOT EXISTS { $this <https://top.scientix.ai/cr/v1#precedes> ?o . }
              FILTER NOT EXISTS { ?p <https://top.scientix.ai/cr/v1#precedes> $this . }
            }
        """ ;
    ] .

# STRUCTURAL (Violation): a projected planned visit must carry its resolved window.
cr:PlannedVisitWindowShape a sh:NodeShape ;
    rdfs:label "Planned visit must carry a resolved target + window" ;
    sh:targetClass cr:PlannedVisit ;
    sh:property [ sh:path cr:targetDate  ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "PlannedVisit has no cr:targetDate." ] ;
    sh:property [ sh:path cr:windowStart ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "PlannedVisit has no cr:windowStart." ] ;
    sh:property [ sh:path cr:windowEnd   ; sh:minCount 1 ; sh:severity sh:Violation ;
        sh:message "PlannedVisit has no cr:windowEnd." ] .

# RECONCILIATION (Warning): an actual visit realized outside its planned window.
# Out-of-window is a deviation candidate — a materiality judgment, not an automatic
# hard failure.
cr:VisitWindowShape a sh:NodeShape ;
    rdfs:label "Visit outside planned window (warning)" ;
    sh:severity sh:Warning ;
    sh:targetSubjectsOf cr:realizes ;
    sh:sparql [
        sh:message "Actual visit's observedAt falls outside the planned window of the visit it realizes (out-of-window) — review materiality." ;
        sh:select """
            SELECT $this WHERE {
              $this <https://top.scientix.ai/cr/v1#realizes> ?pv ;
                    <https://top.scientix.ai/core/v1#observedAt> ?t .
              ?pv a <https://top.scientix.ai/cr/v1#PlannedVisit> ;
                  <https://top.scientix.ai/cr/v1#windowStart> ?ws ;
                  <https://top.scientix.ai/cr/v1#windowEnd> ?we .
              FILTER ( ?t < ?ws || ?t > ?we )
            }
        """ ;
    ] .

# RECONCILIATION (Violation): a hard ordering constraint broken in execution.
# If the plan says activity A precedes activity B, the acts realizing them must keep
# that order; a reversal (e.g. bloods drawn before the ECG they must follow) is hard.
cr:ActivityOrderingShape a sh:NodeShape ;
    rdfs:label "Execution violates planned ordering (hard)" ;
    sh:severity sh:Violation ;
    sh:targetSubjectsOf cr:realizes ;
    sh:sparql [
        sh:message "Acts executed out of the order their planned activities require (cr:precedes violated)." ;
        sh:select """
            SELECT $this WHERE {
              $this   <https://top.scientix.ai/cr/v1#realizes> ?pa ;
                      <https://top.scientix.ai/core/v1#observedAt> ?ta .
              ?pa     <https://top.scientix.ai/cr/v1#precedes> ?pb .
              ?other  <https://top.scientix.ai/cr/v1#realizes> ?pb ;
                      <https://top.scientix.ai/core/v1#observedAt> ?tb .
              FILTER ( ?ta > ?tb )
            }
        """ ;
    ] .
