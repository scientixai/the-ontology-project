@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .

# TOP Core's Universal DNA: every entity carries identity, time, and lifecycle state.
# observedAt (the time strand) is enforced by top:BitemporalProvShape; this shape
# enforces the other two strands — identifier and status — on the same entities.
top:UniversalDNAShape a sh:NodeShape ;
    sh:targetClass top:ProvenancedEntity ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path top:identifier ; sh:minCount 1 ;
        sh:message "Universal DNA: every entity must carry a top:identifier." ;
    ] ;
    sh:property [
        sh:path top:status ; sh:minCount 1 ;
        sh:message "Universal DNA: every entity must carry a top:status." ;
    ] .
