@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# NEGATIVE (Violation): an act attached directly to an identifiable Person — a PII leak.
# Envelope present so the failure isolates to PII containment.
ex:pii-leak-ae a cr:AdverseEvent ;
    cr:forSubject ex:pii-person ;
    top:observedAt  "2026-06-01T00:00:00Z"^^xsd:dateTime ;
    top:recordedAt "2026-06-01T06:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:pii-inv2 .
ex:pii-person a hcls:Person ; rdfs:label "Jane Doe (identifiable — must not appear here)" .
ex:pii-inv2 a hcls:Practitioner .

# --- Universal DNA (TOP Core): identifier + status (observedAt already present above) ---
<https://top.scientix.ai/examples/pii-leak-ae> top:identifier "urn:pii-leak-ae" ; top:status "active" .
