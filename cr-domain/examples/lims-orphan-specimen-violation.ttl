@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# NEGATIVE (Violation): a specimen with no collection event and no parent — unrooted
# custody (chain of custody can't begin). Subject present so failure isolates to origin.
ex:spec-orphan a hcls:Specimen ; rdfs:label "Unrooted specimen" ;
    cr:forSubject ex:os-subj .
ex:os-subj a cr:StudySubject .
