@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Universal DNA — conformant. A bare top:ProvenancedEntity that carries all three
# strands: identity (top:identifier), time (top:observedAt), and lifecycle (top:status),
# plus the bitemporal/PROV envelope. This is the minimum every TOP entity must satisfy.
ex:dna-ok a top:ProvenancedEntity ;
    rdfs:label "A minimally well-formed TOP entity" ;
    top:identifier "urn:dna-ok" ;
    top:status "active" ;
    top:observedAt "2026-03-01T00:00:00Z"^^xsd:dateTime ;
    top:recordedAt "2026-03-01T00:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:agent-1 .
