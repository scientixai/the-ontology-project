@prefix ex:  <https://top.scientix.ai/examples/> .
@prefix cr:  <https://top.scientix.ai/cr/v1#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Conformant: cr:Arm with randomizationRatio and plannedEnrollment (US-200-002).

ex:arm-active a cr:Arm ;
    top:identifier "urn:arm:LY900018-active"^^xsd:anyURI ;
    top:observedAt "2025-06-01T00:00:00Z"^^xsd:dateTime ;
    top:status "active" ;
    cr:randomizationRatio "2:1" ;
    cr:stratificationFactor "ECOG PS (0 vs 1)" ;
    cr:plannedEnrollment 100 ;
    cr:actualEnrollment 98 .

ex:arm-placebo a cr:Arm ;
    top:identifier "urn:arm:LY900018-placebo"^^xsd:anyURI ;
    top:observedAt "2025-06-01T00:00:00Z"^^xsd:dateTime ;
    top:status "active" ;
    cr:randomizationRatio "1:2" ;
    cr:plannedEnrollment 50 ;
    cr:actualEnrollment 51 .
