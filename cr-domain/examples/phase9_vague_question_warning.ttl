@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# RISK-PROPORTIONATE (Warning): briefing book + question present (readiness ok), but the
# question is vague — no proposed position. Reviewable, not fatal.
ex:preind2 a cr:RegulatoryInteraction ;
    cr:meetingType "Pre-IND" ;
    cr:hasBriefingBook ex:bb2 ;
    cr:hasQuestion ex:q2 .
ex:bb2 a cr:BriefingBook .
ex:q2 a cr:RegulatoryQuestion ; rdfs:label "Is our overall development plan promising?" .
