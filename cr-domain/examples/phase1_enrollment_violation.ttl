@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# NEGATIVE: an Enrollment missing cr:asSubject (no pseudonymous bridge).
# Envelope is present so the failure isolates to EnrollmentShape.
ex:bad-enroll a cr:Enrollment ;
    top:observedAt  "2026-02-05T10:00:00Z"^^xsd:dateTime ;
    top:recordedAt "2026-02-05T10:05:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:agent-x ;
    cr:enrolledPerson ex:p-x ;
    cr:intoStudy ex:s-x .

ex:agent-x a top:Agent, prov:Agent .
ex:p-x a hcls:Person .
ex:s-x a cr:Study .

# --- Universal DNA (TOP Core): identifier + status (observedAt already present above) ---
<https://top.scientix.ai/examples/bad-enroll> top:identifier "urn:bad-enroll" ; top:status "active" .
