@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix tmf:  <https://top.scientix.ai/tmf/v1#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# WORKED EXAMPLE — TMF binding. An artifact type with BOTH bindings: it is classified
# (document-type binding: a Protocol Deviation Log) AND its facts are bound to the domain
# (content binding: tmf:records cr:DeviationEvent). This is comprehension, not just filing.
# (The runtime that classifies a real document and extracts its facts is the consuming
# system, out of scope — this example is the schema-level binding only.)

ex:site-deviation-log a tmf:TMFArtifactType ;
    skos:prefLabel "Site 03 Protocol Deviation Log" ; rdfs:label "Site 03 Protocol Deviation Log" ;
    tmf:records cr:DeviationEvent .
