@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# NEGATIVE (Violation): an ADaM dataset with no declared source — breaks
# reproducibility-to-source. Envelope present so the failure isolates to traceability.
ex:orphan-adam a cr:AnalysisDataset ;
    top:observedAt  "2026-08-01T00:00:00Z"^^xsd:dateTime ;
    top:recordedAt "2026-08-01T00:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:b-adam .
ex:b-adam a hcls:Person, prov:Agent .

# --- Universal DNA (TOP Core): identifier + status (observedAt already present above) ---
<https://top.scientix.ai/examples/orphan-adam> top:identifier "urn:orphan-adam" ; top:status "active" .
