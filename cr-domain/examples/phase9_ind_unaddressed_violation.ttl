@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# NEGATIVE (Violation): an animal toxicity with NO clinical safety assessment addressing
# it — the "broken narrative" that draws an immediate clinical hold.
ex:finding-qt a cr:NonclinicalFinding ; rdfs:label "QT prolongation in dog" ;
    cr:identifiedIn ex:tox-x .
ex:tox-x a cr:GLPToxReport ; rdfs:label "Cardiovascular safety study (dog)" .
