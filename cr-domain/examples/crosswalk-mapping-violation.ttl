@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cx:   <https://top.scientix.ai/crosswalk/v1#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# NEGATIVE: an uncurated mapping — no confidence, no justification, no provenance.
# The curation gate must reject it (Violation).
ex:bad-map a cx:Mapping ;
    cx:subjectId cr:Study ;
    cx:predicateId skos:exactMatch ;
    cx:objectId <https://example.org/some-external-term> .
