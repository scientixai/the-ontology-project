@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# NEGATIVE (Violation): a custody event with an invalid lifecycle state ("Lost").
ex:cb-spec a hcls:Specimen ; cr:collectedAt ex:cb-ev .
ex:cb-ev a cr:StudyEvent .
ex:ce-bad a cr:CustodyEvent ; cr:specimen ex:cb-spec ; cr:toState "Lost" ;
    top:observedAt "2026-03-10T13:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-03-10T13:02:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:cb-tech .
ex:cb-tech a hcls:Person, prov:Agent .

# --- Universal DNA (TOP Core): identifier + status (observedAt already present above) ---
<https://top.scientix.ai/examples/ce-bad> top:identifier "urn:ce-bad" ; top:status "active" .
