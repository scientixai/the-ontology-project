@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Universal DNA — negative. This entity has identity, time, and the bitemporal/PROV
# envelope, but is MISSING its lifecycle strand (top:status). top:UniversalDNAShape
# must bite: an entity with no status is not a well-formed TOP entity.
ex:dna-no-status a top:ProvenancedEntity ;
    rdfs:label "Missing its status strand" ;
    top:identifier "urn:dna-no-status" ;
    top:observedAt "2026-03-01T00:00:00Z"^^xsd:dateTime ;
    top:recordedAt "2026-03-01T00:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:agent-1 .
