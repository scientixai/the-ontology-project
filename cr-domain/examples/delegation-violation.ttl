@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# NEGATIVE: a Delegation missing cr:requiresCredential (ungated delegation).
# Envelope present so the failure isolates to DelegationShape.
ex:bad-deleg a cr:Delegation ;
    top:observedAt  "2026-02-03T08:30:00Z"^^xsd:dateTime ;
    top:recordedAt "2026-02-03T08:31:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:pi-x ;
    cr:delegator ex:pi-x ;
    cr:delegate ex:nurse-x ;
    cr:delegatedCapability ex:cap-x .

ex:pi-x a hcls:Person .
ex:nurse-x a hcls:Person .
ex:cap-x a cr:Capability .

# --- Universal DNA (TOP Core): identifier + status (observedAt already present above) ---
<https://top.scientix.ai/examples/bad-deleg> top:identifier "urn:bad-deleg" ; top:status "active" .
