@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .

# RISK-PROPORTIONATE (Warning): an EOP2 meeting recorded with a risk register but no
# binding agreement yet — readiness warning, not a hard failure.
ex:eop2-bad a cr:RegulatoryInteraction ;
    cr:meetingType "EOP2" ;
    cr:hasRiskRegister ex:rr-x .
ex:rr-x a cr:RiskRegister .
