@prefix ex:  <https://top.scientix.ai/examples/> .
@prefix cr:  <https://top.scientix.ai/cr/v1#> .
@prefix top: <https://top.scientix.ai/top/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# -----------------------------------------------------------
#  Conformant DataProcessingAgreement example  (US-600-003)
# -----------------------------------------------------------

ex:Org_CRO_Acme
    a top:Organization ;
    rdfs:label "Acme CRO Ltd" .

ex:Org_Sponsor_Pharma
    a top:Organization ;
    rdfs:label "Pharma Sponsor Inc." .

ex:DPA_Trial42
    a cr:DataProcessingAgreement ;
    cr:controllerOrg      ex:Org_Sponsor_Pharma ;
    cr:processorOrg       ex:Org_CRO_Acme ;
    cr:dpaEffectiveDate   "2025-01-15"^^xsd:date ;
    cr:processingPurposes "Clinical trial data management and biostatistical analysis for Study TRIAL-42 under GDPR Art 28." .

ex:Study_Trial42
    a cr:ClinicalStudy ;
    rdfs:label      "TRIAL-42 Phase III" ;
    cr:governedByDPA ex:DPA_Trial42 ;
    cr:hasLawfulBasis cr:Art9_2_j .
