@prefix ex:  <https://top.scientix.ai/examples/> .
@prefix cr:  <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top: <https://top.scientix.ai/v1#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Conformant DataProcessingAgreement example (US-600-003)
ex:DPA_CRO_Alpha_2024 a cr:DataProcessingAgreement ;
    rdfs:label "DPA: Sponsor XYZ — CRO Alpha (2024)" ;
    cr:controllerOrg ex:SponsorXYZ ;
    cr:processorOrg ex:CRO_Alpha ;
    cr:dpaEffectiveDate "2024-01-15"^^xsd:date ;
    cr:processingPurposes cr:GDPR_Art9_2_j .

ex:SponsorXYZ a cr:Sponsor ;
    rdfs:label "Sponsor XYZ Pharmaceuticals" .

ex:CRO_Alpha a hcls:Organization ;
    rdfs:label "CRO Alpha Clinical Services" .
