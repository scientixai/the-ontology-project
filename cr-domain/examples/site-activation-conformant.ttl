@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# WORKED EXAMPLE — site start-up to activation. IRB approval -> executed CTA ->
# coverage analysis -> SIV -> activation (green-light), each milestone dated (bitemporal).

ex:site-act a cr:StudySite ; rdfs:label "Denver Cancer Center" ; cr:targetAccrual 20 .
ex:su-mgr a hcls:Practitioner ; rdfs:label "Start-up manager" .

ex:irb1 a cr:IRBApproval ; cr:forStudySite ex:site-act ;
    top:observedAt "2026-01-15T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-15T12:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:su-mgr .
ex:cta1 a cr:ClinicalTrialAgreement ; rdfs:label "Executed CTA" ; cr:forStudySite ex:site-act ;
    top:observedAt "2026-01-20T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-20T12:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:su-mgr .
ex:mca1 a cr:CoverageAnalysis ; rdfs:label "Medicare coverage analysis" ; cr:forStudySite ex:site-act .
ex:siv1 a cr:SiteInitiationVisit ; cr:forStudySite ex:site-act ;
    top:observedAt "2026-02-01T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-02-01T16:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:su-mgr .

ex:act1 a cr:SiteActivation ; rdfs:label "Denver site activated" ;
    cr:activates ex:site-act ; cr:irbApproval ex:irb1 ; cr:cta ex:cta1 ; cr:siv ex:siv1 ;
    top:observedAt "2026-02-05T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-02-05T09:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:su-mgr .

# --- Universal DNA (TOP Core): identifier + status (observedAt already present above) ---
<https://top.scientix.ai/examples/act1> top:identifier "urn:act1" ; top:status "active" .
<https://top.scientix.ai/examples/cta1> top:identifier "urn:cta1" ; top:status "active" .
<https://top.scientix.ai/examples/irb1> top:identifier "urn:irb1" ; top:status "active" .
<https://top.scientix.ai/examples/siv1> top:identifier "urn:siv1" ; top:status "active" .
