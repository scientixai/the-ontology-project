@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix tmf:  <https://top.scientix.ai/tmf/v1#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# GRADED (Warning) — an artifact type that is classified but has NO content binding.
# It tells a system where to file the document, not what its facts mean. tmf:ContentBindingShape
# raises a reviewable Warning: a filing label is not comprehension.

ex:misc-admin-form a tmf:TMFArtifactType ;
    skos:prefLabel "Miscellaneous Administrative Form" ; rdfs:label "Miscellaneous Administrative Form" .
