@prefix ex:   <https://top.scientix.ai/examples/> .
@prefix tmf:  <https://top.scientix.ai/tmf/v1#> .
@prefix cr:   <https://top.scientix.ai/cr/v1#> .
@prefix top:  <https://top.scientix.ai/core/v1#> .
@prefix hcls: <https://top.scientix.ai/hcls/v1#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# GRADED (Warning) — a recommended-document gap. Every ESSENTIAL type is filed and current
# (so no inspection finding), but a RECOMMENDED type (the Monitoring Plan) has no current
# filed artifact. tmf:TMFRecommendedCompletenessShape raises a reviewable Warning — a
# completeness gap, not a failure.

ex:rec-mgr   a hcls:Practitioner ; rdfs:label "Dana Brooks, TMF manager" .
ex:sponsor-rec a cr:Sponsor ; rdfs:label "Acme Oncology" .
ex:site-rec    a cr:StudySite ; rdfs:label "Denver Cancer Center" .
ex:elig-rec    a cr:EligibilityCriterion ; rdfs:label "ECOG 0-1" .
ex:pv-rec a cr:ProtocolVersion ; top:identifier "OPP-101 v1.0" ; top:status "effective" ;
    top:observedAt "2026-01-05T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-05T10:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:rec-mgr ; cr:hasEligibilityCriterion ex:elig-rec .
ex:study-rec a cr:Study ; top:identifier "OPP-101" ; rdfs:label "OPP-101 (Phase 1 FIH)" ;
    cr:sponsoredBy ex:sponsor-rec ; cr:conductedAt ex:site-rec ; cr:hasProtocolVersion ex:pv-rec .

ex:tmf-rec a tmf:TrialMasterFile ;
    top:identifier "TMF:OPP-101-rec" ; rdfs:label "OPP-101 TMF (recommended gap)" ;
    tmf:forStudy ex:study-rec ;
    tmf:followsProfile tmf:CoreStartupProfile ;
    tmf:hasFiledArtifact
        ex:far-protocol , ex:far-irb , ex:far-icf , ex:far-1572 , ex:far-cta ,
        ex:far-cv .
    # NB: no Monitoring Plan filed (recommended) -> Warning; CV (recommended) is present.

ex:far-protocol a tmf:FiledArtifact ; rdfs:label "Protocol v1.0" ;
    top:identifier "FA:r-protocol" ; top:status "current" ; tmf:ofType tmf:Protocol ;
    top:observedAt "2026-01-05T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-05T10:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:rec-mgr .
ex:far-irb a tmf:FiledArtifact ; rdfs:label "IRB approval letter" ;
    top:identifier "FA:r-irb" ; top:status "current" ; tmf:ofType tmf:IRBApprovalLetter ;
    top:observedAt "2026-01-15T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-16T09:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:rec-mgr .
ex:far-icf a tmf:FiledArtifact ; rdfs:label "Informed consent form v2.0" ;
    top:identifier "FA:r-icf" ; top:status "current" ; tmf:ofType tmf:InformedConsentForm ;
    top:observedAt "2026-01-18T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-18T11:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:rec-mgr .
ex:far-1572 a tmf:FiledArtifact ; rdfs:label "Form FDA 1572 (signed)" ;
    top:identifier "FA:r-1572" ; top:status "current" ; tmf:ofType tmf:Form1572 ;
    top:observedAt "2026-01-12T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-12T15:00:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:rec-mgr .
ex:far-cta a tmf:FiledArtifact ; rdfs:label "Clinical trial agreement (executed)" ;
    top:identifier "FA:r-cta" ; top:status "current" ; tmf:ofType tmf:ClinicalTrialAgreementDoc ;
    top:observedAt "2026-01-20T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-20T16:30:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:rec-mgr .
ex:far-cv a tmf:FiledArtifact ; rdfs:label "Principal investigator CV" ;
    top:identifier "FA:r-cv" ; top:status "current" ; tmf:ofType tmf:CurriculumVitae ;
    top:observedAt "2026-01-10T00:00:00Z"^^xsd:dateTime ; top:recordedAt "2026-01-10T08:30:00Z"^^xsd:dateTime ;
    prov:wasAttributedTo ex:rec-mgr .
